; r12=pointer to variable
; r11=pointer to variable
; r10=cyclestogo
; r9=PC
; r8=PS
; r7=Y
; r6=X
; r5=A

  GET h.6502cpus

  GET h.6502cpui

; Use the GET directive to include register definitions as if typed here

  GET h.RegNames

; Use the GET directive to include a list of SWI names as if typed here

  GET h.SWInames

; Area name C$$code advisable as wanted to link with C output

  AREA |C$$code|, CODE, READONLY

; Import global symbols

  IMPORT |r6502busop|
  IMPORT |r6502atzerocycles|
  
  IMPORT |r6502zeropagexreadreadforwrite|
  IMPORT |r6502zeropagexread|
  IMPORT |r6502hiabsoluteread|
  IMPORT |r6502hiabsolutexreadreadforwrite|
  IMPORT |r6502zeropageindirectread|

  IMPORT |r6502dec|
  IMPORT |r6502cmp|
  IMPORT |r65c12phx|
  IMPORT |r6502nop|

; Export global symbols

  EXPORT |r65c12opcodeD2|
  EXPORT |r65c12opcodeD3|
  EXPORT |r65c12opcodeD4|
  EXPORT |r65c12opcodeD6|
  EXPORT |r65c12opcodeD7|
  EXPORT |r65c12opcodeDA|
  EXPORT |r65c12opcodeDB|
  EXPORT |r65c12opcodeDC|
  EXPORT |r65c12opcodeDE|
  EXPORT |r65c12opcodeDF|

|r65c12opcodeD2|
  INDIRECTLOAD r6502cmp

|r65c12opcodeD3|
  B r6502nop

|r65c12opcodeD4|
  ZEROPAGEXLOAD r6502nop

|r65c12opcodeD6|
  ZEROPAGEXMODIFYC r6502dec

|r65c12opcodeD7|
  B r6502nop

|r65c12opcodeDA|
  IMPLIED r65c12phx

|r65c12opcodeDB|
  B r6502nop

|r65c12opcodeDC|
  ABSOLUTELOAD r6502nop

|r65c12opcodeDE|
  ABSOLUTEXMODIFYC r6502dec

|r65c12opcodeDF|
  B r6502nop

;Data Area

;  AREA    |C$$data|, DATA

  END
