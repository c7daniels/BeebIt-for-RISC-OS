  MACRO
  R6502_START_STRETCH1 $sequence
  STR r1,[r0,#:INDEX:R6502_STRETCHED_ADDRESS_CODE]
  LDR r1,[r0,#:INDEX:R6502_CPU_STATE]
  ADD r3,r0,#:INDEX:R6502_SEQUENCES
  STR r1,[r0,#:INDEX:R6502_STRETCHED_CPU_STATE]
  LDR r1,[r3,#$sequence:SHL:2]
  ADD r1,r1,#1:SHL:2
  STR r1,[r0,#:INDEX:R6502_CPU_STATE]
  MEND

  MACRO
  R6502_START_STRETCH2 $sequence
  STR r1,[r0,#:INDEX:R6502_STRETCHED_ADDRESS_CODE]
  LDR r1,[r0,#:INDEX:R6502_CPU_STATE]
  ADD r3,r0,#:INDEX:R6502_SEQUENCES
  STR r1,[r0,#:INDEX:R6502_STRETCHED_CPU_STATE]
  LDR r1,[r3,#$sequence:SHL:2]
  STR r1,[r0,#:INDEX:R6502_CPU_STATE]
  MEND

|r6502invokeaddressing|
  STMFD sp!,{r2,r6-r7,lr}
  AND r2,r1,#&F000000F
  LDR r6,[r0,#:INDEX:R6502_SYNC_PC_CODE]
  LDR r7,[r0,#:INDEX:R6502_TOGOMINUSONE_CYCLESTATE]
  R6502_INVOKE_ADDRESSING s_r6502invokeaddressing,s1_r6502invokeaddressing,s2_r6502invokeaddressing
  MOV r1,r2
  LDMFD sp!,{r2,r6-r7,lr}
  LDR pc,[r2, #12]
s_r6502invokeaddressing
  LDMFD sp!,{r2,r6-r7,lr}
  LDR pc,[r2]
s1_r6502invokeaddressing
  LDMFD sp!,{r2,r6-r7,lr}
  LDR pc,[r2, #4]
s2_r6502invokeaddressing
  LDMFD sp!,{r2,r6-r7,lr}
  LDR pc,[r2, #8]

