  EXPORT |r6502opcodeEE|
  EXPORT |r6502opcodeEF|

|r6502opcodeE0|
  VALUEOFIMMEDIATE
  R6502CPX
  CPU_CYCLES 2
  ;LDR pc,[sp],#4
  R6502NEXTOPCODE

|r6502opcodeE1|
  ;SBC
  ADDRESSOFPREINDEXED ;4 cycles
  READMEM ;1 cycle
  ANDS r1,rps,#DFLAG
  BNE r6502opcodeE1_2
  ;binary
  R6502SBC ;1 cycle
  CPU_CYCLES 2
  ;LDR pc,[sp],#4
  R6502NEXTOPCODE
r6502opcodeE1_2
  ;BCD
  R6502SBCD ;1 cycle
  CPU_CYCLES 2
  ;LDR pc,[sp],#4
  R6502NEXTOPCODE

|r6502opcodeE2|
  ;SKB
  R6502SKB
  CPU_CYCLES 2
  ;LDR pc,[sp],#4
  R6502NEXTOPCODE

|r6502opcodeE3|
  ;ISB
  ADDRESSOFPREINDEXED ;4 cycles
  STR r0,[r12,#:INDEX:R6502_RMWTEMP] ;store address
  READMEM ;1 cycle
  ADD r0,r0,#1
  AND r0,r0,#&FF
  MOV r1,r0 ;value
  LDR r0,[r12,#:INDEX:R6502_RMWTEMP] ;address
  WRITEMEM ;1 cycle
  MOV r0,r1 ;r0=value
  ;SBC
  ANDS r1,rps,#DFLAG
  BNE r6502opcodeE3_2
  ;binary
  R6502SBC ;1 cycle
  CPU_CYCLES 4
  ;LDR pc,[sp],#4
  R6502NEXTOPCODE
r6502opcodeE3_2
  ;BCD
  R6502SBCD ;1 cycle
  CPU_CYCLES 4
  ;LDR pc,[sp],#4
  R6502NEXTOPCODE

|r6502opcodeE4|
  VALUEOFZEROPAGE
  R6502CPX
  CPU_CYCLES 3
  ;LDR pc,[sp],#4
  R6502NEXTOPCODE

|r6502opcodeE5|
