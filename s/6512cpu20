|r6512opcode28|
  ;PLP
  STACKPOP rps
  CPU_CYCLES 4

  ANDS r0,rps,#IFLAG
  BNE r6512opcode28end

  R6502IRQCHECK1

r6512opcode28end
  R6502NEXTOPCODE

