|r6512opcode20|
  ;JSR
  ADD r11,r12,rpc ;r11=memory+pc (offset)
  LDRB r2,[r11] ;lo
  LDRB r1,[r11,#1] ;hi

  ;MOV r0,rpc
  ;READMEM
  ;MOV r2,r0
  ;ADD r0,rpc,#1
  ;READMEM
  ;MOV r1,r0

  ADD r0,rpc,#1 ;jsr bug
  ADD rpc,r2,r1,LSL#8 ;r0=lo+(hi<<8)

  ;ADD rpc,rpc,#1 ;jsr bug
  AND r2,r0,#&FF00 ;pc & 0xFF00
  MOV r2,r2,LSR#8  ;>>8
  STACKPUSH r2
  AND r2,r0,#&FF ;pc & 0xFF
  STACKPUSH r2
  ;MOV rpc,r0
  CPU_CYCLES 6

  ;STMFD sp!,{rpc}
  ;SWI OS_WriteI+32
  ;MOV r0,rpc
  ;LDR r1,=buffer20
  ;MOV r2,#16
  ;SWI OS_ConvertHex4 ;BinaryToDecimal
  ;SWI OS_Write0
  ;SWI OS_WriteI+32
  ;LDMFD sp!,{rpc}

  R6502NEXTOPCODE

