  STRB r12,[r0,#:INDEX:HOST_ASYSVIA+:INDEX:HOSTAVIA_PORTA]
  ADDEQ r1,r1,#1:SHL:27
  ADDNE r1,r1,#(1:SHL:27)+KEYBOARDCA2FLAG
  STR r1,[r0,#:INDEX:HOST_KEYBOARD_STATE]
  MOVEQ pc,lr
  MOV r1,#(R6502_IRQ:SHL:4)|R6502_IRQ
  B systemviasetca2

