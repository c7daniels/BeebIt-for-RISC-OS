|r6502sheilawrite_b|
  STR rcycles,[r12,#:INDEX:R6502_CYCLESTOGO]
  STMFD sp!,{r0-r1,r12,lr}
  MOV r2,r0
  MOV r0,r1,LSR #16
  MOV r1,r2
  BL sheilawrite_b
  LDMFD sp!,{r0-r1,r12}
  LDR rcycles,[r12,#:INDEX:R6502_CYCLESTOGO]
  LDR pc, [sp], #4

