;
;rockwell 6502 cpu
;
|r6502readmem|
  ;OUT:      r0=value
  ;PRESERVED:r1=address:LSL:16
  AND r2,r1,#&F0000000
  ASSERT :INDEX:R6502_READOFFSET=0 ; save 1 instruction
  LDR pc,[r12,r2,LSR #26]

|r6502readb|
|r6502readbp|
|r6502readm|
  ;IN: r0=address
  ;OUT:r0=value
  STMFD sp!,{r1-r9,r11-r12,lr}
  LDR r12,=r6502workspace
  MOV r1,r0,LSL #16
  BL r6502readmem
  LDMFD sp!,{r1-r9,r11-r12,pc}

