;
;rockwell 6502 cpu
;
r6502readbF000
r6502readbpF000
  ADDS r2,r1,#&02000000 ;>=&FE00
  BMI r6502readbF000_low
  CMP r1,#&FF000000 ;>=&FF00
  BPL r6502readbFF00
;r6502readbFE00
  ;&FE00 - &FEFF (SHEILA)
  AND r2,r2,#&00FF0000
  ADD r11,r12,#:INDEX:R6502_SHEILAREADS
  LDR pc,[r11,r2,LSR #14]

r6502readbF000_low
  CMP r1,#&FC000000 ;<&FC00
  ADDMI r11,r12,#:INDEX:R6502_MEMORY
  LDRMIB r0,[r11,r1,LSR #16]  ;r0=memory[address]
  MOVMI pc,lr
  CMP r1,#&FD000000 ;>=&FD00
  BPL r6502readbFD00
;r6502readbFC00
  ;&FC00 - &FCFF (FRED)
  STMFD sp!,{r1,lr}
  MOV r1,r1,LSR #16
  AND r1,r1,#255 ; low 8 bits in R1
  MOV r2,#&FE ; unimplemented
  MOV r0,#&92 ; (146) read FRED
  SWI XOS_Byte ; may return V
  MOVS r0,r2 ; result in R0 (clearing V!)
  SUB rcycles,rcycles,#2
  LDMFD sp!,{r1,pc}

r6502readbFD00
  ;&FD00 - &FDFF (JIM)
  STMFD sp!,{r1,lr}
  MOV r1,r1,LSR #16
  AND r1,r1,#255 ; low 8 bits in R1
  MOV r2,#&FE ; unimplemented
  MOV r0,#&94 ; (148) read JIM
  SWI XOS_Byte ; may return V
  MOVS r0,r2 ; result in R0 (clearing V!)
  SUB rcycles,rcycles,#2
  LDMFD sp!,{r1,pc}

r6502readbFF00
  ADD r11,r12,#:INDEX:R6502_MEMORY
  LDRB r0,[r11,r1,LSR #16]  ;r0=memory[address]
  MOV pc,lr

;
;rockwell 6502 cpu
;
r6502readbp3000_ram
  ;&3000 - &7FFF (RAM)
  ;VDU driver
  CMP rpc,#&C0000000 ;if r6502_pc < &C000
  BLT r6502readbp3000_ram2

  CMP rpc,#&E0000000 ;if r6502_pc >= &E000
  BGE r6502readbp3000_ram2

  ADD r11,r12,#:INDEX:R6502_LYNNE-&3000
  LDRB r0,[r11,r1,LSR #16] ;r0=shadow[address]
  MOV pc,lr

r6502readbp3000_ram2
  LDR r11,=beebit_romsel ;acccon
  LDR r2,[r11] ;romsel
  ANDS r2,r2,#&80
  ADD r11,r12,#:INDEX:R6502_MEMORY
  LDREQB r0,[r11,r1,LSR #16] ;r0=memory[address]
  MOVEQ pc,lr

  ;romsel AND &80
  CMP rpc,#&A0000000 ;if r6502_pc < &A000
  ;;BLT r6502write3000
  LDRLTB r0,[r11,r1,LSR #16] ;r0=memory[address]
  MOVLT pc,lr
  CMP rpc,#&B0000000 ;if r6502_pc >= &B000
  ;;BGE r6502write3000
  LDRGEB r0,[r11,r1,LSR #16] ;r0=memory[address]
  MOVGE pc,lr

  ADD r11,r12,#:INDEX:R6502_LYNNE-&3000
  LDRB r0,[r11,r1,LSR #16] ;r0=shadow[address]
  MOV pc,lr

r6502readbp8000_ram
  ;&8000 - &AFFF (ROMSEL b7) (SIDEWAYS RAM)
r6502readm8000_ram
  ;&8000 - &8FFF (ROMSEL b7) (SIDEWAYS RAM)
  ADD r11,r12,#:INDEX:R6502_ANDY-&8000
  LDRB r0,[r11,r1,LSR #16]  ;r0=shadow[address-&8000]
  MOV pc,lr

;
;rockwell 6502 cpu
;
r6502readm3000_x
  ;&3000 - &7FFF (ACCCON b2) (LYNNE) (RAM)
  ADD r11,r12,#:INDEX:R6502_LYNNE-&3000
  LDRB r0,[r11,r1,LSR #16]  ;r0=shadow[address]
  MOV pc,lr

r6502readm3000_e
  ;&3000 - &7FFF (ACCCON b1) (E) (RAM)
  CMP rpc,#&C0000000 ;skip
  BLT r6502read3000 ;if < &C000

  CMP rpc,#&E0000000 ;skip
  BGE r6502read3000 ;if >= &E000

  ADD r11,r12,#:INDEX:R6502_LYNNE-&3000
  LDRB r0,[r11,r1,LSR #16]  ;r0=shadow[address]
  MOV pc,lr

r6502readmC000_y
  ;&C000 - &DFFF (ACCCON b3) (RAM)
  ADD r11,r12,#:INDEX:R6502_HAZEL-&C000
  LDRB r0,[r11,r1,LSR #16]  ;r0=shadow[address-&B000]
  MOV pc,lr

r6502readmF000
  ADDS r2,r1,#&02000000 ;>=&FE00
  BMI r6502readmF000_low
  CMP r1,#&FF000000 ;>=&FF00
  BPL r6502readmFF00
;r6502readmFE00
  ;&FE00 - &FEFF (SHEILA)
  AND r2,r2,#&00FF0000
  ADD r11,r12,#:INDEX:R6502_SHEILAREADS
  LDR pc,[r11,r2,LSR #14]

r6502readmF000_low
  CMP r1,#&FC000000 ;<&FC00
  ADDMI r11,r12,#:INDEX:R6502_MEMORY
  LDRMIB r0,[r11,r1,LSR #16]  ;r0=memory[address]
  MOVMI pc,lr
  CMP r1,#&FD000000 ;>=&FD00
  BPL r6502readmFD00
;r6502readmFC00
  ;&FC00 - &FCFF (FRED)
  LDR r11,=beebit_acccon
  LDR r3,[r11] ;acccon
  ANDS r2,r3,#&40 ;TST
  ADDNE r11,r12,#:INDEX:R6502_MEMORY
  LDRNEB r0,[r11,r1,LSR #16] ;r0=memory[address]
  MOVNE pc,lr

  ANDS r2,r3,#&20 ;IFJ
  MOVNE r0,#0 ;cartridge
  MOVNE pc,lr

  ;1MHz bus
  STMFD sp!,{r1,lr}
  MOV r1,r1,LSR #16
  AND r1,r1,#255 ; low 8 bits in R1
  MOV r2,#&00 ; unimplemented
  MOV r0,#&92 ; (146) read FRED
  SWI XOS_Byte ; may return V
  MOVS r0,r2 ; result in R0 (clearing V!)
  SUB rcycles,rcycles,#2
  LDMFD sp!,{r1,pc}

r6502readmFD00
  ;&FD00 - &FDFF (JIM)
  LDR r11,=beebit_acccon
  LDR r3,[r11] ;acccon
  ANDS r2,r3,#&40 ;TST
  ADDNE r11,r12,#:INDEX:R6502_MEMORY
  LDRNEB r0,[r11,r1,LSR #16] ;r0=memory[address]
  MOVNE pc,lr

  ANDS r2,r3,#&20 ;IFJ
  MOVNE r0,#0 ;cartridge
  MOVNE pc,lr

  ;1MHz bus
  STMFD sp!,{r1,lr}
  MOV r1,r1,LSR #16
  AND r1,r1,#255 ; low 8 bits in R1
  MOV r2,#&00 ; unimplemented
  MOV r0,#&94 ; (148) read JIM
  SWI XOS_Byte ; may return V
  MOVS r0,r2 ; result in R0 (clearing V!)
  SUB rcycles,rcycles,#2
  LDMFD sp!,{r1,pc}

r6502readmFF00
  ADD r11,r12,#:INDEX:R6502_MEMORY
  LDRB r0,[r11,r1,LSR #16]  ;r0=memory[address]
