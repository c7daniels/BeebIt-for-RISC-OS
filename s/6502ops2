  MEND

  MACRO
  R6502_O_LOAD_OPCODE_BODY $type,$tag,$mode
  LCLS genericload
  LCLS action
  IF "$type"=="r65c12" && ("$tag"=="decimaladc" || "$tag"=="decimalsbc")
genericload SETS "r65c12decimalload"
  ELIF "$type"=="r65c12" && !("$mode"=="imm" || "$mode"=="zpg" || "$mode"=="abs")
genericload SETS "r65c12load"
  ELSE
genericload SETS "r6502load"
  ENDIF
  IF "$tag"=="bit" && "$mode"=="imm"
action SETS "$type.$tag.immaction"
  ELIF "$type"=="r65c12" && ("$tag"=="adc" || "$tag"=="sbc" || "$tag"=="decimaladc" || "$tag"=="decimalsbc")
action SETS "r65c12$tag.action"
  ELSE
action SETS "r6502$tag.action"
  ENDIF
  [ "$type"=="r65c12" && ("$mode"=="zpgx" || "$mode"=="zpgy" || "$mode"=="preindexed")
  R6502_OPERAND_LO_TWICE_FOLD_OR_TRAP $genericload.$mode.nofold,$type.$tag.$mode.infold,$action
  |
  R6502_OPERAND_LO_FOLD_OR_TRAP $genericload.$mode.nofold,$type.$tag.$mode.infold,$action
  ]
  MEND

  MACRO
  R6502_O_LOAD_OPCODE $type,$tag,$mode
  [ "$tag"=="adc" || "$tag"=="sbc"
  R6502_DECIMAL_SET_O_OPCODE_HEADER $type.$tag.$mode
  R6502_O_LOAD_OPCODE_BODY $type,decimal$tag,$mode
  R6502_DECIMAL_CLEAR_O_OPCODE_HEADER $type.$tag.$mode
  R6502_O_LOAD_OPCODE_BODY $type,$tag,$mode
  |
  R6502_O_OPCODE_HEADER $type.$tag.$mode
  R6502_O_LOAD_OPCODE_BODY $type,$tag,$mode
  ]
  MEND

  MACRO
  R6502_LOAD_OPCODE_SPLIT $type,$tag,$mode
  LCLS lengthdigit
  LCLS genericload
  LCLS action
  [ "$mode"=="abs" || "$mode"=="absx" || "$mode"=="absy"
lengthdigit SETS "3"
  |
lengthdigit SETS "2"
  ]
  IF "$type"=="r65c12" && ("$tag"=="decimaladc" || "$tag"=="decimalsbc")
genericload SETS "r65c12decimalload"
  ELIF "$type"=="r65c12" && ("$mode"=="nonindexed" || "$mode"=="postindexed" || "$mode"=="absx" || "$mode"=="absy")
genericload SETS "r65c12load"
  ELSE
genericload SETS "r6502load"
  ENDIF
  IF "$tag"=="bit" && "$mode"=="imm"
action SETS "$type.$tag.immaction"
  ELIF "$type"=="r65c12" && ("$tag"=="adc" || "$tag"=="sbc" || "$tag"=="decimaladc" || "$tag"=="decimalsbc")
action SETS "r65c12$tag.action"
  ELSE
action SETS "r6502$tag.action"
  ENDIF
  R6502_GENERIC_SCAN$lengthdigit._SPLIT $type.$tag.$mode,$genericload.$mode,$action
  MEND

  MACRO
  R6502_LOAD_PREINDEXED $type,$tag,$mode,$waittype,$aname
  ADD r2,r4,r2,LSL #24
  ADD r3,r2,#1:SHL:24
  LDRB r2,[r0,r2,LSR #24]
  LDRB r3,[r0,r3,LSR #24]
  MOV r1,#ADDRESSING_BASECODE
  ORR r1,r1,r2,LSL #16
  ORR r1,r1,r3,LSL #24
  R6502_LOAD 4,$waittype,$tag,zpgind,$aname
  MEND

  MACRO
  R6502_LOAD_NONINDEXED $type,$tag,$mode,$waittype,$aname
  MOV r2,r2,LSL #24
  ADD r3,r2,#1:SHL:24
  LDRB r2,[r0,r2,LSR #24]
  LDRB r3,[r0,r3,LSR #24]
  MOV r1,#ADDRESSING_BASECODE
  ORR r1,r1,r2,LSL #16
  ORR r1,r1,r3,LSL #24
  R6502_LOAD 3,$waittype,$tag,zpgind,$aname
  MEND

  MACRO
  R6502_LOAD_POSTINDEXED $type,$tag,$mode,$waittype,$aname
  MOV r2,r2,LSL #24
  ADD r3,r2,#1:SHL:24
  LDR r4,[r0,#:INDEX:R6502_Y_SHIFT]
  LDRB r2,[r0,r2,LSR #24]
  LDRB r3,[r0,r3,LSR #24]
  ADDS r2,r4,r2,LSL #24
  MOV r1,#ADDRESSING_BASECODE
  ORR r1,r1,r2,LSR #8
  ORR r1,r1,r3,LSL #24
  BCS %F1
  R6502_LOAD 3,$waittype,$tag,zpgind,$aname
1
  [ "$type"=="r65c12"
  ADD r1,r1,#1:SHL:24
  R6502_LOAD 4,$waittype,$tag,zpgind,$aname
  |
  R6502_PAGE_INCREMENT_LOAD 3,$waittype,$tag,zpgind,$aname
  ]
  MEND

  MACRO
  R6502_LOAD_ABS $type,$tag,$mode,$waittype,$aname
  SUB r3,r8,#2
  LDRB r3,[r9,r3]
  MOV r1,#ADDRESSING_BASECODE
  ORR r1,r1,r2,LSL #16
  ORR r1,r1,r3,LSL #24
  R6502_LOAD 2,$waittype,$tag,abs,$aname
  MEND

  MACRO
  R6502_LOAD_ABS_INDEXED $type,$tag,$mode,$waittype,$aname
