  MACRO
  ARR_ACTION
  LDRB r1,[r0,#:INDEX:R6502_A]
  MOVS r3,r5,LSL #31
  AND r2,r2,r1
  BIC r5,r5,#NFLAG|VFLAG|ZFLAG|CFLAG
  MOV r1,r3,LSR #24
  ORRMI r5,r5,#NFLAG
  ORRS r1,r1,r2,LSR #1
  ORREQ r5,r5,#ZFLAG
  MOV r3,r1,LSL #25
  EORS r3,r3,r2,LSL #25
  ORRMI r5,r5,#VFLAG
  TST r5,#DFLAG
  BNE %F0
  TST r2,#NFLAG
  STRB r1,[r0,#:INDEX:R6502_A]
  ORRNE r5,r5,#CFLAG
  B %F1
0
  CMP r2,#&50
  ADDHS r1,r1,#&60
  ORRHS r5,r5,#CFLAG
  AND r2,r2,#&0F
  CMP r2,#&05
  MOVHS r1,r1,ROR #4
  ADDHS r1,r1,#&60000000
  MOVHS r1,r1,ROR #28
  STRB r1,[r0,#:INDEX:R6502_A]
1
  MEND

