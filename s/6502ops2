  LDR r3,[r0,#:INDEX:R6502_X_SHIFT]
  AND r1,r1,r3
  SUBS r1,r1,r2,LSL #24
  BIC r5,r5,#NFLAG|ZFLAG|CFLAG
  STR r1,[r0,#:INDEX:R6502_X_SHIFT]
  ORRMI r5,r5,#NFLAG
  ORREQ r5,r5,#ZFLAG
  ORRCS r5,r5,#CFLAG
  MEND

