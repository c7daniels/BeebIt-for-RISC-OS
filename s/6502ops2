  MACRO
  R6502_DECIMAL_RETURN_WAIT_ACTION $n,$ctype,$tag
  [ "$tag"=="loadzpg"
  ADD r6,r6,#2:SHL:16
  |
  ADD r6,r6,#3:SHL:16
  ]
  R6502_OPCODE_$ctype._ADDRESSED_RETURN $n+2,interrupt
  MEND

  MACRO
  R6502_DECIMAL_RETURN_WAITS $n,$type,$ctype,$tag
  R6502_WAIT_HANDLERS ,$n,move,$type,decimal$tag.return,0
  R6502_DECIMAL_RETURN_WAIT_ACTION $n,$ctype,$tag
  MEND

  MACRO
  R6502_DECIMAL_RETURN_TAIL $type,$ctype,$tag
  R6502_TAIL_ENTRY move,$type,decimal$tag.return,0
  R6502_OPCODE_READ_SPECIAL
  R6502_DECIMAL_RETURN_WAIT_ACTION 0,$ctype,$tag
  MEND

  MACRO
  R6502_LOAD_RETURN $n,$ctype,$tag,$mode,$aname
  [ "$ctype"=="NOFOLD"
  LCLA n1value
n1value SETA $n+1
  ADD r1,r6,#2:SHL:16
  R6502_TOUCH_OR_TRAP ,r65c12nofoldwait$n1value.decimalload$mode.return
  |
  [ "$mode"=="zpgind"
  ADD r6,r6,#2:SHL:16
  |
  ADD r6,r6,#3:SHL:16
  ]
  [ "$tag"=="decimalload" || "$aname"=="CMOS_DECIMAL_ADC" || "$aname"=="CMOS_DECIMAL_SBC"
  R6502_OPCODE_$ctype._ADDRESSED_RETURN $n+3,interrupt
  |
  R6502_OPCODE_$ctype._ADDRESSED_RETURN $n+2,interrupt
  ]
  ]
  MEND

  MACRO
  R6502_LOAD_ACTION $n,$ctype,$tag,$mode,$special,$aname
  [ "$aname"!="TOP"
  [ $special==0
  LDRB r2,[r2]
  |
  LDRB r2,[r0,#:INDEX:R6502_M]
  ]
  ]
  $aname._ACTION
  R6502_LOAD_RETURN $n,$ctype,$tag,$mode,$aname
  MEND

  MACRO
  R6502_LOAD_WAITS $n,$type,$ctype,$tag,$mode,$aname
  [ "$type"=="r6502" || "$type"=="r65c12"
