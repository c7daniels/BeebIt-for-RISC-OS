  MACRO
  NMOS_DECIMAL_ADC_ACTION
  LDRB r1,[r0,#:INDEX:R6502_A]
  MOV r2,r2,LSL #24
  TEQ r2,r5,LSR #1   ;jdl** ARM c =6502 c
  ORR r1,r1,r1,ROR #8
  ORR r2,r2,#&000FF000
  AND r1,r1,#&F000000F
  ORR r2,r2,#&00000FF0
  ADD r1,r1,#6
  ORR r2,r2,r2,ROR #24
  BIC r5,r5,#NFLAG|VFLAG|ZFLAG|CFLAG
  ADCS r1,r1,r2
  ORRMI r5,r5,#NFLAG
  ORRVS r5,r5,#VFLAG
  CMPCC r1,#&A0000000
  SUB r2,r1,#6
  ADDCS r1,r1,#&60000000
  ORRCS r5,r5,#CFLAG
  TST r1,#&80
  SUBNE r1,r1,#6
  AND r1,r1,#&F000000F
  TST r2,#&F000000F
  ORR r1,r1,r1,LSR #24
  ORREQ r5,r5,#ZFLAG
  STRB r1,[r0,#:INDEX:R6502_A]
  MEND

  MACRO
  NMOS_ADC_ACTION
  LDRB r1,[r0,#:INDEX:R6502_A]
  MOV r2,r2,LSL #24
  TEQ r2,r5,LSR #1   ;jdl** ARM c =6502 c
  SUB r1,r1,#1:SHL:8
  BIC r5,r5,#NFLAG|VFLAG|ZFLAG|CFLAG
  ADCS r1,r2,r1,ROR #8
  ORRMI r5,r5,#NFLAG
  ORRVS r5,r5,#VFLAG
  ORRCS r5,r5,#CFLAG
  MOVS r1,r1,LSR#24 ;(a=(a>>24) jdl** also (z=(a=0))
  ORREQ r5,r5,#ZFLAG
  STRB r1,[r0,#:INDEX:R6502_A]
  MEND

  MACRO
  CMOS_DECIMAL_ADC_ACTION
  LDRB r1,[r0,#:INDEX:R6502_A]
  TEQ r2,r5,LSR #1   ;jdl** ARM c =6502 c
  MOV r2,r2,LSL #24
  ORR r1,r1,r1,ROR #8
  ORR r2,r2,#&000FF000
  AND r1,r1,#&F000000F
  ORR r2,r2,#&00000FF0
  ADD r1,r1,#6
  ORR r2,r2,r2,ROR #24
  BIC r5,r5,#NFLAG|VFLAG|ZFLAG|CFLAG
  ADCS r1,r1,r2
  ORRVS r5,r5,#VFLAG
  CMPCC r1,#&A0000000
  SUB r2,r1,#6
  ADDCS r1,r1,#&60000000
  ORRCS r5,r5,#CFLAG
  TST r1,#&80
  SUBNE r1,r1,#6
  ANDS r1,r1,#&F000000F
  ORR r1,r1,r1,LSR #24
  ORRMI r5,r5,#NFLAG
  ORREQ r5,r5,#ZFLAG
  STRB r1,[r0,#:INDEX:R6502_A]
  MEND

