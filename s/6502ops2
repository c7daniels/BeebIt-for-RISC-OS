  MACRO
  NMOS_DECIMAL_SBC_ACTION
  LDRB r1,[r0,#:INDEX:R6502_A]
  MOV r2,r2,LSL #24
  TEQ r2,r5,LSR #1   ;jdl** ARM c =6502 c
  ORR r2,r2,r2,ROR #24
  ORR r1,r1,r1,ROR #8
  AND r2,r2,#&F000000F
  AND r1,r1,#&F000000F
  MVN r2,r2
  BIC r5,r5,#NFLAG|VFLAG|ZFLAG|CFLAG
  ADCS r1,r1,r2
  ORRCS r5,r5,#CFLAG
  ORRMI r5,r5,#NFLAG
  ORRVS r5,r5,#VFLAG
  MOV r2,r1
  SUBCC r1,r1,#&60000000
  TST r1,#&80
  SUBNE r1,r1,#6
  AND r1,r1,#&F000000F
  TST r2,#&F000000F
  ORR r1,r1,r1,LSR #24
  ORREQ r5,r5,#ZFLAG
  STRB r1,[r0,#:INDEX:R6502_A]
  MEND

