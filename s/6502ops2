  ADDS r2,r1,r2,LSL #24
  LDRB r3,[r9,r3]
  MOV r1,#ADDRESSING_BASECODE
  ORR r1,r1,r2,LSR #8
  ORR r1,r1,r3,LSL #24
  BCS %F1
  R6502_LOAD 2,$waittype,$tag,abs,$aname
1
  [ "$type"=="r65c12"
  ADD r1,r1,#1:SHL:24
  R6502_LOAD 3,$waittype,$tag,abs,$aname
  |
  R6502_PAGE_INCREMENT_LOAD 2,$waittype,$tag,abs,$aname
  ]
  MEND

  MACRO
  R6502_LOAD_OPCODE_BODY $type,$tag,$mode,$aname,$features
  LCLS resolvedaname
  LCLS waittype
  IF "$tag"=="adc" || "$tag"=="sbc"
  [ "$type"=="r65c12"
resolvedaname SETS "CMOS_$aname"
  |
resolvedaname SETS "NMOS_$aname"
  ]
waittype SETS "$type"
  ELIF "$tag"=="decimaladc" || "$tag"=="decimalsbc"
  [ "$type"=="r65c12"
resolvedaname SETS "CMOS_DECIMAL_$aname"
  |
resolvedaname SETS "NMOS_DECIMAL_$aname"
  ]
waittype SETS "$type"
  ELSE
resolvedaname SETS "$aname"
waittype SETS "r6502"
  ENDIF
  IF "$mode"=="imm"
  $resolvedaname._ACTION
  ADD r6,r6,#2:SHL:16
  [ "$resolvedaname"=="CMOS_DECIMAL_$aname"
  R6502_OPCODE_INFOLD_ADDRESSED_RETURN 3,interrupt
  |
  R6502_OPCODE_INFOLD_ADDRESSED_RETURN 2,interrupt
  ]
  ELIF "$mode"=="zpg"
  [ "$resolvedaname"!="CMOS_DECIMAL_$aname"
  ADD r6,r6,#2:SHL:16
  ]
  LDRB r2,[r0,r2]
  $resolvedaname._ACTION
  [ "$resolvedaname"=="CMOS_DECIMAL_$aname"
  MOV r1,r6
  R6502_TOUCH_OR_TRAP ,r65c12infoldwait00000002decimalloadzpgreturn
  |
  R6502_OPCODE_INFOLD_ADDRESSED_RETURN 3,interrupt
  ]
  ELIF "$mode"=="zpgx" || "$mode"=="zpgy"
  [ "$mode"=="zpgx"
  LDR r4,[r0,#:INDEX:R6502_X_SHIFT]
  |
  LDR r4,[r0,#:INDEX:R6502_Y_SHIFT]
  ]
  ADD r2,r4,r2,LSL #24
  [ "$resolvedaname"!="CMOS_DECIMAL_$aname"
  ADD r6,r6,#2:SHL:16
  ]
  LDRB r2,[r0,r2,LSR #24]
  $resolvedaname._ACTION
  [ "$resolvedaname"=="CMOS_DECIMAL_$aname"
  MOV r1,r6
  R6502_TOUCH_OR_TRAP ,r65c12infoldwait00000003decimalloadzpgreturn
  |
  R6502_OPCODE_INFOLD_ADDRESSED_RETURN 4,interrupt
  ]
  ELIF "$mode"=="preindexed"
  LDR r4,[r0,#:INDEX:R6502_X_SHIFT]
  R6502_LOAD_PREINDEXED $type,$tag,$mode,$waittype,$resolvedaname
  ELIF "$mode"=="nonindexed"
  R6502_LOAD_NONINDEXED $type,$tag,$mode,$waittype,$resolvedaname
  ELIF "$mode"=="postindexed"
  R6502_LOAD_POSTINDEXED $type,$tag,$mode,$waittype,$resolvedaname
  ELIF "$mode"=="abs"
  R6502_LOAD_ABS $type,$tag,$mode,$waittype,$resolvedaname
  ELIF "$mode"=="absx" || "$mode"=="absy"
  [ "$mode"=="absx"
  LDR r1,[r0,#:INDEX:R6502_X_SHIFT]
  |
  LDR r1,[r0,#:INDEX:R6502_Y_SHIFT]
  ]
  R6502_LOAD_ABS_INDEXED $type,$tag,$mode,$waittype,$resolvedaname
  ENDIF
  MEND

  MACRO
  R6502_DECIMAL_LOAD_OPCODE_VARIANTS $type,$tag,$mode,$aname
  LCLS lengthdigit
  [ "$mode"=="abs" || "$mode"=="absx" || "$mode"=="absy"
lengthdigit SETS "3"
  |
lengthdigit SETS "2"
  ]
  R6502_DECIMAL_SET_SCAN_OPCODE_ENTRY $lengthdigit,$type.$tag.$mode,$type.decimal$tag.$mode,0,0
  R6502_LOAD_OPCODE_BODY $type,decimal$tag,$mode,$aname,0
  R6502_DECIMAL_CLEAR_SCAN_OPCODE_ENTRY $lengthdigit,$type.$tag.$mode,0,0
  R6502_LOAD_OPCODE_BODY $type,$tag,$mode,$aname,0
  MEND

  MACRO
  R6502_LOAD_OPCODE_VARIANTS $type,$tag,$mode,$aname
  LCLS lengthdigit
  [ "$mode"=="abs" || "$mode"=="absx" || "$mode"=="absy"
lengthdigit SETS "3"
  |
lengthdigit SETS "2"
  ]
  R6502_SCAN_OPCODE_ENTRY $lengthdigit,$type.$tag.$mode,0,0
  R6502_LOAD_OPCODE_BODY $type,$tag,$mode,$aname,0
  MEND

  MACRO
  R6502_LOAD_OPCODE $type,$tag,$mode,$aname
  R6502_O_LOAD_OPCODE $type,$tag,$mode
  R6502_LOAD_OPCODE_SPLIT $type,$tag,$mode
  [ "$tag"=="adc" || "$tag"=="sbc"
  R6502_LOAD_OPCODE_SPLIT $type,decimal$tag,$mode
  R6502_DECIMAL_LOAD_OPCODE_VARIANTS $type,$tag,$mode,$aname
  |
  R6502_LOAD_OPCODE_VARIANTS $type,$tag,$mode,$aname
  ]
  MEND

