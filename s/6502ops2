  TEQ r2,r5,LSR #1   ;jdl** ARM c =6502 c
  BIC r5,r5,#NFLAG|VFLAG|ZFLAG|CFLAG
  RSCS r1,r2,r1,ROR #8
  ORRMI r5,r5,#NFLAG
  ORRVS r5,r5,#VFLAG
  ORRCS r5,r5,#CFLAG
  MOVS r1,r1,LSR#24 ;(a=(a>>24) jdl** also (z=(a=0))
