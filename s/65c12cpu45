  BGE r65c12opcode4C_2

  LDRB r2,[r12,rpc] ;lo
  ADD rpc,rpc,#1
  LDRB r1,[r12,rpc] ;hi
  ADD rpc,r2,r1,LSL#8 ;r0=lo+(hi<<8)

  ;STR rpc,[r11] ;pc
  CPU_CYCLES 3
  ;LDMFD sp!,{r0-r2,rpc,r10-r12,pc}
  ;MOV pc,lr
  R65C12NEXTOPCODE

r65c12opcode4C_2
  ;master 128
  MOV r0,rpc
  READMEM ;lo
  MOV r2,r0 ;lo
  ADD r0,rpc,#1
  READMEM ;hi

  ADD rpc,r2,r0,LSL#8 ;r0=lo+(hi<<8)
  CPU_CYCLES 3
  R65C12NEXTOPCODE

