  R6502NEXTOPCODE

|r65c12opcode5A|
  ;PHY
  ;STMFD sp!,{lr}
  STACKPUSH ry
  CPU_CYCLES 3
  ;LDMFD sp!,{pc}
  ;LDR pc,[sp],#4
  R6502NEXTOPCODE

|r65c12opcode5B|
  ;Reserved NOP
  SUB rcycles,rcycles,#1
  ;LDR pc,[sp],#4
  R6502NEXTOPCODE

|r65c12opcode5C|
  ;Reserved NOP
  R6502SKW
  SUB rcycles,rcycles,#8
  ;LDR pc,[sp],#4
  R6502NEXTOPCODE

|r65c12opcode5F|
  ;Reserved NOP
  SUB rcycles,rcycles,#1
  ;LDR pc,[sp],#4
  R6502NEXTOPCODE

