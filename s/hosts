  LDR r0, [sp], #4
  MOV pc,lr

host_r6502cycle0s1
  ADD r12,r0,#:INDEX:HOST_STEPROUTINES
  SUBS r7,r7,#1:SHL:12
  AND r3,r7,#&7C0
  LDR r2,[r0,#:INDEX:HOST_KEYCOLUMNFLAGS]
  LDRCS pc,[r12,r3,LSR #4]
  STR lr,[sp, #-4]!
  MOV lr,pc
  LDR pc,[r12,r3,LSR #4]
  LDR lr, [sp], #4
  B assemblyhostadvancetimers

host_r6502cycle1
  ADD r12,r0,#:INDEX:HOST_STEPROUTINES+&100
  SUBS r7,r7,#1:SHL:12
  AND r3,r7,#&7C0
  LDR r2,[r0,#:INDEX:HOST_KEYCOLUMNFLAGS]
  LDRCS pc,[r12,r3,LSR #4]
  STR lr,[sp, #-4]!
  MOV lr,pc
  LDR pc,[r12,r3,LSR #4]
  LDR lr, [sp], #4
  B assemblyhostadvancetimers

