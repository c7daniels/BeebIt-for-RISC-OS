  MACRO
  TOUCH_ADDRESS_RETURN $directaccesscondition
  IF "$directaccesscondition"=="AL"
  HOST_ADDRESSING_RETURN_TOUCHED
  ELSE
  IF "$directaccesscondition"=="NE"
  HOST_ADDRESSING_RETURN_TOUCHEDNE
  ENDIF
  LDRB r12,[r2]
  ADD r2,r0,#:INDEX:R6502_COPIEDVALUE
  STRB r12,[r0,#:INDEX:R6502_COPIEDVALUE]
  HOST_ADDRESSING_RETURN_TOUCHED
  ENDIF
  MEND

  MACRO
  TOUCH_ROUTINE_FOR_PAGED_ROM $tag
  LCLA n
  LCLA nminustwo
  LCLA offset
  IF "$tag"=="A"
n SETA 10
  ELIF "$tag"=="B"
n SETA 11
  ELIF "$tag"=="C"
n SETA 12
  ELIF "$tag"=="D"
n SETA 13
  ELIF "$tag"=="E"
n SETA 14
  ELIF "$tag"=="F"
n SETA 15
  ELSE
n SETA $tag
  ENDIF
nminustwo SETA &$n-2
offset SETA (&$nminustwo:AND:&3FFFF):SHL:14
host_r6502touch8000_$tag
  LDRB r12,[r0,#:INDEX:HOST_ROMWRITABLE+&$n]
  ADD r2,r0,r1,LSR #16
  ADD r2,r2,#:INDEX:HOST_ROMS+&$offset
  TST r12,r12
  TOUCH_ADDRESS_RETURN NE
  MEND

host_r6502touch0000
  ADD r2,r0,r1,LSR #16
  TOUCH_ADDRESS_RETURN AL

host_r6502touchbp3000_ram
  ADD r2,r6,#&20000000
  CMP r2,#&E0000000
  ADD r2,r0,r1,LSR #16
  ADDHS r2,r2,#:INDEX:HOST_SHADOW
  TOUCH_ADDRESS_RETURN AL

host_r6502touchbp3000_ramram
  ADD r2,r6,#&50000000
  CMP r2,#&F0000000
  BHS host_r6502touchbp3000_ramram2
  ADD r2,r2,#&D0000000
  CMP r2,#&E0000000
host_r6502touchbp3000_ramram2
  ADD r2,r0,r1,LSR #16
  ADDHS r2,r2,#:INDEX:HOST_SHADOW
  TOUCH_ADDRESS_RETURN AL

host_r6502touchm3000_x
  ADD r2,r0,r1,LSR #16
  ADD r2,r2,#:INDEX:HOST_SHADOW
