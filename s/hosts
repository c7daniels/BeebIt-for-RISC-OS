  AND r3,r7,#&7C0
  LDR r2,[r0,#:INDEX:HOST_KEYCOLUMNFLAGS]
  LDRCS pc,[r12,r3,LSR #4]
  STR lr,[sp, #-4]!
  MOV lr,pc
  LDR pc,[r12,r3,LSR #4]
  LDR lr, [sp], #4
  B assemblyhostadvancetimers

