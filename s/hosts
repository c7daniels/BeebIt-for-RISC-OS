host_r6502foldbpB000_$tag
  FOLD_ADDRESS_RETURN &$offset+&3000,&B000,&1000

host_r6502foldm9000_$tag
  FOLD_ADDRESS_RETURN &$offset+&1000,&9000,&3000
  MEND

