  MACRO
  FOLD_ADDRESS_RETURN $offset,$base,$length
  MOV r8,#$base+$length
  ADD r9,r0,#$offset+$length
  RSB r2,r8,#$base
  RSB r8,r8,r1,LSR #16
  STR r2,[r0,#:INDEX:R6502_FOLDFLOOR]
  HOST_ADDRESSING_RETURN_FOLDED
  MEND

  MACRO
  FOLD_ROUTINES_FOR_PAGED_ROM $tag
