|r65c12sbczpgstep|
  R6502_CYCLE_UPDATE_PUSH
  LDR r2,[r0,#:INDEX:R6502_M_SHIFT]
  TST r5,#DFLAG
  BNE r65c12sbczpgstepD
  LDRB r1,[r0,#:INDEX:R6502_A]
  TEQ r2,r5,LSR #1   ;jdl** ARM c =6502 c
  BIC r5,r5,#NFLAG|VFLAG|ZFLAG|CFLAG
  RSCS r1,r2,r1,ROR #8
  ORRMI r5,r5,#NFLAG
