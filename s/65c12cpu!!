;// IMPLIED STEPS
|r65c12fastnopstep|
  R6502_CYCLE_UPDATE_PUSH
  ADD r1,r6,#1:SHL:16
  R6502_CYCLE_UPDATE_POP
  R6502_CYCLE_FETCH_RETURN uninterrupted

|r65c12pulledxstep|
  R6502_CYCLE_UPDATE_PUSH
  LDRB r2,[r0,#:INDEX:R6502_M]
  BIC r5,r5,#NFLAG|ZFLAG
  MOVS r3,r2,LSL #24
  ORRMI r5,r5,#NFLAG
  STRB r2,[r0,#:INDEX:R6502_X]
  ORREQ r5,r5,#ZFLAG
  R6502_CYCLE_UPDATE_POP
  R6502_CYCLE_IMPLIED_FETCH_RETURN interrupt

|r65c12pulledystep|
  R6502_CYCLE_UPDATE_PUSH
  LDRB r2,[r0,#:INDEX:R6502_M]
  BIC r5,r5,#NFLAG|ZFLAG
  MOVS r3,r2,LSL #24
  ORRMI r5,r5,#NFLAG
  STRB r2,[r0,#:INDEX:R6502_Y]
  ORREQ r5,r5,#ZFLAG
  R6502_CYCLE_UPDATE_POP
  R6502_CYCLE_IMPLIED_FETCH_RETURN interrupt

;// LOAD STEPS
|r65c12sumtoimmediatestep|
  R6502_CYCLE_UPDATE_PUSH
  STR r1,[r0,#:INDEX:R6502_CPU_STATE]
  ADD r1,r6,#1:SHL:16
  STR r6,[r0,#:INDEX:R6502_ADDRESS_CODE]
  STR r1,[r0,#:INDEX:R6502_LAST_PC_CODE]
  R6502_CYCLE_UPDATE_POP
  R6502_CYCLE_READ_RETURN

|r65c12tozpgstep|
  R6502_CYCLE_UPDATE_PUSH
  STR r1,[r0,#:INDEX:R6502_CPU_STATE]
  ADD r1,r6,#1:SHL:16
  LDR r2,[r0,#:INDEX:R6502_M_SHIFT]
  STR r1,[r0,#:INDEX:R6502_LAST_PC_CODE]
  STR r2,[r0,#:INDEX:R6502_ADDRESS_CODE]
  R6502_CYCLE_UPDATE_POP
  R6502_CYCLE_READ_RETURN

|r65c12latchabsstep|
  STR r1,[r0,#:INDEX:R6502_CPU_STATE]
  LDRB r1,[r0,#:INDEX:R6502_M]
  LDR r2,[r0,#:INDEX:R6502_LATCH]
  ORR r2,r2,r1,LSL #24
  ORR r2,r2,#ADDRESSING_BASECODE
  LDR r1,[r0,#:INDEX:R6502_ADDRESS_CODE]
  STR r2,[r0,#:INDEX:R6502_FIXED_ADDRESS_CODE]
  R6502_CYCLE_READ_RETURN

|r65c12sumloadzpgxstep|
  STR r1,[r0,#:INDEX:R6502_CPU_STATE]
  LDR r1,[r0,#:INDEX:R6502_ADDRESS_CODE]
  LDRB r2,[r0,#:INDEX:R6502_X]
  LDR r3,[r0,#:INDEX:R6502_LAST_PC_CODE]
  ADD r1,r1,r2,LSL #24
  STR r3,[r0,#:INDEX:R6502_ADDRESS_CODE]
  R6502_CYCLE_ZPG_READ_RETURN

|r65c12latchabsxstep|
  STR r1,[r0,#:INDEX:R6502_CPU_STATE]
  LDRB r3,[r0,#:INDEX:R6502_X]
  LDR r2,[r0,#:INDEX:R6502_LATCH]
  ADD r2,r2,r3,LSL #16
  LDRB r3,[r0,#:INDEX:R6502_M]
  ADD r3,r2,r3,LSL #24
  ORR r3,r3,#ADDRESSING_BASECODE
  LDR r1,[r0,#:INDEX:R6502_ADDRESS_CODE]
  STR r3,[r0,#:INDEX:R6502_FIXED_ADDRESS_CODE]
  R6502_CYCLE_READ_RETURN

|r65c12loadabsxtomodifystep|
  LDRB r3,[r0,#:INDEX:R6502_X]
  LDR r2,[r0,#:INDEX:R6502_LATCH]
  ADD r2,r2,r3,LSL #16
  TST r2,#1:SHL:24
  LDRB r3,[r0,#:INDEX:R6502_M]
  ADDNE r1,r1,#3:SHL:2
  ADD r3,r2,r3,LSL #24
  STR r1,[r0,#:INDEX:R6502_CPU_STATE]
  ORR r3,r3,#ADDRESSING_BASECODE
  LDRNE r1,[r0,#:INDEX:R6502_ADDRESS_CODE]
  MOVEQ r1,r3
  STRNE r3,[r0,#:INDEX:R6502_FIXED_ADDRESS_CODE]
  STREQ r3,[r0,#:INDEX:R6502_ADDRESS_CODE]
  R6502_CYCLE_READ_RETURN

|r65c12loadabsxstep|
  LDRB r3,[r0,#:INDEX:R6502_X]
  LDR r2,[r0,#:INDEX:R6502_LATCH]
  ADD r2,r2,r3,LSL #16
  TST r2,#1:SHL:24
  LDRB r3,[r0,#:INDEX:R6502_M]
  ADDEQ r1,r1,#1:SHL:2
  ADD r3,r2,r3,LSL #24
  STR r1,[r0,#:INDEX:R6502_CPU_STATE]
  ORR r3,r3,#ADDRESSING_BASECODE
  LDRNE r1,[r0,#:INDEX:R6502_ADDRESS_CODE]
  MOVEQ r1,r3
  STRNE r3,[r0,#:INDEX:R6502_FIXED_ADDRESS_CODE]
  R6502_CYCLE_READ_RETURN

|r65c12loadabsystep|
  LDRB r3,[r0,#:INDEX:R6502_Y]
  LDR r2,[r0,#:INDEX:R6502_LATCH]
  ADD r2,r2,r3,LSL #16
  TST r2,#1:SHL:24
  LDRB r3,[r0,#:INDEX:R6502_M]
  ADDEQ r1,r1,#1:SHL:2
  ADD r3,r2,r3,LSL #24
  STR r1,[r0,#:INDEX:R6502_CPU_STATE]
  ORR r3,r3,#ADDRESSING_BASECODE
  LDRNE r1,[r0,#:INDEX:R6502_ADDRESS_CODE]
  MOVEQ r1,r3
  STRNE r3,[r0,#:INDEX:R6502_FIXED_ADDRESS_CODE]
  R6502_CYCLE_READ_RETURN

|r65c12loadpostindexedstep|
  LDRB r3,[r0,#:INDEX:R6502_Y]
  LDR r2,[r0,#:INDEX:R6502_LATCH]
  ADD r2,r2,r3,LSL #16
  TST r2,#1:SHL:24
  LDRB r3,[r0,#:INDEX:R6502_M]
  ADD r3,r2,r3,LSL #24
  BEQ %F1
  STR r1,[r0,#:INDEX:R6502_CPU_STATE]
  ORR r3,r3,#ADDRESSING_BASECODE
  LDR r1,[r0,#:INDEX:R6502_ADDRESS_CODE]
  STR r3,[r0,#:INDEX:R6502_FIXED_ADDRESS_CODE]
  R6502_CYCLE_ZPG_READ_RETURN
1
  ADD r1,r1,#1:SHL:2
  ORR r3,r3,#ADDRESSING_BASECODE
