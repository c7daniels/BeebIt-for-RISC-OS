|r6502opcode6C|
  ;JMP
  ADDRESSOFABSOLUTE ;2 cycles
  READMEM
  STR r0,[r12,#:INDEX:R6502_ABSTEMP] ;lo

  ADD r1,r1,#&10000 ;address += 1
  TST r1,#&00FF0000
  SUBEQ r0,r0,#&01000000 ;emulate NMOS CPU loss of carry
  READMEM ;hi
  LDR r2,[r12,#:INDEX:R6502_ABSTEMP] ;lo
  MOV r2,r2,LSL #16

  ADD rpc,r2,r0,LSL #24 ;r6502_pc=lo+(hi<<8)

  CPU_CYCLES 3
  ;LDR pc,[sp],#4
  R6502NEXTOPCODE

