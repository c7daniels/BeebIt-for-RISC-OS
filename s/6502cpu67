|r6502opcode60|
  ;RTS
  STACKPOP r2 ;lo
  STACKPOP r3 ;hi
  MOV r2,r2,LSL #16
  ADD rpc,r2,r3,LSL#24 ;r6502_pc=lo+(hi<<8)
  ADD rpc,rpc,#&10000 ;r6502_pc++ (6502 bug)

  CPU_CYCLES 6
  ;LDR pc,[sp],#4
  R6502NEXTOPCODE

|r6502opcode61|
  ;ADC
  ADDRESSOFPREINDEXED ;4 cycles
  READMEM ;1 cycle
  TST rps,#DFLAG
  BNE r6502opcode61_2
  ;binary
  R6502ADC ;1 cycle
  CPU_CYCLES 2
  ;LDR pc,[sp],#4
  R6502NEXTOPCODE
r6502opcode61_2
  ;BCD
  R6502ADCD ;1 cycle
  CPU_CYCLES 2
  ;LDR pc,[sp],#4
  R6502NEXTOPCODE

