|r6502pushedtointerruptlostep|
  LDR r1,[r0,#:INDEX:R6502_SP_CODE]
  LDRB r2,[r0,#:INDEX:R6502_PS]
  LDRB r3,[r0,#:INDEX:R6502_NMIS]
  SUB r1,r1,#1:SHL:24
  ORR r2,r2,#IFLAG
  STR r1,[r0,#:INDEX:R6502_SP_CODE]
  STRB r2,[r0,#:INDEX:R6502_PS]
  BIC r1,r3,r3,LSR #4
  TST r1,#NMIS_NMI
  MOV r2,#BUS_BASEFLAG
  ORRNE r3,r3,#NMIS_OLDNMI
  SUBNE r2,r2,#6:SHL:16
  SUBEQ r2,r2,#2:SHL:16
  LDR r1,[r0,#:INDEX:R6502_TRANSITION2ACTION]
  STRNEB r3,[r0,#:INDEX:R6502_NMIS]
  STR r1,[r0,#:INDEX:R6502_TRANSITION1ACTION]
  STR r2,[r0,#:INDEX:R6502_ADDRESS_CODE]
  LDR r1,[r0,#:INDEX:R6502_LBREAK]
  TST r1,r1
  LDRNE r3,[r0,#:INDEX:R6502_RESETACTION]
  STRNE r3,[r0,#:INDEX:R6502_TRANSITION1ACTION]
  LDR r3,[r0,#:INDEX:R6502_CPU_STATE]
  ADD r3,r3,#1
  STR r3,[r0,#:INDEX:R6502_CPU_STATE]
  MOV pc,lr

