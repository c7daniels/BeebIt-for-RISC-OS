|r6502opcode07|
  ;check if it's called from the ROM space
  ANDS r0,rpc,#&8000
  BNE r6502opcode07_interface
  ;ASO
  VALUEOFZEROPAGE
  R6502ASO
  STRB r0,[r11]
  CPU_CYCLES 5
  ;LDR pc,[sp],#4
  R6502NEXTOPCODE

r6502opcode07_interface
  ;Opcode 07 Interface
  STMFD sp!,{r0-ry,r11-r12}
  ;MOV r0,#31
  ;SWI OS_WriteC
  ;MOV r0,#0
  ;SWI OS_WriteC
  ;MOV r0,#0
  ;SWI OS_WriteI+55
  ;save the pc for later
  LDR r11,=r6502_pc
  STR rpc,[r11]
  ;save the ps for later
  LDR r11,=r6502_ps
  STRB rps,[r11]

  ;pointer to bbc memory
  ADD r12,r12,#:INDEX:R6502_MEMORY
  ;pointer to control block
  MOV r11,ry,LSL#8
  ORR r11,r11,rx
  ADD r11,r11,r12

  ;bit set of registers to relocate
  LDRB r10,[r11,#4]

  ;set the registers r0-r7
  LDR r0,[r11,#09]
  ANDS r9,r10,#1
  ADDNE r0,r0,r12
  LDR r1,[r11,#13]
  ANDS r9,r10,#2
  ADDNE r1,r1,r12
  LDR r2,[r11,#17]
  ANDS r9,r10,#4
  ADDNE r2,r2,r12
  LDR r3,[r11,#21]
  ANDS r9,r10,#8
  ADDNE r3,r3,r12
  LDR r4,[r11,#25]
  ANDS r9,r10,#16
  ADDNE r4,r4,r12
  LDR r5,[r11,#29]
  ANDS r9,r10,#32
  ADDNE r5,r5,r12
  LDR r6,[r11,#33]
  ANDS r9,r10,#64
  ADDNE r6,r6,r12
  LDR r7,[r11,#37]
  ANDS r9,r10,#128
  ADDNE r7,r7,r12

  ;load the swi number
  LDRB r10,[r11,#0]
  LDRB r9,[r11,#1]
  ORR r10,r10,r9,LSL#8
  LDRB r9,[r11,#2]
  ORR r10,r10,r9,LSL#16
  ;set the 'X' error flag
  ORR r10,r10,#&20000
  SWI OS_CallASWI

  LDR r10,=r6502_ps
  LDRB rps,[r10]
  AND rps,rps,#&3C ;%00111100 ;clear NVubdiZC
  ORRMI rps,rps,#NFLAG
  ORREQ rps,rps,#ZFLAG
  ORRCS rps,rps,#CFLAG
  ORRVS rps,rps,#VFLAG
  STRB rps,[r10]

  BVS r6502opcode07_error

  LDRB r8,[r11,#3] ;number of registers to return
  LDRB r10,[r11,#5] ;bit set of registers to relocate

  ;write the registers r0-r7
  CMP r8,#0
  BEQ r6502opcode07_2
  ANDS r9,r10,#1
  SUBNE r0,r0,r12
  STR r0,[r11,#09]
  CMP r8,#1
  BEQ r6502opcode07_2
  ANDS r9,r10,#2
  SUBNE r1,r1,r12
  STR r1,[r11,#13]
  CMP r8,#2
  BEQ r6502opcode07_2
  ANDS r9,r10,#4
  SUBNE r2,r2,r12
  STR r2,[r11,#17]
  CMP r8,#3
  BEQ r6502opcode07_2
  ANDS r9,r10,#8
  SUBNE r3,r3,r12
  STR r3,[r11,#21]
  CMP r8,#4
  BEQ r6502opcode07_2
  ANDS r9,r10,#16
  SUBNE r4,r4,r12
  STR r4,[r11,#25]
  CMP r8,#5
  BEQ r6502opcode07_2
  ANDS r9,r10,#32
  SUBNE r5,r5,r12
  STR r5,[r11,#29]
  CMP r8,#6
  BEQ r6502opcode07_2
  ANDS r9,r10,#64
  SUBNE r6,r6,r12
  STR r6,[r11,#33]
  CMP r8,#7
  BEQ r6502opcode07_2
  ANDS r9,r10,#128
  SUBNE r7,r7,r12
  STR r7,[r11,#37]

r6502opcode07_2
  LDR r11,=r6502_ps
  LDRB rps,[r11]
  LDR r11,=r6502_pc
  LDR rpc,[r11]
  LDMFD sp!,{r0-ry,r11-r12}
  ;LDR pc,[sp],#4
  R6502NEXTOPCODE

r6502opcode07_error
  ;load the swi number
  LDRB r10,[r11,#2]
  ;test the 'X' error flag
  ANDS r10,r10,#&02

  BEQ r6502opcode07_errorXC

  ;X set
  ;if set, point to error buffer
  LDRB r10,[r11,#6]
  LDRB r9,[r11,#7]
  ORR r10,r10,r9,LSL#8
  ADD r10,r10,r12
  ;length of error buffer
  LDRB r9,[r11,#8]
  CMP r9,#0
  BEQ r6502opcode07_error5
  B r6502opcode07_error2

r6502opcode07_errorXC
  ;if X not set, point pc to &100
  LDR r10,=r6502_pc
  MOV rpc,#&100
  STR rpc,[r10]
  ADD r10,r12,rpc
  ;length of error buffer
  MOV r9,#&40

r6502opcode07_error2
  ;set the BRK opcode
  MOV r8,#0
  ;write 00 opcode
  STRB r8,[r10],#1
  ;counter--
  SUBS r9,r9,#1
  BEQ r6502opcode07_error5
  ;store the error code
  LDRB r8,[r0],#4
  STRB r8,[r10],#1
  ;remove 1 for the error code
  SUBS r9,r9,#1
  BEQ r6502opcode07_error4

  ;remove 1 for the terminator
  SUBS r9,r9,#1
  BEQ r6502opcode07_error4

r6502opcode07_error3
  LDRB r8,[r0],#1
  STRB r8,[r10],#1
  CMP r8,#0
  BEQ r6502opcode07_error5
  SUBS r9,r9,#1
  BNE r6502opcode07_error3

r6502opcode07_error4
  ;set the terminator
  MOV r8,#0
  STRB r8,[r10]

r6502opcode07_error5
  LDR r11,=r6502_ps
  LDRB rps,[r11]
  LDR r11,=r6502_pc
  LDR rpc,[r11]
  LDMFD sp!,{r0-ry,r11-r12}
  ;LDR pc,[sp],#4
  R6502NEXTOPCODE

