|r6502branchtakenstep|
  LDR r1,[r0,#:INDEX:R6502_PC_CODE]
  LDR r2,[r0,#:INDEX:R6502_LATCH]
  ADD r1,r1,r2
  LDR r2,[r0,#:INDEX:R6502_ADDRESS_CODE]
  STR r1,[r0,#:INDEX:R6502_PC_CODE]
  EOR r3,r2,r1
  TST r3,#&FF000000
  BNE r6502branchtakenstep2
  STR r1,[r0,#:INDEX:R6502_ADDRESS_CODE]
  LDR r1,[r0,#:INDEX:R6502_TRANSITION1ACTION]
  LDR r2,[r0,#:INDEX:R6502_INTERRUPTACTION]
  CMP r1,r2
  MOVNE pc,r1
  MOV_R6502_FIRST_STEP_IN r3,R6502_DECODE_SEQUENCE
  LDR r2,[r0,#:INDEX:R6502_TIMESINTERRUPTMISSED]
  STR r3,[r0,#:INDEX:R6502_CPU_STATE]
  CMP r2,#256
  ADD r2,r2,#1
  STRLO r2,[r0,#:INDEX:R6502_TIMESINTERRUPTMISSED]
  MOVLO pc,lr
  LDR r1,[r0,#:INDEX:R6502_TRANSITION2ACTION]
  LDR r2,[r0,#:INDEX:R6502_YIELDACTION]
  CMP r1,r2
  MOVNE pc,lr
  LDR r1,[r0,#:INDEX:R6502_FETCHACTION]
  LDRB r2,[r0,#:INDEX:R6502_NMIS]
  ORR r2,r2,#NMIS_YIELD
  STR r1,[r0,#:INDEX:R6502_TRANSITION2ACTION]
  STRB r2,[r0,#:INDEX:R6502_NMIS]
  MOV pc,lr
r6502branchtakenstep2
