|r6502opcode00|
  ;BRK
  ADD rpc,rpc,#1

  MOV r1,#&FF00
  AND r0,rpc,r1
  MOV r0,r0,LSR#8 ;r0=(r0>>8)
  STACKPUSH r0 ;(r6502_pc & 0xFF00)

  MOV r1,#&00FF
  AND r0,rpc,r1
  STACKPUSH r0 ;(r6502_pc & 0x00FF)

  ORR rps,rps,#BFLAG

  MOV r0,rps
  ORR r0,r0,#UFLAG
  STACKPUSH r0

  ORR rps,rps,#IFLAG

  ADD r2,r12,#:INDEX:R6502_MEMORY+&10000 ;memory+&10000
  LDRB r0,[r2,#-1] ;&FFFF
  LDRB r1,[r2,#-2] ;&FFFE
  ADD rpc,r1,r0,LSL#8
  CPU_CYCLES 7
  ;LDR pc,[sp],#4
  R6502NEXTOPCODE

