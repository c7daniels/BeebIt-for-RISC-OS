|r6502opcode40|
  ;RTI
  STACKPOP rps
  STACKPOP r2 ;lo
  STACKPOP r3 ;hi
  MOV r2,r2,LSL #16
  ADD rpc,r2,r3,LSL #24 ;r6502_pc=lo+(hi<<8)

  CPU_CYCLES 6

  ANDS r0,rps,#IFLAG
  BNE r6502opcode40end

  R6502IRQCHECK0

r6502opcode40end
  ;LDR pc,[sp],#4
  R6502NEXTOPCODE

