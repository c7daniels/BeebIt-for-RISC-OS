|r6502opcode4C|
  ;JMP
  ;STMFD sp!,{r0-r2,rpc,r10-r12,lr}
  CMP rpc,#&2FC0
  ADDGT pc,pc,#12 ;4*4 (-4)

  ;rpc < &2FC1 < &3000
  ADD r11,r12,rpc ;r11=memory+pc (offset)
  LDRB r2,[r11] ;lo
  LDRB r0,[r11,#1] ;hi
  ADD pc,pc,#(READMEM_LEN*2)+(3*4)-4 ;9*4 (-4)

  ;rpc > &2FC0
  MOV r0,rpc
  READMEM ;lo
  MOV r2,r0 ;lo
  ADD r0,rpc,#1
  READMEM ;hi

  ;continue
  ADD rpc,r2,r0,LSL#8 ;r0=lo+(hi<<8)
  CPU_CYCLES 3
  R6502NEXTOPCODE

