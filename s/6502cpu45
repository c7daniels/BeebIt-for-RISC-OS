r6502opcode50_2
  ;LDR r12,=memory ;pointer to memory block
  VALUEOFIMMEDIATE r0
  MOV r1,rpc,LSR#8 ;r1=(pc>>8)
  AND r1,r1,#&FF
  ANDS r2,r0,#&80 ;r2=(n & 0x80)
