|r6502opcode4C|
  ;JMP
  MOV r1,rpc
  READMEM
  STR r0,[r12,#:INDEX:R6502_ABSTEMP] ;lo

  ADD r1,r1,#&10000 ;rpc + 1
  READMEM ;hi
  LDR r2,[r12,#:INDEX:R6502_ABSTEMP] ;lo
  MOV r2,r2,LSL #16

  ADD rpc,r2,r0,LSL #24 ;r6502_pc=lo+(hi<<8)
  CPU_CYCLES 3
  R6502NEXTOPCODE

