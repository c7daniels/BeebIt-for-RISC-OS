  MACRO
  LOAD_KEY
  ADD r3,r0,r3,LSR #1
  LDRB r12,[r0,#:INDEX:HOST_KEYBIT]
  LDRPLB r3,[r3,#:INDEX:HOST_KEYSTATUS]
  MOVMI r3,#0
  MEND

  MACRO
  TEST_KEY
  TST r3,r12
  ORRNE r2,r2,#&80
  BICEQ r2,r2,#&80
  MEND

  MACRO
  SHIFT_INTERRUPTQUEUE_START
  AND r3,r5,#&0F00
  TST r5,#R6502_NMI
  MOV r5,r5,ROR #8
  ORREQ r3,r3,#R6502_NMI_ENABLE
  MEND

  MACRO
  SHIFT_INTERRUPTQUEUE_FINISH $shift
  IF $shift==1
  ORR r3,r3,r5,LSR #24
  ORR r5,r3,r5,LSL #12
  ELIF $shift==2
  ORR r3,r3,r3,LSL #4
  ORR r3,r3,r5,LSR #24
  ORR r5,r3,r5,LSL #16
  ELIF $shift==3
  ORR r3,r3,r3,LSL #4
  ORR r3,r3,r3,LSL #4
  ORR r3,r3,r5,LSR #24
  ORR r5,r3,r5,LSL #20
  ELIF $shift==4
  ORR r3,r3,r3,LSL #4
  ORR r3,r3,r3,LSL #8
  ORR r3,r3,r5,LSR #24
  ORR r5,r3,r5,LSL #24
  ELIF $shift==5
  ORR r3,r3,r3,LSL #4
  ORR r3,r3,r3,LSL #8
  ORR r3,r3,r3,LSL #4
  ORR r3,r3,r5,LSR #24
  ORR r5,r3,r5,LSL #28
  ELSE
  ORR r3,r3,r3,LSL #4
  ORR r3,r3,r3,LSL #8
  ORR r3,r3,r3,LSL #8
  ORR r5,r3,r5,LSR #24
  ENDIF
  MEND

  MACRO
  SET_IFR
  LDRB r3,[r0,#:INDEX:HOST_ASYSVIA+:INDEX:HOSTAVIA_IER]
  LDRB r2,[r0,#:INDEX:HOST_ASYSVIA+:INDEX:HOSTAVIA_IFR]
  TST r3,#1
  ORR r7,r7,#KEYSCANIFRFLAG
  ORREQ r2,r2,#&01
  ORRNE r2,r2,#&81
  STRB r2,[r0,#:INDEX:HOST_ASYSVIA+:INDEX:HOSTAVIA_IFR]
  BEQ %F1
  LDR r3,[r0,#:INDEX:HOST_INTERRUPTS]
  ORR r5,r5,#R6502_IRQ
  ORR r3,r3,#HOST_IRQ_6522SYSVIA
  STR r3,[r0,#:INDEX:HOST_INTERRUPTS]
1
  MEND

  MACRO
  SET_IFR_RETURN
  LDRB r3,[r0,#:INDEX:HOST_ASYSVIA+:INDEX:HOSTAVIA_IER]
  LDRB r2,[r0,#:INDEX:HOST_ASYSVIA+:INDEX:HOSTAVIA_IFR]
  TST r3,#1
  ORR r7,r7,#KEYSCANIFRFLAG
  ORREQ r2,r2,#&01
  ORRNE r2,r2,#&81
  STRB r2,[r0,#:INDEX:HOST_ASYSVIA+:INDEX:HOSTAVIA_IFR]
  MOVEQ pc,lr
  LDR r3,[r0,#:INDEX:HOST_INTERRUPTS]
  ORR r5,r5,#R6502_IRQ
  ORR r3,r3,#HOST_IRQ_6522SYSVIA
  STR r3,[r0,#:INDEX:HOST_INTERRUPTS]
  MOV pc,lr
  MEND

host0s1_000
  ;    [[[0, 0, 1, 0, 'F+']], [1, 0], 0]
  MOV r2,r2,ROR r7
  ORR r2,r2,r2,ROR #1
  ANDS r2,r2,#&40000000
  BEQ %F10
  ADD r7,r7,#&001
  ADD r7,r7,#&400
  MOV pc,lr
10
  LDRB r3,[r0,#:INDEX:HOST_ASYSVIA+:INDEX:HOSTAVIA_PCR]
  ADD r7,r7,#&041
  ADD r7,r7,#&400
  AND r3,r3,#&0E
  CMP r3,#4
  CMPNE r3,#6
  MOVNE pc,lr
  SET_IFR_RETURN

host0s1_040
  ;    [[[0, 0, 1, 0, 'F-']], [1, 0], 0]
  MOV r2,r2,ROR r7
  ORR r2,r2,r2,ROR #1
  ANDS r2,r2,#&40000000
  BNE %F10
  ADD r7,r7,#&001
  ADD r7,r7,#&400
  MOV pc,lr
10
  LDRB r3,[r0,#:INDEX:HOST_ASYSVIA+:INDEX:HOSTAVIA_PCR]
  ADD r7,r7,#&001
  ADD r7,r7,#&400
  BIC r7,r7,#&040
  AND r3,r3,#&0E
  CMP r3,#2
  MOVNE pc,lr
  SET_IFR_RETURN

host0s1_080
  ;    [[[0, 0, 1, 0, '+']], [1, 0], 0]
  MOV r2,r2,ROR r7
  ORR r2,r2,r2,ROR #1
  TST r2,#&40000000
  ADD r7,r7,#&001
  ADD r7,r7,#&400
  ORREQ r7,r7,#KEYSCANCA2FLAG
  MOV pc,lr

host0s1_0C0
  ;    [[[0, 0, 1, 0, '-']], [1, 0], 0]
  MOV r2,r2,ROR r7
  ORR r2,r2,r2,ROR #1
  TST r2,#&40000000
  ADD r7,r7,#&001
  ADD r7,r7,#&400
