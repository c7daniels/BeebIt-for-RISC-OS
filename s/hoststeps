; Import global symbols

; Export global symbols

  EXPORT hoststeps

  MACRO
  LOAD_KEY
  ADD r3,r0,r3,LSR #1
  LDRB r12,[r0,#:INDEX:HOST_KEYBIT]
  LDRPLB r3,[r3,#:INDEX:HOST_KEYSTATUS]
  MOVMI r3,#0
  MEND

  MACRO
  TEST_KEY
  TST r3,r12
  ORRNE r2,r2,#&80
  BICEQ r2,r2,#&80
  MEND

  MACRO
  SHIFT_INTERRUPTQUEUE_START
  AND r3,r5,#&0F00
  TST r5,#R6502_NMI
  MOV r5,r5,ROR #8
  ORREQ r3,r3,#R6502_NMI_ENABLE
  MEND

  MACRO
  SHIFT_INTERRUPTQUEUE_FINISH
  ORR r3,r3,r5,LSR #24
  ORR r5,r3,r5,LSL #12
  MEND

  MACRO
  SET_IFR_RETURN
  LDRB r3,[r0,#:INDEX:HOST_ASYSVIA+:INDEX:HOSTAVIA_IER]
  LDRB r2,[r0,#:INDEX:HOST_ASYSVIA+:INDEX:HOSTAVIA_IFR]
  TST r3,#1
  ORR r7,r7,#KEYSCANIFRFLAG
  ORREQ r2,r2,#&01
  ORRNE r2,r2,#&81
  STRB r2,[r0,#:INDEX:HOST_ASYSVIA+:INDEX:HOSTAVIA_IFR]
  MOVEQ pc,lr
  LDR r3,[r0,#:INDEX:HOST_INTERRUPTS]
  ORR r5,r5,#R6502_IRQ
  ORR r3,r3,#HOST_IRQ_6522SYSVIA
  STR r3,[r0,#:INDEX:HOST_INTERRUPTS]
  MOV pc,lr
  MEND

