  MACRO
  LOAD_KEY
  ADD r3,r0,r3,LSR #1
  LDRB r12,[r0,#:INDEX:HOST_KEYBIT]
  LDRPLB r3,[r3,#:INDEX:HOST_KEYSTATUS]
  MOVMI r3,#0
  MEND

  MACRO
  SHIFT_INTERRUPTQUEUE
  TST r3,#R6502_NMI
  AND r2,r3,#&0F
  ORREQ r2,r2,#R6502_NMI_ENABLE
  ORR r2,r2,r3,LSL #4
  MEND

  MACRO
  SET_IFR_RETURN
  LDRB r3,[r0,#:INDEX:HOST_ASYSVIA+:INDEX:HOSTAVIA_IER]
  LDRB r2,[r0,#:INDEX:HOST_ASYSVIA+:INDEX:HOSTAVIA_IFR]
  TST r3,#1
  ORR r1,r1,#KEYSCANIFRFLAG
  ORREQ r2,r2,#&01
  ORRNE r2,r2,#&81
  STRB r2,[r0,#:INDEX:HOST_ASYSVIA+:INDEX:HOSTAVIA_IFR]
  STR r1,[r0,#:INDEX:HOST_KEYSCANSTATE]
  MOVEQ pc,lr
  LDR r2,[r0,#:INDEX:R6502_INTERRUPTQUEUE]
  LDR r3,[r0,#:INDEX:HOST_INTERRUPTS]
  ORR r2,r2,#R6502_IRQ
  ORR r3,r3,#HOST_IRQ_6522SYSVIA
  STR r2,[r0,#:INDEX:R6502_INTERRUPTQUEUE]
  STR r3,[r0,#:INDEX:HOST_INTERRUPTS]
  MOV pc,lr
  MEND

