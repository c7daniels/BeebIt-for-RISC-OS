; r9=PC
; r8=PS
; r7=Y
; r6=X
; r5=A

  GET h.6502cpus

  GET h.6502cpui

; Use the GET directive to include register definitions as if typed here

  GET h.RegNames

; Use the GET directive to include a list of SWI names as if typed here

  GET h.SWInames

; Area name C$$code advisable as wanted to link with C output

  AREA |C$$code|, CODE, READONLY

; Import global symbols

  IMPORT |r6502busop|
  IMPORT |r6502intoyield|
  
  IMPORT |r6502immediatedone|
  IMPORT |r6502zeropagereadreadforwrite|
  IMPORT |r6502hiabsolutereadreadforwrite|

  IMPORT |r6502dec|
  IMPORT |r6502nop|

; Export global symbols

  EXPORT |r65c12opcodeC2|
  EXPORT |r65c12opcodeC3|
  EXPORT |r65c12opcodeC6|
  EXPORT |r65c12opcodeC7|
  EXPORT |r65c12opcodeCB|
  EXPORT |r65c12opcodeCE|
  EXPORT |r65c12opcodeCF|

|r65c12opcodeC2|
  IMMEDIATELOAD r6502nop

|r65c12opcodeC3|
  B r6502nop

|r65c12opcodeC6|
  ZEROPAGEMODIFYC r6502dec

|r65c12opcodeC7|
  B r6502nop

|r65c12opcodeCB|
  B r6502nop

|r65c12opcodeCE|
  ABSOLUTEMODIFYC r6502dec

|r65c12opcodeCF|
  B r6502nop

;Data Area

;  AREA    |C$$data|, DATA

  END
