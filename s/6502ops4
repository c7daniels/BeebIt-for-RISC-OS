  MACRO
  MODIFY_ZPGIND_ACTION $r
  LDR r3, [sp], #4
  [ "$r"!="r2"
  STR r2,[sp, #-4]!
  MOV r2,$r
  ]
  MOV lr,pc
  LDR pc,[r3,#8]
  [ "$r"!="r2"
  MOV $r,r2
  LDR r2, [sp], #4
  ]
  MEND

  MACRO
  MODIFY_ABS_ACTION $r
  LDR r3, [sp], #4
  [ "$r"!="r2"
  STR r2,[sp, #-4]!
  MOV r2,$r
  ]
  MOV lr,pc
  LDR pc,[r3,#12]
  [ "$r"!="r2"
  MOV $r,r2
  LDR r2, [sp], #4
  ]
  MEND

  MACRO
  ASL_ACTION $r
  BIC r5,r5,#NFLAG|ZFLAG|CFLAG
  MOVS r3,$r,LSL #25
  ORRMI r5,r5,#NFLAG
  MOV $r,r3,LSR #24
  ORREQ r5,r5,#ZFLAG
  ORRCS r5,r5,#CFLAG
  MEND

  MACRO
  DCP_ACTION $r
  LDR r1,[r0,#:INDEX:R6502_A_SHIFT]
  SUB $r,$r,#1
  BIC r5,r5,#NFLAG|ZFLAG|CFLAG
  SUBS r1,r1,$r,LSL #24
  ORRMI r5,r5,#NFLAG
  ORREQ r5,r5,#ZFLAG
  ORRCS r5,r5,#CFLAG
  MEND

  MACRO
  DEC_ACTION $r
  SUB $r,$r,#1
  BIC r5,r5,#NFLAG|ZFLAG
  MOVS r3,$r,LSL #24
  ORRMI r5,r5,#NFLAG
  ORREQ r5,r5,#ZFLAG
  MEND

  MACRO
  INC_ACTION $r
  ADD $r,$r,#1
  BIC r5,r5,#NFLAG|ZFLAG
  MOVS r3,$r,LSL #24
  ORRMI r5,r5,#NFLAG
  ORREQ r5,r5,#ZFLAG
  MEND

  MACRO
  ISC_ACTION $r
  LDRB r1,[r0,#:INDEX:R6502_A]
  ADD $r,$r,#1
  TST r5,#DFLAG
  MOV r3,$r,LSL #24
  BNE %F0
  TEQ r3,r5,LSR #1   ;jdl** ARM c =6502 c
  BIC r5,r5,#NFLAG|VFLAG|ZFLAG|CFLAG
  RSCS r1,r3,r1,ROR #8
  ORRMI r5,r5,#NFLAG
  ORRVS r5,r5,#VFLAG
  ORRCS r5,r5,#CFLAG
  MOVS r1,r1,LSR#24 ;(a=(a>>24) jdl** also (z=(a=0))
  B %F1
0
  TEQ r3,r5,LSR #1   ;jdl** ARM c =6502 c
  ORR r3,r3,r3,ROR #24
  ORR r1,r1,r1,ROR #8
  AND r3,r3,#&F000000F
  AND r1,r1,#&F000000F
  MVN r3,r3
  BIC r5,r5,#NFLAG|VFLAG|ZFLAG|CFLAG
  ADCS r1,r1,r3
  ORRCS r5,r5,#CFLAG
  ORRMI r5,r5,#NFLAG
  ORRVS r5,r5,#VFLAG
  MOV r3,r1
  SUBCC r1,r1,#&60000000
  TST r1,#&80
  SUBNE r1,r1,#6
  AND r1,r1,#&F000000F
  TST r3,#&F000000F
  ORR r1,r1,r1,LSR #24
1
  ORREQ r5,r5,#ZFLAG
  STRB r1,[r0,#:INDEX:R6502_A]
  MEND

  MACRO
  LSR_ACTION $r
  BIC r5,r5,#NFLAG|ZFLAG|CFLAG
  MOVS $r,$r,LSR #1
  ORREQ r5,r5,#ZFLAG
  ORRCS r5,r5,#CFLAG
  MEND

  MACRO
  RLA_ACTION $r
  TST r5,#CFLAG
  MOV r3,$r,LSL #24
  BIC r5,r5,#NFLAG|ZFLAG|CFLAG
  ORRNE r3,r3,#&800000
  MOVS r1,r3,LSL #1
  LDR r3,[r0,#:INDEX:R6502_A_SHIFT]
  MOV $r,r1,LSR #24
  ORRCS r5,r5,#CFLAG
  ANDS r3,r1,r3
  ORRMI r5,r5,#NFLAG
  STR r3,[r0,#:INDEX:R6502_A_SHIFT]
  ORREQ r5,r5,#ZFLAG
  MEND

  MACRO
  ROL_ACTION $r
  TST r5,#CFLAG
  MOV r3,$r,LSL #24
  BIC r5,r5,#NFLAG|ZFLAG|CFLAG
  ORRNE r3,r3,#&800000
  MOVS r3,r3,LSL #1
  ORRMI r5,r5,#NFLAG
  MOV $r,r3,LSR #24
  ORREQ r5,r5,#ZFLAG
  ORRCS r5,r5,#CFLAG
  MEND

  MACRO
  ROR_ACTION $r
  TST r5,#CFLAG
  BIC r5,r5,#NFLAG|ZFLAG|CFLAG
  ORRNE $r,$r,#&100
  ORRNE r5,r5,#NFLAG
  MOVS $r,$r,LSR #1
  ORREQ r5,r5,#ZFLAG
  ORRCS r5,r5,#CFLAG
  MEND

  MACRO
  RRA_ACTION $r
  TST r5,#CFLAG
  LDRB r1,[r0,#:INDEX:R6502_A]
  MOVEQ r3,$r
  ORRNE r3,$r,#&100
  TST r5,#DFLAG
  BNE %F0
  MOVS r3,r3,LSR #1
  MOV $r,r3
  MOV r3,r3,LSL #24
  SUB r1,r1,#1:SHL:8
  BIC r5,r5,#NFLAG|VFLAG|ZFLAG|CFLAG
  ADCS r1,r3,r1,ROR #8
  ORRMI r5,r5,#NFLAG
  ORRVS r5,r5,#VFLAG
  ORRCS r5,r5,#CFLAG
  MOVS r1,r1,LSR#24 ;(a=(a>>24) jdl** also (z=(a=0))
  B %F1
0
  MOVS r3,r3,LSR #1
  ORR r1,r1,r1,ROR #8
  MOV $r,r3
  ORR r3,r3,#&0FF00000
  AND r1,r1,#&F000000F
  ORR r3,r3,#&000FF000
  ADD r1,r1,#6
  ORR r3,r3,r3,ROR #8
  BIC r5,r5,#NFLAG|VFLAG|ZFLAG|CFLAG
  ADCS r1,r1,r3
  ORRMI r5,r5,#NFLAG
  ORRVS r5,r5,#VFLAG
  CMPCC r1,#&A0000000
  SUB r3,r1,#6
  ADDCS r1,r1,#&60000000
  ORRCS r5,r5,#CFLAG
  TST r1,#&80
  SUBNE r1,r1,#6
  AND r1,r1,#&F000000F
  ORR r1,r1,r1,LSR #24
  TST r3,#&F000000F
1
  ORREQ r5,r5,#ZFLAG
  STRB r1,[r0,#:INDEX:R6502_A]
  MEND

  MACRO
  SLO_ACTION $r
  LDR r1,[r0,#:INDEX:R6502_A_SHIFT]
  BIC r5,r5,#NFLAG|ZFLAG|CFLAG
  MOVS r3,$r,LSL #25
  ORRCS r5,r5,#CFLAG
  ORRS r1,r1,r3
  MOV $r,r3,LSR #24
  ORRMI r5,r5,#NFLAG
  STR r1,[r0,#:INDEX:R6502_A_SHIFT]
  ORREQ r5,r5,#ZFLAG
  MEND

  MACRO
  SRE_ACTION $r
  LDR r1,[r0,#:INDEX:R6502_A_SHIFT]
  BIC r5,r5,#NFLAG|ZFLAG|CFLAG
  MOVS $r,$r,LSR #1
  ORRCS r5,r5,#CFLAG
  EORS r1,r1,$r,LSL #24
  STR r1,[r0,#:INDEX:R6502_A_SHIFT]
  ORRMI r5,r5,#NFLAG
  ORREQ r5,r5,#ZFLAG
  MEND

  MACRO
  TRB_ACTION $r
  LDRB r3,[r0,#:INDEX:R6502_A]
  TST r3,$r
  BIC $r,$r,r3
  BICNE r5,r5,#ZFLAG
  ORREQ r5,r5,#ZFLAG
  MEND

  MACRO
  TSB_ACTION $r
  LDRB r3,[r0,#:INDEX:R6502_A]
  TST r3,$r
  ORR $r,$r,r3
  BICNE r5,r5,#ZFLAG
  ORREQ r5,r5,#ZFLAG
  MEND

