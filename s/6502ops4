  MACRO
  R6502_LINEAR_MODIFY_ZPG_TAIL $tag,$ctype,$aname
$tag.zpgtail
  LDRB r2,[r4]
  $aname._ACTION r2
  STRB r2,[r4]
  R6502_OPCODE_$ctype._ADDRESSED_RETURN 2,interrupt
  MEND

  MACRO
  R6502_MODIFY_ACTION $returntype,$n,$r,$type,$ctype,$tag,$mode,$special,$stretch,$aname
  [ $special==0
  [ "$r"=="r2"
  LDRB r2,[r4]
  |
  LDRB $r,[r2]
  ]
  |
  R6502_OPCODE_READ_SPECIAL
  R6502_OPCODE_CYCLES 1,$stretch
  LDRB r2,[r0,#:INDEX:R6502_M]
  MOV r1,r4
  STR r2,[sp, #-4]!
  [ "$type"=="r65c12" || "$type"=="r65c12outfold" || "$type"=="r65c12atfold" || "$type"=="r65c12infold"
  R6502_OPCODE_READ_SPECIAL
  |
  R6502_OPCODE_WRITE_SPECIAL
  ]
  [ $stretch==0
  R6502_OPCODE_CYCLES 1,0
s_$type.$tag.$mode.tailreturn
  LDR r2, [sp], #4
  |
  R6502_OPCODE_CYCLES_BRANCH 1,1,s_$type.$tag.$mode.tailreturn
  ]
  ]
  [ $stretch==0
  $aname._ACTION $r
  [ $special==0
  [ "$r"=="r2"
  STRB r2,[r4]
  |
  STRB $r,[r2]
  ]
  |
  MOV r1,r4
  R6502_OPCODE_WRITE_SPECIAL
  ]
  [ "$mode"=="zpgind"
  ADD r6,r6,#2:SHL:16
  |
  ADD r6,r6,#3:SHL:16
  ]
  R6502_OPCODE_$ctype._ADDRESSED_RETURN $n+2,$returntype
  ]
  MEND

  MACRO
  R6502_MODIFY_WAITS $entrytype,$returntype,$n,$type,$ctype,$tag,$mode,$aname
  LCLS tag2
  [ "$returntype"=="uninterrupted"
tag2 SETS "$tag"
  |
tag2 SETS "linear$tag"
  ]
  [ "$entrytype"=="inpage"
  LCLA nm1value
nm1value SETA $n-1
  R6502_WAIT_HANDLERS inline,$nm1value,move,$type,inpage$tag.$mode,1
  ]
  [ "$type"=="r6502" || "$type"=="r65c12"
  R6502_WAIT_HANDLERS inline,$n,move,$type,$tag2.$mode,1
  |
  R6502_WAIT_HANDLERS ,$n,move,$type,$tag2.$mode,1
  [ "$entrytype"=="inpage"
d_$type.wait$nm1value.inpage$tag.$mode
  ]
  MOV r4,r2
  R6502_OPCODE_CYCLES $n+2,0
  R6502_MODIFY_ACTION $returntype,0,r2,$type,$ctype,$tag2,$mode,0,0,$aname
  ]
  MEND

  MACRO
  R6502_MODIFY_TAIL $entrytype,$returntype,$type,$ctype,$tag,$mode,$aname
  LCLS tag2
  [ "$returntype"=="uninterrupted"
tag2 SETS "$tag"
  |
tag2 SETS "linear$tag"
  ]
  [ "$entrytype"=="inpage"
  R6502_TAIL_ENTRY move,$type,inpage$tag.$mode,0
  R6502_OPCODE_READ_SPECIAL
  R6502_OPCODE_CYCLES 1,0
  ]
  R6502_TAIL_ENTRY move,$type,$tag2.$mode,0
  R6502_MODIFY_ACTION $returntype,0,r2,$type,$ctype,$tag2,$mode,1,0,$aname
  [ "$entrytype"=="inpage"
  R6502_TAIL_ENTRY move,$type,inpage$tag.$mode,1
  R6502_OPCODE_READ_SPECIAL
  R6502_OPCODE_CYCLES 1,1
  ]
  R6502_TAIL_ENTRY move,$type,$tag2.$mode,1
  R6502_MODIFY_ACTION $returntype,0,r2,$type,$ctype,$tag2,$mode,1,1,$aname
  MEND

  MACRO
  R6502_PAGE_INCREMENT_ACTION $continuationtype,$r,$n,$type,$tag,$mode
  ADD r1,$r,#1:SHL:24
  R6502_TOUCH_OR_WAIT $continuationtype,$n+1,$type,linear$tag.$mode
  MEND

  MACRO
  R6502_PAGE_INCREMENT_WAITS $n,$type,$tag,$mode
  [ "$type"=="r6502" || "$type"=="r65c12"
  R6502_WAIT_HANDLERS inline,$n,move,$type,pageincrement$tag.$mode,0
  |
  R6502_WAIT_HANDLERS ,$n,move,$type,pageincrement$tag.$mode,0
  R6502_PAGE_INCREMENT_ACTION ,r1,$n,$type,$tag,$mode
  ]
  MEND

  MACRO
  R6502_PAGE_INCREMENT_WAIT_TAIL $type,$tag,$mode,$aname
  R6502_TAIL_ENTRY move,$type,pageincrement$tag.$mode,0
  R6502_OPCODE_READ_SPECIAL
  [ "$type"=="r6502" || "$type"=="r65c12"
  R6502_PAGE_INCREMENT_ACTION inline,r4,0,$type,$tag,$mode
  MOV r4,r2
  R6502_OPCODE_CYCLES 3,0
  R6502_MODIFY_ACTION interrupt,0,r2,$type,INFOLD,linear$tag,$mode,0,0,$aname
  |
  R6502_PAGE_INCREMENT_ACTION ,r4,0,$type,$tag,$mode
  ]
  MEND

  MACRO
  R6502_IN_PAGE_MODIFY $n,$type,$tag,$mode,$aname,$features
  R6502_TOUCH_OR_WAIT inline,$n,$type,inpage$tag.$mode
  [ ($features&1)==0
  MOV r4,r2
  R6502_OPCODE_CYCLES $n+3,0
  R6502_MODIFY_ACTION interrupt,0,r2,$type,INFOLD,linear$tag,$mode,0,0,$aname
  |
  R6502_MODIFY_ACTION interrupt,$n+3,r4,$type,INFOLD,linear$tag,$mode,0,0,$aname
  ]
  MEND

  MACRO
  R6502_PAGE_INCREMENT_MODIFY $n,$type,$tag,$mode,$aname,$features
  R6502_TOUCH_OR_WAIT inline,$n,$type,pageincrement$tag.$mode
  R6502_PAGE_INCREMENT_ACTION inline,r1,$n,$type,$tag,$mode
  [ ($features&1)==0
  MOV r4,r2
  R6502_OPCODE_CYCLES $n+3,0
  R6502_MODIFY_ACTION interrupt,0,r2,$type,INFOLD,linear$tag,$mode,0,0,$aname
  |
  R6502_MODIFY_ACTION interrupt,$n+3,r4,$type,INFOLD,linear$tag,$mode,0,0,$aname
  ]
  MEND

  MACRO
  R6502_LINEAR_MODIFY $n,$type,$tag,$mode,$aname,$features
  R6502_TOUCH_OR_WAIT inline,$n,$type,linear$tag.$mode
  [ ($features&1)==0
  MOV r4,r2
  R6502_OPCODE_CYCLES $n+2,0
  R6502_MODIFY_ACTION interrupt,0,r2,$type,INFOLD,linear$tag,$mode,0,0,$aname
  |
  R6502_MODIFY_ACTION interrupt,$n+2,r4,$type,INFOLD,linear$tag,$mode,0,0,$aname
  ]
  MEND

  MACRO
  R6502_MODIFY $n,$type,$tag,$mode,$aname,$features
  R6502_TOUCH_OR_WAIT inline,$n,$type,$tag.$mode
  [ ($features&1)==0
  MOV r4,r2
  R6502_OPCODE_CYCLES $n+2,0
  R6502_MODIFY_ACTION uninterrupted,0,r2,$type,INFOLD,$tag,$mode,0,0,$aname
  |
