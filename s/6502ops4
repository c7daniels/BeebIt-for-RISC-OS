  IF "$tag"=="asl" || "$tag"=="lsr" || "$tag"=="rol" || "$tag"=="ror"
genericmodify SETS "r65c12modify"
  ELSE
genericmodify SETS "r65c12linearmodify"
  ENDIF
  ELSE
genericmodify SETS "r6502linearmodify"
  ENDIF
  IF "$tag"=="trb" || "$tag"=="tsb"
action SETS "r65c12$tag.action"
  ELSE
action SETS "r6502$tag.action"
  ENDIF
