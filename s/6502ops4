  MACRO
  R6502_MODIFY_OPCODE_BODY $type,$tag,$mode,$aname,$features
  IF "$mode"=="zpg"
  ADD r6,r6,#2:SHL:16
  ADD r4,r0,r2
  [ ($features&1)==0
  IF "$tag"=="trb" || "$tag"=="tsb"
  R6502_OPCODE_CYCLES_BRANCH 3,0,r65c12$tag.zpgtail
  ELSE
