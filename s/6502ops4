  LDRB r3,[r9,r3]
  MOV r1,#ADDRESSING_BASECODE
  ORR r1,r1,r2,LSR #8
  ORR r1,r1,r3,LSL #24
  BCS %F1
  [ "$type"=="r65c12" && ("$tag"=="asl" || "$tag"=="lsr" || "$tag"=="rol" || "$tag"=="ror")
