  ENDIF
  |
  LDRB r2,[r4]
  $aname._ACTION r2
  STRB r2,[r4]
  R6502_OPCODE_INFOLD_ADDRESSED_RETURN 5,interrupt
  ]
  ELIF "$mode"=="zpgx" || "$mode"=="zpgy"
  [ "$mode"=="zpgx"
  LDR r4,[r0,#:INDEX:R6502_X_SHIFT]
  |
  LDR r4,[r0,#:INDEX:R6502_Y_SHIFT]
  ]
  ADD r2,r4,r2,LSL #24
  ADD r6,r6,#2:SHL:16
  ADD r4,r0,r2,LSR #24
  [ ($features&1)==0
  IF "$tag"=="trb" || "$tag"=="tsb"
  R6502_OPCODE_CYCLES_BRANCH 4,0,r65c12$tag.zpgtail
  ELSE
  R6502_OPCODE_CYCLES_BRANCH 4,0,r6502$tag.zpgtail
  ENDIF
  |
  LDRB r2,[r4]
  $aname._ACTION r2
  STRB r2,[r4]
  R6502_OPCODE_INFOLD_ADDRESSED_RETURN 6,interrupt
  ]
  ELIF "$mode"=="preindexed"
  LDR r4,[r0,#:INDEX:R6502_X_SHIFT]
  R6502_MODIFY_PREINDEXED $type,$tag,$mode,$aname,$features
  ELIF "$mode"=="postindexed"
  R6502_MODIFY_POSTINDEXED $type,$tag,$mode,$aname,$features
  ELIF "$mode"=="abs"
  R6502_MODIFY_ABS $type,$tag,$mode,$aname,$features
  ELIF "$mode"=="absx" || "$mode"=="absy"
  [ "$mode"=="absx"
  LDR r1,[r0,#:INDEX:R6502_X_SHIFT]
  |
  LDR r1,[r0,#:INDEX:R6502_Y_SHIFT]
  ]
  R6502_MODIFY_ABS_INDEXED $type,$tag,$mode,$aname,$features
  ENDIF
  MEND

  MACRO
  R6502_MODIFY_OPCODE $type,$tag,$mode,$aname
  LCLS lengthdigit
  [ "$mode"=="abs" || "$mode"=="absx" || "$mode"=="absy"
lengthdigit SETS "3"
  |
lengthdigit SETS "2"
  ]
  R6502_O_MODIFY_OPCODE $type,$tag,$mode
  R6502_MODIFY_OPCODE_SPLIT $type,$tag,$mode
  R6502_SCAN_OPCODE_ENTRY $lengthdigit,$type.$tag.$mode,1,0
  R6502_MODIFY_OPCODE_BODY $type,$tag,$mode,$aname,0
  R6502_SCAN_OPCODE_ENTRY $lengthdigit,$type.$tag.$mode,1,1
  R6502_MODIFY_OPCODE_BODY $type,$tag,$mode,$aname,1
  MEND

