  ELSE
action SETS "r6502$tag.action"
  ENDIF
  [ "$type"=="r65c12" && ("$mode"=="zpgx" || "$mode"=="zpgy" || "$mode"=="preindexed")
  R6502_OPERAND_LO_TWICE_FOLD_OR_TRAP $genericmodify.$mode.nofold,$type.$tag.$mode.infold,$action
  |
  R6502_OPERAND_LO_FOLD_OR_TRAP $genericmodify.$mode.nofold,$type.$tag.$mode.infold,$action
  ]
