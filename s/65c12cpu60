|r65c12opcode6C|
  ;JMP
  ;STMFD sp!,{r0-r2,rpc,r10-r12,lr}
  ADDRESSOFABSOLUTE_M ;r0 ;2 cycles
  CMP r0,#&2FC0
  ADDGT pc,pc,#12 ;4*4 (-4)

  ;address < &2FC1 < &3000
  ADD r11,r12,r0 ;r11=memory+address (offset)
  LDRB r2,[r11] ;lo
  LDRB r0,[r11,#1] ;hi
  ADD pc,pc,#(READMEM_LEN*2)+(3*4)-4 ;9*4 (-4)

  ;address > &2FC0
  MOV r3,r0 ;store address
  READMEM ;3*4
  MOV r2,r0 ;lo

  ADD r0,r3,#1 ;address += 1
  READMEM ;3*4

  ;continue
  ADD rpc,r2,r0,LSL#8 ;rpc=lo+(hi<<8)

  CPU_CYCLES 3
  ;LDMFD sp!,{r0-r2,rpc,r10-r12,pc}
  ;MOV pc,lr
  R65C12NEXTOPCODE

