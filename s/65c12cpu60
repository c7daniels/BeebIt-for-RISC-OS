  ;MOV pc,lr
  R65C12NEXTOPCODE
r65c12opcode61_2
  ;BCD
  R6502ADCD_M ;2 cycles
  CPU_CYCLES 3 ;+1
  ;LDMFD sp!,{r0-r12,pc}
  ;MOV pc,lr
  R65C12NEXTOPCODE

