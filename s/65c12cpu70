|r65c12opcode73|
  B r6502nop

|r65c12opcode74|
  ZEROPAGEXSTORE r65c12stz

|r65c12opcode75|
  ZEROPAGEXLOAD_DECIMALFORK r6502adc,r65c12adcd

|r65c12opcode76|
  ZEROPAGEXMODIFYC r6502ror

|r65c12opcode77|
  B r6502nop

|r65c12opcode79|
  ABSOLUTEYLOAD_DECIMALFORK r6502adc,r65c12adcd

|r65c12opcode7A|
  IMPLIED r65c12ply

|r65c12opcode7B|
  B r6502nop

|r65c12opcode7C|
  IMMEDIATELOAD r65c12jmpxind

|r65c12opcode7D|
  ABSOLUTEXLOAD_DECIMALFORK r6502adc,r65c12adcd

|r65c12opcode7E|
  ABSOLUTEXMODIFYC r6502ror

|r65c12opcode7F|
  B r6502nop

