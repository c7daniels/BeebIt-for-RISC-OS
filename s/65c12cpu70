  GET h.SWInames

; Area name C$$code advisable as wanted to link with C output

  AREA |C$$code|, CODE, READONLY

; Import global symbols

  IMPORT |r6502busop|
  IMPORT |r6502intoyield|
  
  IMPORT |r6502immediatedone|
  IMPORT |r6502zeropagexreadreadforwrite|
  IMPORT |r6502zeropagexforwrite|
  IMPORT |r6502zeropagexread|
  IMPORT |r6502hiabsolutexreadreadforwrite|
  IMPORT |r6502hiabsolutexread|
  IMPORT |r6502hiabsoluteyread|
  IMPORT |r6502zeropageindirectread|
  IMPORT |r6502zeropageindirectyread|
  
  IMPORT |r6502adc|
  IMPORT |r65c12adcd|
  IMPORT |r65c12ply|
  IMPORT |r6502ror|
  IMPORT |r65c12stz|
  IMPORT |r65c12jmpxind|
  IMPORT |r6502nop|

; Export global symbols

  EXPORT |r65c12opcode71|
  EXPORT |r65c12opcode72|
  EXPORT |r65c12opcode73|
  EXPORT |r65c12opcode74|
  EXPORT |r65c12opcode75|
