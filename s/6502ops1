  ORRNE r5,r5,#NFLAG
  MOVS r3,r3,LSR #1
  ORREQ r5,r5,#ZFLAG
  STRB r3,[r0,#:INDEX:R6502_A]
  ORRCS r5,r5,#CFLAG
  MEND

