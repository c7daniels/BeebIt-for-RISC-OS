  MACRO
  PLP_ACTION
  LDR r1,[r0,#:INDEX:R6502_SP_CODE]
  ADD r1,r1,#1:SHL:24
  LDRB r2,[r0,r1,ROR #24]
  BIC r5,r5,#&FF
  TST r2,#IFLAG
  ORR r5,r5,#UFLAG|BFLAG|IFLAG
  STR r1,[r0,#:INDEX:R6502_SP_CODE]
  BICNE r5,r5,#R6502_IRQ_ENABLE
  ORREQ r5,r5,#R6502_IRQ_ENABLE
  ORR r5,r5,r2
  MEND

  MACRO
  PLP_SHIFTED_ACTION
  LDR r1,[r0,#:INDEX:R6502_SP_CODE]
  BIC r5,r5,#&FF
  ADD r1,r1,#1:SHL:24
  LDRB r2,[r0,r1,ROR #24]
  ORR r5,r5,#UFLAG|BFLAG|IFLAG
  TST r2,#IFLAG
  STR r1,[r0,#:INDEX:R6502_SP_CODE]
  BICNE r5,r5,#(R6502_IRQ_ENABLE<<4)|R6502_IRQ_ENABLE
  ORREQ r5,r5,#(R6502_IRQ_ENABLE<<4)|R6502_IRQ_ENABLE
  ORR r5,r5,r2
  MEND

  MACRO
  R6502_O_PUSH $name,$r
  R6502_O_OPCODE_HEADER $name
  IF "$r"=="P"
  AND r4,r5,#&FF
  TST r5,#R6502_IRQ_ENABLE
  BICNE r4,r4,#IFLAG
  ELSE
  LDRB r4,[r0,#:INDEX:R6502_$r]
  ENDIF
  R6502_IMPLIED_FOLD_OR_TRAP r6502push
  MEND

  MACRO
  R6502_PUSH_BODY $r,$features
  [ $features==0
  R6502_OPCODE_CYCLES 1,0
  ]
  LDR r1,[r0,#:INDEX:R6502_SP_CODE]
  IF "$r"=="P"
  AND r2,r5,#&FF
  TST r5,#R6502_IRQ_ENABLE
  SUB r3,r1,#1:SHL:24
  BICNE r2,r2,#IFLAG
  ELSE
  LDRB r2,[r0,#:INDEX:R6502_$r]
  SUB r3,r1,#1:SHL:24
  ENDIF
  STRB r2,[r0,r1,ROR #24]
  STR r3,[r0,#:INDEX:R6502_SP_CODE]
  R6502_OPCODE_STEP r6502push,1
  ADD r6,r6,#1:SHL:16
  [ $features==0
  R6502_OPCODE_INFOLD_ADDRESSED_RETURN 2,interrupt
  |
  R6502_OPCODE_INFOLD_ADDRESSED_RETURN 3,interrupt
  ]
  MEND

  MACRO
  R6502_PUSH $name,$r
  R6502_OPCODE_ENTRY $name,2,0
  R6502_PUSH_BODY $r,0
  R6502_OPCODE_ENTRY $name,2,2
  R6502_PUSH_BODY $r,2
  MEND

  MACRO
  R6502_O_PULL $name,$r
  R6502_O_OPCODE_HEADER $name
  IF "$r"=="P"
  R6502_IMPLIED_FOLD_OR_TRAP $name
  ELSE
  LDR r1,[r0,#:INDEX:R6502_SP_CODE]
  BIC r5,r5,#NFLAG|ZFLAG
  ADD r1,r1,#1:SHL:24
  LDRB r2,[r0,r1,ROR #24]
  STR r1,[r0,#:INDEX:R6502_SP_CODE]
  MOVS r3,r2,LSL #24
  STRB r2,[r0,#:INDEX:R6502_$r]
  ORRMI r5,r5,#NFLAG
  ORREQ r5,r5,#ZFLAG
  R6502_IMPLIED_FOLD_OR_TRAP r6502pull
  ENDIF
  MEND

  MACRO
  R6502_PULL $name,$r
  R6502_OPCODE_ENTRY $name,0,0
  IF "$r"=="P"
  R6502_OPCODE_CYCLES 4,0
  PLP_SHIFTED_ACTION
  R6502_OPCODE_SCAN r6502plp,1
  ADD r6,r6,#1:SHL:16
  R6502_OPCODE_INFOLD_ADDRESSED_RETURN 0,interrupt
  ELSE
  LDR r1,[r0,#:INDEX:R6502_SP_CODE]
  BIC r5,r5,#NFLAG|ZFLAG
  ADD r1,r1,#1:SHL:24
  LDRB r2,[r0,r1,ROR #24]
  STR r1,[r0,#:INDEX:R6502_SP_CODE]
  MOVS r3,r2,LSL #24
  STRB r2,[r0,#:INDEX:R6502_$r]
  ORRMI r5,r5,#NFLAG
  ORREQ r5,r5,#ZFLAG
  R6502_OPCODE_STEP r6502pull,1
  ADD r6,r6,#1:SHL:16
  R6502_OPCODE_INFOLD_ADDRESSED_RETURN 4,interrupt
  ENDIF
  MEND

  MACRO
  R6502_RTI_PART1 $r
  LDR r1,[r0,#:INDEX:R6502_SP_CODE]
  MOV $r,#ADDRESSING_BASECODE
  ADD r1,r1,#2:SHL:24
  LDRB r2,[r0,r1,ROR #24]
  ADD r1,r1,#1:SHL:24
  LDRB r3,[r0,r1,ROR #24]
  STR r1,[r0,#:INDEX:R6502_SP_CODE]
  ORR $r,$r,r2,LSL #16
  ORR $r,$r,r3,LSL #24
  MEND

  MACRO
  R6502_RTI_PART2 $r
  LDR r1,[r0,#:INDEX:R6502_SP_CODE]
  BIC r5,r5,#&FF
  SUB r1,r1,#2:SHL:24
  LDRB r2,[r0,r1,ROR #24]
  MOV r1,$r
  [ "$r"!="r6"
  MOV r6,$r
  ]
  ORR r5,r5,#UFLAG|BFLAG|IFLAG
  TST r2,#IFLAG
  BICNE r5,r5,#R6502_IRQ_ENABLE
  ORREQ r5,r5,#R6502_IRQ_ENABLE
  ORR r5,r5,r2
  MEND

  MACRO
  R6502_RTS_POP
  LDR r1,[r0,#:INDEX:R6502_SP_CODE]
  MOV r4,#ADDRESSING_BASECODE
  ADD r1,r1,#1:SHL:24
  LDRB r2,[r0,r1,ROR #24]
  ADD r1,r1,#1:SHL:24
  LDRB r3,[r0,r1,ROR #24]
  STR r1,[r0,#:INDEX:R6502_SP_CODE]
  ORR r1,r4,r2,LSL #16
  ORR r1,r1,r3,LSL #24
  ADD r4,r1,#1:SHL:16
  MEND

  MACRO
  R6502_JAM_WAIT $name,$name2,$special,$stretch
$name.yieldedref
  DCD $name.yielded
$name.yielded
  R6502_OPCODE_PUSH
$name.wait
  [ $stretch!=0
  R6502_OPCODE_CYCLES 0,1
  ]
  [ $special!=0
  MOV r1,r6
  R6502_OPCODE_READ_SPECIAL
  ]
  R6502_OPCODE_CYCLES 1,0
$name
  [ "$name2"!=""
$name2
  ]
  LDR r3,[r0,#:INDEX:R6502_TRANSITION1]
  CMP r3,#R6502_REGULAR_TRANSITION
  BEQ $name.wait
  R6502_OPCODE_POP
  CMP r3,#R6502_RESET_TRANSITION
  BEQ r6502jamreset
  ADD r1,r0,#:INDEX:R6502_SEQUENCES
  ADR r2,$name.yieldedref
  LDR r1,[r1,#R6502_YIELD_SEQUENCE:SHL:2]
  STR r2,[r0,#:INDEX:R6502_EXECUTE_CPU_STATE]
  STR r1,[r0,#:INDEX:R6502_CPU_STATE]
  R6502_OPCODE_YIELD_RETURN
  MEND

  MACRO
  R6502_RESET_WAIT $name,$name2,$special,$stretch
$name.wait
  [ $stretch!=0
  R6502_OPCODE_CYCLES 0,1
  ]
  [ $special!=0
  MOV r1,r6
  R6502_OPCODE_READ_SPECIAL
  ]
  R6502_OPCODE_CYCLES 1,0
$name
  [ "$name2"!=""
$name2
  ]
  LDR r3,[r0,#:INDEX:R6502_LBREAK]
  TST r3,r3
  BNE $name.wait
  [ $stretch!=0
  R6502_OPCODE_CYCLES 0,1
  ]
  [ $special!=0
  MOV r1,r6
  R6502_OPCODE_READ_SPECIAL
  ]
  MEND

  MACRO
  R6502_RESET_CONTINUE $name
  MOV r2,#0
  STRB r2,[r0,#:INDEX:R6502_OLDRESET]
  MOV lr,pc
  LDR pc,[r0,#:INDEX:R6502_RESETCONTINUINGACTION]
  LDR r2,[r0,#:INDEX:R6502_TRANSITION2]
  ADD r3,r0,#&FF00
  STR r2,[r0,#:INDEX:R6502_TRANSITION1]
  LDR r2,[r0,#:INDEX:R6502_LBREAK]
  LDR r3,[r3,#&FC]
  TST r2,r2
  MOV r6,#ADDRESSING_BASECODE
  MOVNE r2,#R6502_RESET_TRANSITION
  STRNE r2,[r0,#:INDEX:R6502_TRANSITION1]
  ORR r1,r6,r3,LSL #16
  ORR r6,r6,r3,LSL #16
  R6502_FOLD_OR_TRAP ,$name
  MEND

  MACRO
  R6502_RESET_PART2 $shiftedmore
  LDR r1,[r0,#:INDEX:R6502_SP_CODE]
  BIC r5,r5,#(R6502_IRQ_ENABLE<<4)|R6502_IRQ_ENABLE
  [ $shiftedmore==0
  BIC r5,r5,#(R6502_IRQ_ENABLE<<8)
  |
  BIC r5,r5,#(R6502_IRQ_ENABLE<<12)|(R6502_IRQ_ENABLE<<8)
  ]
  SUB r1,r1,#3:SHL:24
  STR r1,[r0,#:INDEX:R6502_SP_CODE]
  MEND

  MACRO
  R65C12_RESET_PART2
  R6502_OPCODE_CYCLES 1,0
  LDR r1,[r0,#:INDEX:R6502_SP_CODE]
  MOV r2,r4,LSR #24
  STRB r2,[r0,r1,ROR #24]
  R6502_OPCODE_CYCLES 1,0
  LDR r1,[r0,#:INDEX:R6502_SP_CODE]
  MOV r2,r4,LSR #16
  SUB r1,r1,#1:SHL:24
  STRB r2,[r0,r1,ROR #24]
  R6502_OPCODE_CYCLES 1,0
  LDR r1,[r0,#:INDEX:R6502_SP_CODE]
  TST r5,#R6502_IRQ_ENABLE
  MOV r2,r5
  SUB r3,r1,#3:SHL:24
  SUB r1,r1,#2:SHL:24
