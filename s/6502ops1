  MACRO
  ASLA_ACTION
  LDR r3,[r0,#:INDEX:R6502_A_SHIFT]
  BIC r5,r5,#NFLAG|ZFLAG|CFLAG
  MOVS r3,r3,LSL #1
  ORRMI r5,r5,#NFLAG
  STR r3,[r0,#:INDEX:R6502_A_SHIFT]
  ORREQ r5,r5,#ZFLAG
  ORRCS r5,r5,#CFLAG
  MEND

  MACRO
  ROLA_ACTION
  TST r5,#CFLAG
  LDR r3,[r0,#:INDEX:R6502_A_SHIFT]
  BIC r5,r5,#NFLAG|ZFLAG|CFLAG
  ORRNE r3,r3,#&800000
  MOVS r3,r3,LSL #1
  ORRMI r5,r5,#NFLAG
  STR r3,[r0,#:INDEX:R6502_A_SHIFT]
  ORREQ r5,r5,#ZFLAG
  ORRCS r5,r5,#CFLAG
  MEND

  MACRO
  LSRA_ACTION
  LDRB r3,[r0,#:INDEX:R6502_A]
  BIC r5,r5,#NFLAG|ZFLAG|CFLAG
  MOVS r3,r3,LSR #1
  ORREQ r5,r5,#ZFLAG
  STRB r3,[r0,#:INDEX:R6502_A]
  ORRCS r5,r5,#CFLAG
  MEND

  MACRO
  RORA_ACTION
  LDRB r3,[r0,#:INDEX:R6502_A]
