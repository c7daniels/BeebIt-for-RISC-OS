HOST_IRQ_SOURCE_MASK EQU &FF
HOST_IRQ_6522SYSVIA EQU &01
HOST_IRQ_6522USRVIA EQU &02
HOST_IRQ_6850ACIA EQU &04
HOST_IRQ_IRR EQU &08

  MACRO
  HOST_LOAD_WORK_AREA
  ADD r3,r0,#:INDEX:R6502_INTERRUPTQUEUE_PS
  LDMIA r3,{r5-r9}
  MEND

  MACRO
  HOST_STORE_WORK_AREA
  ADD r3,r0,#:INDEX:R6502_INTERRUPTQUEUE_PS
  STMIA r3,{r5-r9}
  MEND

  MACRO
  HOST_EXECUTE_PUSH
  [ Optimise6502WorkAreas
  STMFD sp!,{r4-r9,lr}
  HOST_LOAD_WORK_AREA
  |
  STR lr,[sp, #-4]!
  ]
  MEND

  MACRO
  HOST_EXECUTE_POP
  [ Optimise6502WorkAreas
  HOST_STORE_WORK_AREA
  LDMFD sp!,{r4-r9,pc}
  |
  LDR pc, [sp], #4
  ]
  MEND

  MACRO
  HOST_ADDRESSING_RETURN_SPECIAL
  LDR pc,[lr,#-12]
  MEND

  MACRO
  HOST_ADDRESSING_RETURN_STRETCHSPECIAL
  LDREQ pc,[lr,#-8]
  LDR pc,[lr,#-4]
  MEND

  MACRO
  HOST_ADDRESSING_RETURN_TOUCHED
  MOV pc,lr
  MEND

  MACRO
  HOST_ADDRESSING_RETURN_TOUCHEDNE
  MOVNE pc,lr
  MEND

  MACRO
  HOST_ADDRESSING_RETURN_FOLDED
  MOV pc,lr
  MEND

  END
