#ifndef __BEEBIT_6502CMAP_H__
#define __BEEBIT_6502CMAP_H__

#include "6502zmap.h"

#define R6502_SEQUENCE_ALLOWANCE 288

struct R6502CPUMAP;

typedef struct R6502CPUMAP* (*R6502OP)(struct R6502CPUMAP* ctop, uintptr_t incremented_cpu_state); /*returning the first parameter leaves it in r0 for the next call from AArch32 assembly language*/

typedef struct R6502CPUMAP* (*R6502TRANSITIONOP)(struct R6502CPUMAP* ctop, uintptr_t pc_code); /*returning the first parameter leaves it in r0 for the next call from AArch32 assembly language*/

/*addressing op spaced for an AArch32 access optimisation*/
typedef struct
{
  R6502ADDRESSINGOP op;
  uintptr_t _unused[3];
} R6502PADDEDADDRESSINGOP;

/*storage map specialised for 6502 CPU emulation*/
typedef struct R6502CPUMAP
{
  // AArch32 offsets -&4000 - -&1001
  const R6502OP* sequences[R6502_SEQUENCE_ALLOWANCE];
  R6502_DP_ZONE DP;

  // AArch32 offsets -&1000 - -&401
  uintptr_t CC_unused[4];
  R6502PADDEDADDRESSINGOP addressingops[32];
  R6502_CP_ZONE CP;

  // AArch32 offsets -&400 - -&101
  uintptr_t interruptqueue;
  R6502BYTESHIFT m_shift; uint8_t m; /*value on data bus*/
  R6502BYTESHIFT a_shift; uint8_t a; /*register*/
  R6502BYTESHIFT x_shift; uint8_t x; /*register*/
  R6502BYTESHIFT y_shift; uint8_t y; /*register*/
  R6502BYTESHIFT ps_shift; uint8_t ps; /*processor status*/
  uintptr_t sp_code; /*rotated stack pointer*/
  uintptr_t sync_pc_code; /*shifted program counter with bits for an AArch32 access optimisation*/
  uintptr_t last_pc_code;
  uintptr_t latch; /*shifted addressing temporary byte*/
  uintptr_t address_code;
  uintptr_t fixed_address_code;
  uintptr_t stretched_address_code;
  const R6502OP* cpu_state; /*pointer to current step*/
  const R6502OP* stretched_cpu_state; /*pointer to stretched step*/
  const R6502OP* execute_cpu_state;
  uintptr_t transition1, transition2;
  R6502PERIPHERALOP resetstartingaction,resetcontinuingaction;
  R6502PERIPHERALOP cycleaction;
  R6502READSPECIALOP readspecialaction;
  R6502WRITESPECIALOP writespecialaction;
  uintptr_t yieldlink; /*storage for the Optimise6502Links optimisation*/
  uintptr_t lbreak;
  uintptr_t BC_unused[19];
  R6502_BP_ZONE BP;

  // AArch32 offsets -&100 - -&01
  uint8_t oldreset;
  uint8_t copiedvalue;
  uint8_t AC_unused[sizeof(uintptr_t)-2];
  R6502_AP_ZONE AP;

} R6502CPUMAP;

#endif //__BEEBIT_6502CMAP_H__
