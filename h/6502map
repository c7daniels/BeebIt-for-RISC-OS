/*Rockwell 6502 Central Processor Unit (CPU)*/
/*an assembly language representation of this struct appears in 6502cpus.h*/
/*offsets are intended to equal barrel-shift constants in AArch32*/
typedef struct R6502HOSTMAP
{

  // shift 0 offsets &00 - &FF
  uint8_t irq;
  uint8_t nmis;
  uint8_t lsoundlatch;
  uint8_t _lsoundlatch_padding[1];
  int8_t romwritable[16];
  uint8_t romsel; /*ROMSELect*/
  uint8_t acccon;  /*ACCCON*/
  uint8_t lsoundoption;
  uint8_t screenstartindex; /*screen start index (system via)*/
  S0SERIAL s0serial;
  S0VIA s0sysvia;
  S0VIA s0usrvia;
  S0RTC s0rtc;
  S0I8271 s0i8271;
  S0W1770 s0w1770;
  S0ADC s0adc;
  uint8_t _s0_padding[132];

  // shift 2 offsets &100 - &3FC
  uint8_t m_shift[3];
  uint8_t m; /*value on data bus*/
  uint8_t a_shift[3];
  uint8_t a; /*register*/
  uint8_t x_shift[3];
  uint8_t x; /*register*/
  uint8_t y_shift[3];
  uint8_t y; /*register*/
  uint8_t ps_shift[3];
  uint8_t ps; /*processor status*/
  R6502OP *cpu_state; /*pointer into table of steps*/
  R6502OP *stretched_cpu_state;
  unsigned int sync_pc_code; /*shifted program counter with bus code*/
  unsigned int last_pc_code;
  unsigned int address_code; /*shifted value on address bus with bus code*/
  unsigned int sp_code; /*shifted stack pointer*/
  unsigned int address_fix_code;
  unsigned int latch; /*shifted addressing temporary byte*/
  char *pagezero;
  char *pageone;
  R6502TRANSITIONOP transition1action, transition2action;
  R6502TRANSITIONOP yieldaction;
  R6502TRANSITIONOP fetchaction, interruptfetchaction;
  R6502TRANSITIONOP fetchthentestirqaction, resetaction;
  int timesinterruptmissed;
  unsigned int lbreak;
  unsigned int screenstartaddress;
  void *zeribeep_writebyte;
  void *zeribeep_workspace;
  S2CYCLES s2cycles;
  S2PAGING s2paging;
  S2SERIAL s2serial;
  S2VIA s2sysvia;
  S2VIA s2usrvia;
  S2AMX s2amx;
  S2I8271 s2i8271;
  S2W1770 s2w1770;
  S2ADC s2adc;
  unsigned int _s2_padding[76];

  // shift 4 offsets &400 - &FF0
  unsigned int _s4_padding[640];
  R6502S4FORKS s4forks[32];

  // shift 6+ offsets &1000 -
  R6502BUSOP read8000s[16];
  R6502BUSOP write8000s[16];
  R6502OP* sequences[R6502_SEQUENCE_CAPACITY];
  R6502OP* _sequences_padding[R6502_SEQUENCE_OUTSIZE_CAPACITY - R6502_SEQUENCE_CAPACITY];
  unsigned int _s6_padding[448];
  R6502OP steps[R6502_SEQUENCE_CAPACITY<<R6502_LOG2_MAX_SEQUENCE_LENGTH];
  R6502OP _steps_padding[(R6502_SEQUENCE_OUTSIZE_CAPACITY-R6502_SEQUENCE_CAPACITY)<<R6502_LOG2_MAX_SEQUENCE_LENGTH];

  /*6502cpus.s appends the following to the host R6502WORKSPACE:
   r6502_high_read_fork
   r6502_high_write_fork
   r6502_high_stretched_read_fork
   r6502_high_stretched_write_fork
   memory
   shadow
   roms
   */
} R6502HOSTMAP;

extern R6502BUSOP r6502_high_read_fork[1024];
extern R6502BUSOP r6502_high_write_fork[1024];
extern R6502BUSOP r6502_high_stretched_read_fork[1024];
extern R6502BUSOP r6502_high_stretched_write_fork[1024];

#define TIMER_LIMIT_CYCLES_TO_GO(MAP, LIMIT) \
  { \
    S2CYCLES *cy = &(MAP)->s2cycles; \
    int excess = cy->original - (LIMIT); \
    if (excess > 0) \
    { \
      cy->original -= excess; \
      cy->togo -= excess; \
    } \
  }

#define TIMER_LIMIT_PERIPHERAL_CYCLES_TO_GO(MAP, P, LIMIT) \
  { \
    S2CYCLES *cy = &(MAP)->s2cycles; \
    int excess = cy->P##_original - (LIMIT); \
    if (excess > 0) \
    { \
      cy->P##_original -= excess; \
      cy->P##_togo -= excess; \
      excess = cy->original - cy->P##_togo; \
      if (excess > 0) \
      { \
        cy->original -= excess; \
        cy->togo -= excess; \
      } \
    } \
  }

#define TIMER_GET_PERIPHERAL_CYCLE_COUNT(OUT, MAP, P) \
  { \
    S2CYCLES *cy = &(MAP)->s2cycles; \
    OUT = cy->original - cy->togo + cy->P##_original - cy->P##_togo; \
  }

#define TIMER_GET_1MHZ_PERIPHERAL_TOGO_FOR_SNAPSHOT_OFFSET(OUT, MAP, P) \
  { \
    S2CYCLES *cy = &(MAP)->s2cycles; \
    OUT = cy->original - cy->togo; \
    OUT += (cy->odd^OUT^1)&1; \
    OUT += cy->P##_original - cy->P##_togo; \
  }

#define TIMER_GET_TOGO_FROM_WRITE_OFFSET(OUT, MAP) \
  { \
    S2CYCLES *cy = &(MAP)->s2cycles; \
    OUT = 1 + cy->original - cy->togo; \
  }

#define TIMER_GET_1MHZ_PERIPHERAL_TOGO_FROM_WRITE_OFFSET(OUT, MAP, P) \
  { \
    S2CYCLES *cy = &(MAP)->s2cycles; \
    OUT = 2 + cy->original - cy->togo; \
    OUT += cy->P##_original - cy->P##_togo; \
  }
