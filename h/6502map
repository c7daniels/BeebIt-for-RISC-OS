struct R6502HOSTMAP;

typedef struct R6502HOSTMAP* (*R6502OP)(struct R6502HOSTMAP *map, intptr_t incremented_cpu_state); /*returning the first parameter leaves it in r0 for the next call from AArch32 assembly language*/

typedef struct R6502HOSTMAP* (*R6502BUSOP)(struct R6502HOSTMAP *map, unsigned int address_code); /*returning the first parameter leaves it in r0 for the next call from AArch32 assembly language*/

typedef struct R6502HOSTMAP* (*R6502TRANSITIONOP)(struct R6502HOSTMAP *map, unsigned int pc_code); /*returning the first parameter leaves it in r0 for the next call from AArch32 assembly language*/

typedef struct R6502HOSTMAP* (*R6502SWAPOP)(struct R6502HOSTMAP *map); /*returning the first parameter leaves it in r0 for the next call from AArch32 assembly language*/

