/*Rockwell 6502 Central Processor Unit (CPU)*/
/*an assembly language representation of this struct appears in 6502cpus.h*/
/*offsets are intended to equal barrel-shift constants in AArch32*/
typedef struct R6502HOSTMAP
{

  // shift 0 offsets &00 - &FF
  uint8_t m; /*value on data bus*/
  uint8_t a, x, y; /*3 registers A,X,Y*/
  uint8_t ps; /*processor status*/
  uint8_t irq;
  uint8_t nmis;
  uint8_t readcompleted;
  int8_t romwritable[16];
  uint8_t romsel; /*ROMSELect*/
  uint8_t acccon;  /*ACCCON*/
  uint8_t lsoundoption;
  uint8_t lsoundlatch;
  uint8_t screenstartindex; /*screen start index (system via)*/
  uint8_t _s0_structpadding[3];
  S0SERIAL s0serial;
  S0VIA s0sysvia;
  S0VIA s0usrvia;
  S0RTC s0rtc;
  S0I8271 s0i8271;
  S0W1770 s0w1770;
  S0ADC s0adc;
  uint8_t _s0_padding[124];

  // shift 2 offsets &100 - &3FC
  int cpu_state; /*index into table of steps*/
  unsigned int address_code; /*shifted value on address bus with bus code*/
  unsigned int pc_code; /*shifted program counter with bus code*/
  unsigned int sp_code; /*rotated stack pointer and bus code*/
  unsigned int latch; /*addressing temporary value*/
  R6502OP transition1action, transition2action;
  R6502OP yieldaction;
  R6502OP fetchaction, fetchthentestirqaction;
  R6502OP resetaction, interruptaction;
  int timesinterruptmissed;
  unsigned int lbreak;
  unsigned int screenstartaddress;
  R6502OP read3000, write3000;
  R6502OP read3000_ram, write3000_ram;
  R6502OP read3000_e, write3000_e;
  R6502OP read3000_x, write3000_x;
  R6502OP read8000_ram, write8000_ram;
  R6502OP readC000_y, writeC000_y;
  R6502OP swappagesintomemory, swappagesoutofmemory;
  void *zeribeep_writebyte;
  void *zeribeep_workspace;
  S2CYCLES s2cycles;
  S2SERIAL s2serial;
  S2VIA s2sysvia;
  S2VIA s2usrvia;
  S2AMX s2amx;
  S2I8271 s2i8271;
  S2W1770 s2w1770;
  S2ADC s2adc;
  unsigned int _s2_padding[88];

  // shift 4 offsets &400 - &FF0
  unsigned int _s4_padding[256];
  R6502S4FORKS s4forks[128];

  // shift 6+ offsets &1000 -
  R6502OP read8000s[16];
  R6502OP write8000s[16];
  unsigned int _s6_padding[736];
  R6502OP high_read_fork[1024];
  R6502OP high_write_fork[1024];
  R6502OP high_stretched_read_fork[1024];
  R6502OP high_stretched_write_fork[1024];
  R6502OP steps[R6502_SEQUENCE_CAPACITY<<R6502_LOG2_MAX_SEQUENCE_LENGTH];
  R6502OP _steps_padding[(288-R6502_SEQUENCE_CAPACITY)<<R6502_LOG2_MAX_SEQUENCE_LENGTH];
  /*6502cpus.s appends memory, shadow and roms to the host R6502HOSTMAP*/
} R6502HOSTMAP;


#define TIMER_LIMIT_CYCLES_TO_GO(MAP, LIMIT) \
  { \
    S2CYCLES *cy = &(MAP)->s2cycles; \
    int excess = cy->original - (LIMIT); \
    if (excess > 0) \
    { \
      cy->original -= excess; \
      cy->togo -= excess; \
    } \
  }

#define TIMER_LIMIT_PERIPHERAL_CYCLES_TO_GO(MAP, P, LIMIT) \
  { \
    S2CYCLES *cy = &(MAP)->s2cycles; \
    int excess = cy->P##_original - (LIMIT); \
    if (excess > 0) \
    { \
      cy->P##_original -= excess; \
      cy->P##_togo -= excess; \
      excess = cy->original - cy->P##_togo; \
      if (excess > 0) \
      { \
        cy->original -= excess; \
        cy->togo -= excess; \
      } \
    } \
  }

#define TIMER_GET_CYCLE_COUNT(OUT, MAP) \
  { \
    S2CYCLES *cy = &(MAP)->s2cycles; \
OUT = cy->original - cy->togo; \
  }

#define TIMER_GET_PERIPHERAL_CYCLE_COUNT(OUT, MAP, P) \
  { \
    S2CYCLES *cy = &(MAP)->s2cycles; \
OUT = cy->original - cy->togo + cy->P##_original - cy->P##_togo; \
  }

#define TIMER_GET_PERIPHERAL_CYCLE_COUNT_AFTER_EVEN_CYCLE(OUT, MAP, P) \
  { \
    S2CYCLES *cy = &(MAP)->s2cycles; \
    OUT = cy->original - cy->togo; \
    OUT += (cy->odd^OUT^1)&1; \
    OUT += cy->P##_original - cy->P##_togo; \
  }
