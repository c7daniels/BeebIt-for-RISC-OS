R6502_IRQ_ENABLE EQU &0100
R6502_NMI_ENABLE EQU &0200
R6502_IRQ EQU &0400
R6502_NMI EQU &0800
R6502_NMI_IRQ_ENABLE EQU &0300
R6502_NMI_IRQ EQU &0C00

SIZEOF_R6502_AC_ZONE EQU 4
SIZEOF_R6502_AP_ZONE EQU 252
SIZEOF_R6502_BC_ZONE EQU 164
SIZEOF_R6502_BP_ZONE EQU 588
SIZEOF_R6502_CC_ZONE EQU 528
SIZEOF_R6502_CP_ZONE EQU 2544
SIZEOF_R6502_DC_ZONE EQU 3456
SIZEOF_R6502_DP_ZONE EQU 8832

                        ^ 0
R6502ADDRESSINGCALLBACKS_SPECIAL # &4
R6502ADDRESSINGCALLBACKS_STRETCH1SPECIAL # &4
R6502ADDRESSINGCALLBACKS_STRETCH2SPECIAL # &4
R6502ADDRESSINGCALLBACKS_MAPPED # &4
SIZEOF_R6502ADDRESSINGCALLBACKSMAP * @

;outline of a storage map for both 6502 CPU and peripheral emulation
;a C representation of this storage map appears in 6502zmap.h
R6502ZONEMAP_ORIGIN EQU -&4000
                        ^ R6502ZONEMAP_ORIGIN
; offsets -&4000 - -&1001
R6502ZONE_DC            # SIZEOF_R6502_DC_ZONE
R6502ZONE_DP            # SIZEOF_R6502_DP_ZONE

; offsets -&1000 - -&401
R6502ZONE_CC            # SIZEOF_R6502_CC_ZONE
R6502ZONE_CP            # SIZEOF_R6502_CP_ZONE

; offsets -&400 - -&101
R6502ZONE_M_SHIFT       # &3
R6502ZONE_M             # &1
R6502ZONE_INTERRUPTQUEUE_PS # &4
R6502ZONE_SYNC_PC_CODE  # &4
R6502ZONE_TOGOMINUSONE_CYCLESTATE # &4
R6502ZONE_BC            # SIZEOF_R6502_BC_ZONE
R6502ZONE_BP            # SIZEOF_R6502_BP_ZONE

; offsets -&100 - -&01
R6502ZONE_AC            # SIZEOF_R6502_AC_ZONE
R6502ZONE_AP            # SIZEOF_R6502_AP_ZONE

SIZEOF_R6502ZONEMAP     * @ - R6502ZONEMAP_ORIGIN

  END
