;
;rockwell 6502 cpu
;
  MACRO
  SETNFLAG $n
  ;IN :$n=register
  TST $n,#NFLAG
  ;set bit 7 (N)
  ORRNE rps,rps,#NFLAG
  ;clear bit 7 (N)
  ANDEQ rps,rps,#NOTNFLAG
  MEND

  MACRO
  SETVFLAG $n
  ;IN :$n=register
  TST $n,#VFLAG
  ;set bit 6 (V)
  ORRNE rps,rps,#VFLAG
  ;clear bit 6 (V)
  ANDEQ rps,rps,#NOTVFLAG
  MEND

  MACRO
  SETBFLAG $n
  ;IN :$n=register
  TST $n,#BFLAG
  ;set bit 4 (B)
  ORRNE rps,rps,#BFLAG
  ;clear bit 4 (B)
  ANDEQ rps,rps,#NOTBFLAG
  MEND

  MACRO
  SETIFLAG $n
  ;IN :$n=register
  TST $n,#IFLAG
  ;set bit 2 (I)
  ORRNE rps,rps,#IFLAG
  ;clear bit 2 (I)
  ANDEQ rps,rps,#NOTIFLAG
  MEND

  MACRO
  SETZFLAG $n
  ;IN :$n=register
  CMP $n,#0
  ;set bit 1 (Z)
  ORREQ rps,rps,#ZFLAG
  ;clear bit 1 (Z)
  ANDNE rps,rps,#NOTZFLAG
  MEND

  MACRO
  SETZFLAG0
  ;set bit 1 (Z)
  ORREQ rps,rps,#ZFLAG
  ;clear bit 1 (Z)
  ANDNE rps,rps,#NOTZFLAG
  MEND

  MACRO
  SETFLAG $n
  ;IN :$n=flag
  ORR rps,rps,$n
  MEND

  MACRO
  STACKPUSH $n
  ;IN: $n=value
  ;    r12=pointer to r6502workspace
  ;    rsp=r6502_sp:SHL:24
  ADD r11,r12,#:INDEX:R6502_MEMORY+&100
  STRB $n,[r11,rsp,LSR #24] ;memory[0x100+r6502_sp] = $n
  SUB rsp,rsp,#&01000000 ;r6502_sp--
  MEND

  MACRO
  STACKPOP $n
  ;IN: r12=pointer to r6502workspace
  ;    rsp=r6502_sp:SHL:24
  ;OUT:$n=value
  ADD r11,r12,#:INDEX:R6502_MEMORY+&100
  ADD rsp,rsp,#&01000000 ;r6502_sp++
  LDRB $n,[r11,rsp,LSR #24] ;$n = memory[0x100+r6502_sp]
  MEND

  MACRO
  IMPLIED $n
  ADD r1,r1,#&10000
  R6502NEXTCYCLE $n
  MEND

  MACRO
  ADDRESSING_BASE $n
  ADD r1,r1,#&10000
  STR r2,[r12,#:INDEX:R6502_CONTINUATION2]
  R6502NEXTCYCLE $n
  MEND

  MACRO
  ADDRESSING_NOFORK $n, $o
  LDR r2,=$o
  ADDRESSING_BASE $n
  MEND
  
  MACRO
  ADDRESSING_DECIMALFORK $n, $o, $p
  TST rps,#DFLAG
  LDREQ r2,=$o
  LDRNE r2,=$p
  ADDRESSING_BASE $n
  MEND

