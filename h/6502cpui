  ANDEQ rps,rps,#NOTCFLAG ;clear c flag
  MOV r0,r0,LSR #&01 ;shift right
  EORS ra,ra,r0
  SETZFLAG0 ;ra
  SETNFLAG ra
  MEND

;
;rockwell 6502 cpu
;
  MACRO
  R6502LSR $n
