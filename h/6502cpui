  MACRO
  MOV_R6502_FIRST_STEP_IN $d,$s
  MOV $d,#($s:SHL:R6502_LOG2_MAX_SEQUENCE_LENGTH+R6502_STEP_BASE)&0xFF
  ORR $d,$d,#($s:SHL:R6502_LOG2_MAX_SEQUENCE_LENGTH+R6502_STEP_BASE)&0xFF00
  MEND

  END
