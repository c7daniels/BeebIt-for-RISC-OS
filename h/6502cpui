;
;rockwell 6502 cpu
;
  MACRO
  R6502RLA
  ;IN: r0=number to rla
  ;OUT:r0=result
  AND r3,rps,#CFLAG ;store c flag
  ANDS r1,r0,#&80
  ORRNE rps,rps,#CFLAG ;set c flag
  ANDEQ rps,rps,#NOTCFLAG ;clear c flag
  MOV r0,r0,LSL #&01 ;shift left
  CMP r3,#0
  ORRNE r0,r0,#&01
  AND r0,r0,#&FF
  ANDS ra,ra,r0
  SETZFLAG0 ;ra
  SETNFLAG ra
  MEND

;
;rockwell 6502 cpu
;
  MACRO
  R6502ROL $n
  ;IN: $n=number to rol
  ;OUT:$n=result
