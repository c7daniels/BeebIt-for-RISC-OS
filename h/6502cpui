;
;rockwell 6502 cpu
;
  MACRO
  R6502SBC
  ;r0=number to sbc with A

  ;if not decimal
  MOV r0,r0,LSL#24 ;n=(n<<24)

  ;LDR r12,=r6502_a
  ;LDRB ra,[r12] ;load a
  MOV ra,ra,LSL#24 ;a=(a<<24)

;  MOV r1,#1 ;bit       jdl** no longer required
;  MOV r2,#0 ;bit mask  jdl** no longer required
  ;LDR r11,=r6502_ps
  ;LDRB rps,[r11]

  ;n flag
  ;ANDS r3,rps,#NFLAG
  ;ORRNE r2,r2,r1,LSL#31 ;set n flag in bit mask
  ;z flag
  ;ANDS r3,rps,#ZFLAG
  ;ORRNE r2,r2,r1,LSL#30 ;set z flag in bit mask
  ;c flag
;  ANDS r3,rps,#CFLAG   jdl** no longer required
;  ORRNE r2,r2,r1,LSL#29 ;set c flag in bit mask jdl** no longer required
  ;v flag
  ;ANDS r3,rps,#VFLAG
  ;ORRNE r2,r2,r1,LSL#28 ;set v flag in bit mask

;  TEQP r3,r2 ;set flags in ARM PSR jdl** not 32bit
  TEQ r0,rps,LSR #1    ;jdl** ARM c =6502 c

  SBCS ra,ra,r0 ;ra=a-n-c

  AND rps,rps,#&3C ;%00111100 ;clear NVubdiZC
  ORRMI rps,rps,#NFLAG
  ORRVS rps,rps,#VFLAG
  ;ORREQ rps,rps,#ZFLAG
  ORRCS rps,rps,#CFLAG
  ;STRB rps,[r11]

  MOVS ra,ra,LSR#24 ;(a=(a>>24) jdl** also (z=(a=0))
;  CMP ra,#0     jdl** combined with MOV above
  ORREQ rps,rps,#ZFLAG
  ;STRB ra,[r12] ;store a
  MEND

;
;rockwell 6502 cpu
;
  MACRO
  R6502SBCD
  ;r0=number to sbc with A

  ;if decimal and NMOS
  MOV r0,r0,LSL#24

  MOV ra,ra,LSL#24

  TEQ r0,rps,LSR #1

  SBCS r3,ra,r0

  AND rps,rps,#&3D ;%00111101 ;clear NVubdiZc
  ORRMI rps,rps,#NFLAG
  ORRVS rps,rps,#VFLAG

  MOVS r3,r3,LSR#24
  ORREQ rps,rps,#ZFLAG
  
  MOV r3,ra,LSL #4
  
  TEQ r0,rps,LSR #1

  SBCS r3,r3,r0,LSL #4
  SUBCC r3,r3,#&60000000
  
  AND ra,ra,#&F0000000
  AND r0,r0,#&F0000000
  
  SBCS r0,ra,r0
  SUBCC r0,r0,#&60000000
  
  ORRCS rps,rps,#CFLAG
  ANDCC rps,rps,#NOTCFLAG
  
  MOV r0,r0,LSR #28
  MOV r3,r3,LSR #28
  ORR ra,r3,r0,LSL #4
  MEND

;
;rockwell 6502 cpu
;
  MACRO
  R6502SBCD_M
  ;r0=number to sbc with A

  ;if decimal and CMOS
  MOV r0,r0,LSL#24

  MOV ra,ra,LSL#24
  
  MOV r3,ra,LSL #4
  
  TEQ r0,rps,LSR #1

  SBCS r3,r3,r0,LSL #4
  SUBCC r3,r3,#&60000000
  
  AND ra,ra,#&F0000000
  AND r0,r0,#&F0000000
  
  SBCS r2,ra,r0
  SUBCC r2,r2,#&60000000
  
  AND rps,rps,#&3C ;%00111100 ;clear NVubdiZC
  ORRCS rps,rps,#CFLAG
  TST r2,r2
  ORRMI rps,rps,#NFLAG
  
  EOR ra,r0,ra
  EOR r0,r0,r2
  ANDS r0,r0,ra
  ORRMI rps,rps,#VFLAG
  
  MOV r2,r2,LSR #28
  MOV r3,r3,LSR #28
  ORRS ra,r3,r2,LSL #4
  ORREQ rps,rps,#ZFLAG
  MEND

