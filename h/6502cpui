;
;rockwell 6502 cpu
;
  MACRO
  R6502ASL $n
  ;IN: $n=number to asl
  ;OUT:$n=result
  ;LDR r11,=r6502_ps
  ;LDRB rps,[r11]
  ANDS r1,$n,#&80
  ORRNE rps,rps,#CFLAG ;set c flag
  ANDEQ rps,rps,#NOTCFLAG ;clear c flag
  MOV $n,$n,LSL #&01 ;shift left
  ANDS $n,$n,#&FF
  SETZFLAG0 ;r0
  SETNFLAG $n
  ;STRB rps,[r11]
  MEND

