;
;rockwell 6502 cpu
;
  MACRO
  R6502NEXTCYCLE_BASE
  SUBS rcycles,rcycles,#1
  BGT r6502busop
  B r6502intoyield
  MEND

;
;rockwell 6502 cpu
;
  MACRO
  R6502CONTINUECYCLE
  LDR pc,[r12,#:INDEX:R6502_CONTINUATION2]
  MEND

;
;rockwell 6502 cpu
;
  MACRO
  R6502NEXTCYCLE $o
  LDR lr,=$o
  R6502NEXTCYCLE_BASE
  MEND

;
;rockwell 6502 cpu
;
  MACRO
  R6502NEXTCYCLE_LSorHI $o,$p
  LDRLS lr,=$o
  LDRHI lr,=$p
  R6502NEXTCYCLE_BASE
  MEND

;
;rockwell 6502 cpu
;
  MACRO
  R6502NEXTCYCLE_CCorCS $o,$p
  LDRCC lr,=$o
  LDRCS lr,=$p
  R6502NEXTCYCLE_BASE
  MEND

;
;rockwell 6502 cpu
;
  MACRO
  R6502NEXTCYCLE_NEorEQ $o,$p
  LDRNE lr,=$o
