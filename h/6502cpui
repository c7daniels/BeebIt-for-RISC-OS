  ANDS r1,$n,#&80
  ORRNE rps,rps,#CFLAG ;set c flag
  ANDEQ rps,rps,#NOTCFLAG ;clear c flag
  MOV $n,$n,LSL #&01 ;shift left
  CMP r3,#0
  ORRNE $n,$n,#&01
  ANDS $n,$n,#&FF
  SETZFLAG0 ;$n
  SETNFLAG $n
  MEND

;
;rockwell 6502 cpu
;
  MACRO
  R6502ROR $n
  ;IN: $n=number to ror
  ;OUT:$n=result
  AND r3,rps,#CFLAG ;store c flag
  ANDS r1,$n,#&01
  ORRNE rps,rps,#CFLAG ;set c flag
  ANDEQ rps,rps,#NOTCFLAG ;clear c flag
  MOV $n,$n,LSR #&01 ;shift right
  CMP r3,#0
  ORRNE $n,$n,#&80
  ANDS $n,$n,#&FF
  SETZFLAG0 ;$n
  SETNFLAG $n
  MEND

