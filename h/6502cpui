;
;rockwell 6502 cpu
;
  MACRO
  R6502ASL $n
  ;IN: $n=number to asl
  ;OUT:$n=result
  ANDS r1,$n,#&80
  ORRNE rps,rps,#CFLAG ;set c flag
  ANDEQ rps,rps,#NOTCFLAG ;clear c flag
  MOV $n,$n,LSL #&01 ;shift left
  ANDS $n,$n,#&FF
  SETZFLAG0 ;r0
  SETNFLAG $n
  MEND

;
;rockwell 6502 cpu
;
  MACRO
  R6502ASO
  ;IN: r0=number to aso
  ;OUT:r0=result
  ANDS r1,r0,#&80
  ORRNE rps,rps,#CFLAG
  ANDNE rps,rps,#NOTCFLAG
  MOV r0,r0,LSL #&01 ;shift left
  ORR ra,ra,r0
  ANDS ra,ra,#&FF
  SETZFLAG0 ;ra
  SETNFLAG ra
  MEND

;
;rockwell 6502 cpu
;
  MACRO
  R6502BRA
  ;IN: r0=offset
  MOV r1,rpc,LSR#8 ;r1=(pc>>8)
  AND r1,r1,#&FF
  ANDS r2,r0,#&80 ;r2=(n & 0x80)
  MOVNE r3,#&100
  SUBNE r0,r3,r0 ;r0=(&100-r0)
  SUBNE rpc,rpc,r0 ;rpc=(rpc-r0)
  ADDEQ rpc,rpc,r0 ;rpc=(rpc+r0)

  ;MOV rpc,rpc,LSL #16
  ;MOV rpc,rpc,LSR #16

  MOV r2,rpc,LSR#8 ;r2=(pc>>8)
  AND r2,r2,#&FF
  CMP r1,r2 ;if (n1 != (r6502_pc >> 8))
  SUBNE rcycles,rcycles,#4 ;r3=(r3-4)
  SUBEQ rcycles,rcycles,#3 ;r3=(r3-3)
  MEND

