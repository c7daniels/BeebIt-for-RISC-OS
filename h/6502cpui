;
;rockwell 6502 cpu
;
  MACRO
  R6502NEXTOPCODE ;_SLOW ;rename for tracing
  LDR pc,[sp],#4
  MEND

;
;rockwell 6502 cpu
;
  MACRO
  R6502NEXTOPCODE_FAST ;rename for tracing
  CMP rcycles,#0
  LDRLE pc,[sp],#4
  CMP rpc,#&3000
  LDRLTB r0,[r12,rpc] ;get opcode
  ADDLT pc,pc,#READMEM_LEN+(1*4)-4

  MOV r0,rpc ;1*4
  READMEM ;1*4

  ADD rpc,rpc,#1
  LDR r1,=r6502opcodes
  LDR pc,[r1,r0,LSL#2]
  ;LDR pc,[sp],#4
  MEND

;
;rockwell 6502 cpu
;
  MACRO
  R6502JAM
  SUB rpc,rpc,#1
  CPU_CYCLES 1
  MEND

;
;rockwell 6502 cpu
;
  MACRO
  R6502IRQCHECK0
  LDR r11,=beebit_irq
  LDR r2,[r11]
  CMP r2,#0
  ADDEQ pc,pc,#24 ;(7*4)-4

  CMP rcycles,#0
  ADDLE pc,pc,#16 ;(5*4)-4
  LDR r11,=r6502_cyclesoriginal
  LDR r2,[r11]
  SUB r2,r2,rcycles
  STR r2,[r11]
  MOV rcycles,#0
  MEND

;
;rockwell 6502 cpu
;
  MACRO
  R6502IRQCHECK1
  LDR r11,=beebit_irq
  LDR r2,[r11]
  CMP r2,#0
  ADDEQ pc,pc,#28 ;(8*4)-4

  CMP rcycles,#1
  ADDLE pc,pc,#20 ;(6*4)-4
  LDR r11,=r6502_cyclesoriginal
  LDR r2,[r11]
  SUB r2,r2,rcycles
  ADD r2,r2,#1
  STR r2,[r11]
  MOV rcycles,#1
  MEND

;
;rockwell 6502 cpu
;
  MACRO
  R6502ADC
  ;r0=number to adc with A

  ;if not decimal
  MOV r0,r0,LSL#24 ;n=(n<<24)

  ;LDR r12,=r6502_a
  ;LDRB ra,[r12] ;load a
;  MOV ra,ra,LSL#24 ;a=(a<<24) jdl** combined with ORR
  MOV r1,#&00FFFFFF ;raFFFFFF
  ORR ra,r1,ra,LSL #24 ;jdl** changed to eliminate MOV

;  MOV r1,#1 ;bit      jdl** no longer required
;  MOV r2,#0 ;bit mask jdl** no longer required
  ;LDR r11,=r6502_ps
  ;LDRB rps,[r11]

  ;n flag
  ;ANDS r3,rps,#NFLAG
  ;ORRNE r2,r2,r1,LSL#31 ;set n flag in bit mask
  ;z flag
  ;ANDS r3,rps,#ZFLAG
  ;ORRNE r2,r2,r1,LSL#30 ;set z flag in bit mask
  ;c flag
;  ANDS r3,rps,#CFLAG  jdl** no longer required
;  ORRNE r2,r2,r1,LSL#29 ;set c flag in bit mask jdl** no longer required
  ;v flag
  ;ANDS r3,rps,#VFLAG
  ;ORRNE r2,r2,r1,LSL#28 ;set v flag in bit mask

;  TEQP r3,r2 ;set flags in ARM PSR jdl** not 32bit
  TEQ r0,rps,LSR #1   ;jdl** ARM c =6502 c

  ;TEQ   PC,#0             ; ensure some processor flags are set
  ;TEQ   PC,PC             ; if not equal flags are in PC therefor 26bit mode
  ;CMPNE PC,#1<<29         ; old way of setting V
  ;MSREQ CPSR_f,#1<<29     ; new way of setting V

  ADCS ra,ra,r0 ;ra=a+n+c

  AND rps,rps,#&3C ;%00111100 ;clear NVubdiZC
  ORRMI rps,rps,#NFLAG
  ORRVS rps,rps,#VFLAG
  ;ORREQ rps,rps,#ZFLAG
  ORRCS rps,rps,#CFLAG
  ;STRB rps,[r11]

  MOVS ra,ra,LSR#24 ;(a=(a>>24) jdl** also (z=(a=0))
;  CMP ra,#0    jdl** combined with MOV above
  ORREQ rps,rps,#ZFLAG
  ;STRB ra,[r12] ;store a
  MEND

;
;rockwell 6502 cpu
;
  MACRO
  R6502ADCD
  ;r0=number to adc with A
  
  ;if decimal and NMOS
  MOV r0,r0,LSL #24

  MOV r1,#&00FFFFFF
  ORR r1,r1,ra,LSL #24

  TEQ r0,rps,LSR #1

  ADCS r3,r1,r0
  
  CMP r3,#&01000000
  ORRCC rps,rps,#ZFLAG
  ANDCS rps,rps,#NOTZFLAG

  MOV r3,r1,LSL #4
  ORR r3,r3,#&0F
  
  TEQ r0,rps,LSR #1
  
  ADCS r3,r3,r0,LSL #4
  
  BIC r0,r0,#&0F000000
  ORR r1,r1,#&0F000000
  
  CMPCC r3,#&A0000000
  ADDCS r3,r3,#&60000000
  
  ADCS r0,r0,r1

  AND rps,rps,#&3E ;%00111110 ;clear NVubdizC
  ORRMI rps,rps,#NFLAG
  ORRVS rps,rps,#VFLAG

  CMPCC r0,#&A0000000
  ADDCS r0,r0,#&60000000
  
  ORRCS rps,rps,#CFLAG
  ANDCC rps,rps,#NOTCFLAG
  
  MOV r0,r0,LSR #28
  MOV r3,r3,LSR #28
  ORR ra,r3,r0,LSL #4
  MEND

;
;rockwell 6502 cpu
;
  MACRO
  R6502ADCD_M
  ;r0=number to adc with A
  
  ;if decimal and CMOS
  MOV r0,r0,LSL #24

  MOV r1,#&00FFFFFF
  ORR r1,r1,ra,LSL #24

  MOV r3,r1,LSL #4
  ORR r3,r3,#&0F
  
  TEQ r0,rps,LSR #1
  
  ADCS r3,r3,r0,LSL #4
  
  BIC r0,r0,#&0F000000
  ORR r1,r1,#&0F000000
  
  CMPCC r3,#&A0000000
  ADDCS r3,r3,#&60000000
  
  ADCS r2,r0,r1

  CMPCC r2,#&A0000000
  ADDCS r2,r2,#&60000000
  
  AND rps,rps,#&3C ;%00111100 ;clear NVubdiZC
  ORRCS rps,rps,#CFLAG
  TST r2,r2
  ORRMI rps,rps,#NFLAG
  
  EOR r0,r0,r1
  EOR r1,r1,r2
  BICS r0,r1,r0
  ORRMI rps,rps,#VFLAG
  
  MOV r2,r2,LSR #28
  MOV r3,r3,LSR #28
  ORRS ra,r3,r2,LSL #4
  ORREQ rps,rps,#ZFLAG
  MEND

;
;rockwell 6502 cpu
;
  MACRO
  R6502ALR
  ;r0=number to alr
  ;LDR r12,=r6502_a
  ;LDRB ra,[r12] ;load a
  AND ra,ra,r0 ;a = a and n
  ANDS r0,ra,#&01
  ORRNE rps,rps,#CFLAG ;set c flag
  ANDEQ rps,rps,#NOTCFLAG ;clear c flag
  MOVS ra,ra,LSR #&01 ;shift right
  ;STRB ra,[r12] ;save a
  ;set psr
  ;LDR r12,=r6502_ps
  ;LDRB rps,[r12] ;load ps
  SETZFLAG0 ;ra
  AND rps,rps,#NOTNFLAG
  ;STRB rps,[r12]
  MEND

;
;rockwell 6502 cpu
;
  MACRO
  R6502ARR
  ;r0=number to arr
  AND ra,ra,r0
  MOV r3,ra,LSL#24
  ADCS r1,r3,r3
  AND r3,rps,#CFLAG
  AND rps,rps,#&3C
  ORRVS rps,rps,#VFLAG
  ORRCS rps,rps,#CFLAG
  CMP r3,#0
  ORRNE ra,ra,#&100
  ORRNE rps,rps,#NFLAG
  MOVS ra,ra,LSR #1
  ORREQ rps,rps,#ZFLAG
  MEND

;
;rockwell 6502 cpu
;
  MACRO
  R6502ARRD
  ;r0=number to arr
  AND ra,ra,r0
  MOV r0,ra
  MOV r3,ra,LSL#24
  ADCS r1,r3,r3
  AND r3,rps,#CFLAG
  AND rps,rps,#&3C
  ORRVS rps,rps,#VFLAG
  CMP r3,#0
  ORRNE ra,ra,#&100
  ORRNE rps,rps,#NFLAG
  MOVS ra,ra,LSR #1
  ORREQ rps,rps,#ZFLAG
  AND r3,r0,#&0F
  CMP r3,#&0A
  ADDCS r3,ra,#&06
  ANDCS r3,r3,#&0F
  ANDCS ra,ra,#&F0
  ORRCS ra,r3,ra
  AND r3,r0,#&F0
  CMP r3,#&A0
  ADDCS ra,ra,#&60
  ANDCS ra,ra,#&FF
  ORRCS rps,rps,#CFLAG
  MEND

