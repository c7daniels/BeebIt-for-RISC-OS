  MACRO
  R6502_OPCODE_PUSH
  [ !Optimise6502WorkAreas && Optimise6502Links
  STMFD sp!,{r4-r9}
  ]
  [ !Optimise6502WorkAreas && !Optimise6502Links
  STMFD sp!,{r4-r9,lr}
  ]
  [ !Optimise6502WorkAreas
  HOST_LOAD_WORK_AREA
  ]
  [ Optimise6502WorkAreas && !Optimise6502Links
  STR lr,[sp, #-4]!
  ]
  MEND

  MACRO
  R6502_OPCODE_POP
  [ !Optimise6502WorkAreas
  HOST_STORE_WORK_AREA
  ]
  [ !Optimise6502WorkAreas && Optimise6502Links
  LDMFD sp!,{r4-r9}
  ]
  [ !Optimise6502WorkAreas && !Optimise6502Links
  LDMFD sp!,{r4-r9,lr}
  ]
  [ Optimise6502WorkAreas && !Optimise6502Links
  LDR lr, [sp], #4
  ]
  MEND

  MACRO
  R6502_FOLD_OR_TRAP $continuationtype,$tag
  AND r2,r1,#&F000000F
  ADR lr,%F1
  LDR pc,[r0,-r2,ROR #24]
  DCD s_$tag,s1_$tag,s2_$tag
1
  [ "$continuationtype"!="inline"
  B d_$tag
  ]
  MEND

  MACRO
  R6502_IMPLIED_FOLD_OR_TRAP $tag
  ADD r1,r6,#1:SHL:16
  R6502_FOLD_OR_TRAP ,$tag
  MEND

  MACRO
  R6502_SIMPLE_IMPLIED_FOLD_OR_TRAP
  ADD r1,r6,#1:SHL:16
  R6502_FOLD_OR_TRAP ,r6502simpleimplied
  MEND

  MACRO
  R6502_OPERAND_FOLD_OR_TRAP $offset,$tag,$ocontinuation,$icontinuation,$link
  ADD r1,r6,#$offset:SHL:16
  AND r2,r1,#&F000000F
  ADR lr,%F1
  LDR pc,[r0,-r2,ROR #24]
  [ "$link"!=""
  DCD $link
  ]
  DCD $ocontinuation
  DCD s_$tag,s1_$tag,s2_$tag
1
  B $icontinuation
  MEND

  MACRO
  R6502_OPERAND_LO_FOLD_OR_TRAP $ocontinuation,$icontinuation,$link
  R6502_OPERAND_FOLD_OR_TRAP 1,r6502operand,$ocontinuation,$icontinuation,$link
  MEND

  MACRO
  R6502_OPERAND_LO_TWICE_FOLD_OR_TRAP $ocontinuation,$icontinuation,$link
  R6502_OPERAND_FOLD_OR_TRAP 1,r6502operandtwice,$ocontinuation,$icontinuation,$link
  MEND

  MACRO
  R6502_OPERAND_HI_FOLD_OR_TRAP $ocontinuation,$icontinuation,$link
  R6502_OPERAND_FOLD_OR_TRAP 2,r6502wait1operand,$ocontinuation,$icontinuation,$link
  MEND

  MACRO
  R6502_OPERAND_HI_TWICE_FOLD_OR_TRAP $ocontinuation,$icontinuation,$link
  R6502_OPERAND_FOLD_OR_TRAP 2,r6502wait1operandtwice,$ocontinuation,$icontinuation,$link
  MEND

  MACRO
  R6502_INDIRECT_FOLD_OR_TRAP $continuationtype,$n,$ocontinuation,$icontinuation
  AND r2,r1,#&F000000F
  ADR lr,%F1
  LDR pc,[r0,-r2,ROR #24]
  DCD $ocontinuation
  DCD s_r6502indirect$n,s1_r6502indirect$n,s2_r6502indirect$n
1
  [ "$continuationtype"!="inline"
  B $icontinuation
  ]
  MEND

  MACRO
  R6502_TOUCH_OR_TRAP $continuationtype,$tag
  AND r2,r1,#&F000000F-ADDRESSING_FOLDFLAG
  ADR lr,%F1
  LDR pc,[r0,-r2,ROR #24]
  DCD s_$tag,s1_$tag,s2_$tag
1
  [ "$continuationtype"!="inline"
  B d_$tag
  ]
  MEND

  MACRO
  R6502_NOFOLD_TO_SPLIT1_LINK $offset
  SUB r3,r3,#20+$offset
  MEND

