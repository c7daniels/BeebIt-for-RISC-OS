struct R6502WORKSPACE* sheilawrite_b(R6502WORKSPACE* w)
{
  int naddress = (w->address_code>>16);
  int nvalue = w->m;
  #ifdef __DEBUG__
    fprintf(htrace,"WRITEsheila=&%X,&%X\n",naddress,nvalue);
  #endif
  /*sheila address space FE00-&FEFF*/
  /*these values are only used for snapshots*/
  /*sheila_b[naddress-0xFE00] = nvalue;*/

  switch (naddress & 0xFC)
  {
    case 0x00:
    case 0x04:
      /*&FE00 - &FE07*/
      #ifdef __DEBUG__
        fprintf(htrace,"writecrtc(%X)",nvalue);
      #endif
      crtcwrite(naddress,nvalue);
      break;
    case 0x08:
    case 0x0C:
      /*&FE08 - &FE0F (ACIA)*/
      aciawrite(naddress,nvalue);
      break;
    case 0x10:
    case 0x14:
      /*&FE10 - &FE17 (SERIALULA)*/
      #ifdef __DEBUG__
        fprintf(htrace,"writeserialula()");
      #endif
      serialulawrite(naddress,nvalue);
      break;
    case 0x18:
    case 0x1C:
      /*&FE18 - &FE1F (SERIALULA/ADC)*/
      serialulawrite(naddress,nvalue);
      #ifdef __DEBUG__
        fprintf(htrace,"writeserialula()");
      #endif
      break;
    case 0x20:
      /*&FE20 - &FE23 (VIDEOULA)*/
      #ifdef __DEBUG__
        fprintf(htrace,"writevideoula(&%X,&%X)\n",naddress,nvalue);
      #endif
      videoulawrite(naddress, nvalue);
      break;
    case 0x24:
      /*&FE24 - &FE27 (VIDEOULA/FDC INTERFACE CONTROL REG)*/
      videoulawrite(naddress, nvalue);
      break;
    case 0x28:
    case 0x2C:
      /*&FE28 - &FE2F (VIDEOULA/FDC INTERFACE)*/
      videoulawrite(naddress, nvalue);
      break;
    case 0x30:
    case 0x34:
    case 0x38:
    case 0x3C:
      /*&FE30 - &FE3F (ROMSEL)*/
      #ifdef __DEVELOPxx__
        fprintf(htrace,"ROMSEL(&%X,&%X)",naddress,nvalue);
      #endif
      {
        int nrom = (nvalue & 0x0F);
        w->bus_fork[0x0B] = w->bus_fork[0x0A]
            = w->bus_fork[0x09] = w->bus_fork[0x08] = w->read8000s[nrom];
        w->bus_fork[0x1B] = w->bus_fork[0x1A]
            = w->bus_fork[0x19] = w->bus_fork[0x18] = w->write8000s[nrom];
      }
      w->romsel = nvalue;
      break;
    case 0x40:
    case 0x44:
    case 0x48:
    case 0x4C:
    case 0x50:
    case 0x54:
    case 0x58:
    case 0x5C:
      /*&FE40 - &FE5F (SYSTEMVIA)*/
      /*printf(" &FE40 ");*/
      #ifdef __DEBUG__
        fprintf(htrace,"systemviawrite(%X,%X)",(naddress & 0x0F),nvalue);
      #endif
      systemviawrite(naddress,nvalue);
      break;
    case 0x60:
    case 0x64:
    case 0x68:
    case 0x6C:
    case 0x70:
    case 0x74:
    case 0x78:
    case 0x7C:
      /*&FE60 - &FE7F (USERVIA)*/
      #ifdef __DEBUG__
        if (beebit_trace)
          fprintf(htrace,"writeuservia(&%X,&%X)",(naddress & 0x0F),nvalue);
      #endif
      userviawrite(naddress, nvalue);
      break;
    case 0x80:
    case 0x84:
    case 0x88:
    case 0x8C:
    case 0x90:
    case 0x94:
    case 0x98:
    case 0x9C:
      /*&FE80 - &FE9F (8271 or 1770)*/
      #ifdef __DEBUG__
        fprintf(htrace,"write8271(&%X,&%X)\n",(naddress & 0x0F),nvalue);
      #endif
      i8271write(naddress, nvalue);
      /*w1770write(naddress, nvalue);*/
      if ((r6502.nmis & NMIS_NMI) AND !(r6502.nmis & NMIS_OLDNMI))
      {
        r6502startinterrupt(&r6502);
      }
      break;
    case 0xC0:
    case 0xC4:
    case 0xC8:
    case 0xCC:
    case 0xD0:
    case 0xD4:
    case 0xD8:
    case 0xDC:
      /*&FEC0 - &FEDF (ADC)*/
      adcwrite(naddress,nvalue);
      #ifdef __DEBUG__
        fprintf(htrace,"writeadc()");
      #endif
      break;
    case 0xE0:
    case 0xE4:
    case 0xE8:
    case 0xEC:
      /*&FEE0-&FEFF (TUBE)*/
      /*tubewrite(naddress,nvalue);*/
      break;
    case 0xF0:
    case 0xF4:
    case 0xF8:
    case 0xFC:
      /*FEE0-&FEFF (TUBE)*/
      /*tubewrite(naddress,nvalue);*/
      break;
  }
  R6502_EXECUTE_STEP(w)
  return w;
}

struct R6502WORKSPACE* sheilawrite_bp(R6502WORKSPACE* w)
{
  int naddress = (w->address_code>>16);
  int nvalue = w->m;
  #ifdef __DEBUG__
    fprintf(htrace,"WRITEsheila=&%X,&%X\n",naddress,nvalue);
  #endif
  /*sheila address space FE00-&FEFF*/
  /*these values are only used for snapshots*/
  /*sheila_b[naddress-0xFE00] = nvalue;*/

  switch (naddress & 0xFC)
  {
    case 0x00:
    case 0x04:
      /*&FE00 - &FE07*/
      #ifdef __DEBUG__
        fprintf(htrace,"writecrtc(%X)",nvalue);
      #endif
      crtcwrite(naddress,nvalue);
      break;
    case 0x08:
    case 0x0C:
      /*&FE08 - &FE0F (ACIA)*/
      aciawrite(naddress,nvalue);
      break;
    case 0x10:
    case 0x14:
      /*&FE10 - &FE17 (SERIALULA)*/
      #ifdef __DEBUG__
        fprintf(htrace,"writeserialula()");
      #endif
      serialulawrite(naddress,nvalue);
      break;
    case 0x18:
    case 0x1C:
      /*&FE18 - &FE1F (SERIALULA/ADC)*/
      serialulawrite(naddress,nvalue);
      #ifdef __DEBUG__
        fprintf(htrace,"writeserialula()");
      #endif
      break;
    case 0x20:
      /*&FE20 - &FE23 (VIDEOULA)*/
      /*fprintf(htrace,"UW:&%X,&%X - PC=&%x\n",naddress,nvalue,w->pc);*/
      #ifdef __DEBUG__
        fprintf(htrace,"writevideoula(&%X,&%X)\n",naddress,nvalue);
      #endif
      videoulawrite(naddress, nvalue);
      break;
    case 0x24:
      /*&FE24 - &FE27 (VIDEOULA/FDC INTERFACE CONTROL REG)*/
      videoulawrite(naddress, nvalue);
      break;
    case 0x28:
    case 0x2C:
      /*&FE28 - &FE2F (VIDEOULA/FDC INTERFACE)*/
      videoulawrite(naddress, nvalue);
      break;
    case 0x30:
    case 0x38:
      /*&FE30 - &FE33, &FE38 - &FE3B (ROMSEL)*/
      #ifdef __DEVELOPxx__
        fprintf(htrace,"ROMSEL(&%X,&%X)",naddress,nvalue);
      #endif
      {
        int nrom = (nvalue & 0x0F);
        if (nvalue & 0x80)
        {
          /*ROMSEL b7 (RAM) (&8000-&AFFF)*/
          w->bus_fork[0x0A] = w->bus_fork[0x09]
              = w->bus_fork[0x08] = w->read8000_ram;
          w->bus_fork[0x1A] = w->bus_fork[0x19]
              = w->bus_fork[0x18] = w->write8000_ram;
        }
        else
        {
          w->bus_fork[0x0A] = w->bus_fork[0x09]
              = w->bus_fork[0x08] = w->read8000s[nrom];
          w->bus_fork[0x1A] = w->bus_fork[0x19]
              = w->bus_fork[0x18] = w->write8000s[nrom];
        }
        w->bus_fork[0x0B] = w->read8000s[nrom];
        w->bus_fork[0x1B] = w->write8000s[nrom];
      }
      w->romsel = nvalue;
      break;
    case 0x34:
    case 0x3C:
      /*&FE34 - &FE37, &FE3C - &FE3F (ACCCON)*/
      #ifdef __DEVELOPxx__
        fprintf(htrace,"ACCCON(&%X,&%X)\n",naddress,nvalue);
      #endif
      if (nvalue & 0x80)
      {
        /*ACCCON b7 (VDUSEL) (&3000-&7FFF)*/
        w->bus_fork[0x07] = w->bus_fork[0x06]
            = w->bus_fork[0x05] = w->bus_fork[0x04]
            = w->bus_fork[0x03] = w->read3000_ram;
        w->bus_fork[0x17] = w->bus_fork[0x16]
            = w->bus_fork[0x15] = w->bus_fork[0x14]
            = w->bus_fork[0x13] = w->write3000_ram;
      }
      else
      {
        w->bus_fork[0x07] = w->bus_fork[0x06]
            = w->bus_fork[0x05] = w->bus_fork[0x04]
            = w->bus_fork[0x03] = w->read3000;
        w->bus_fork[0x17] = w->bus_fork[0x16]
            = w->bus_fork[0x15] = w->bus_fork[0x14]
            = w->bus_fork[0x13] = w->write3000;
      }
      w->acccon = nvalue;
      break;
    case 0x40:
    case 0x44:
    case 0x48:
    case 0x4C:
    case 0x50:
    case 0x54:
    case 0x58:
    case 0x5C:
      /*&FE40 - &FE5F (SYSTEMVIA)*/
      #ifdef __DEBUG__
        fprintf(htrace,"systemviawrite(%X,%X)",(naddress & 0x0F),nvalue);
      #endif
      systemviawrite(naddress,nvalue);
      break;
    case 0x60:
    case 0x64:
    case 0x68:
    case 0x6C:
    case 0x70:
    case 0x74:
    case 0x78:
    case 0x7C:
      /*&FE60 - &FE7F (USERVIA)*/
      #ifdef __DEBUG__
        if (beebit_trace)
          fprintf(htrace,"writeuservia(&%X,&%X)",(naddress & 0x0F),nvalue);
      #endif
      userviawrite(naddress, nvalue);
      break;
    case 0x80:
    case 0x84:
    case 0x88:
    case 0x8C:
    case 0x90:
    case 0x94:
    case 0x98:
    case 0x9C:
      /*&FE80 - &FE9F (8271 or 1770)*/
      if ((naddress & 0xFF) == 0x80)
        w1770controlwrite(nvalue);
      else if ((naddress & 0xFF) == 0x85 AND !w1770_initialised)
        w1770controlwrite(nvalue);
      else
        w1770write(naddress,nvalue);
      break;
    case 0xC0:
    case 0xC4:
    case 0xC8:
    case 0xCC:
    case 0xD0:
    case 0xD4:
    case 0xD8:
    case 0xDC:
      /*&FEC0 - &FEDF (ADC)*/
      adcwrite(naddress,nvalue);
      #ifdef __DEBUG__
        fprintf(htrace,"writeadc()");
      #endif
      break;
    case 0xE0:
    case 0xE4:
    case 0xE8:
    case 0xEC:
      /*&FEE0-&FEFF (TUBE)*/
      /*tubewrite(naddress,nvalue);*/
      break;
    case 0xF0:
    case 0xF4:
    case 0xF8:
    case 0xFC:
      /*FEE0-&FEFF (TUBE)*/
      /*tubewrite(naddress,nvalue);*/
      break;
  }
  R6502_EXECUTE_STEP(w)
  return w;
}

struct R6502WORKSPACE* sheilawrite_m(R6502WORKSPACE* w)
{
  int naddress = (w->address_code>>16);
  int nvalue = w->m;
  #ifdef __DEBUG__
    fprintf(htrace,"WRITEsheila=&%X,&%X\n",naddress,nvalue);
  #endif
  /*sheila address space FE00-&FEFF*/
  /*these values are only used for snapshots*/
  /*sheila_b[naddress-0xFE00] = nvalue;*/
  switch (naddress & 0xFC)
  {
    case 0x00:
    case 0x04:
      /*&FE00 - &FE07*/
      #ifdef __DEBUG__
        fprintf(htrace,"writecrtc(%X)",nvalue);
      #endif
      crtcwrite(naddress,nvalue);
      break;
    case 0x08:
    case 0x0C:
      /*&FE08 - &FE0F (ACIA)*/
      aciawrite(naddress,nvalue);
      break;
    case 0x10:
    case 0x14:
      /*&FE10 - &FE17 (SERIALULA)*/
      #ifdef __DEBUG__
        fprintf(htrace,"writeserialula()");
      #endif
      serialulawrite(naddress,nvalue);
      break;
    case 0x18:
    case 0x1C:
      /*&FE18 - &FE1F (SERIALULA/ADC)*/
      adcwrite(naddress,nvalue);
      #ifdef __DEBUG__
        fprintf(htrace,"writeserialula()");
      #endif
      break;
    case 0x20:
      /*&FE20 - &FE23 (VIDEOULA)*/
      #ifdef __DEBUG__
        fprintf(htrace,"writevideoula(&%X,&%X)\n",naddress,nvalue);
      #endif
      videoulawrite(naddress, nvalue);
      break;
    case 0x24:
      /*&FE24 - &FE27 (VIDEOULA/FDC INTERFACE CONTROL REG)*/
      w1770controlwrite(nvalue);
      break;
    case 0x28:
    case 0x2C:
      /*&FE28 - &FE2F (VIDEOULA/FDC INTERFACE)*/
      w1770write(naddress,nvalue);
      break;
    case 0x30:
      /*&FE30 - &FE33 (ROMSEL)*/
      #ifdef __DEVELOPxx__
        fprintf(htrace,"ROMSEL(&%X,&%X)",naddress,nvalue);
      #endif
      {
        int nrom = (nvalue & 0x0F);
        if (nvalue & 0x80)
        {
          /*ROMSEL b7 (RAM) (&8000-&8FFF)*/
          w->bus_fork[0x08] = w->read8000_ram;
          w->bus_fork[0x18] = w->write8000_ram;
        }
        else
        {
          w->bus_fork[0x08] = w->read8000s[nrom];
          w->bus_fork[0x18] = w->write8000s[nrom];
        }
        w->bus_fork[0x0B] = w->bus_fork[0x0A]
            = w->bus_fork[0x09] = w->read8000s[nrom];
        w->bus_fork[0x1B] = w->bus_fork[0x1A]
            = w->bus_fork[0x19] = w->write8000s[nrom];
      }
      w->romsel = nvalue;
      break;
    case 0x34:
      /*&FE34 - &FE37 (ACCCON)*/
      #ifdef __DEVELOPxx__
        fprintf(htrace,"ACCCON(&%X,&%X)\n",naddress,nvalue);
      #endif
      switch (nvalue & 0x06)
      {
        case 0x00:
          /*RAM*/
          w->bus_fork[0x07] = w->bus_fork[0x06]
              = w->bus_fork[0x05] = w->bus_fork[0x04]
              = w->bus_fork[0x03] = w->read3000;
          w->bus_fork[0x17] = w->bus_fork[0x16]
              = w->bus_fork[0x15] = w->bus_fork[0x14]
              = w->bus_fork[0x13] = w->write3000;
          break;
        case 0x02:
          /*ACCCON b1 (E)*/
          w->bus_fork[0x07] = w->bus_fork[0x06]
              = w->bus_fork[0x05] = w->bus_fork[0x04]
              = w->bus_fork[0x03] = w->read3000_e;
          w->bus_fork[0x17] = w->bus_fork[0x16]
              = w->bus_fork[0x15] = w->bus_fork[0x14]
              = w->bus_fork[0x13] = w->write3000_e;
          break;
        case 0x04:
        case 0x06:
          /*ACCCON b2 (X)*/
          w->bus_fork[0x07] = w->bus_fork[0x06]
              = w->bus_fork[0x05] = w->bus_fork[0x04]
              = w->bus_fork[0x03] = w->read3000_x;
          w->bus_fork[0x17] = w->bus_fork[0x16]
              = w->bus_fork[0x15] = w->bus_fork[0x14]
              = w->bus_fork[0x13] = w->write3000_x;
          break;
      }
      if (nvalue & 0x08)
      {
        /*ACCCON b3 (Y)*/
        /*&C000-&DFFF*/
        w->bus_fork[0x0D] = w->bus_fork[0x0C] = w->readC000_y;
        w->bus_fork[0x1D] = w->bus_fork[0x1C] = w->writeC000_y;
      }
      else
      {
        /*&C000-&DFFF*/
        w->bus_fork[0x0D] = w->bus_fork[0x0C] = w->bus_fork[0x0E];
        w->bus_fork[0x1D] = w->bus_fork[0x1C] = w->bus_fork[0x1E];
      }

      if (nvalue & 0x80)
      {
        /*IRR*/
        r6502startinterrupt(&r6502);
        nvalue &= 0x7F;
      }
      w->acccon = nvalue;
      break;
    case 0x38:
      /*&FE38 - &FE3B (INTOFF)*/
      break;
    case 0x3C:
      /*&FE3C - &FE3F (INTON)*/
      break;
    case 0x40:
    case 0x44:
    case 0x48:
    case 0x4C:
    case 0x50:
    case 0x54:
    case 0x58:
    case 0x5C:
      /*&FE40 - &FE5F (SYSTEMVIA)*/
      /*printf(" &FE40 ");*/
      #ifdef __DEBUG__
        fprintf(htrace,"systemviawrite(%X,%X)",(naddress & 0x0F),nvalue);
      #endif
      systemviawrite(naddress,nvalue);
      break;
    case 0x60:
    case 0x64:
    case 0x68:
    case 0x6C:
    case 0x70:
    case 0x74:
    case 0x78:
    case 0x7C:
      /*&FE60 - &FE7F (USERVIA)*/
      #ifdef __DEBUG__
        if (beebit_trace)
          fprintf(htrace,"writeuservia(&%X,&%X)",(naddress & 0x0F),nvalue);
      #endif
      userviawrite(naddress, nvalue);
      break;
    case 0x80:
    case 0x84:
    case 0x88:
    case 0x8C:
    case 0x90:
    case 0x94:
    case 0x98:
    case 0x9C:
      /*&FE80 - &FE9F (8271 or 1770)*/
      i8271write(naddress, nvalue);
      if ((r6502.nmis & NMIS_NMI) AND !(r6502.nmis & NMIS_OLDNMI))
      {
        r6502startinterrupt(&r6502);
      }
      break;
    case 0xC0:
    case 0xC4:
    case 0xC8:
    case 0xCC:
    case 0xD0:
    case 0xD4:
    case 0xD8:
    case 0xDC:
      /*&FEC0 - &FEDF (ADC)*/
      break;
    case 0xE0:
    case 0xE4:
    case 0xE8:
    case 0xEC:
      /*&FEE0-&FEFF (TUBE)*/
      /*tubewrite(naddress,nvalue);*/
      break;
    case 0xF0:
    case 0xF4:
    case 0xF8:
    case 0xFC:
      /*FEE0-&FEFF (TUBE)*/
      /*tubewrite(naddress,nvalue);*/
      break;
  }
  R6502_EXECUTE_STEP(w)
  return w;
}
