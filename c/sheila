void sheilareset(R6502HOSTMAP* map)
{
  const int slow_mask = 0x0F00FF0F;
  int i,j;
  R6502BUSOP* read_fork = &r6502_high_read_fork[0x200];
  R6502BUSOP* write_fork = &r6502_high_write_fork[0x200];

  /*&FE00 - &FE07 (CRTC)*/
  for (i=0x00; i<0x08; i+=0x02)
  {
    read_fork[i] = crtc00read;
    read_fork[i+1] = crtc01read;
    write_fork[i] = crtc00write;
    write_fork[i+1] = crtc01write;
  }

  /*&FE08 - &FE0F (ACIA)*/
  for (i=0x08; i<0x10; i+=0x02)
  {
    read_fork[i] = acia00read;
    read_fork[i+1] = acia01read;
    write_fork[i] = acia00write;
    write_fork[i+1] = acia01write;
  }

  /*&FE10 - &FE17 (SERIALULA)*/
  for (i=0x10; i<0x18; i+=0x01)
  {
    read_fork[i] = serialularead;
    write_fork[i] = serialulawrite;
  }

  if (beebit_machinetype == MACHINE_MASTER128 || beebit_machinetype == MACHINE_COMPACT)
  {
    /*&FE18 - &FE1F (ADC)*/
    for (i=0x18; i<0x20; i+=0x04)
    {
      read_fork[i] = adc00read;
      read_fork[i+1] = adc01read;
      read_fork[i+2] = adc02read;
      read_fork[i+3] = adc02read;
      write_fork[i] = adcwrite;
      write_fork[i+1] = adcwrite;
      write_fork[i+2] = adcwrite;
      write_fork[i+3] = adcwrite;
    }
  }
  else
  {
    /*&FE18 - &FE1F (ECONET STATION NUMBER/INTOFF)*/
    for (i=0x18; i<0x20; i+=0x01)
    {
      read_fork[i] = hostconstantreadFE;
      write_fork[i] = hostnowrite;
    }
  }

  if (beebit_machinetype == MACHINE_MASTER128 || beebit_machinetype == MACHINE_COMPACT)
  {
    /*&FE20 - &FE23 (VIDEOULA)*/
    for (i=0x20; i<0x24; i+=0x02)
    {
      read_fork[i] = hostconstantread00;
      read_fork[i+1] = hostconstantread00;
      write_fork[i] = videoula00write;
      write_fork[i+1] = videoula01write;
    }
    /*&FE24 - &FE27 (FDC INTERFACE CONTROL REG)*/
    for (i=0x24; i<0x28; i+=0x01)
    {
      read_fork[i] = w1770controlread;
      write_fork[i] = w1770controlwrite_m;
    }
    /*&FE28 - &FE2F (FDC INTERFACE)*/
    for (i=0x28; i<0x30; i+=0x04)
    {
      read_fork[i] = w1770statusread;
      read_fork[i+1] = w1770trackread;
      read_fork[i+2] = w1770sectorread;
      read_fork[i+3] = w1770dataread;
      write_fork[i] = w1770commandwrite;
      write_fork[i+1] = w1770trackwrite;
      write_fork[i+2] = w1770sectorwrite;
      write_fork[i+3] = w1770datawrite;
    }
  }
  else
  {
    /*&FE20 - &FE2F (VIDEOULA/INTON)*/
    for (i=0x20; i<0x30; i+=0x02)
    {
      read_fork[i] = hostconstantreadFE;
      read_fork[i+1] = hostconstantreadFE;
      write_fork[i] = videoula00write;
      write_fork[i+1] = videoula01write;
    }
  }

  if (beebit_machinetype == MACHINE_MASTER128 || beebit_machinetype == MACHINE_COMPACT)
  {
    /*&FE30 - &FE33 (ROMSEL)*/
    for (i=0x30; i<0x34; i++)
    {
      read_fork[i] = romselread;
      write_fork[i] = romselwrite_m;
    }
    /*&FE34 - &FE37 (ACCCON)*/
    for (i=0x34; i<0x38; i++)
    {
      read_fork[i] = accconread;
      write_fork[i] = accconwrite_m;
    }
    /*&FE38 - &FE3B (INTOFF)*/
    for (i=0x38; i<0x3C; i++)
    {
      read_fork[i] = hostconstantread00;
      write_fork[i] = hostnowrite;
    }
    /*&FE3C - &FE3F (INTON)*/
    for (i=0x3C; i<0x40; i++)
    {
      read_fork[i] = hostconstantread00;
      write_fork[i] = hostnowrite;
    }
  }
  else if (beebit_machinetype == MACHINE_MODELBPLUS)
  {
    for (j=0x30; j<0x40; j+=0x08)
    {
      /*&FE30 - &FE33 (ROMSEL)*/
      for (i=0x00; i<0x04; i++)
      {
        read_fork[j+i] = romselread;
        write_fork[j+i] = romselwrite_bp;
      }
      /*&FE34 - &FE37 (ACCCON)*/
      for (i=0x04; i<0x08; i++)
      {
        read_fork[j+i] = accconread;
        write_fork[j+i] = accconwrite_bp;
      }
    }
  }
  else
  {
    /*&FE30 - &FE3F (ROMSEL)*/
    for (i=0x30; i<0x40; i++)
    {
      read_fork[i] = romselread;
      write_fork[i] = romselwrite_b;
    }
  }

  /*&FE40-&FE5F*/
  for (i=0x40; i<0x60; i+=0x10)
  {
    read_fork[i] = systemvia00read;
    read_fork[i+0x02] = systemvia02read;
    read_fork[i+0x03] = systemvia03read;
    read_fork[i+0x04] = systemvia04read;
    read_fork[i+0x05] = systemvia05read;
    read_fork[i+0x06] = systemvia06read;
    read_fork[i+0x07] = systemvia07read;
    read_fork[i+0x08] = systemvia08read;
    read_fork[i+0x09] = systemvia09read;
    read_fork[i+0x0A] = systemvia0Aread;
    read_fork[i+0x0B] = systemvia0Bread;
    read_fork[i+0x0C] = systemvia0Cread;
    read_fork[i+0x0D] = systemvia0Dread;
    read_fork[i+0x0E] = systemvia0Eread;
    write_fork[i+0x02] = systemvia02write;
    write_fork[i+0x03] = systemvia03write;
    write_fork[i+0x04] = systemvia04write;
    write_fork[i+0x05] = systemvia05write;
    write_fork[i+0x06] = systemvia06write;
    write_fork[i+0x07] = systemvia07write;
    write_fork[i+0x08] = systemvia08write;
    write_fork[i+0x09] = systemvia09write;
    write_fork[i+0x0A] = systemvia0Awrite;
    write_fork[i+0x0B] = systemvia0Bwrite;
    write_fork[i+0x0C] = systemvia0Cwrite;
    write_fork[i+0x0D] = systemvia0Dwrite;
    write_fork[i+0x0E] = systemvia0Ewrite;
    if (beebit_machinetype == MACHINE_MASTER128 || beebit_machinetype == MACHINE_COMPACT)
    {
      read_fork[i+0x01] = systemvia01read_m;
      read_fork[i+0x0F] = systemvia0Fread_m;
      write_fork[i] = systemvia00write_m;
      write_fork[i+0x01] = systemvia01write_m;
      write_fork[i+0x0F] = systemvia0Fwrite_m;
    }
    else
    {
      read_fork[i+0x01] = systemvia01read_b;
      read_fork[i+0x0F] = systemvia0Fread_b;
      write_fork[i] = systemvia00write_b;
      write_fork[i+0x01] = systemvia01write_b;
      write_fork[i+0x0F] = systemvia0Fwrite_b;
    }
  }

  /*&FE60-&FE7F*/
  for (i=0x60; i<0x80; i+=0x10)
  {
    read_fork[i] = uservia00read;
    read_fork[i+0x01] = uservia01read;
    read_fork[i+0x02] = uservia02read;
    read_fork[i+0x03] = uservia03read;
    read_fork[i+0x04] = uservia04read;
    read_fork[i+0x05] = uservia05read;
    read_fork[i+0x06] = uservia06read;
    read_fork[i+0x07] = uservia07read;
    read_fork[i+0x08] = uservia08read;
    read_fork[i+0x09] = uservia09read;
    read_fork[i+0x0A] = uservia0Aread;
    read_fork[i+0x0B] = uservia0Bread;
    read_fork[i+0x0C] = uservia0Cread;
    read_fork[i+0x0D] = uservia0Dread;
    read_fork[i+0x0E] = uservia0Eread;
    read_fork[i+0x0F] = uservia0Fread;
    write_fork[i] = uservia00write;
    write_fork[i+0x01] = uservia01write;
    write_fork[i+0x02] = uservia02write;
    write_fork[i+0x03] = uservia03write;
    write_fork[i+0x04] = uservia04write;
    write_fork[i+0x05] = uservia05write;
    write_fork[i+0x06] = uservia06write;
    write_fork[i+0x07] = uservia07write;
    write_fork[i+0x08] = uservia08write;
    write_fork[i+0x09] = uservia09write;
    write_fork[i+0x0A] = uservia0Awrite;
    write_fork[i+0x0B] = uservia0Bwrite;
    write_fork[i+0x0C] = uservia0Cwrite;
    write_fork[i+0x0D] = uservia0Dwrite;
    write_fork[i+0x0E] = uservia0Ewrite;
    write_fork[i+0x0F] = uservia0Fwrite;
  }

  if (beebit_machinetype == MACHINE_MODELBPLUS)
  {
    /*&FE80-&FE9F (8271 or 1770)*/
    for (j=0x80; j<0xA0; j+=0x08)
    {
      /*&FE80 - &FE83 (FDC INTERFACE CONTROL REG)*/
      for (i=0x00; i<0x04; i+=0x01)
      {
        read_fork[j+i] = w1770controlread;
        write_fork[j+i] = w1770controlwrite_bp;
      }
      /*&FE84 - &FE87 (FDC INTERFACE)*/
      read_fork[j+0x04] = w1770statusread;
      read_fork[j+0x05] = w1770trackread;
      read_fork[j+0x06] = w1770sectorread;
      read_fork[j+0x07] = w1770dataread;
      write_fork[j+0x04] = w1770commandwrite;
      write_fork[j+0x05] = w1770trackwrite;
      write_fork[j+0x06] = w1770sectorwrite;
      write_fork[j+0x07] = w1770datawrite;
    }
  }
  else if (beebit_machinetype == MACHINE_MODELB)
  {
    /*&FE80-&FE9F (8271 or 1770)*/
    for (j=0x80; j<0xA0; j+=0x08)
    {
      read_fork[j] = i8271statusread;
      read_fork[j+1] = i8271resultread;
      read_fork[j+2] = hostconstantreadFE;
      read_fork[j+3] = hostconstantreadFE;
      write_fork[j] = i8271commandwrite;
      write_fork[j+1] = i8271parameterwrite;
      write_fork[j+2] = i8271resetwrite;
      write_fork[j+3] = hostnowrite;

      for (i=0x04; i<0x08; i+=0x01)
      {
        read_fork[j+i] = i8271dataread;
        write_fork[j+i] = i8271datawrite;
      }
    }
  }
  else
  {
    for (i=0x80; i<0xA0; i+=0x01)
    {
      read_fork[i] = hostconstantread00;
      write_fork[i] = hostnowrite;
    }
  }

  /*&FEA0-&FEBF (ECONET)*/
  for (i=0xA0; i<0xC0; i+=0x01)
  {
    read_fork[i] = hostconstantreadFE;
    write_fork[i] = hostnowrite;
  }

  if (beebit_machinetype == MACHINE_MASTER128 || beebit_machinetype == MACHINE_COMPACT)
  {
    /*&FEC0-&FEDF (ECONET)*/
    for (i=0xC0; i<0xE0; i++)
    {
      read_fork[i] = hostconstantreadFF;
      write_fork[i] = hostnowrite;
    }
  }
  else
  {
    /*FEC0-&FEDF (ADC)*/
    for (i=0xC0; i<0xE0; i+=0x04)
    {
      read_fork[i] = adc00read;
      read_fork[i+1] = adc01read;
      read_fork[i+2] = adc02read;
      read_fork[i+3] = adc02read;
      write_fork[i] = adcwrite;
      write_fork[i+1] = adcwrite;
      write_fork[i+2] = adcwrite;
      write_fork[i+3] = adcwrite;
    }
  }

  /*FEE0-&FEFF (TUBE)*/
  if (beebit_machinetype == MACHINE_MASTER128 || beebit_machinetype == MACHINE_COMPACT)
  {
    for (i=0xE0; i<0x100; i+=0x01)
    {
      read_fork[i] = hostconstantreadFF;
      write_fork[i] = hostnowrite;
    }
  }
  else
  {
    for (i=0xE0; i<0x100; i+=0x01)
    {
      read_fork[i] = hostconstantreadFE;
      write_fork[i] = hostnowrite;
    }
  }

  memcpy(&r6502_high_stretched_read_fork[0x200], read_fork, sizeof(R6502BUSOP)<<8);
  memcpy(&r6502_high_stretched_write_fork[0x200], write_fork, sizeof(R6502BUSOP)<<8);

  for (i=0; i<0x100; i++)
  {
    if (slow_mask & (1<<(i>>3)))
    {
      read_fork[i] = r6502startreadstretch;
      write_fork[i] = r6502startwritestretch;
    }
  }
}

R6502HOSTMAP* hostconstantread00(R6502HOSTMAP* map, unsigned int address_code)
{
  map->m = 0x00;
  return map;
}

R6502HOSTMAP* hostconstantreadFE(R6502HOSTMAP* map, unsigned int address_code)
{
  map->m = 0xFE;
  return map;
}

R6502HOSTMAP* hostconstantreadFF(R6502HOSTMAP* map, unsigned int address_code)
{
  map->m = 0xFF;
  return map;
}

R6502HOSTMAP* romselread(R6502HOSTMAP* map, unsigned int address_code)
{
  map->m = map->romsel;
  return map;
}

R6502HOSTMAP* accconread(R6502HOSTMAP* map, unsigned int address_code)
{
  map->m = map->acccon;
  return map;
}

R6502HOSTMAP* hostnowrite(R6502HOSTMAP* map, unsigned int address_code)
{
  return map;
}

R6502HOSTMAP* romselwrite_b(R6502HOSTMAP* map, unsigned int address_code)
{
  int nrom = (map->m & 0x0F);
  map->s4forks[0x0B].busop = map->s4forks[0x0A].busop
      = map->s4forks[0x09].busop = map->s4forks[0x08].busop = map->read8000s[nrom];
  map->s4forks[0x1B].busop = map->s4forks[0x1A].busop
      = map->s4forks[0x19].busop = map->s4forks[0x18].busop = map->write8000s[nrom];
  map->romsel = map->m;
  return map;
}

R6502HOSTMAP* romselwrite_bp(R6502HOSTMAP* map, unsigned int address_code)
{
  int nrom = (map->m & 0x0F);
  if (map->m & 0x80)
  {
    /*ROMSEL b7 (RAM) (&8000-&AFFF)*/
    map->s4forks[0x0A].busop = map->s4forks[0x09].busop
        = map->s4forks[0x08].busop = map->s2paging.read8000_ram;
    map->s4forks[0x1A].busop = map->s4forks[0x19].busop
        = map->s4forks[0x18].busop = map->s2paging.write8000_ram;
    if (map->acccon & 0x80)
    {
      /*ACCCON b7 (VDUSEL) (&3000-&7FFF)*/
      map->s4forks[0x07].busop = map->s4forks[0x06].busop
      = map->s4forks[0x05].busop = map->s4forks[0x04].busop
      = map->s4forks[0x03].busop = map->s2paging.read3000_ramram;
      map->s4forks[0x17].busop = map->s4forks[0x16].busop
      = map->s4forks[0x15].busop = map->s4forks[0x14].busop
      = map->s4forks[0x13].busop = map->s2paging.write3000_ramram;
    }
  }
  else
  {
    map->s4forks[0x0A].busop = map->s4forks[0x09].busop
        = map->s4forks[0x08].busop = map->read8000s[nrom];
    map->s4forks[0x1A].busop = map->s4forks[0x19].busop
        = map->s4forks[0x18].busop = map->write8000s[nrom];
    if (map->acccon & 0x80)
    {
      /*ACCCON b7 (VDUSEL) (&3000-&7FFF)*/
      map->s4forks[0x07].busop = map->s4forks[0x06].busop
      = map->s4forks[0x05].busop = map->s4forks[0x04].busop
      = map->s4forks[0x03].busop = map->s2paging.read3000_ram;
      map->s4forks[0x17].busop = map->s4forks[0x16].busop
      = map->s4forks[0x15].busop = map->s4forks[0x14].busop
      = map->s4forks[0x13].busop = map->s2paging.write3000_ram;
    }
  }
  map->s4forks[0x0B].busop = map->read8000s[nrom];
  map->s4forks[0x1B].busop = map->write8000s[nrom];
  map->romsel = map->m;
  return map;
}

R6502HOSTMAP* romselwrite_m(R6502HOSTMAP* map, unsigned int address_code)
{
  int nrom = (map->m & 0x0F);
  if (map->m & 0x80)
  {
    /*ROMSEL b7 (RAM) (&8000-&8FFF)*/
    map->s4forks[0x08].busop = map->s2paging.read8000_ram;
    map->s4forks[0x18].busop = map->s2paging.write8000_ram;
  }
  else
  {
    map->s4forks[0x08].busop = map->read8000s[nrom];
    map->s4forks[0x18].busop = map->write8000s[nrom];
  }
  map->s4forks[0x0B].busop = map->s4forks[0x0A].busop
      = map->s4forks[0x09].busop = map->read8000s[nrom];
  map->s4forks[0x1B].busop = map->s4forks[0x1A].busop
      = map->s4forks[0x19].busop = map->write8000s[nrom];
  map->romsel = map->m;
  return map;
}

R6502HOSTMAP* accconwrite_bp(R6502HOSTMAP* map, unsigned int address_code)
{
  if (map->m & 0x80)
  {
    /*ACCCON b7 (VDUSEL) (&3000-&7FFF)*/
    if (map->romsel & 0x80)
    {
      /*ROMSEL b7 (RAM) (&8000-&AFFF)*/
      map->s4forks[0x07].busop = map->s4forks[0x06].busop
      = map->s4forks[0x05].busop = map->s4forks[0x04].busop
      = map->s4forks[0x03].busop = map->s2paging.read3000_ramram;
      map->s4forks[0x17].busop = map->s4forks[0x16].busop
      = map->s4forks[0x15].busop = map->s4forks[0x14].busop
      = map->s4forks[0x13].busop = map->s2paging.write3000_ramram;
    }
    else
    {
      map->s4forks[0x07].busop = map->s4forks[0x06].busop
      = map->s4forks[0x05].busop = map->s4forks[0x04].busop
      = map->s4forks[0x03].busop = map->s2paging.read3000_ram;
      map->s4forks[0x17].busop = map->s4forks[0x16].busop
      = map->s4forks[0x15].busop = map->s4forks[0x14].busop
      = map->s4forks[0x13].busop = map->s2paging.write3000_ram;
    }
  }
  else
  {
    map->s4forks[0x07].busop = map->s4forks[0x06].busop
        = map->s4forks[0x05].busop = map->s4forks[0x04].busop
        = map->s4forks[0x03].busop = map->s2paging.read3000;
    map->s4forks[0x17].busop = map->s4forks[0x16].busop
        = map->s4forks[0x15].busop = map->s4forks[0x14].busop
        = map->s4forks[0x13].busop = map->s2paging.write3000;
  }
  map->acccon = map->m;
  return map;
}

R6502HOSTMAP* accconwrite_m(R6502HOSTMAP* map, unsigned int address_code)
{
  switch (map->m & 0x06)
  {
    case 0x00:
      /*RAM*/
      map->s4forks[0x07].busop = map->s4forks[0x06].busop
          = map->s4forks[0x05].busop = map->s4forks[0x04].busop
          = map->s4forks[0x03].busop = map->s2paging.read3000;
      map->s4forks[0x17].busop = map->s4forks[0x16].busop
          = map->s4forks[0x15].busop = map->s4forks[0x14].busop
          = map->s4forks[0x13].busop = map->s2paging.write3000;
      break;
    case 0x02:
      /*ACCCON b1 (E)*/
      map->s4forks[0x07].busop = map->s4forks[0x06].busop
          = map->s4forks[0x05].busop = map->s4forks[0x04].busop
          = map->s4forks[0x03].busop = map->s2paging.read3000_e;
      map->s4forks[0x17].busop = map->s4forks[0x16].busop
          = map->s4forks[0x15].busop = map->s4forks[0x14].busop
          = map->s4forks[0x13].busop = map->s2paging.write3000_e;
      break;
    case 0x04:
    case 0x06:
      /*ACCCON b2 (X)*/
      map->s4forks[0x07].busop = map->s4forks[0x06].busop
          = map->s4forks[0x05].busop = map->s4forks[0x04].busop
          = map->s4forks[0x03].busop = map->s2paging.read3000_x;
      map->s4forks[0x17].busop = map->s4forks[0x16].busop
          = map->s4forks[0x15].busop = map->s4forks[0x14].busop
          = map->s4forks[0x13].busop = map->s2paging.write3000_x;
      break;
  }
  if (map->m & 0x08)
  {
    /*ACCCON b3 (Y)*/
    /*&C000-&DFFF*/
    map->s4forks[0x0D].busop = map->s4forks[0x0C].busop = map->s2paging.readC000_y;
    map->s4forks[0x1D].busop = map->s4forks[0x1C].busop = map->s2paging.writeC000_y;
  }
  else
  {
    /*&C000-&DFFF*/
    map->s4forks[0x0D].busop = map->s4forks[0x0C].busop = map->s4forks[0x0E].busop;
    map->s4forks[0x1D].busop = map->s4forks[0x1C].busop = map->s4forks[0x1E].busop;
  }

  if (map->m & 0x80)
  {
    /*IRR*/
    r6502startinterrupt(&hostmap);
    map->m &= 0x7F;
  }
  map->acccon = map->m;
  return map;
}
