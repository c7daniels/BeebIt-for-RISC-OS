R6502WORKSPACE* r65c12bitfromimmediatestep(R6502WORKSPACE* w)
{
  unsigned int aandm = w->a & w->m;
  w->ps &= ~ZFLAG;
  w->ps |= (aandm == 0 ? ZFLAG : 0);
  R6502_IMMEDIATE_FINISHED(w)
  return w;
}

R6502WORKSPACE* r65c12adcfromimmediatestep(R6502WORKSPACE* w)
{
  unsigned int m = w->m;
  unsigned int a = w->a;
  unsigned int sum;
  m = ((m<<4)&0xF00) | (m&0xF);
  a = ((a<<4)&0xF00) | (a&0xF);
  sum = a + 0x0F0 + m + (w->ps & CFLAG);
  w->ps &= (NOTNFLAG & NOTVFLAG & NOTZFLAG & NOTCFLAG);
  w->ps |= ((sum & 0xF0F) == 0 ? ZFLAG : 0);
  if (w->ps & DFLAG)
    sum += 6;
  w->ps |= ((sum>>4) & NFLAG) | ((((sum ^ a) & (sum ^ m))>>5) & VFLAG);
  if (w->ps & DFLAG)
  {
    if (sum & 0x80)
      sum -= 6;
    if (sum >= 0xA00)
      sum += 0x600;
    w->cpu_state++;
  }
  else
    R6502_IMMEDIATE_FINISHED(w)
  if (sum >= 0x1000)
    w->ps |= CFLAG;
  w->a = ((sum>>4)&0xF0) | (sum&0xF);
  return w;
}

