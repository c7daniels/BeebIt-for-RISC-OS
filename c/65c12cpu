  if ((w->address_code & 0x00FF0000) == 0)
  {
    w->address_code = (w->address_code+0x01000000) & 0xFFFFFFFF;
  }
  w->cpu_state++;
  return w;
}

R6502WORKSPACE* r65c12fixjmpabsxindstep(R6502WORKSPACE* w)
{
  w->address_code = w->latch;
  w->cpu_state += 4;
  return w;
}

