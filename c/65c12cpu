R6502WORKSPACE* swappagesintomemorym(R6502WORKSPACE* w)
{
  int nrom;
  unsigned int pc = (w->pc_code>>16);

  if ((w->acccon & 0x04)
    OR ((w->acccon & 0x02) AND pc >= 0xC000 AND pc < 0xE000))
  {
    swappages(&memory[0x3000],&shadow[0x3000],0x50);
  }

  nrom = w->romsel & 0x0F;
  if (w->romsel & 0x80)
  {
    memcpy(&memory[0x8000],shadow,0x1000);
    memcpy(&memory[0x9000],&roms[nrom][0x1000],0x3000);
  }
  else
    memcpy(&memory[0x8000],roms[nrom],0x4000);

  if (w->acccon & 0x04)
    swappages(&memory[0xC000],&shadow[0x1000],0x20);

  return w;
}

R6502WORKSPACE* swappagesoutofmemorym(R6502WORKSPACE* w)
{
  int nrom;
  unsigned int pc = (w->pc_code>>16);

  if ((w->acccon & 0x04)
    OR ((w->acccon & 0x02) AND pc >= 0xC000 AND pc < 0xE000))
  {
    swappages(&memory[0x3000],&shadow[0x3000],0x50);
  }

  nrom = w->romsel & 0x0F;
  if (w->romsel & 0x80)
  {
    memcpy(shadow,&memory[0x8000],0x1000);
    if (w->romwritable[nrom])
      memcpy(&roms[nrom][0x1000],&memory[0x9000],0x1000);
  }
  else
  {
    if (w->romwritable[nrom])
      memcpy(roms[nrom],&memory[0x8000],0x4000);
  }

  if (w->acccon & 0x04)
    swappages(&memory[0xC000],&shadow[0x1000],0x20);

  return w;
}

