int r65c12reset(R6502WORKSPACE* w)
{
  int lreturn;

  /*w->a = 0;
  w->x = 0;
  w->y = 0;*/
  w->pc_code = BUS_BASEFLAG;
  w->sp_code = (0xFF000001) | (BUS_BASEFLAG<<8);
  w->ps = UFLAG | BFLAG;

  r6502resetbusfork(w);
  r6502resetreadsandwrite8000s(w);

  w->read3000 = r6502read3000;
  w->write3000 = r6502write3000;
  w->read3000_ram = NULL;
  w->write3000_ram = NULL;
  w->read3000_e = r6502readm3000_e;
  w->write3000_e = r6502writem3000_e;
  w->read3000_x = r6502readm3000_x;
  w->write3000_x = r6502writem3000_x;
  w->read8000_ram = r6502readm8000_ram;
  w->write8000_ram = r6502writem8000_ram;
  w->readC000_y = r6502readmC000_y;
  w->writeC000_y = r6502writemC000_y;

  w->swappagesintomemory = swappagesintomemorym;
  w->swappagesoutofmemory = swappagesoutofmemorym;

  r6502resethighforks(w,
      r6502readmFC00, r6502writemFC00,
      r6502readmFD00, r6502writemFD00,
      sheilareadsm, sheilawritesm);

  lreturn = r6502setcpuops(w, r65c12sequences);

  w->transition1action = w->fetchaction;
  w->transition2action = w->fetchaction;
  w->timesinterruptmissed = 0;

  w->cpu_state = R6502_FIRST_STEP_IN(R6502_RESET_SEQUENCE);
  w->address_code = (w->address_code & 0xFFFF0000) | BUS_BASEFLAG;

  return lreturn;
}
