R6502WORKSPACE* r65c12pushedtoresetlostep(R6502WORKSPACE* w)
{
  w->sp_code = (w->sp_code - 0x1000000) & 0xFFFFFFFF;
  w->ps &= NOTDFLAG;
  w->ps |= IFLAG;
  w->address_code = 0xFFFC0000 | BUS_BASEFLAG;
  w->transition1action = w->transition2action;
  R6502_CHECK_FOR_BREAK(w)
  w->cpu_state++;
  return w;
}

R6502WORKSPACE* r65c12pushedtointerruptlostep(R6502WORKSPACE* w)
{
  w->sp_code = (w->sp_code - 0x1000000) & 0xFFFFFFFF;
  w->ps &= NOTDFLAG;
  w->ps |= IFLAG;
  if ((w->nmis & NMIS_NMI) && !(w->nmis & NMIS_OLDNMI))
  {
    w->nmis |= NMIS_OLDNMI;
    w->address_code = 0xFFFA0000 | BUS_BASEFLAG;
  }
  else
    w->address_code = 0xFFFE0000 | BUS_BASEFLAG;
  w->transition1action = w->transition2action;
  R6502_CHECK_FOR_BREAK(w)
  w->cpu_state++;
  return w;
}

R6502WORKSPACE* r65c12pushedtobrklostep(R6502WORKSPACE* w)
{
  w->sp_code = (w->sp_code - 0x1000000) & 0xFFFFFFFF;
  w->ps &= NOTDFLAG;
  w->ps |= IFLAG;
  w->address_code = 0xFFFE0000 | BUS_BASEFLAG;
  w->cpu_state++;
  return w;
}
