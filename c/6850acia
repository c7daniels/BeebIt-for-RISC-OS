/*counter divide poll speed in 1MHz cycles (bits 0-15)*/
int m6850_pollspeed01[0x10] = {0,52,105,156,208,260,312,365,417,469,521,573,625,677,729,781};
int m6850_pollspeed16[0x10] = {0,833,1667,2500,3333,4167,5000,5833,6667,7500,8333,9167,10000,10833,11667,12500};
int m6850_pollspeed64[0x10] = {0,3333,6667,10000,13333,16667,20000,23333,26667,30000,33333,36667,40000,43333,46667,50000};

/*int serialula_baudrate[8] = {19200,1200,4800,150,9600,300,2400,75};*/

char uef_buffer[0xFF];

void aciareset(void)
{
  HOSTMAP* htop = (HOSTMAP*)&hostmap.upper;

  htop[-1].A_serial.m6850_controlreg = 0x00;
  htop[-1].A_serial.m6850_rxdatareg = 0x00;
  htop[-1].A_serial.m6850_txdatareg = 0x00;
  htop[-1].A_serial.m6850_rxdatashiftreg = 0x00;
  htop[-1].A_serial.m6850_txdatashiftreg = 0x00;

  htop[-1].A_serial.m6850_statusreg = 0x00;
  htop[-1].B_serial.m6850_CTS = htop[-1].B_serial.m6850_RTS = htop[-1].B_serial.m6850_DCD = FALSE;

  htop[-1].B_serial.m6850_counterdivide = 0x00;
  htop[-1].B_serial.m6850_bits = htop[-1].B_serial.m6850_parity = htop[-1].B_serial.m6850_stop = 0x00;
  htop[-1].B_serial.m6850_transmittingRTS = FALSE;
  htop[-1].B_serial.m6850_transmittingIRQ = FALSE;

  htop[-1].B_serial.m6850_cleardcd = 0;
  htop[-1].B_serial.m6850_timerreset = m6850_pollspeed64[9]; /*300 baud*/
  htop[-1].cycles.m6850_togo = 0;

  htop[-1].B_serial.m6850_firstreset = TRUE;

  htop[-1].A_serial.ula_reg = 0x00;
  htop[-1].B_serial.ula_txbaud = 0x00;
  htop[-1].B_serial.ula_rxbaud = 0x00;

  *((long*)&htop[-1].B_serial.uef_filepointerarea) = 12;
  htop[-1].B_serial.uef_buffer = uef_buffer;
  htop[-1].B_serial.uef_bufferpointer = 0;
}

void aciasetirq(void)
{
  HOSTMAP* htop = (HOSTMAP*)&hostmap.upper;
  if (htop[-1].A_serial.m6850_statusreg & 0x80 AND htop[-1].A_serial.m6850_controlreg & 0x80)
    HOST_SETSHIFTEDIRQ(htop, HOST_IRQ_6850ACIA)
  else
    HOST_CLEARSHIFTEDIRQ(htop, HOST_IRQ_6850ACIA)
}

void aciadcdhigh(void)
{
  HOSTMAP* htop = (HOSTMAP*)&hostmap.upper;
  htop[-1].A_serial.m6850_statusreg |= 0x84; /*dcd, irq*/
  aciasetirq();
}

void aciadcdlow(void)
{
  HOSTMAP* htop = (HOSTMAP*)&hostmap.upper;
  htop[-1].A_serial.m6850_statusreg &= 0xFB; /*not dcd*/
  htop[-1].A_serial.m6850_statusreg |= 0x80; /*irq*/
  aciasetirq();
}

void aciareceive(char nbyte)
{
  HOSTMAP* htop = (HOSTMAP*)&hostmap.upper;

  htop[-1].A_serial.m6850_rxdatareg = nbyte;

  htop[-1].A_serial.m6850_statusreg |= 0x81; /*receive, irq*/
  aciasetirq();
}

HOSTMAP* aciapoll(HOSTMAP* htop)
{
  if (htop[-1].A_serial.ula_reg & 0x80)
  {
    /*motor on*/
    /*printf("MOTOR ON\n");*/

    if (!(htop[-1].A_serial.m6850_statusreg & 0x01))
      uefread();
  }

  htop[-1].cycles.m6850_togo = htop[-1].B_serial.m6850_timerreset<<1;

  return htop;
}

void aciaresettimer(void)
{
  HOSTMAP* htop = (HOSTMAP*)&hostmap.upper;
  intptr_t bits;

  if (beebit_fasttape)
    htop[-1].B_serial.m6850_timerreset = 800; /*1000;*/
  else
  {
    bits = htop[-1].B_serial.m6850_bits + htop[-1].B_serial.m6850_stop;
    if (htop[-1].B_serial.m6850_parity != PARITY_NONE)
      bits++;
    switch (htop[-1].A_serial.m6850_controlreg & 0x03)
    {
      case 0x00:
        /*19200 baud*/
        htop[-1].B_serial.m6850_timerreset = m6850_pollspeed01[bits]; /*19200 baud*/
        break;
      case 0x01:
        /*1200 baud*/
        htop[-1].B_serial.m6850_timerreset = m6850_pollspeed16[bits]; /*1200 baud*/
        break;
      case 0x02:
        /*300 baud*/
        htop[-1].B_serial.m6850_timerreset = m6850_pollspeed64[bits]; /*300 baud*/
        break;
    }
  }
}

struct R6502CPUMAP* acia00read(struct R6502CPUMAP* ctop, uintptr_t address_code)
{
  HOSTMAP* htop = (HOSTMAP*)ctop;
  if (htop[-1].A_serial.m6850_statusreg & 0x02)
  {
    if (htop[-1].B_serial.m6850_cleardcd > 0)
      htop[-1].B_serial.m6850_cleardcd = 2;
    else
    {
      htop[-1].B_serial.m6850_cleardcd--;
      if (htop[-1].B_serial.m6850_cleardcd == 0)
        htop[-1].A_serial.m6850_statusreg &= 0xFD; /*clear dcd*/
    }
  }
  htop[-1].m = (htop[-1].A_serial.m6850_statusreg);
  return ctop;
}

struct R6502CPUMAP* acia01read(struct R6502CPUMAP* ctop, uintptr_t address_code)
{
  /*clear irq*/
  HOSTMAP* htop = (HOSTMAP*)ctop;
  /*regs.r[0] = 0x04;*/ /*read byte*/
  /*_kernel_swi(OS_SerialOp,&regs,&regs);

   htop[-1].A_serial.m6850_rxdatareg = (regs.r[1] & 0xFF);*/

  htop[-1].A_serial.m6850_statusreg &= 0xFE;

  htop[-1].A_serial.m6850_statusreg &= 0x7F;
  HOST_CLEARIRQ(htop, HOST_IRQ_6850ACIA)

  htop[-1].m = (htop[-1].A_serial.m6850_rxdatareg);
  return ctop;
}

struct R6502CPUMAP* acia00write(struct R6502CPUMAP* ctop, uintptr_t address_code, uint8_t value)
{
  HOSTMAP* htop = (HOSTMAP*)ctop;
  htop[-1].A_serial.m6850_controlreg = value;
  if (!(htop[-1].A_serial.m6850_controlreg & 0x10))
  {
    htop[-1].B_serial.m6850_bits = 7;
    htop[-1].B_serial.m6850_parity = 2 - ((htop[-1].A_serial.m6850_controlreg & 0x04) >> 2);
    htop[-1].B_serial.m6850_stop = 2 - ((htop[-1].A_serial.m6850_controlreg & 0x08) >> 3);
  }
  else
  {
    htop[-1].B_serial.m6850_bits = 8;
    switch (htop[-1].A_serial.m6850_controlreg & 0x0C)
    {
      case 0x00:
        htop[-1].B_serial.m6850_parity = PARITY_NONE;
        htop[-1].B_serial.m6850_stop = 2;
        break;
      case 0x04:
        htop[-1].B_serial.m6850_parity = PARITY_NONE;
        htop[-1].B_serial.m6850_stop = 1;
        break;
      case 0x08:
        htop[-1].B_serial.m6850_parity = PARITY_EVEN;
        htop[-1].B_serial.m6850_stop = 1;
        break;
      case 0x0C:
        htop[-1].B_serial.m6850_parity = PARITY_ODD;
        htop[-1].B_serial.m6850_stop = 2;
        break;
    }
  }

  switch (htop[-1].A_serial.m6850_controlreg & 0x60)
  {
    case 0x00:
      htop[-1].B_serial.m6850_transmittingRTS = FALSE;
      htop[-1].B_serial.m6850_transmittingIRQ = FALSE;
      break;
    case 0x20:
      htop[-1].B_serial.m6850_transmittingRTS = FALSE;
      htop[-1].B_serial.m6850_transmittingIRQ = TRUE;
      break;
    case 0x40:
      htop[-1].B_serial.m6850_transmittingRTS = TRUE;
      htop[-1].B_serial.m6850_transmittingIRQ = FALSE;
      break;
    case 0x60:
      htop[-1].B_serial.m6850_transmittingRTS = FALSE;
      htop[-1].B_serial.m6850_transmittingIRQ = FALSE;
      break;
  }

  switch (htop[-1].A_serial.m6850_controlreg & 0x03)
  {
    case 0x00:
      /*19200 baud*/
      htop[-1].B_serial.m6850_counterdivide = 1;
      aciaresettimer();
      break;
    case 0x01:
      /*1200 baud*/
      htop[-1].B_serial.m6850_counterdivide = 16;
      aciaresettimer();
      break;
    case 0x02:
      /*300 baud*/
      htop[-1].B_serial.m6850_counterdivide = 64;
      aciaresettimer();
      break;
    case 0x03:
      /*master reset*/
      /*aciareset();*/
      if (htop[-1].B_serial.m6850_firstreset)
      {
        /*set IRQ to level 1*/
        /*htop[-1].B_serial.m6850_CTS = TRUE;*/
        htop[-1].B_serial.m6850_RTS = TRUE;
        /*htop[-1].A_serial.m6850_statusreg |= 0x08;*/ /*CTS*/
        htop[-1].B_serial.m6850_firstreset = FALSE;
      }
      else
      {
        htop[-1].B_serial.m6850_RTS = htop[-1].B_serial.m6850_transmittingRTS;
      }
      /*clear RDRF*/
      htop[-1].A_serial.m6850_statusreg &= 0xFE;
      /*clear irq*/
      htop[-1].A_serial.m6850_statusreg &= 0x7F;
      HOST_CLEARIRQ(htop, HOST_IRQ_6850ACIA)
      break;
  }
  return ctop;
}

struct R6502CPUMAP* acia01write(struct R6502CPUMAP* ctop, uintptr_t address_code, uint8_t value)
{
  /*transmit data register*/
  HOSTMAP* htop = (HOSTMAP*)ctop;
  htop[-1].A_serial.m6850_txdatareg = value;
  htop[-1].A_serial.m6850_statusreg &= 0xFD; /*TDRE*/
  /*clear irq*/
  htop[-1].A_serial.m6850_statusreg &= 0x7F;
  HOST_CLEARIRQ(htop, HOST_IRQ_6850ACIA)
  return ctop;
}

/*-- SERIAL ULA --*/

struct R6502CPUMAP* serialularead(struct R6502CPUMAP* ctop, uintptr_t address_code)
{
  HOSTMAP* htop = (HOSTMAP*)ctop;
  htop[-1].m = (htop[-1].A_serial.ula_reg);
  return ctop;
}

struct R6502CPUMAP* serialulawrite(struct R6502CPUMAP* ctop, uintptr_t address_code, uint8_t value)
{
  HOSTMAP* htop = (HOSTMAP*)ctop;
  intptr_t cyclecount;
  htop[-1].A_serial.ula_reg = value;

  htop[-1].B_serial.ula_txbaud = (htop[-1].A_serial.ula_reg & 0x07);
  htop[-1].B_serial.ula_rxbaud = ((htop[-1].A_serial.ula_reg & 0x38) >> 3);

  if (htop[-1].A_serial.ula_reg & 0x40)
  {
    /*RS423*/
    /*clear DCD*/
    htop[-1].A_serial.m6850_statusreg &= 0xFB;
  }
  else
  {
    /*TAPE*/
    /*clear CTS*/
    htop[-1].A_serial.m6850_statusreg &= 0xF7;
  }

  if (htop[-1].A_serial.ula_reg & 0x80)
  {
    /*TAPE*/
    if (htop[-1].cycles.m6850_togo == 0 && htop[-1].B_serial.m6850_timerreset > 0)
    {
      htop[-1].cycles.m6850_togo = htop[-1].B_serial.m6850_timerreset<<1;
      HOST_GET_TOGO_FROM_WRITE_OFFSET(cyclecount, htop)
      htop[-1].cycles.m6850_togo += 1 + cyclecount;
      HOST_LIMIT_CYCLES_TO_GO(htop, htop[-1].cycles.m6850_togo)
    }
  }
  else
    /*RS423*/
    htop[-1].cycles.m6850_togo = 0;
  return ctop;
}

/*-- UEF --*/

int uefvalidate(FILE *hfile)
{
  int nreturn;
  if (hfile == NULL)
    nreturn = FALSE;
  else
  {
    /*reset file pointer*/
    fseek(hfile,0,SEEK_SET);
    /*check header*/
    if (fread(uef_buffer,1,10,hfile))
    {
      if (strcmp(uef_buffer, "UEF File!") == 0)
        nreturn = TRUE;
      else
        nreturn = FALSE;
    }
    else
      nreturn = FALSE;
  }
  return (nreturn);
}

int uefopen(void)
{
  HOSTMAP* htop = (HOSTMAP*)&hostmap.upper;
  long uef_filepointer;
  int nreturn;

  htop[-1].B_serial.uef_chunk = -1;
  htop[-1].B_serial.uef_chunklen = 0;
  htop[-1].B_serial.uef_chunkstart = FALSE;
  htop[-1].B_serial.uef_tone = 0;

  beebit_tapeimage = fopen(beebit_uefimage, "rb");

  nreturn = uefvalidate(beebit_tapeimage);

  if (nreturn)
  {
    uef_filepointer = *(long*)&htop[-1].B_serial.uef_filepointerarea;
    fread(uef_buffer, 1, 2, beebit_tapeimage);
    htop[-1].B_serial.uef_version = (getword(uef_buffer) & 0xFFFF);
    fseek(beebit_tapeimage,uef_filepointer,SEEK_SET);
  }
  else
    fclose(beebit_tapeimage);

  return (nreturn);
}

void uefclose(void)
{
  HOSTMAP* htop = (HOSTMAP*)&hostmap.upper;

  if (beebit_tapeimage != NULL)
  {
    *((long*)&htop[-1].B_serial.uef_filepointerarea) = ftell(beebit_tapeimage);
    fclose(beebit_tapeimage);
  }
}

void uefrewind(void)
{
  HOSTMAP* htop = (HOSTMAP*)&hostmap.upper;

  *((long*)&htop[-1].B_serial.uef_filepointerarea) = 12;
  if (beebit_tapeimage != NULL)
    fseek(beebit_tapeimage,12,SEEK_SET);
}

void uefread(void)
{
  if (beebit_tapeimage == NULL)
    return;

  HOSTMAP* htop = (HOSTMAP*)&hostmap.upper;

  if (htop[-1].B_serial.uef_chunk == -1)
  {
    /*no chunk definied*/
    fread(uef_buffer, 1, 2, beebit_tapeimage);
    htop[-1].B_serial.uef_chunk = (getword(uef_buffer) & 0xFFFF);
    fread(uef_buffer, 1, 4, beebit_tapeimage);
    htop[-1].B_serial.uef_chunklen = getword(uef_buffer);
    htop[-1].B_serial.uef_chunkstart = TRUE;
  }

  switch (htop[-1].B_serial.uef_chunk)
  {
    case 0x00:
      /*origin information chunk*/
      fseek(beebit_tapeimage, htop[-1].B_serial.uef_chunklen, SEEK_CUR);
      htop[-1].B_serial.uef_chunk = -1;
      break;
    case 0x01:
      /*game information/manual*/
      fseek(beebit_tapeimage, htop[-1].B_serial.uef_chunklen, SEEK_CUR);
      htop[-1].B_serial.uef_chunk = -1;
      break;
    case 0x100:
      /*implicit start/stop bit tape data block*/
      if (htop[-1].B_serial.uef_chunkstart)
      {
        /*start of chunk*/
        if (htop[-1].B_serial.uef_chunklen < sizeof(uef_buffer))
          fread(uef_buffer, 1, htop[-1].B_serial.uef_chunklen, beebit_tapeimage);
        else
          fread(uef_buffer, 1, sizeof(uef_buffer), beebit_tapeimage);
        htop[-1].B_serial.uef_bufferpointer = 0;

        aciadcdlow();
        htop[-1].B_serial.uef_chunkstart = FALSE;
      }
      /*fread(&htop[-1].A_serial.uef_data, 1, 1, beebit_tapeimage);*/
      htop[-1].A_serial.uef_data = uef_buffer[htop[-1].B_serial.uef_bufferpointer];

      htop[-1].B_serial.uef_chunklen--;
      if (htop[-1].B_serial.uef_chunklen == 0)
        htop[-1].B_serial.uef_chunk = -1;
      else
      {
        if (htop[-1].B_serial.uef_bufferpointer == sizeof(uef_buffer)-1)
        {
          if (htop[-1].B_serial.uef_chunklen < sizeof(uef_buffer))
            fread(uef_buffer, 1, htop[-1].B_serial.uef_chunklen, beebit_tapeimage);
          else
            fread(uef_buffer, 1, sizeof(uef_buffer), beebit_tapeimage);
          htop[-1].B_serial.uef_bufferpointer = 0;
        }
        else
          htop[-1].B_serial.uef_bufferpointer++;
      }

      aciareceive(htop[-1].A_serial.uef_data);
      break;
    case 0x101:
      /*multiplexed implicit start/stop bit data block*/
      htop[-1].B_serial.uef_chunk = -1;
      break;
    case 0x110:
      /*high tone*/
      if (htop[-1].B_serial.uef_tone == 0)
      {
        aciadcdhigh();
        htop[-1].B_serial.uef_tone = 7; /*8 bits*/
      }
      else
      {
        htop[-1].B_serial.uef_tone--;
        if (htop[-1].B_serial.uef_tone == 0)
        {
          /*running length*/
          fseek(beebit_tapeimage, 2, SEEK_CUR);
          htop[-1].B_serial.uef_chunk = -1;
        }
      }
      break;
    case 0x112:
      /*gap*/
      if (htop[-1].B_serial.uef_tone == 0)
      {
        aciadcdhigh();
        htop[-1].B_serial.uef_tone = 7; /*8 bits*/
      }
      else
      {
        htop[-1].B_serial.uef_tone--;
        if (htop[-1].B_serial.uef_tone == 0)
        {
          /*running length*/
          fseek(beebit_tapeimage, 2, SEEK_CUR);
          htop[-1].B_serial.uef_chunk = -1;
        }
      }
      break;
    /*case 0x113:*/
      /*baud rate*/
      /*fread(uef_buffer, 1, 2, beebit_tapeimage);
      htop[-1].B_serial.uef_baud = (uef_buffer[1] << 8) | uef_buffer[0]*/
      /*break;*/
    default:
      /*printf("bad chunk &%X &%X\n",htop[-1].B_serial.uef_chunk, htop[-1].B_serial.uef_chunklen);*/
      fseek(beebit_tapeimage, htop[-1].B_serial.uef_chunklen, SEEK_CUR);
      htop[-1].B_serial.uef_chunk = -1;
      break;
  }
}
