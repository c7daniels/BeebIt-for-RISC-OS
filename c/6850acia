/*counter divide poll speed in 1MHz cycles (bits 0-15)*/
int m6850_pollspeed01[0x10] = {0,52,105,156,208,260,312,365,417,469,521,573,625,677,729,781};
int m6850_pollspeed16[0x10] = {0,833,1667,2500,3333,4167,5000,5833,6667,7500,8333,9167,10000,10833,11667,12500};
int m6850_pollspeed64[0x10] = {0,3333,6667,10000,13333,16667,20000,23333,26667,30000,33333,36667,40000,43333,46667,50000};

/*int serialula_baudrate[8] = {19200,1200,4800,150,9600,300,2400,75};*/

char uef_buffer[0xFF];

void aciareset(void)
{
  hostmap.s0serial.m6850_controlreg = 0x00;
  hostmap.s0serial.m6850_rxdatareg = 0x00;
  hostmap.s0serial.m6850_txdatareg = 0x00;
  hostmap.s0serial.m6850_rxdatashiftreg = 0x00;
  hostmap.s0serial.m6850_txdatashiftreg = 0x00;

  hostmap.s0serial.m6850_statusreg = 0x00;
  hostmap.s2serial.m6850_CTS = hostmap.s2serial.m6850_RTS = hostmap.s2serial.m6850_DCD = FALSE;

  hostmap.s2serial.m6850_counterdivide = 0x00;
  hostmap.s2serial.m6850_bits = hostmap.s2serial.m6850_parity = hostmap.s2serial.m6850_stop = 0x00;
  hostmap.s2serial.m6850_transmittingRTS = FALSE;
  hostmap.s2serial.m6850_transmittingIRQ = FALSE;

  hostmap.s2serial.m6850_cleardcd = 0;
  hostmap.s2serial.m6850_timerreset = m6850_pollspeed64[9]; /*300 baud*/
  hostmap.s2cycles.m6850_togo = 0;

  hostmap.s2serial.m6850_firstreset = TRUE;

  hostmap.s0serial.ula_reg = 0x00;
  hostmap.s2serial.ula_txbaud = 0x00;
  hostmap.s2serial.ula_rxbaud = 0x00;

  hostmap.s2serial.uef_filepointer = 12;
  hostmap.s2serial.uef_buffer = uef_buffer;
  hostmap.s2serial.uef_bufferpointer = 0;
}

void aciasetirq(void)
{
  if (hostmap.s0serial.m6850_statusreg & 0x80 AND hostmap.s0serial.m6850_controlreg & 0x80)
    hostmap.irq |= IRQ_6850ACIA;
  else
    hostmap.irq &= IRQ_NOT6850ACIA;
}

void aciadcdhigh(void)
{
  hostmap.s0serial.m6850_statusreg |= 0x84; /*dcd, irq*/
  aciasetirq();
}

void aciadcdlow(void)
{
  hostmap.s0serial.m6850_statusreg &= 0xFB; /*not dcd*/
  hostmap.s0serial.m6850_statusreg |= 0x80; /*irq*/
  aciasetirq();
}

void aciareceive(char nbyte)
{
  hostmap.s0serial.m6850_rxdatareg = nbyte;

  hostmap.s0serial.m6850_statusreg |= 0x81; /*receive, irq*/
  aciasetirq();
}

R6502HOSTMAP* aciapoll(R6502HOSTMAP* map)
{
  if (map->s0serial.ula_reg & 0x80)
  {
    /*motor on*/
    /*printf("MOTOR ON\n");*/

    if (!(map->s0serial.m6850_statusreg & 0x01))
      uefread();
  }

  map->s2cycles.m6850_togo = map->s2serial.m6850_timerreset<<1;

  return map;
}

void aciaresettimer(void)
{
  int bits;

  if (beebit_fasttape)
    hostmap.s2serial.m6850_timerreset = 1000;
  else
  {
    bits = hostmap.s2serial.m6850_bits + hostmap.s2serial.m6850_stop;
    if (hostmap.s2serial.m6850_parity != PARITY_NONE)
      bits++;
    switch (hostmap.s0serial.m6850_controlreg & 0x03)
    {
      case 0x00:
        /*19200 baud*/
        hostmap.s2serial.m6850_timerreset = m6850_pollspeed01[bits]; /*19200 baud*/
        break;
      case 0x01:
        /*1200 baud*/
        hostmap.s2serial.m6850_timerreset = m6850_pollspeed16[bits]; /*1200 baud*/
        break;
      case 0x02:
        /*300 baud*/
        hostmap.s2serial.m6850_timerreset = m6850_pollspeed64[bits]; /*300 baud*/
        break;
    }
  }
}

R6502HOSTMAP* acia00read(R6502HOSTMAP* map)
{
  if (map->s0serial.m6850_statusreg & 0x02)
  {
    if (map->s2serial.m6850_cleardcd > 0)
      map->s2serial.m6850_cleardcd = 2;
    else
    {
      map->s2serial.m6850_cleardcd--;
      if (map->s2serial.m6850_cleardcd == 0)
        map->s0serial.m6850_statusreg &= 0xFD; /*clear dcd*/
    }
  }
  map->m = (map->s0serial.m6850_statusreg);
  return R6502_EXECUTE_STEP(map);
}

R6502HOSTMAP* acia01read(R6502HOSTMAP* map)
{
  /*clear irq*/
  /*regs.r[0] = 0x04;*/ /*read byte*/
  /*_kernel_swi(OS_SerialOp,&regs,&regs);

   map->s0serial.m6850_rxdatareg = (regs.r[1] & 0xFF);*/

  map->s0serial.m6850_statusreg &= 0xFE;

  map->s0serial.m6850_statusreg &= 0x7F;
  map->irq &= IRQ_NOT6850ACIA;

  map->m = (map->s0serial.m6850_rxdatareg);
  return R6502_EXECUTE_STEP(map);
}

R6502HOSTMAP* acia00write(R6502HOSTMAP* map)
{
  map->s0serial.m6850_controlreg = map->m;
  if (!(map->s0serial.m6850_controlreg & 0x10))
  {
    map->s2serial.m6850_bits = 7;
    map->s2serial.m6850_parity = 2 - ((map->s0serial.m6850_controlreg & 0x04) >> 2);
    map->s2serial.m6850_stop = 2 - ((map->s0serial.m6850_controlreg & 0x08) >> 3);
  }
  else
  {
    map->s2serial.m6850_bits = 8;
    switch (map->s0serial.m6850_controlreg & 0x0C)
    {
      case 0x00:
        map->s2serial.m6850_parity = PARITY_NONE;
        map->s2serial.m6850_stop = 2;
        break;
      case 0x04:
        map->s2serial.m6850_parity = PARITY_NONE;
        map->s2serial.m6850_stop = 1;
        break;
      case 0x08:
        map->s2serial.m6850_parity = PARITY_EVEN;
        map->s2serial.m6850_stop = 1;
        break;
      case 0x0C:
        map->s2serial.m6850_parity = PARITY_ODD;
        map->s2serial.m6850_stop = 2;
        break;
    }
  }

  switch (map->s0serial.m6850_controlreg & 0x60)
  {
    case 0x00:
      map->s2serial.m6850_transmittingRTS = FALSE;
      map->s2serial.m6850_transmittingIRQ = FALSE;
      break;
    case 0x20:
      map->s2serial.m6850_transmittingRTS = FALSE;
      map->s2serial.m6850_transmittingIRQ = TRUE;
      break;
    case 0x40:
      map->s2serial.m6850_transmittingRTS = TRUE;
      map->s2serial.m6850_transmittingIRQ = FALSE;
      break;
    case 0x60:
      map->s2serial.m6850_transmittingRTS = FALSE;
      map->s2serial.m6850_transmittingIRQ = FALSE;
      break;
  }

  switch (map->s0serial.m6850_controlreg & 0x03)
  {
    case 0x00:
      /*19200 baud*/
      map->s2serial.m6850_counterdivide = 1;
      aciaresettimer();
      break;
    case 0x01:
      /*1200 baud*/
      map->s2serial.m6850_counterdivide = 16;
      aciaresettimer();
      break;
    case 0x02:
      /*300 baud*/
      map->s2serial.m6850_counterdivide = 64;
      aciaresettimer();
      break;
    case 0x03:
      /*master reset*/
      /*aciareset();*/
      if (map->s2serial.m6850_firstreset)
      {
        /*set IRQ to level 1*/
        /*map->s2serial.m6850_CTS = TRUE;*/
        map->s2serial.m6850_RTS = TRUE;
        /*map->s0serial.m6850_statusreg |= 0x08;*/ /*CTS*/
        map->s2serial.m6850_firstreset = FALSE;
      }
      else
      {
        map->s2serial.m6850_RTS = map->s2serial.m6850_transmittingRTS;
      }
      /*clear RDRF*/
      map->s0serial.m6850_statusreg &= 0xFE;
      /*clear irq*/
      map->s0serial.m6850_statusreg &= 0x7F;
      map->irq &= IRQ_NOT6850ACIA;
      break;
  }
  return R6502_EXECUTE_STEP(map);
}

R6502HOSTMAP* acia01write(R6502HOSTMAP* map)
{
  /*transmit data register*/
  map->s0serial.m6850_txdatareg = map->m;
  map->s0serial.m6850_statusreg &= 0xFD; /*TDRE*/
  /*clear irq*/
  map->s0serial.m6850_statusreg &= 0x7F;
  map->irq &= IRQ_NOT6850ACIA;
  return R6502_EXECUTE_STEP(map);
}

/*-- SERIAL ULA --*/

R6502HOSTMAP* serialularead(R6502HOSTMAP* map)
{
  map->m = (map->s0serial.ula_reg);
  return R6502_EXECUTE_STEP(map);
}

R6502HOSTMAP* serialulawrite(R6502HOSTMAP* map)
{
  int cyclecount;
  map->s0serial.ula_reg = map->m;

  map->s2serial.ula_txbaud = (map->s0serial.ula_reg & 0x07);
  map->s2serial.ula_rxbaud = ((map->s0serial.ula_reg & 0x38) >> 3);

  if (map->s0serial.ula_reg & 0x40)
  {
    /*RS423*/
    /*clear DCD*/
    map->s0serial.m6850_statusreg &= 0xFB;
  }
  else
  {
    /*TAPE*/
    /*clear CTS*/
    map->s0serial.m6850_statusreg &= 0xF7;
  }

  if (map->s0serial.ula_reg & 0x80)
  {
    /*TAPE*/
    if (map->s2cycles.m6850_togo == 0 && map->s2serial.m6850_timerreset > 0)
    {
      map->s2cycles.m6850_togo = map->s2serial.m6850_timerreset<<1;
      TIMER_GET_CYCLE_COUNT(cyclecount, &hostmap)
      map->s2cycles.m6850_togo += cyclecount;
      TIMER_LIMIT_CYCLES_TO_GO(&hostmap, map->s2cycles.m6850_togo)
    }
  }
  else
    /*RS423*/
    map->s2cycles.m6850_togo = 0;
  return R6502_EXECUTE_STEP(map);
}

/*-- UEF --*/

int uefvalidate(FILE *hfile)
{
  int nreturn;
  if (hfile == NULL)
    nreturn = FALSE;
  else
  {
    /*reset file pointer*/
    fseek(hfile,0,SEEK_SET);
    /*check header*/
    if (fread(uef_buffer,1,10,hfile))
    {
      if (strcmp(uef_buffer, "UEF File!") == 0)
        nreturn = TRUE;
      else
        nreturn = FALSE;
    }
    else
      nreturn = FALSE;
  }
  return (nreturn);
}

int uefopen(void)
{
  int nreturn;

  hostmap.s2serial.uef_chunk = -1;
  hostmap.s2serial.uef_chunklen = 0;
  hostmap.s2serial.uef_chunkstart = FALSE;
  hostmap.s2serial.uef_tone = 0;

  beebit_tapeimage = BEEBIT_FOPEN(beebit_uefimage, "rb");

  nreturn = uefvalidate(beebit_tapeimage);

  if (nreturn)
  {
    fread(uef_buffer, 1, 2, beebit_tapeimage);
    hostmap.s2serial.uef_version = (getword(uef_buffer) & 0xFFFF);
    fseek(beebit_tapeimage,hostmap.s2serial.uef_filepointer,SEEK_SET);
  }
  else
    fclose(beebit_tapeimage);

  return (nreturn);
}

void uefclose(void)
{
  if (beebit_tapeimage != NULL)
  {
    hostmap.s2serial.uef_filepointer = ftell(beebit_tapeimage);
    fclose(beebit_tapeimage);
  }
}

void uefrewind(void)
{
  hostmap.s2serial.uef_filepointer = 12;
  if (beebit_tapeimage != NULL)
    fseek(beebit_tapeimage,12,SEEK_SET);
}

void uefread(void)
{
  if (beebit_tapeimage == NULL)
    return;

  if (hostmap.s2serial.uef_chunk == -1)
  {
    /*no chunk definied*/
    fread(uef_buffer, 1, 2, beebit_tapeimage);
    hostmap.s2serial.uef_chunk = (getword(uef_buffer) & 0xFFFF);
    fread(uef_buffer, 1, 4, beebit_tapeimage);
    hostmap.s2serial.uef_chunklen = getword(uef_buffer);
    hostmap.s2serial.uef_chunkstart = TRUE;
  }

  switch (hostmap.s2serial.uef_chunk)
  {
    case 0x00:
      /*origin information chunk*/
      fseek(beebit_tapeimage, hostmap.s2serial.uef_chunklen, SEEK_CUR);
      hostmap.s2serial.uef_chunk = -1;
      break;
    case 0x01:
      /*game information/manual*/
      fseek(beebit_tapeimage, hostmap.s2serial.uef_chunklen, SEEK_CUR);
      hostmap.s2serial.uef_chunk = -1;
      break;
    case 0x100:
      /*implicit start/stop bit tape data block*/
      if (hostmap.s2serial.uef_chunkstart)
      {
        /*start of chunk*/
        if (hostmap.s2serial.uef_chunklen < sizeof(uef_buffer))
          fread(uef_buffer, 1, hostmap.s2serial.uef_chunklen, beebit_tapeimage);
        else
          fread(uef_buffer, 1, sizeof(uef_buffer), beebit_tapeimage);
        hostmap.s2serial.uef_bufferpointer = 0;

        aciadcdlow();
        hostmap.s2serial.uef_chunkstart = FALSE;
      }
      /*fread(&hostmap.s0serial.uef_data, 1, 1, beebit_tapeimage);*/
      hostmap.s0serial.uef_data = uef_buffer[hostmap.s2serial.uef_bufferpointer];

      hostmap.s2serial.uef_chunklen--;
      if (hostmap.s2serial.uef_chunklen == 0)
        hostmap.s2serial.uef_chunk = -1;
      else
      {
        if (hostmap.s2serial.uef_bufferpointer == sizeof(uef_buffer)-1)
        {
          if (hostmap.s2serial.uef_chunklen < sizeof(uef_buffer))
            fread(uef_buffer, 1, hostmap.s2serial.uef_chunklen, beebit_tapeimage);
          else
            fread(uef_buffer, 1, sizeof(uef_buffer), beebit_tapeimage);
          hostmap.s2serial.uef_bufferpointer = 0;
        }
        else
          hostmap.s2serial.uef_bufferpointer++;
      }

      aciareceive(hostmap.s0serial.uef_data);
      break;
    case 0x101:
      /*multiplexed implicit start/stop bit data block*/
      hostmap.s2serial.uef_chunk = -1;
      break;
    case 0x110:
      /*high tone*/
      if (hostmap.s2serial.uef_tone == 0)
      {
        aciadcdhigh();
        hostmap.s2serial.uef_tone = 7; /*8 bits*/
      }
      else
      {
        hostmap.s2serial.uef_tone--;
        if (hostmap.s2serial.uef_tone == 0)
        {
          /*running length*/
          fseek(beebit_tapeimage, 2, SEEK_CUR);
          hostmap.s2serial.uef_chunk = -1;
        }
      }
      break;
    case 0x112:
      /*gap*/
      if (hostmap.s2serial.uef_tone == 0)
      {
        aciadcdhigh();
        hostmap.s2serial.uef_tone = 7; /*8 bits*/
      }
      else
      {
        hostmap.s2serial.uef_tone--;
        if (hostmap.s2serial.uef_tone == 0)
        {
          /*running length*/
          fseek(beebit_tapeimage, 2, SEEK_CUR);
          hostmap.s2serial.uef_chunk = -1;
        }
      }
      break;
    /*case 0x113:*/
      /*baud rate*/
      /*fread(uef_buffer, 1, 2, beebit_tapeimage);
      hostmap.s2serial.uef_baud = (uef_buffer[1] << 8) | uef_buffer[0]*/
      /*break;*/
    default:
      /*printf("bad chunk &%X &%X\n",hostmap.s2serial.uef_chunk, hostmap.s2serial.uef_chunklen);*/
      fseek(beebit_tapeimage, hostmap.s2serial.uef_chunklen, SEEK_CUR);
      hostmap.s2serial.uef_chunk = -1;
      break;
  }
}
