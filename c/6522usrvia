extern _kernel_swi_regs regs;

void userviaamxmouse(void)
{
  if ((hostmap.s0usrvia.ifr & 0x18) == 0)
  {
    if ((hostmap.s2amx.targetx != hostmap.s2amx.currentx) || (hostmap.s2amx.targety != hostmap.s2amx.currenty))
    {
      if (hostmap.s2amx.targetx != hostmap.s2amx.currentx)
      {
        hostmap.s0usrvia.ifr |= 0x10;
        if (hostmap.s2amx.targetx < hostmap.s2amx.currentx)
        {
          hostmap.s0usrvia.irb &= ~0x01;
          hostmap.s0usrvia.portb &= ~0x01;
          hostmap.s2amx.currentx--;
        }
        else
        {
          hostmap.s0usrvia.irb |= 0x01;
          hostmap.s0usrvia.portb |= 0x01;
          hostmap.s2amx.currentx++;
        }
      }

      if (hostmap.s2amx.targety != hostmap.s2amx.currenty)
      {
        hostmap.s0usrvia.ifr |= 0x08;
        if (hostmap.s2amx.targety > hostmap.s2amx.currenty)
        {
          hostmap.s0usrvia.irb |= 0x04;
          hostmap.s0usrvia.portb |= 0x04;
          hostmap.s2amx.currenty++;
        }
        else
        {
          hostmap.s0usrvia.irb &= ~0x04;
          hostmap.s0usrvia.portb &= ~0x04;
          hostmap.s2amx.currenty--;
        }
      }
      userviasetirq();
    }
  }
}

void userviasetirq(void)
{
  if (hostmap.s0usrvia.ifr & hostmap.s0usrvia.ier & 0x7F)
  {
    hostmap.s0usrvia.ifr |= 0x80;
    hostmap.irq |= IRQ_6522USRVIA;
  }
  else
  {
    hostmap.s0usrvia.ifr &= 0x7F;
    hostmap.irq &= IRQ_NOT6522USRVIA;
  }
}

static int userviapickcyclestogo(void)
{
  int cyclestogo;

  // the interrupt flag is set after the counter has passed through zero
  if (!(hostmap.s0usrvia.acr & 0x20))
  {
    if (hostmap.s2usrvia.t1doubled < hostmap.s2usrvia.t2doubled)
    {
      cyclestogo = hostmap.s2usrvia.t1doubled + 2;
    }
    else
    {
      cyclestogo = hostmap.s2usrvia.t2doubled + 2;
    }
  }
  else
  {
    cyclestogo = hostmap.s2usrvia.t1doubled + 2;
  }

  if (hostmap.s2amx.timer > 0 && hostmap.s2amx.timer < cyclestogo)
  {
    cyclestogo = hostmap.s2amx.timer;
  }

  if (hostmap.s2usrvia.aftert1)
  {
    cyclestogo = 1;
  }

  return cyclestogo;
}

void userviastartreset(int lfull)
{
  int expiryoffset;

  if (lfull)
  {
    hostmap.s2usrvia.t1doubled = 0;
    hostmap.s2usrvia.t2doubled = 0;
    hostmap.s0usrvia.sr = 0;
  }
  else
  {
    TIMER_GET_PERIPHERAL_CYCLE_COUNT(expiryoffset, &hostmap, usrvia)

    hostmap.s2usrvia.t1doubled -= expiryoffset;

    if (!(hostmap.s0usrvia.acr & 0x20))
    {
      hostmap.s2usrvia.t2doubled -= expiryoffset;
    }
  }

  hostmap.s0usrvia.ier = 0x80;
  hostmap.s0usrvia.ifr = 0x00;
  hostmap.s0usrvia.ddra = 0; /*input*/
  hostmap.s0usrvia.ddrb = 0; /*input*/
  hostmap.s0usrvia.t1ll = 0xFF;
  hostmap.s0usrvia.t1lh = 0xFF;
  hostmap.s0usrvia.t2ll = 0xFF;
  hostmap.s0usrvia.acr = 0;
  hostmap.s0usrvia.pcr = 0;
  hostmap.s0usrvia.ora = 0xFF;
  hostmap.s0usrvia.ira = 0xFF;
  hostmap.s0usrvia.orb = 0xFF;
  hostmap.s0usrvia.irb = 0xFF;
  hostmap.s0usrvia.porta = 0xFF;
  hostmap.s0usrvia.portb = 0xFF;

  hostmap.s2usrvia.aftert1 = FALSE;
  hostmap.s2usrvia.t1setint = FALSE;
  hostmap.s2usrvia.t2setint = FALSE;
  userviasetirq();
  hostmap.s2amx.timer = 0;
  hostmap.s2amx.buttons = 0;

  hostmap.s2cycles.usrvia_original = 0;
  hostmap.s2cycles.usrvia_togo = 0;
}

void userviafinishreset(void)
{
  int expiryoffset;
  TIMER_GET_1MHZ_PERIPHERAL_TOGO_FOR_SNAPSHOT_OFFSET(expiryoffset, &hostmap, usrvia)

  hostmap.s2usrvia.t1doubled += expiryoffset;
  hostmap.s2usrvia.t2doubled += expiryoffset;

  hostmap.s2cycles.usrvia_togo = userviapickcyclestogo();
  hostmap.s2cycles.usrvia_original = hostmap.s2cycles.usrvia_togo;

  TIMER_LIMIT_CYCLES_TO_GO(&hostmap, hostmap.s2cycles.usrvia_togo)
}

void userviabeforesnapshot(void)
{
  int expiryoffset;
  TIMER_GET_1MHZ_PERIPHERAL_TOGO_FOR_SNAPSHOT_OFFSET(expiryoffset, &hostmap, usrvia)

  hostmap.s2usrvia.t1doubled -= expiryoffset;
  if (!(hostmap.s0usrvia.acr & 0x20))
  {
    /*one-shot mode*/
    hostmap.s2usrvia.t2doubled -= expiryoffset;
  }
}

void userviaaftersnapshot(void)
{
  int expiryoffset;
  TIMER_GET_1MHZ_PERIPHERAL_TOGO_FOR_SNAPSHOT_OFFSET(expiryoffset, &hostmap, usrvia)

  hostmap.s2usrvia.t1doubled += expiryoffset;
  TIMER_LIMIT_PERIPHERAL_CYCLES_TO_GO(&hostmap, usrvia, hostmap.s2usrvia.t1doubled + 2)
  if (!(hostmap.s0usrvia.acr & 0x20))
  {
    /*one-shot mode*/
    hostmap.s2usrvia.t2doubled += expiryoffset;
    TIMER_LIMIT_PERIPHERAL_CYCLES_TO_GO(&hostmap, usrvia, hostmap.s2usrvia.t2doubled + 2)
  }
}

R6502HOSTMAP* userviaatzerocycles(R6502HOSTMAP* map)
{
  /*we are dealing with a 1MHz device here*/
  hostmap.s2usrvia.t1doubled -= map->s2cycles.usrvia_original;

  if (hostmap.s2usrvia.t1doubled == -2)
  {
    switch (hostmap.s0usrvia.acr & 0xC0)
    {
      case 0x00:
        /*output disabled and one-shot mode*/
        /*timed interrupt each time T1 is loaded*/
        /*ELITE uses this one*/
        if (hostmap.s2usrvia.t1setint)
        {
          /*T1 interrupt flag set*/
          hostmap.s0usrvia.ifr |= 0x40;
          hostmap.s2usrvia.t1setint = FALSE;
        }
        break;
      case 0x40:
        /*output disabled and free-run mode*/
        /*continuous interrupts*/
        /*REVS, SKIRMISH AND RIG ATTACK USE THIS ONE!*/
         if (hostmap.s2usrvia.t1setint)
          /*T1 interrupt flag set*/
          hostmap.s0usrvia.ifr |= 0x40;
        break;
      case 0x80:
        /*output enabled and one-shot mode*/
        /*timed interrupt each time T1 is loaded*/
        if (hostmap.s2usrvia.t1setint)
        {
          /*PB7 goes high*/
          hostmap.s0usrvia.portb |= 0x80;
          /*T1 interrupt flag set*/
          hostmap.s0usrvia.ifr |= 0x40;
          hostmap.s2usrvia.t1setint = FALSE;
        }
        break;
      case 0xC0:
        /*output enabled and free-run mode*/
        /*continuous interrupts*/
        hostmap.s0usrvia.portb ^= 0x80;
        if (hostmap.s2usrvia.t1setint)
          /*T1 interrupt flag set*/
          hostmap.s0usrvia.ifr |= 0x40;
        break;
    }

    hostmap.s2usrvia.t1doubled += 0x20000;
    hostmap.s2usrvia.aftert1 = TRUE;
  }
  else if (hostmap.s2usrvia.aftert1)
  {
    if (hostmap.s0usrvia.acr & 0x40)
    {
      hostmap.s2usrvia.t1doubled = ((hostmap.s0usrvia.t1lh<<9) | (hostmap.s0usrvia.t1ll<<1)) + 1;
    }
    hostmap.s2usrvia.aftert1 = 0;
  }

  if (!(hostmap.s0usrvia.acr & 0x20))
  {
    hostmap.s2usrvia.t2doubled -= map->s2cycles.usrvia_original;

    if (hostmap.s2usrvia.t2doubled == -2)
    {
      if (hostmap.s2usrvia.t2setint)
      {
        /*on completion of the timing interval,
          T2 interrupt flag is set (IFR b5)*/
        hostmap.s0usrvia.ifr |= 0x20;
        hostmap.s2usrvia.t2setint=FALSE;
      }

      hostmap.s2usrvia.t2doubled += 0x20000;
    }
  }

  if (hostmap.s2amx.timer > 0)
  {
    hostmap.s2amx.timer -= map->s2cycles.usrvia_original;

    if (hostmap.s2amx.timer == 0)
    {
      if (beebit_mouseemulation == MOUSE_AMXMOUSE)
        userviaamxmouse();
    }
  }

  map->s2cycles.usrvia_togo = map->s2cycles.usrvia_original = userviapickcyclestogo();

  userviasetirq();

  return map;
}

R6502HOSTMAP* uservia00read(R6502HOSTMAP* map, unsigned int address_code)
{
  int expiryoffset;
  unsigned int nresult;

  /*input/output reg b*/
  /*PCR & 0x20 = CB2 input*/
  /*PCR & 0x40 = CB2 active edge input*/
  /*independant mode*/
  if (((map->s0usrvia.pcr & 0xE0) == 0x20) OR ((map->s0usrvia.pcr & 0xE0) == 0x60))
  {
    /*clear b4 (CB1)*/
    map->s0usrvia.ifr &= 0xEF;
  }
  else
  {
    /*clear b4,b3 (CB1,CB2)*/
    map->s0usrvia.ifr &= 0xE7;
  }
  /*userviasetirq();*/
  /*reads output register bit in orb. pin level has no effect*/
  nresult = (map->s0usrvia.orb & map->s0usrvia.ddrb);

  if (map->s0usrvia.acr & 0x02)
  {
    /*input latching enabled*/
    /*read input level on irb*/
    nresult |= (map->s0usrvia.irb & ~map->s0usrvia.ddrb);
  }
  else
  {
    /*input latching disabled*/
    /*read input level on PB pin*/
    nresult |= (map->s0usrvia.portb & ~map->s0usrvia.ddrb);
  }

  if (beebit_mouseemulation == MOUSE_AMXMOUSE)
  {
    /*AMX mouse stuff*/
    _kernel_swi(OS_Mouse,&regs,&regs);
    map->s2amx.targetx = regs.r[0];
    map->s2amx.targety = regs.r[1];
    map->s2amx.buttons = ((regs.r[2] & 0x04) >> 2);
    map->s2amx.buttons |= (regs.r[2] & 0x02);
    map->s2amx.buttons |= ((regs.r[2] & 0x01) << 2);

    nresult &= 0x1F;
    nresult |= (map->s2amx.buttons ^ 7) << 5;
    map->s0usrvia.ifr &= 0xE7;

    userviasetirq();

    if ((map->s2amx.targetx != map->s2amx.currentx) OR (map->s2amx.targety != map->s2amx.currenty))
    {
      /*set trigger*/
      TIMER_GET_1MHZ_PERIPHERAL_TOGO_FROM_WRITE_OFFSET(expiryoffset, map, usrvia)
      map->s2amx.timer = (500<<1) + expiryoffset;
      TIMER_LIMIT_PERIPHERAL_CYCLES_TO_GO(map, usrvia, map->s2amx.timer)
    }
    else
    {
      /*clear trigger*/
      map->s2amx.timer = 0;
    }
  }
  map->m = nresult;

  return map;
}

R6502HOSTMAP* uservia01read(R6502HOSTMAP* map, unsigned int address_code)
{
  /*input/output reg a*/
  /*map->s0usrvia.pcr & 0x02 = CA2 input*/
  /*map->s0usrvia.pcr & 0x04 = CA2 active edge input*/
  /*independant mode*/
  if (((map->s0usrvia.pcr & 0x0E) == 0x02) OR ((map->s0usrvia.pcr & 0x0E) == 0x06))
  {
    /*independant interrupt*/
    /*clear b2 (CA1)*/
    map->s0usrvia.ifr &= 0xFD;
  }
  else
  {
    /*clear b2,b1 (CA1,CA2)*/
    map->s0usrvia.ifr &= 0xFC;
  }
  userviasetirq();
  if (map->s0usrvia.acr & 0x01)
  {
    /*input latching enabled*/
    map->m = map->s0usrvia.ira;
  }
  else
  {
    /*input latching disabled*/
    map->m = map->s0usrvia.porta;
  }

  return map;
}

R6502HOSTMAP* uservia02read(R6502HOSTMAP* map, unsigned int address_code)
{
  map->m = map->s0usrvia.ddrb;

  return map;
}

R6502HOSTMAP* uservia03read(R6502HOSTMAP* map, unsigned int address_code)
