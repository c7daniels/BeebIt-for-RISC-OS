}

struct R6502CPUMAP* uservia0Aread(struct R6502CPUMAP* ctop, uintptr_t address_code)
{
  /*shift register*/
  HOSTMAP* htop = (HOSTMAP*)ctop;
  /*SR interrupt flag is cleared (IFR b2)*/
  htop[-1].A_usrvia.ifr &= 0xFB;
  userviaregistersetirq(htop);
  htop[-1].m = htop[-1].A_usrvia.sr;

  return ctop;
}

