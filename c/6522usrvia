R6502HOSTMAP* uservia04write(R6502HOSTMAP* map, unsigned int address_code)
{
  /*T1 low order latch*/
  map->s0usrvia.t1ll = map->m;

  return map;
}

R6502HOSTMAP* uservia05write(R6502HOSTMAP* map, unsigned int address_code)
{
  int expiryoffset;

  /*T1 high order counter*/
  map->s0usrvia.t1lh = map->m;
  /*clear T1 interrupt flag (b6)*/
  map->s0usrvia.ifr &= 0xBF;
  userviasetirq();
  if ((map->s0usrvia.acr & 0xC0) == 0x80)
  {
    /*output enabled (b7=1) and free-run disabled (b6=0)*/
    /*one-shot mode*/
    /*PB7 goes low, but goes high when timer 1 times out*/
    /*map->s0usrvia.orb &= 0x7F;
    map->s0usrvia.irb &= 0x7F;*/
    map->s0usrvia.portb &= 0x7F;
  }
  map->s2usrvia.t1setint = TRUE;
  map->s2usrvia.t1doubled = (map->s0usrvia.t1lh<<9) | (map->s0usrvia.t1ll<<1);
  TIMER_GET_1MHZ_PERIPHERAL_TOGO_FROM_WRITE_OFFSET(expiryoffset, map, usrvia)
  map->s2usrvia.t1doubled += expiryoffset;
  // the interrupt flag is set after the counter has passed through zero
  TIMER_LIMIT_PERIPHERAL_CYCLES_TO_GO(map, usrvia, map->s2usrvia.t1doubled + 2)
  map->s2usrvia.aftert1 = 0;

  return map;
}

R6502HOSTMAP* uservia06write(R6502HOSTMAP* map, unsigned int address_code)
{
  /*T1 low order latch*/
  map->s0usrvia.t1ll = map->m;

  return map;
}

R6502HOSTMAP* uservia07write(R6502HOSTMAP* map, unsigned int address_code)
{
  /*T1 high order latch*/
  map->s0usrvia.t1lh = map->m;

  return map;
}

R6502HOSTMAP* uservia08write(R6502HOSTMAP* map, unsigned int address_code)
{
  /*T2 low order latch*/
  map->s0usrvia.t2ll = map->m;

  return map;
}

R6502HOSTMAP* uservia09write(R6502HOSTMAP* map, unsigned int address_code)
{
  int expiryoffset;

  /*T2 high order counter*/
  /*clear T2 interrupt flag (bit 5)*/
  map->s0usrvia.ifr &= 0xDF;
  userviasetirq();
  /*provide a single interrupt*/
  map->s2usrvia.t2setint = TRUE;
  if (!(map->s0usrvia.acr & 0x20))
  {
    /*one-shot mode*/
    map->s2usrvia.t2doubled = (map->m<<9) | (map->s0usrvia.t2ll<<1);
    TIMER_GET_1MHZ_PERIPHERAL_TOGO_FROM_WRITE_OFFSET(expiryoffset, map, usrvia)
    map->s2usrvia.t2doubled += expiryoffset;
    // the interrupt flag is set after the counter has passed through zero
    TIMER_LIMIT_PERIPHERAL_CYCLES_TO_GO(map, usrvia, map->s2usrvia.t2doubled + 2)
  }
  else
  {
    /*pulse counting mode*/
    map->s2usrvia.t2doubled = (map->m<<9) | (map->s0usrvia.t2ll<<1);
  }

  return map;
}

R6502HOSTMAP* uservia0Awrite(R6502HOSTMAP* map, unsigned int address_code)
{
  /*shift reg*/
  map->s0usrvia.sr = map->m;
  map->s0usrvia.ifr &= 0xFB;
  userviasetirq();

  return map;
}

R6502HOSTMAP* uservia0Bwrite(R6502HOSTMAP* map, unsigned int address_code)
{
  int expiryoffset;

  /*auxiliary control reg*/
  if ((map->s0usrvia.acr ^ map->m) & 0x20)
  {
    TIMER_GET_1MHZ_PERIPHERAL_TOGO_FROM_WRITE_OFFSET(expiryoffset, map, usrvia)
    if (!(map->m & 0x20))
    {
      /*one-shot mode*/
      map->s2usrvia.t2doubled += expiryoffset;
      TIMER_LIMIT_PERIPHERAL_CYCLES_TO_GO(map, usrvia, map->s2usrvia.t2doubled + 2)
    }
    else
    {
      /*pulse counting mode*/
      map->s2usrvia.t2doubled -= expiryoffset;
    }
  }
  map->s0usrvia.acr = map->m;

  return map;
}

R6502HOSTMAP* uservia0Cwrite(R6502HOSTMAP* map, unsigned int address_code)
{
  /*peripheral control reg*/
  map->s0usrvia.pcr = map->m;
  /*CA1 active edge*/
  if (map->s0usrvia.pcr & 0x01)
  {
    /*set b2 (CA1)*/
    map->s0usrvia.ifr |= 0x02;
  }
  /*CA2 active edge*/
  if ((map->s0usrvia.pcr & 0x0E) == 0x04)
  {
    /*set b1 (CA2)*/
    map->s0usrvia.ifr |= 0x01;
  }
  /*CB1 active edge*/
  if (map->s0usrvia.pcr & 0x10)
  {
    /*set b5 (CB1)*/
    map->s0usrvia.ifr |= 0x10;
  }
  /*CB2 active edge*/
  if ((map->s0usrvia.pcr & 0xE0) == 0x40)
  {
    /*set b4 (CB2)*/
    map->s0usrvia.ifr |= 0x08;
  }

  return map;
}

R6502HOSTMAP* uservia0Dwrite(R6502HOSTMAP* map, unsigned int address_code)
{
  /*interrupt flag reg*/
  map->m &= 0x7F; /*not really needed*/
  map->s0usrvia.ifr &= (~map->m);
  userviasetirq();

  return map;
}

R6502HOSTMAP* uservia0Ewrite(R6502HOSTMAP* map, unsigned int address_code)
{
  /*interrupt enable reg*/
  if (map->m & 0x80)
    map->s0usrvia.ier |= map->m;
  else
    map->s0usrvia.ier &= (~map->m);
  map->s0usrvia.ier &= 0x7F;
  userviasetirq();

  return map;
}

R6502HOSTMAP* uservia0Fwrite(R6502HOSTMAP* map, unsigned int address_code)
{
  /*output reg a*/
  map->s0usrvia.ora = map->m;
  map->s0usrvia.porta = (map->s0usrvia.ora & map->s0usrvia.ddra) +(map->s0usrvia.porta & ~map->s0usrvia.ddra);

  return map;
}
