struct R6502CPUMAP* uservia04read(struct R6502CPUMAP* ctop, uintptr_t address_code)
{
  /*T1 low order counter*/
  HOSTMAP* htop = (HOSTMAP*)ctop;
  intptr_t cyclecount;

  /*T1 interrupt flag is cleared (IFR b6)*/
  htop[-1].A_usrvia.ifr &= 0xBF;
  userviaregistersetirq(htop);
  HOST_GET_PERIPHERAL_CYCLE_COUNT(cyclecount, htop, usrvia)
  htop[-1].m = ((htop[-1].B_usrvia.t1doubled - cyclecount)>>1)&0xFF;

  return ctop;
}

struct R6502CPUMAP* uservia05read(struct R6502CPUMAP* ctop, uintptr_t address_code)
{
  /*T1 high order counter*/
  HOSTMAP* htop = (HOSTMAP*)ctop;
  intptr_t cyclecount;

  HOST_GET_PERIPHERAL_CYCLE_COUNT(cyclecount, htop, usrvia)
  htop[-1].m = ((htop[-1].B_usrvia.t1doubled - cyclecount)>>9)&0xFF;

  return ctop;
}

