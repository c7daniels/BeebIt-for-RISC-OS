R6502HOSTMAP* uservia0Aread(R6502HOSTMAP* map, unsigned int address_code)
{
  /*shift register*/
  /*SR interrupt flag is cleared (IFR b2)*/
  map->s0usrvia.ifr &= 0xFB;
  userviasetirq();
  map->m = map->s0usrvia.sr;

  return map;
}

R6502HOSTMAP* uservia0Bread(R6502HOSTMAP* map, unsigned int address_code)
{
  /*auxilary control reg*/
  map->m = map->s0usrvia.acr;

  return map;
}

R6502HOSTMAP* uservia0Cread(R6502HOSTMAP* map, unsigned int address_code)
{
  /*peripheral control reg*/
  map->m = map->s0usrvia.pcr;

  return map;
}

R6502HOSTMAP* uservia0Dread(R6502HOSTMAP* map, unsigned int address_code)
{
  /*interrupt flag reg*/
  /*b7 of this register will be read as a logic 1*/
  /*when an interrupt exists within the chip*/
  userviasetirq();
  map->m = map->s0usrvia.ifr;

  return map;
}

R6502HOSTMAP* uservia0Eread(R6502HOSTMAP* map, unsigned int address_code)
{
  /*interrupt enable reg*/
  map->m = (map->s0usrvia.ier | 0x80);

  return map;
}

R6502HOSTMAP* uservia0Fread(R6502HOSTMAP* map, unsigned int address_code)
{
  /*output reg a*/
  if (map->s0usrvia.acr & 0x01)
  {
    /*latching enabled*/
    map->m = map->s0usrvia.ira;
  }
  else
  {
    /*latching disabled*/
    map->m = map->s0usrvia.porta;
  }

  return map;
}

R6502HOSTMAP* uservia00write(R6502HOSTMAP* map, unsigned int address_code)
{
  /*input/output reg b*/
  map->s0usrvia.orb = map->m;
  map->s0usrvia.portb = (map->s0usrvia.orb & map->s0usrvia.ddrb) | (map->s0usrvia.portb & ~map->s0usrvia.ddrb);
  /*PCR & 0x20 = CB2 input*/
  /*PCR & 0x40 = CB2 active edge input*/
  /*independant mode*/
  if (((map->s0usrvia.pcr & 0xE0) == 0x20) OR ((map->s0usrvia.pcr & 0xE0) == 0x60))
  {
    /*clear b4 (CB1)*/
    map->s0usrvia.ifr &= 0xEF;
  }
  else
  {
    /*clear b4,b3 (CB1,CB2)*/
    map->s0usrvia.ifr &= 0xE7;
  }
  userviasetirq();

  return map;
}

R6502HOSTMAP* uservia01write(R6502HOSTMAP* map, unsigned int address_code)
{
  /*input/output reg a*/
  /*VDU 21 writes &0D (%1101) only*/
  /*VDU 2 writes &OD then character*/
  map->s0usrvia.ora = map->m;
  map->s0usrvia.porta = (map->s0usrvia.ora & map->s0usrvia.ddra) | (map->s0usrvia.porta & ~map->s0usrvia.ddra);
  /*PCR & 0x02 = CA2 input*/
  /*PCR & 0x04 = CA2 active edge input*/
  if (((map->s0usrvia.pcr & 0x0E) == 0x02) OR ((map->s0usrvia.pcr & 0x0E) == 0x06))
  {
    /*clear b2 (CA1)*/
    map->s0usrvia.ifr &= 0xFD;
  }
  else
  {
    /*clear b2,b1 (CA1,CA2)*/
    map->s0usrvia.ifr &= 0xFC;
  }
  if (beebit_printer)
  {
    regs.r[0] = map->s0usrvia.porta;
    _kernel_swi(OS_PrintChar,&regs,&regs);
  }
  /*clear b2 (CA1)*/
  map->s0usrvia.ifr |= 0x02; /*CA1*/
  userviasetirq();

  return map;
}

R6502HOSTMAP* uservia02write(R6502HOSTMAP* map, unsigned int address_code)
{
  map->s0usrvia.ddrb = map->m;

  return map;
}

R6502HOSTMAP* uservia03write(R6502HOSTMAP* map, unsigned int address_code)
