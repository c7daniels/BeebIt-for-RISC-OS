void userviaamxmouse(void)
{
  HOSTMAP* htop = (HOSTMAP*)&hostmap.upper;

  if ((htop[-1].A_usrvia.ifr & 0x18) == 0)
  {
    if ((htop[-1].amx.targetx != htop[-1].amx.currentx) || (htop[-1].amx.targety != htop[-1].amx.currenty))
    {
      if (htop[-1].amx.targetx != htop[-1].amx.currentx)
      {
        htop[-1].A_usrvia.ifr |= 0x10;
        if (htop[-1].amx.targetx < htop[-1].amx.currentx)
        {
          htop[-1].A_usrvia.irb &= ~0x01;
          htop[-1].A_usrvia.portb &= ~0x01;
          htop[-1].amx.currentx--;
        }
        else
        {
          htop[-1].A_usrvia.irb |= 0x01;
          htop[-1].A_usrvia.portb |= 0x01;
          htop[-1].amx.currentx++;
        }
      }

      if (htop[-1].amx.targety != htop[-1].amx.currenty)
      {
        htop[-1].A_usrvia.ifr |= 0x08;
        if (htop[-1].amx.targety > htop[-1].amx.currenty)
        {
          htop[-1].A_usrvia.irb |= 0x04;
          htop[-1].A_usrvia.portb |= 0x04;
          htop[-1].amx.currenty++;
        }
        else
        {
          htop[-1].A_usrvia.irb &= ~0x04;
          htop[-1].A_usrvia.portb &= ~0x04;
          htop[-1].amx.currenty--;
        }
      }
    }
  }
}

void userviaeventsetirq(HOSTMAP* htop)
{
  if (htop[-1].A_usrvia.ifr & htop[-1].A_usrvia.ier & 0x7F)
  {
    htop[-1].A_usrvia.ifr |= 0x80;
    HOST_SETSHIFTEDIRQ(htop, HOST_IRQ_6522USRVIA)
  }
  else
  {
    htop[-1].A_usrvia.ifr &= 0x7F;
    HOST_CLEARSHIFTEDIRQ(htop, HOST_IRQ_6522USRVIA)
  }
}

void userviaregistersetirq(HOSTMAP* htop)
{
  if (htop[-1].A_usrvia.ifr & htop[-1].A_usrvia.ier & 0x7F)
  {
    htop[-1].A_usrvia.ifr |= 0x80;
    HOST_SETIRQ(htop, HOST_IRQ_6522USRVIA)
  }
  else
  {
    htop[-1].A_usrvia.ifr &= 0x7F;
    HOST_CLEARIRQ(htop, HOST_IRQ_6522USRVIA)
  }
}

static intptr_t userviapickcyclestogo(void)
{
  HOSTMAP* htop = (HOSTMAP*)&hostmap.upper;
  intptr_t cyclestogo;

  // the interrupt flag is set after the counter has passed through zero
  if (!(htop[-1].A_usrvia.acr & 0x20))
  {
    if (htop[-1].B_usrvia.t1doubled < htop[-1].B_usrvia.t2doubled)
    {
      cyclestogo = htop[-1].B_usrvia.t1doubled + 2;
    }
    else
    {
      cyclestogo = htop[-1].B_usrvia.t2doubled + 2;
    }
  }
  else
  {
    cyclestogo = htop[-1].B_usrvia.t1doubled + 2;
  }

  if (htop[-1].amx.timer > 0 && htop[-1].amx.timer < cyclestogo)
  {
    cyclestogo = htop[-1].amx.timer;
  }

  if (htop[-1].A_usrvia.aftert1)
  {
    cyclestogo = 1;
  }

  return cyclestogo;
}

void userviastartreset(int lfull)
{
  HOSTMAP* htop = (HOSTMAP*)&hostmap.upper;
  intptr_t expiryoffset;

  if (lfull)
  {
    htop[-1].B_usrvia.t1doubled = 0;
    htop[-1].B_usrvia.t2doubled = 0;
    htop[-1].A_usrvia.sr = 0;
  }
  else
  {
    HOST_GET_PERIPHERAL_CYCLE_COUNT(expiryoffset, htop, usrvia)

    htop[-1].B_usrvia.t1doubled -= expiryoffset;

    if (!(htop[-1].A_usrvia.acr & 0x20))
    {
      htop[-1].B_usrvia.t2doubled -= expiryoffset;
    }
  }

  htop[-1].A_usrvia.ier = 0x80;
  htop[-1].A_usrvia.ifr = 0x00;
  htop[-1].A_usrvia.ddra = 0; /*input*/
  htop[-1].A_usrvia.ddrb = 0; /*input*/
  htop[-1].A_usrvia.t1ll = 0xFF;
  htop[-1].A_usrvia.t1lh = 0xFF;
  htop[-1].A_usrvia.t2ll = 0xFF;
  htop[-1].A_usrvia.acr = 0;
  htop[-1].A_usrvia.pcr = 0;
  htop[-1].A_usrvia.ora = 0xFF;
  htop[-1].A_usrvia.ira = 0xFF;
  htop[-1].A_usrvia.orb = 0xFF;
  htop[-1].A_usrvia.irb = 0xFF;
  htop[-1].A_usrvia.porta = 0xFF;
  htop[-1].A_usrvia.portb = 0xFF;

  htop[-1].A_usrvia.aftert1 = FALSE;
  htop[-1].A_usrvia.t1setint = FALSE;
  htop[-1].A_usrvia.t2setint = FALSE;
  userviaregistersetirq(htop);
  htop[-1].amx.timer = 0;
  htop[-1].amx.buttons = 0;

  htop[-1].cycles.usrvia_original = 0;
  htop[-1].cycles.usrvia_togo = 0;
}

void userviafinishreset(void)
{
  HOSTMAP* htop = (HOSTMAP*)&hostmap.upper;
  intptr_t expiryoffset;
  HOST_GET_1MHZ_PERIPHERAL_TOGO_FOR_SNAPSHOT_OFFSET(expiryoffset, htop, usrvia)

  htop[-1].B_usrvia.t1doubled += expiryoffset;
  htop[-1].B_usrvia.t2doubled += expiryoffset;

  htop[-1].cycles.usrvia_togo = userviapickcyclestogo();
  htop[-1].cycles.usrvia_original = htop[-1].cycles.usrvia_togo;

  HOST_LIMIT_CYCLES_TO_GO(htop, htop[-1].cycles.usrvia_togo)
}

void userviabeforesnapshot(void)
{
  HOSTMAP* htop = (HOSTMAP*)&hostmap.upper;
  intptr_t expiryoffset;
  HOST_GET_1MHZ_PERIPHERAL_TOGO_FOR_SNAPSHOT_OFFSET(expiryoffset, htop, usrvia)

  htop[-1].B_usrvia.t1doubled -= expiryoffset;
  if (!(htop[-1].A_usrvia.acr & 0x20))
  {
    /*one-shot mode*/
    htop[-1].B_usrvia.t2doubled -= expiryoffset;
  }

  userviaregistersetirq(htop);
}

void userviaaftersnapshot(void)
{
  HOSTMAP* htop = (HOSTMAP*)&hostmap.upper;
  intptr_t expiryoffset;
  HOST_GET_1MHZ_PERIPHERAL_TOGO_FOR_SNAPSHOT_OFFSET(expiryoffset, htop, usrvia)

  htop[-1].B_usrvia.t1doubled += expiryoffset;
  HOST_LIMIT_PERIPHERAL_CYCLES_TO_GO(htop, usrvia, htop[-1].B_usrvia.t1doubled + 2)
  if (!(htop[-1].A_usrvia.acr & 0x20))
  {
    /*one-shot mode*/
    htop[-1].B_usrvia.t2doubled += expiryoffset;
    HOST_LIMIT_PERIPHERAL_CYCLES_TO_GO(htop, usrvia, htop[-1].B_usrvia.t2doubled + 2)
  }
}

HOSTMAP* userviaatzerocycles(HOSTMAP* htop)
{
  /*we are dealing with a 1MHz device here*/
  htop[-1].B_usrvia.t1doubled -= htop[-1].cycles.usrvia_original;

  if (htop[-1].B_usrvia.t1doubled == -2)
  {
    switch (htop[-1].A_usrvia.acr & 0xC0)
    {
      case 0x00:
        /*output disabled and one-shot mode*/
        /*timed interrupt each time T1 is loaded*/
        /*ELITE uses this one*/
        if (htop[-1].A_usrvia.t1setint)
        {
          /*T1 interrupt flag set*/
          htop[-1].A_usrvia.ifr |= 0x40;
          htop[-1].A_usrvia.t1setint = FALSE;
        }
        break;
      case 0x40:
        /*output disabled and free-run mode*/
        /*continuous interrupts*/
        /*REVS, SKIRMISH AND RIG ATTACK USE THIS ONE!*/
         if (htop[-1].A_usrvia.t1setint)
          /*T1 interrupt flag set*/
          htop[-1].A_usrvia.ifr |= 0x40;
        break;
      case 0x80:
        /*output enabled and one-shot mode*/
        /*timed interrupt each time T1 is loaded*/
        if (htop[-1].A_usrvia.t1setint)
        {
          /*PB7 goes high*/
          htop[-1].A_usrvia.portb |= 0x80;
          /*T1 interrupt flag set*/
          htop[-1].A_usrvia.ifr |= 0x40;
          htop[-1].A_usrvia.t1setint = FALSE;
        }
        break;
      case 0xC0:
        /*output enabled and free-run mode*/
        /*continuous interrupts*/
        htop[-1].A_usrvia.portb ^= 0x80;
        if (htop[-1].A_usrvia.t1setint)
          /*T1 interrupt flag set*/
          htop[-1].A_usrvia.ifr |= 0x40;
        break;
    }

    htop[-1].B_usrvia.t1doubled += 0x20000;
    htop[-1].A_usrvia.aftert1 = TRUE;
  }
  else if (htop[-1].A_usrvia.aftert1)
  {
    if (htop[-1].A_usrvia.acr & 0x40)
    {
      htop[-1].B_usrvia.t1doubled = ((htop[-1].A_usrvia.t1lh<<9) | (htop[-1].A_usrvia.t1ll<<1)) + 1;
    }
    htop[-1].A_usrvia.aftert1 = 0;
  }

  if (!(htop[-1].A_usrvia.acr & 0x20))
  {
    htop[-1].B_usrvia.t2doubled -= htop[-1].cycles.usrvia_original;

    if (htop[-1].B_usrvia.t2doubled == -2)
    {
      if (htop[-1].A_usrvia.t2setint)
      {
        /*on completion of the timing interval,
          T2 interrupt flag is set (IFR b5)*/
        htop[-1].A_usrvia.ifr |= 0x20;
        htop[-1].A_usrvia.t2setint=FALSE;
      }

      htop[-1].B_usrvia.t2doubled += 0x20000;
    }
  }

  if (htop[-1].amx.timer > 0)
  {
    htop[-1].amx.timer -= htop[-1].cycles.usrvia_original;

    if (htop[-1].amx.timer == 0)
    {
      if (beebit_mouseemulation == MOUSE_AMXMOUSE)
        userviaamxmouse();
    }
  }

  htop[-1].cycles.usrvia_togo = htop[-1].cycles.usrvia_original = userviapickcyclestogo();

  userviaeventsetirq(htop);
  return htop;
}

struct R6502CPUMAP* uservia00read(struct R6502CPUMAP* ctop, uintptr_t address_code)
{
  /*input/output reg b*/
  HOSTMAP* htop = (HOSTMAP*)ctop;
  intptr_t expiryoffset;
  unsigned int nresult;

  /*PCR & 0x20 = CB2 input*/
  /*PCR & 0x40 = CB2 active edge input*/
  /*independant mode*/
  if (((htop[-1].A_usrvia.pcr & 0xE0) == 0x20) OR ((htop[-1].A_usrvia.pcr & 0xE0) == 0x60))
  {
    /*clear b4 (CB1)*/
    htop[-1].A_usrvia.ifr &= 0xEF;
  }
  else
  {
    /*clear b4,b3 (CB1,CB2)*/
    htop[-1].A_usrvia.ifr &= 0xE7;
  }
  /*userviaregistersetirq(htop);*/
  /*reads output register bit in orb. pin level has no effect*/
  nresult = (htop[-1].A_usrvia.orb & htop[-1].A_usrvia.ddrb);

  if (htop[-1].A_usrvia.acr & 0x02)
  {
    /*input latching enabled*/
    /*read input level on irb*/
    nresult |= (htop[-1].A_usrvia.irb & ~htop[-1].A_usrvia.ddrb);
  }
  else
  {
    /*input latching disabled*/
    /*read input level on PB pin*/
    nresult |= (htop[-1].A_usrvia.portb & ~htop[-1].A_usrvia.ddrb);
  }

  if (beebit_mouseemulation == MOUSE_AMXMOUSE)
  {
    /*AMX mouse stuff*/
#ifdef __RISCOS__
    _kernel_swi(OS_Mouse,&regs,&regs);
    htop[-1].amx.targetx = regs.r[0];
    htop[-1].amx.targety = regs.r[1];
    htop[-1].amx.buttons = ((regs.r[2] & 0x04) >> 2);
    htop[-1].amx.buttons |= (regs.r[2] & 0x02);
    htop[-1].amx.buttons |= ((regs.r[2] & 0x01) << 2);
#endif

    nresult &= 0x1F;
    nresult |= (htop[-1].amx.buttons ^ 7) << 5;
    htop[-1].A_usrvia.ifr &= 0xE7;

    userviaregistersetirq(htop);

    if ((htop[-1].amx.targetx != htop[-1].amx.currentx) OR (htop[-1].amx.targety != htop[-1].amx.currenty))
    {
      /*set trigger*/
      HOST_GET_1MHZ_PERIPHERAL_TOGO_FROM_WRITE_OFFSET(expiryoffset, htop, usrvia)
      htop[-1].amx.timer = (500<<1) + expiryoffset;
      HOST_LIMIT_PERIPHERAL_CYCLES_TO_GO(htop, usrvia, htop[-1].amx.timer)
    }
    else
    {
      /*clear trigger*/
      htop[-1].amx.timer = 0;
    }
  }
  htop[-1].m = nresult;

  return ctop;
}

struct R6502CPUMAP* uservia01read(struct R6502CPUMAP* ctop, uintptr_t address_code)
{
  /*input/output reg a*/
  HOSTMAP* htop = (HOSTMAP*)ctop;
  /*htop[-1].A_usrvia.pcr & 0x02 = CA2 input*/
  /*htop[-1].A_usrvia.pcr & 0x04 = CA2 active edge input*/
  /*independant mode*/
  if (((htop[-1].A_usrvia.pcr & 0x0E) == 0x02) OR ((htop[-1].A_usrvia.pcr & 0x0E) == 0x06))
  {
    /*independant interrupt*/
    /*clear b2 (CA1)*/
    htop[-1].A_usrvia.ifr &= 0xFD;
  }
  else
  {
    /*clear b2,b1 (CA1,CA2)*/
    htop[-1].A_usrvia.ifr &= 0xFC;
  }
  userviaregistersetirq(htop);
  if (htop[-1].A_usrvia.acr & 0x01)
  {
    /*input latching enabled*/
    htop[-1].m = htop[-1].A_usrvia.ira;
  }
  else
  {
    /*input latching disabled*/
    htop[-1].m = htop[-1].A_usrvia.porta;
  }

  return ctop;
}

struct R6502CPUMAP* uservia02read(struct R6502CPUMAP* ctop, uintptr_t address_code)
{
  HOSTMAP* htop = (HOSTMAP*)ctop;
  htop[-1].m = htop[-1].A_usrvia.ddrb;

  return ctop;
}

