R6502HOSTMAP* uservia04read(R6502HOSTMAP* map, unsigned int address_code)
{
  int cyclecount;

  /*T1 low order counter*/
  /*T1 interrupt flag is cleared (IFR b6)*/
  map->s0usrvia.ifr &= 0xBF;
  userviasetirq();
  TIMER_GET_PERIPHERAL_CYCLE_COUNT(cyclecount, map, usrvia)
  map->m = ((map->s2usrvia.t1doubled - cyclecount)>>1)&0xFF;

  return map;
}

R6502HOSTMAP* uservia05read(R6502HOSTMAP* map, unsigned int address_code)
{
  int cyclecount;

  /*T1 high order counter*/
  TIMER_GET_PERIPHERAL_CYCLE_COUNT(cyclecount, map, usrvia)
  map->m = ((map->s2usrvia.t1doubled - cyclecount)>>9)&0xFF;

  return map;
}

R6502HOSTMAP* uservia06read(R6502HOSTMAP* map, unsigned int address_code)
{
  /*T1 low order latch*/
  map->m = map->s0usrvia.t1ll;

  return map;
}

