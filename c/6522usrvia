struct R6502CPUMAP* uservia05write(struct R6502CPUMAP* ctop, uintptr_t address_code, uint8_t value)
{
  /*T1 high order counter*/
  HOSTMAP* htop = (HOSTMAP*)ctop;
  intptr_t expiryoffset;

  htop[-1].A_usrvia.t1lh = value;
  /*clear T1 interrupt flag (b6)*/
  htop[-1].A_usrvia.ifr &= 0xBF;
  userviaregistersetirq(htop);
  if ((htop[-1].A_usrvia.acr & 0xC0) == 0x80)
  {
    /*output enabled (b7=1) and free-run disabled (b6=0)*/
    /*one-shot mode*/
    /*PB7 goes low, but goes high when timer 1 times out*/
    /*htop[-1].A_usrvia.orb &= 0x7F;
    htop[-1].A_usrvia.irb &= 0x7F;*/
    htop[-1].A_usrvia.portb &= 0x7F;
  }
  htop[-1].A_usrvia.t1setint = TRUE;
  htop[-1].B_usrvia.t1doubled = (htop[-1].A_usrvia.t1lh<<9) | (htop[-1].A_usrvia.t1ll<<1);
  HOST_GET_1MHZ_PERIPHERAL_TOGO_FROM_WRITE_OFFSET(expiryoffset, htop, usrvia)
  htop[-1].B_usrvia.t1doubled += expiryoffset;
  // the interrupt flag is set after the counter has passed through zero
  HOST_LIMIT_PERIPHERAL_CYCLES_TO_GO(htop, usrvia, htop[-1].B_usrvia.t1doubled + 2)
  htop[-1].A_usrvia.aftert1 = 0;

  return ctop;
}

