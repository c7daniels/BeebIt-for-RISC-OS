{
  /*T1 high order latch*/
  HOSTMAP* htop = (HOSTMAP*)ctop;
  htop[-1].m = htop[-1].A_usrvia.t1lh;

  return ctop;
}

struct R6502CPUMAP* uservia08read(struct R6502CPUMAP* ctop, uintptr_t address_code)
{
  /*T2 low order counter*/
  HOSTMAP* htop = (HOSTMAP*)ctop;
  intptr_t cyclecount;

  /*T2 interrupt flag is cleared (IFR b5)*/
  htop[-1].A_usrvia.ifr &= 0xDF;
  userviaregistersetirq(htop);
  if (!(htop[-1].A_usrvia.acr & 0x20))
  {
    HOST_GET_PERIPHERAL_CYCLE_COUNT(cyclecount, htop, usrvia)
    htop[-1].m = ((htop[-1].B_usrvia.t2doubled - cyclecount)>>1)&0xFF;
  }
  else
  {
    htop[-1].m = (htop[-1].B_usrvia.t2doubled>>1)&0xFF;
  }

  return ctop;
}

struct R6502CPUMAP* uservia09read(struct R6502CPUMAP* ctop, uintptr_t address_code)
{
  /*T2 high order counter*/
  HOSTMAP* htop = (HOSTMAP*)ctop;
  intptr_t cyclecount;

  if (!(htop[-1].A_usrvia.acr & 0x20))
  {
    HOST_GET_PERIPHERAL_CYCLE_COUNT(cyclecount, htop, usrvia)
    htop[-1].m = ((htop[-1].B_usrvia.t2doubled - cyclecount)>>9)&0xFF;
  }
