struct R6502CPUMAP* uservia0Dread(struct R6502CPUMAP* ctop, uintptr_t address_code)
{
  /*interrupt flag reg*/
  HOSTMAP* htop = (HOSTMAP*)ctop;
  /*b7 of this register will be read as a logic 1*/
  /*when an interrupt exists within the chip*/
  userviaregistersetirq(htop);
  htop[-1].m = htop[-1].A_usrvia.ifr;

  return ctop;
}

struct R6502CPUMAP* uservia0Eread(struct R6502CPUMAP* ctop, uintptr_t address_code)
{
  /*interrupt enable reg*/
  HOSTMAP* htop = (HOSTMAP*)ctop;
  htop[-1].m = (htop[-1].A_usrvia.ier | 0x80);

  return ctop;
}

struct R6502CPUMAP* uservia0Fread(struct R6502CPUMAP* ctop, uintptr_t address_code)
{
  /*output reg a*/
  HOSTMAP* htop = (HOSTMAP*)ctop;
  if (htop[-1].A_usrvia.acr & 0x01)
  {
    /*latching enabled*/
    htop[-1].m = htop[-1].A_usrvia.ira;
  }
  else
  {
    /*latching disabled*/
    htop[-1].m = htop[-1].A_usrvia.porta;
  }

  return ctop;
}

struct R6502CPUMAP* uservia00write(struct R6502CPUMAP* ctop, uintptr_t address_code, uint8_t value)
{
  /*input/output reg b*/
  HOSTMAP* htop = (HOSTMAP*)ctop;
  htop[-1].A_usrvia.orb = value;
  htop[-1].A_usrvia.portb = (htop[-1].A_usrvia.orb & htop[-1].A_usrvia.ddrb) | (htop[-1].A_usrvia.portb & ~htop[-1].A_usrvia.ddrb);
  /*PCR & 0x20 = CB2 input*/
  /*PCR & 0x40 = CB2 active edge input*/
  /*independant mode*/
  if (((htop[-1].A_usrvia.pcr & 0xE0) == 0x20) OR ((htop[-1].A_usrvia.pcr & 0xE0) == 0x60))
  {
    /*clear b4 (CB1)*/
    htop[-1].A_usrvia.ifr &= 0xEF;
  }
  else
  {
    /*clear b4,b3 (CB1,CB2)*/
    htop[-1].A_usrvia.ifr &= 0xE7;
  }
  userviaregistersetirq(htop);

  return ctop;
}

struct R6502CPUMAP* uservia01write(struct R6502CPUMAP* ctop, uintptr_t address_code, uint8_t value)
{
  /*input/output reg a*/
  HOSTMAP* htop = (HOSTMAP*)ctop;
  /*VDU 21 writes &0D (%1101) only*/
  /*VDU 2 writes &OD then character*/
  htop[-1].A_usrvia.ora = value;
  htop[-1].A_usrvia.porta = (htop[-1].A_usrvia.ora & htop[-1].A_usrvia.ddra) | (htop[-1].A_usrvia.porta & ~htop[-1].A_usrvia.ddra);
  /*PCR & 0x02 = CA2 input*/
  /*PCR & 0x04 = CA2 active edge input*/
  if (((htop[-1].A_usrvia.pcr & 0x0E) == 0x02) OR ((htop[-1].A_usrvia.pcr & 0x0E) == 0x06))
  {
    /*clear b2 (CA1)*/
    htop[-1].A_usrvia.ifr &= 0xFD;
  }
  else
  {
    /*clear b2,b1 (CA1,CA2)*/
    htop[-1].A_usrvia.ifr &= 0xFC;
  }
#ifdef __RISCOS__
  if (beebit_printer)
  {
    regs.r[0] = htop[-1].A_usrvia.porta;
    _kernel_swi(OS_PrintChar,&regs,&regs);
  }
#endif
  /*clear b2 (CA1)*/
  htop[-1].A_usrvia.ifr |= 0x02; /*CA1*/
  userviaregistersetirq(htop);

  return ctop;
}

