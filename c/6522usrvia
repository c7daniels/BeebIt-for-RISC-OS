}

R6502HOSTMAP* uservia08read(R6502HOSTMAP* map, unsigned int address_code)
{
  int cyclecount;

  /*T2 low order counter*/
  /*T2 interrupt flag is cleared (IFR b5)*/
  map->s0usrvia.ifr &= 0xDF;
  userviasetirq();
  if (!(map->s0usrvia.acr & 0x20))
  {
    TIMER_GET_PERIPHERAL_CYCLE_COUNT(cyclecount, map, usrvia)
    map->m = ((map->s2usrvia.t2doubled - cyclecount)>>1)&0xFF;
  }
  else
  {
    map->m = (map->s2usrvia.t2doubled>>1)&0xFF;
  }

  return map;
}

