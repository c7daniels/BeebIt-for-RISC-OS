struct R6502CPUMAP* uservia09write(struct R6502CPUMAP* ctop, uintptr_t address_code, uint8_t value)
{
  /*T2 high order counter*/
  HOSTMAP* htop = (HOSTMAP*)ctop;
  intptr_t expiryoffset;

  /*clear T2 interrupt flag (bit 5)*/
  htop[-1].A_usrvia.ifr &= 0xDF;
  userviaregistersetirq(htop);
  /*provide a single interrupt*/
  htop[-1].A_usrvia.t2setint = TRUE;
  if (!(htop[-1].A_usrvia.acr & 0x20))
  {
    /*one-shot mode*/
    htop[-1].B_usrvia.t2doubled = (value<<9) | (htop[-1].A_usrvia.t2ll<<1);
    HOST_GET_1MHZ_PERIPHERAL_TOGO_FROM_WRITE_OFFSET(expiryoffset, htop, usrvia)
    htop[-1].B_usrvia.t2doubled += expiryoffset;
    // the interrupt flag is set after the counter has passed through zero
    HOST_LIMIT_PERIPHERAL_CYCLES_TO_GO(htop, usrvia, htop[-1].B_usrvia.t2doubled + 2)
  }
  else
  {
    /*pulse counting mode*/
    htop[-1].B_usrvia.t2doubled = (value<<9) | (htop[-1].A_usrvia.t2ll<<1);
  }

  return ctop;
}

struct R6502CPUMAP* uservia0Awrite(struct R6502CPUMAP* ctop, uintptr_t address_code, uint8_t value)
{
