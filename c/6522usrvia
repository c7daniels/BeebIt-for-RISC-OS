}

struct R6502CPUMAP* uservia0Bwrite(struct R6502CPUMAP* ctop, uintptr_t address_code, uint8_t value)
{
  /*auxiliary control reg*/
  HOSTMAP* htop = (HOSTMAP*)ctop;
  intptr_t expiryoffset;

  if ((htop[-1].A_usrvia.acr ^ value) & 0x20)
  {
    HOST_GET_1MHZ_PERIPHERAL_TOGO_FROM_WRITE_OFFSET(expiryoffset, htop, usrvia)
    if (!(value & 0x20))
    {
      /*one-shot mode*/
      htop[-1].B_usrvia.t2doubled += expiryoffset;
      HOST_LIMIT_PERIPHERAL_CYCLES_TO_GO(htop, usrvia, htop[-1].B_usrvia.t2doubled + 2)
    }
    else
    {
      /*pulse counting mode*/
      htop[-1].B_usrvia.t2doubled -= expiryoffset;
    }
  }
  htop[-1].A_usrvia.acr = value;

  return ctop;
}

struct R6502CPUMAP* uservia0Cwrite(struct R6502CPUMAP* ctop, uintptr_t address_code, uint8_t value)
{
  /*peripheral control reg*/
  HOSTMAP* htop = (HOSTMAP*)ctop;
  htop[-1].A_usrvia.pcr = value;
  /*CA1 active edge*/
  if (htop[-1].A_usrvia.pcr & 0x01)
  {
    /*set b2 (CA1)*/
    htop[-1].A_usrvia.ifr |= 0x02;
  }
  /*CA2 active edge*/
  if ((htop[-1].A_usrvia.pcr & 0x0E) == 0x04)
  {
    /*set b1 (CA2)*/
    htop[-1].A_usrvia.ifr |= 0x01;
  }
  /*CB1 active edge*/
  if (htop[-1].A_usrvia.pcr & 0x10)
  {
    /*set b5 (CB1)*/
    htop[-1].A_usrvia.ifr |= 0x10;
  }
  /*CB2 active edge*/
  if ((htop[-1].A_usrvia.pcr & 0xE0) == 0x40)
  {
    /*set b4 (CB2)*/
    htop[-1].A_usrvia.ifr |= 0x08;
  }

  return ctop;
}

struct R6502CPUMAP* uservia0Dwrite(struct R6502CPUMAP* ctop, uintptr_t address_code, uint8_t value)
{
  /*interrupt flag reg*/
  HOSTMAP* htop = (HOSTMAP*)ctop;
  value &= 0x7F; /*not really needed*/
  htop[-1].A_usrvia.ifr &= (~value);
  userviaregistersetirq(htop);

  return ctop;
}

struct R6502CPUMAP* uservia0Ewrite(struct R6502CPUMAP* ctop, uintptr_t address_code, uint8_t value)
{
  /*interrupt enable reg*/
  HOSTMAP* htop = (HOSTMAP*)ctop;
  if (value & 0x80)
    htop[-1].A_usrvia.ier |= value;
  else
    htop[-1].A_usrvia.ier &= (~value);
  htop[-1].A_usrvia.ier &= 0x7F;
  userviaregistersetirq(htop);

  return ctop;
}

struct R6502CPUMAP* uservia0Fwrite(struct R6502CPUMAP* ctop, uintptr_t address_code, uint8_t value)
{
  /*output reg a*/
  HOSTMAP* htop = (HOSTMAP*)ctop;
  htop[-1].A_usrvia.ora = value;
  htop[-1].A_usrvia.porta = (htop[-1].A_usrvia.ora & htop[-1].A_usrvia.ddra) +(htop[-1].A_usrvia.porta & ~htop[-1].A_usrvia.ddra);

  return ctop;
}
