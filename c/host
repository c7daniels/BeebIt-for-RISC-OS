R6502CPUMAP* host_r6502touch8000_0(R6502CPUMAP* ctop, uintptr_t address_code, const R6502ADDRESSINGCALLBACKS* callbacks)
{
  /*&8000 - &BFFF (SIDEWAYS RAM)*/
  HOSTMAP* htop = (HOSTMAP*)ctop;
  HOSTMEMORY* mmap = (HOSTMEMORY*)ctop;
  uint8_t* p = &mmap->roms[0][(address_code>>16)-0x8000];
  /*check sideways ram write enabled*/
  if (htop[-1].romwritable[0])
    ADDRESS_TOUCH_RETURN(ctop, p)
  else
    ADDRESS_TOUCH_COPY_RETURN(ctop, p)
}

