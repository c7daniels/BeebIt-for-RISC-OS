R6502CPUMAP* host_r6502touchF000(R6502CPUMAP* ctop, uintptr_t address_code, const R6502ADDRESSINGCALLBACKS* callbacks)
{
  HOSTMAP* htop = (HOSTMAP*)ctop;
  HOSTMEMORY* mmap = (HOSTMEMORY*)ctop;
  if (address_code >= 0xFC000000)
  {
    return htop[-1].touchhigh[(address_code>>16)-0xFC00](ctop, address_code, callbacks);
  }
  else
  {
    /*&F000 - &FBFF (OS - should not be allowed!)*/
    ADDRESS_TOUCH_COPY_RETURN(ctop, &mmap->memory[address_code>>16])
  }
}

