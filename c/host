void hostinit(void)
{
  hostmap.lower.keycolumnflags = 0xFFFFFFFF;

  videoinit();
}

void hostapplysoundoption(void)
{
  HOSTMAP* htop = (HOSTMAP*)&hostmap.upper;
  R6502WRITESPECIALOP* specialwriteops = &htop[-1].specialwriteops[0x200];
  int i;

  for (i=0x40; i<0x60; i+=0x10)
  {
    if (beebit_machinetype == MACHINE_MASTER128 || beebit_machinetype == MACHINE_COMPACT)
    {
      if (beebit_sound)
      {
        specialwriteops[i] = systemvia00write_m;
        specialwriteops[i+0x01] = systemvia01write_m;
        specialwriteops[i+0x0F] = systemvia0Fwrite_m;
      }
      else
      {
        specialwriteops[i] = systemvia00write_nosoundm;
        specialwriteops[i+0x01] = systemvia01write_nosoundm;
        specialwriteops[i+0x0F] = systemvia0Fwrite_nosoundm;
      }
    }
    else
    {
      if (beebit_sound)
      {
        specialwriteops[i] = systemvia00write_b;
        specialwriteops[i+0x01] = systemvia01write_b;
        specialwriteops[i+0x0F] = systemvia0Fwrite_b;
      }
      else
      {
        specialwriteops[i] = systemvia00write_nosoundb;
        specialwriteops[i+0x01] = systemvia01write_nosoundb;
        specialwriteops[i+0x0F] = systemvia0Fwrite_nosoundb;
      }
    }
  }
}

void hostresetcpu(void)
{
  R6502CPUMAP* ctop = (R6502CPUMAP*)&hostmap.upper;
  const R6502OP* const *mainsequences;
  const R6502OP* const extrasequences[R6502_EXTRA_SEQUENCE_COUNT] = {
    host_r6502_opcode07interfacesequence
  };
#ifndef BEEBIT_NO_ASM
  void (*assemblyroutinereset)(R6502CPUMAP* ctop);
#endif

  switch (beebit_machinetype)
  {
    case MACHINE_MODELB:
    case MACHINE_MODELBPLUS:
      mainsequences = r6502sequences;
#ifndef BEEBIT_NO_ASM
      assemblyroutinereset = r6502assemblyroutinereset;
#endif
      break;
    case MACHINE_MASTER128:
    case MACHINE_COMPACT:
      mainsequences = r65c12sequences;
#ifndef BEEBIT_NO_ASM
      assemblyroutinereset = r65c12assemblyroutinereset;
#endif
      break;
  }

  r6502reset(ctop, mainsequences, extrasequences);

  ctop[-1].resetstartingaction = host_r6502onresetstart;
  ctop[-1].resetcontinuingaction = host_r6502onresetcontinue;

#ifndef BEEBIT_NO_ASM
  assemblyroutinereset(ctop);
#endif
}

void hostresetperipherals(void)
{
  R6502CPUMAP* ctop = (R6502CPUMAP*)&hostmap.upper;
  HOSTMAP* htop = (HOSTMAP*)ctop;
  const R6502ADDRESSINGOP initialtouchops[0x10] = {
    host_r6502touch0000, host_r6502touch0000, host_r6502touch0000,
    host_r6502touch0000, host_r6502touch0000, host_r6502touch0000, host_r6502touch0000, host_r6502touch0000,
    host_r6502touch8000_0, host_r6502touch8000_0, host_r6502touch8000_0, host_r6502touch8000_0,
    host_r6502touchC000, host_r6502touchC000, host_r6502touchC000,
    host_r6502touchF000
  };
  const R6502ADDRESSINGOP touch8000s[0x10] =
  {
    host_r6502touch8000_0, host_r6502touch8000_1,
    host_r6502touch8000_2, host_r6502touch8000_3,
    host_r6502touch8000_4, host_r6502touch8000_5,
    host_r6502touch8000_6, host_r6502touch8000_7,
    host_r6502touch8000_8, host_r6502touch8000_9,
    host_r6502touch8000_A, host_r6502touch8000_B,
    host_r6502touch8000_C, host_r6502touch8000_D,
    host_r6502touch8000_E, host_r6502touch8000_F
  };
  R6502ADDRESSINGOP touchFC00;
  R6502READSPECIALOP readfred, readjim;
  R6502WRITESPECIALOP writefred, writejim;
  const int slow_mask = 0x0F00FF0F;
  int i;

  ctop[-1].oldreset = 1;

  htop[-1].cycles.odd = 0;
  htop[-1].cycles.originalminusone = 0x1FFFF;
  htop[-1].togominusone_cyclestate = (htop[-1].cycles.originalminusone<<12)|(htop[-1].togominusone_cyclestate&0x0FFF);
  htop[-1].interrupts = 0;

  ctop[-1].readspecialaction = host_r6502readspecial;
  ctop[-1].writespecialaction = host_r6502writespecial;

  for (i=0; i<16; i++)
  {
    ctop[-1].addressingops[31-i].op = initialtouchops[i];
  }

  memcpy(htop[-1].touch8000s, touch8000s, sizeof(touch8000s));

  if (beebit_machinetype == MACHINE_MODELBPLUS)
  {
    /*make rom F use rom E*/
    htop[-1].touch8000s[0xF] = touch8000s[0xE];
  }

  switch (beebit_machinetype)
  {
    default:
      htop[-1].paging.touch3000_ram_x = NULL;
      htop[-1].paging.touch3000_ramram_e = NULL;
      break;
    case MACHINE_MODELBPLUS:
      htop[-1].paging.touch3000_ram_x = host_r6502touchbp3000_ram;
      htop[-1].paging.touch3000_ramram_e = host_r6502touchbp3000_ramram;
      break;
    case MACHINE_MASTER128:
    case MACHINE_COMPACT:
      htop[-1].paging.touch3000_ram_x = host_r6502touchm3000_x;
      htop[-1].paging.touch3000_ramram_e = host_r6502touchm3000_e;
      break;
  }

  switch (beebit_machinetype)
  {
    default:
      htop[-1].paging.touchC000_y = NULL;
      touchFC00 = host_r6502touchFE00_slow;
      readfred = host_r6502readfred;
      readjim = host_r6502readjim;
      writefred = host_r6502writefred;
      writejim = host_r6502writejim;
      break;
    case MACHINE_MASTER128:
    case MACHINE_COMPACT:
      htop[-1].paging.touchC000_y = host_r6502touchmC000_y;
      touchFC00 = host_r6502touchmFC00;
      readfred = host_r6502readmfred;
      readjim = host_r6502readmjim;
      writefred = host_r6502writemfred;
      writejim = host_r6502writemjim;
      break;
  }

  switch (beebit_machinetype)
  {
    default:
      htop[-1].paging.touch8000_ram = NULL;
      htop[-1].paging.screenopcode07rom = screenopcode07romb;
      htop[-1].paging.swapintomemory = swappagesintomemoryb;
      htop[-1].paging.swapoutofmemory = swappagesoutofmemoryb;
      break;
    case MACHINE_MODELBPLUS:
      htop[-1].paging.touch8000_ram = host_r6502touchbp8000_ram;
      htop[-1].paging.screenopcode07rom = screenopcode07rombp;
      htop[-1].paging.swapintomemory = swappagesintomemorybp;
      htop[-1].paging.swapoutofmemory = swappagesoutofmemorybp;
      break;
    case MACHINE_MASTER128:
    case MACHINE_COMPACT:
      htop[-1].paging.touch8000_ram = host_r6502touchm8000_ram;
      htop[-1].paging.screenopcode07rom = screenopcode07romm;
      htop[-1].paging.swapintomemory = swappagesintomemorym;
      htop[-1].paging.swapoutofmemory = swappagesoutofmemorym;
      break;
  }

  htop[-1].paging.touchFC00 = host_r6502touchFE00_slow;
  htop[-1].paging.touchFC00_ifj = host_r6502touchFE00_fast;
  htop[-1].touchmFC00 = host_r6502touchFE00_slow;

  for (i=0; i<0x200; i++)
  {
    htop[-1].touchhigh[i] = touchFC00;
  }
  for (i=0; i<0x100; i++)
  {
    if (slow_mask & (1<<(i>>3)))
      htop[-1].touchhigh[0x200+i] = host_r6502touchFE00_slow;
    else
      htop[-1].touchhigh[0x200+i] = host_r6502touchFE00_fast;
  }
  for (i=0; i<0x100; i++)
  {
    htop[-1].touchhigh[0x300+i] = host_r6502touchC000;
  }

  for (i=0; i<0x100; i++)
  {
    htop[-1].specialreadops[i] = readfred;
    htop[-1].specialwriteops[i] = writefred;
  }
  for (i=0; i<0x100; i++)
  {
    htop[-1].specialreadops[0x100+i] = readjim;
    htop[-1].specialwriteops[0x100+i] = writejim;
  }

  switch (beebit_machinetype)
  {
    default:
      htop[-1].keycolumnflags = 0x2AA80000|(htop[-1].keycolumnflags&0x55555555);
      break;
    case MACHINE_MASTER128:
    case MACHINE_COMPACT:
      htop[-1].keycolumnflags = 0x2A000000|(htop[-1].keycolumnflags&0x55555555);
      break;
  }

  ctop[-1].stretchcycleaction = host_r6502cycle0s1;
  ctop[-1].cycleaction = host_r6502cycle1;

  sheilareset();
  aciareset();
  adcreset();
  videoulareset();
  crtcreset();
  keyboardreset();
  systemviareset();
  videoreset();
  soundreset();

#ifndef BEEBIT_NO_ASM
  extern const uintptr_t hoststeps[832];

  memcpy(htop[-1].steproutines, hoststeps, sizeof(hoststeps));
  hostassemblyroutinereset(htop);
#endif

  r6502swapopcode07(ctop);
  hoststartreset(TRUE);
}

#ifdef BEEBIT_NO_ASM
HOSTMAP* hostadvancetimers(HOSTMAP* htop)
