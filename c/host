static inline void hoststep(HOSTMAP* htop)
{
  const uint32_t overflowmask = KEYSCANIDLEOVERFLOW|KEYSCANCOLUMNOVERFLOW;
  const uint32_t keytestmask = KEYSCANINPUTFLAG|KEYSCANWRITEENABLEFLAG;
  const uint32_t ca2testmask = KEYSCANIFRFLAG|KEYSCANCA2FLAG;
  const uint32_t notwiredbit = 1U<<31;
  const uint32_t notactivebit = 1U<<30;
  uintptr_t togominusone_cyclestate = htop[-1].togominusone_cyclestate;
  uintptr_t columnflags = htop[-1].keycolumnflags;
  int rotation = togominusone_cyclestate&31;
  int atzerocycles;

  columnflags = (((columnflags<<(32-rotation))&0xFFFFFFFF)|(columnflags>>rotation));
  columnflags |= (columnflags>>1);

  if ((togominusone_cyclestate & (KEYSCANIDLEFLAG|keytestmask)) == keytestmask)
  {
    if (!(columnflags & notwiredbit) && (htop[-1].keystatus[(togominusone_cyclestate>>1)&0xF] & htop[-1].keybit))
      htop[-1].A_sysvia.porta |= 0x80;
    else
      htop[-1].A_sysvia.porta &= ~0x80;
  }

  switch (togominusone_cyclestate & (KEYSCANIDLEFLAG|ca2testmask))
  {
    case 0:
      if (!(columnflags & notactivebit))
      {
        togominusone_cyclestate += KEYSCANCA2FLAG;
        if (systemviasetca2(htop))
          togominusone_cyclestate += KEYSCANIFRFLAG;
      }
      break;
    case KEYSCANCA2FLAG:
      if (columnflags & notactivebit)
      {
        togominusone_cyclestate -= KEYSCANCA2FLAG;
        if (systemviaunsetca2(htop))
          togominusone_cyclestate += KEYSCANIFRFLAG;
      }
      break;
    case KEYSCANIFRFLAG:
      if (!(columnflags & notactivebit))
      {
        togominusone_cyclestate += KEYSCANCA2FLAG;
      }
      break;
    case KEYSCANIFRFLAG|KEYSCANCA2FLAG:
      if (columnflags & notactivebit)
      {
        togominusone_cyclestate -= KEYSCANCA2FLAG;
      }
      break;
  }

  if ((togominusone_cyclestate & KEYSCANIDLEFLAG) && (togominusone_cyclestate & KEYSCANWRITEENABLEFLAG))
    togominusone_cyclestate += KEYSCANIDLEFLAG + 31;
  else
    togominusone_cyclestate += KEYSCANIDLEFLAG + 1;

  atzerocycles = (togominusone_cyclestate>>12) == 0;
  htop[-1].togominusone_cyclestate = (togominusone_cyclestate-(1<<12)) &~ overflowmask;

  if (atzerocycles)
    hostadvancetimers(htop);
}

R6502CPUMAP* host_r6502cycle0s1(R6502CPUMAP* ctop)
{
  HOSTMAP* htop = (HOSTMAP*)ctop;

  hoststep(htop);
  return ctop;
}

R6502CPUMAP* host_r6502cycle1(R6502CPUMAP* ctop)
{
  HOSTMAP* htop = (HOSTMAP*)ctop;
  uintptr_t interruptqueue_ps = ctop[-1].interruptqueue_ps;

  interruptqueue_ps = ((interruptqueue_ps&~0xFF)<<4) | (interruptqueue_ps&0x0FFF);
  if (!(interruptqueue_ps & R6502_NMI))
    interruptqueue_ps |= R6502_NMI_ENABLE;
  ctop[-1].interruptqueue_ps = interruptqueue_ps;

  hoststep(htop);
  return ctop;
}

