static inline void hoststartreset(int poweron)
{
  userviastartreset(poweron);

  i8271reset();
  w1770reset();
}

static inline void hostendreset(void)
{
  userviafinishreset();

  i8271reset();
  w1770reset();
}

static R6502CPUMAP* host_r6502onresetstart(R6502CPUMAP* ctop)
{
  hoststartreset(FALSE);
  return ctop;
}

static R6502CPUMAP* host_r6502onresetcontinue(R6502CPUMAP* ctop)
{
  hostendreset();
  return ctop;
}

#ifdef BEEBIT_NO_ASM
void swappages(uint8_t *block1, uint8_t *block2, int npagecount)
{
  char swap[256];
  for (; npagecount > 0; npagecount--)
  {
    memcpy(swap,block1,256);
    memcpy(block1,block2,256);
    memcpy(block2,swap,256);
    block1 += 256;
    block2 += 256;
  }
}

#define ADDRESS_TOUCH_RETURN(CTOP, PTR) \
  return callbacks->mapped(CTOP, PTR);

#define ADDRESS_TOUCH_COPY_RETURN(CTOP, PTR) \
  { \
    CTOP[-1].copiedvalue = *(PTR); \
    return callbacks->mapped(CTOP, &CTOP[-1].copiedvalue); \
  }

R6502CPUMAP* host_r6502touch0000(R6502CPUMAP* ctop, uintptr_t address_code, const R6502ADDRESSINGCALLBACKS* callbacks)
{
  /*&0000 - &2FFF (RAM)*/
  /*&3000 - &7FFF not shadow mode*/
  HOSTMEMORY* mmap = (HOSTMEMORY*)ctop;
  ADDRESS_TOUCH_RETURN(ctop, &mmap->memory[address_code>>16])
}

R6502CPUMAP* host_r6502touchbp3000_ram(R6502CPUMAP* ctop, uintptr_t address_code, const R6502ADDRESSINGCALLBACKS* callbacks)
{
  /*bbc b+*/
  /*&3000 - &7FFF*/
  /*shadow mode*/
  HOSTMEMORY* mmap = (HOSTMEMORY*)ctop;
  uintptr_t pc = ctop[-1].sync_pc_code;
  uint8_t* block;
  if (pc >= 0xC0000000 AND pc < 0xE0000000)
    block = mmap->shadow;
  else
    block = mmap->memory;
  ADDRESS_TOUCH_RETURN(ctop, &block[address_code>>16])
}

R6502CPUMAP* host_r6502touchbp3000_ramram(R6502CPUMAP* ctop, uintptr_t address_code, const R6502ADDRESSINGCALLBACKS* callbacks)
{
  /*bbc b+*/
  /*&3000 - &7FFF*/
  /*shadow mode plus 12K ram*/
  HOSTMEMORY* mmap = (HOSTMEMORY*)ctop;
  uintptr_t pc = ctop[-1].sync_pc_code;
  uint8_t* block;
  if (pc >= 0xA0000000 AND pc < 0xB0000000)
    block = mmap->shadow;
  else if (pc >= 0xC0000000 AND pc < 0xE0000000)
    block = mmap->shadow;
  else
    block = mmap->memory;
  ADDRESS_TOUCH_RETURN(ctop, &block[address_code>>16])
}

