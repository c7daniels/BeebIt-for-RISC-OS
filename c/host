HOSTMAP* swappagesintomemoryb(HOSTMAP* htop)
{
  HOSTMEMORY* mmap = (HOSTMEMORY*)htop;
  int nrom;

  nrom = htop[-1].romsel & 0x0F;
  memcpy(&mmap->memory[0x8000],mmap->roms[nrom],0x4000);
  return htop;
}

HOSTMAP* swappagesintomemorybp(HOSTMAP* htop)
{
  HOSTMEMORY* mmap = (HOSTMEMORY*)htop;
  R6502CPUMAP* ctop = (R6502CPUMAP*)htop;
  int nrom;
  uintptr_t pc = (ctop[-1].sync_pc_code>>16);

  if ((pc >= 0xC000 AND pc < 0xE000)
    OR ((htop[-1].romsel & 0x80) AND pc >= 0xA000 AND pc < 0xB000))
  {
    swappages(&mmap->memory[0x3000],&mmap->shadow[0x3000],0x50);
  }

  nrom = htop[-1].romsel & 0x0F;
  if (nrom == 0x0F)
    nrom = 0x0E;
  if (htop[-1].romsel & 0x80)
  {
    memcpy(&mmap->memory[0x8000],mmap->shadow,0x3000);
    memcpy(&mmap->memory[0xB000],&mmap->roms[nrom][0x3000],0x1000);
  }
  else
    memcpy(&mmap->memory[0x8000],mmap->roms[nrom],0x4000);
  return htop;
}

