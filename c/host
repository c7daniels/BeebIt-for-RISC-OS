{
  HOSTMEMORY* mmap = (HOSTMEMORY*)htop;
  R6502CPUMAP* ctop = (R6502CPUMAP*)htop;
  int nrom;
  uintptr_t pc = (ctop[-1].sync_pc_code>>16);

  if ((htop[-1].acccon & 0x04)
    OR ((htop[-1].acccon & 0x02) AND pc >= 0xC000 AND pc < 0xE000))
  {
    swappages(&mmap->memory[0x3000],&mmap->shadow[0x3000],0x50);
  }

  nrom = htop[-1].romsel & 0x0F;
  if (htop[-1].romsel & 0x80)
  {
    memcpy(&mmap->memory[0x8000],mmap->shadow,0x1000);
    memcpy(&mmap->memory[0x9000],&mmap->roms[nrom][0x1000],0x3000);
  }
  else
    memcpy(&mmap->memory[0x8000],mmap->roms[nrom],0x4000);

  if (htop[-1].acccon & 0x04)
    swappages(&mmap->memory[0xC000],&mmap->shadow[0x1000],0x20);

  return htop;
}

