struct R6502CPUMAP* systemvia09write(struct R6502CPUMAP* ctop, uintptr_t address_code, uint8_t value)
{
  /*T2 high order counter*/
  HOSTMAP* htop = (HOSTMAP*)ctop;
  intptr_t expiryoffset;

  /*clear T2 interrupt flag (bit 5)*/
  htop[-1].A_sysvia.ifr &= 0xDF;
  systemviaregistersetirq(htop);
  /*provide a single interrupt*/
  htop[-1].A_sysvia.t2setint=TRUE;
  if (!(htop[-1].A_sysvia.acr & 0x20))
  {
    /*one-shot mode*/
    htop[-1].B_sysvia.t2doubled = (value<<9) | (htop[-1].A_sysvia.t2ll<<1);
    HOST_GET_1MHZ_PERIPHERAL_TOGO_FROM_WRITE_OFFSET(expiryoffset, htop, sysvia)
    htop[-1].B_sysvia.t2doubled += expiryoffset;
    // the interrupt flag is set after the counter has passed through zero
    HOST_LIMIT_PERIPHERAL_CYCLES_TO_GO(htop, sysvia, htop[-1].B_sysvia.t2doubled + 2)
  }
  else
  {
    /*pulse counting mode*/
    htop[-1].B_sysvia.t2doubled = (value<<9) | (htop[-1].A_sysvia.t2ll<<1);
    /*speech system not available*/
  }

  return ctop;
}

struct R6502CPUMAP* systemvia0Awrite(struct R6502CPUMAP* ctop, uintptr_t address_code, uint8_t value)
