static inline void systemviaportbwrite(HOSTMAP* htop, uint8_t value)
{
  /*input/output reg b*/
  htop[-1].A_sysvia.orb = value;
  htop[-1].A_sysvia.portb = (htop[-1].A_sysvia.orb & htop[-1].A_sysvia.ddrb) | (htop[-1].A_sysvia.portb & ~htop[-1].A_sysvia.ddrb);
  /*PCR & 0x20 = CB2 input*/
  /*PCR & 0x40 = CB2 active edge input*/
  /*independant mode*/
  if (((htop[-1].A_sysvia.pcr & 0xE0) == 0x20) OR ((htop[-1].A_sysvia.pcr & 0xE0) == 0x60))
  {
    /*clear b4 (CB1)*/
    htop[-1].A_sysvia.ifr &= 0xEF;
  }
  else
  {
    /*clear b4,b3 (CB1,CB2)*/
    htop[-1].A_sysvia.ifr &= 0xE7;
  }
  systemviaregistersetirq(htop);
}

static inline void systemviaportawrite(HOSTMAP* htop, uint8_t value)
{
  /*input/output reg a*/
  /*zeribeep_value = value;*/
  htop[-1].A_sysvia.ora = value;
  htop[-1].A_sysvia.porta = (htop[-1].A_sysvia.ora & htop[-1].A_sysvia.ddra) | (htop[-1].A_sysvia.porta & ~htop[-1].A_sysvia.ddra);
  /*PCR & 0x02 = CA2 input*/
  /*PCR & 0x04 = CA2 active edge input*/
  /*indepandant mode*/
  if (((htop[-1].A_sysvia.pcr & 0x0E) == 0x02) OR ((htop[-1].A_sysvia.pcr & 0x0E) == 0x06))
  {
    /*clear b2 (CA1)*/
    htop[-1].A_sysvia.ifr &= 0xFD;
  }
  else
  {
    /*clear b2,b1 (CA1,CA2)*/
    htop[-1].A_sysvia.ifr &= 0xFC;
  }
  systemviaregistersetirq(htop);
}

