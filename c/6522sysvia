R6502HOSTMAP* systemvia09write(R6502HOSTMAP* map, unsigned int address_code)
{
  int expiryoffset;

  /*T2 high order counter*/
  /*clear T2 interrupt flag (bit 5)*/
  map->s0sysvia.ifr &= 0xDF;
  systemviasetirq();
  /*provide a single interrupt*/
  map->s2sysvia.t2setint=TRUE;
  if (!(map->s0sysvia.acr & 0x20))
  {
    /*one-shot mode*/
    map->s2sysvia.t2doubled = (map->m<<9) | (map->s0sysvia.t2ll<<1);
    TIMER_GET_1MHZ_PERIPHERAL_TOGO_FROM_WRITE_OFFSET(expiryoffset, map, sysvia)
    map->s2sysvia.t2doubled += expiryoffset;
    // the interrupt flag is set after the counter has passed through zero
    TIMER_LIMIT_PERIPHERAL_CYCLES_TO_GO(map, sysvia, map->s2sysvia.t2doubled + 2)
  }
  else
  {
    /*pulse counting mode*/
    map->s2sysvia.t2doubled = (map->m<<9) | (map->s0sysvia.t2ll<<1);
    /*speech system not available*/
  }

  return map;
}

