static intptr_t systemviapickcyclestogo(void)
{
  HOSTMAP* htop = (HOSTMAP*)&hostmap.upper;
  intptr_t cyclestogo;

  // the interrupt flag is set after the counter has passed through zero
  if (!(htop[-1].A_sysvia.acr & 0x20))
  {
    if (htop[-1].B_sysvia.t1doubled < htop[-1].B_sysvia.t2doubled)
    {
      cyclestogo = htop[-1].B_sysvia.t1doubled + 2;
    }
    else
    {
      cyclestogo = htop[-1].B_sysvia.t2doubled + 2;
    }
  }
  else
  {
    cyclestogo = htop[-1].B_sysvia.t1doubled + 2;
  }

  if (htop[-1].A_sysvia.aftert1)
  {
    cyclestogo = 1;
  }

  return cyclestogo;
}

void systemviareset(void)
{
  HOSTMAP* htop = (HOSTMAP*)&hostmap.upper;
  intptr_t expiryoffset;
  HOST_GET_1MHZ_PERIPHERAL_TOGO_FOR_SNAPSHOT_OFFSET(expiryoffset, htop, sysvia)

  htop[-1].B_sysvia.t1doubled = expiryoffset;
  htop[-1].B_sysvia.t2doubled = expiryoffset;
  htop[-1].A_sysvia.sr = 0;

  /*if ier is set to none, a hard reset will be done*/
  htop[-1].A_sysvia.ier = 0x80;

  htop[-1].A_sysvia.ifr = 0x00;
  htop[-1].A_sysvia.ddra = 0; /*input*/
  htop[-1].A_sysvia.ddrb = 0; /*input*/
  htop[-1].A_sysvia.t1ll = 0xFF;
  htop[-1].A_sysvia.t1lh = 0xFF;
  htop[-1].A_sysvia.t2ll = 0xFF;
  htop[-1].A_sysvia.acr = 0;
  htop[-1].A_sysvia.pcr = 0;
  htop[-1].A_sysvia.ora = 0xFF;
  htop[-1].A_sysvia.ira = 0xFF;
  htop[-1].A_sysvia.orb = 0xFF;
  htop[-1].A_sysvia.irb = 0xFF;
  htop[-1].A_sysvia.porta = 0xFF;
  htop[-1].A_sysvia.portb = 0xFF;

  htop[-1].A_sysvia.aftert1 = FALSE;
  htop[-1].A_sysvia.t1setint = FALSE;
  htop[-1].A_sysvia.t2setint = FALSE;

  htop[-1].lsoundlatch = FALSE;
  systemviaregistersetirq(htop);
  htop[-1].screenstartaddress = 0;
  htop[-1].screenstartindex = 0;

  htop[-1].cycles.sysvia_togo = systemviapickcyclestogo();
  htop[-1].cycles.sysvia_original = htop[-1].cycles.sysvia_togo;

  HOST_LIMIT_CYCLES_TO_GO(htop, htop[-1].cycles.sysvia_togo)
}

void systemviabeforesnapshot(void)
{
  HOSTMAP* htop = (HOSTMAP*)&hostmap.upper;
  intptr_t expiryoffset;
  HOST_GET_1MHZ_PERIPHERAL_TOGO_FOR_SNAPSHOT_OFFSET(expiryoffset, htop, sysvia)

  htop[-1].B_sysvia.t1doubled -= expiryoffset;
  if (!(htop[-1].A_sysvia.acr & 0x20))
  {
    /*one-shot mode*/
    htop[-1].B_sysvia.t2doubled -= expiryoffset;
  }
}

void systemviaaftersnapshot(void)
{
  HOSTMAP* htop = (HOSTMAP*)&hostmap.upper;
  intptr_t expiryoffset;
  HOST_GET_1MHZ_PERIPHERAL_TOGO_FOR_SNAPSHOT_OFFSET(expiryoffset, htop, sysvia)

  htop[-1].B_sysvia.t1doubled += expiryoffset;
  HOST_LIMIT_PERIPHERAL_CYCLES_TO_GO(htop, sysvia, htop[-1].B_sysvia.t1doubled + 2)
  if (!(htop[-1].A_sysvia.acr & 0x20))
  {
    /*one-shot mode*/
    htop[-1].B_sysvia.t2doubled += expiryoffset;
    HOST_LIMIT_PERIPHERAL_CYCLES_TO_GO(htop, sysvia, htop[-1].B_sysvia.t2doubled + 2)
  }

  systemviaregistersetirq(htop);
}

HOSTMAP* systemviaatzerocycles(HOSTMAP* htop)
{
  /*we are dealing with a 1MHz device here*/
  htop[-1].B_sysvia.t1doubled -= htop[-1].cycles.sysvia_original;

  if (htop[-1].B_sysvia.t1doubled == -2)
  {
    switch (htop[-1].A_sysvia.acr & 0xC0)
    {
      case 0x00:
        /*output disabled and one-shot mode*/
        /*timed interrupt each time T1 is loaded*/
        if (htop[-1].A_sysvia.t1setint)
        {
          /*T1 interrupt flag set*/
          htop[-1].A_sysvia.ifr |= 0x40;
          htop[-1].A_sysvia.t1setint = FALSE;
        }
        break;
      case 0x40:
        /*output disabled and free-run mode*/
        /*continuous interrupts*/
        /*ELITE uses this one*/
         if (htop[-1].A_sysvia.t1setint)
          /*T1 interrupt flag set*/
          htop[-1].A_sysvia.ifr |= 0x40;
        break;
      case 0x80:
        /*output enabled and one-shot mode*/
        /*timed interrupt each time T1 is loaded*/
        if (htop[-1].A_sysvia.t1setint)
        {
          /*PB7 goes high*/
          htop[-1].A_sysvia.portb |= 0x80;
          /*T1 interrupt flag set*/
          htop[-1].A_sysvia.ifr |= 0x40;
          htop[-1].A_sysvia.t1setint = FALSE;
        }
        break;
      case 0xC0:
        /*output enabled and free-run mode*/
        /*continuous interrupts*/
        htop[-1].A_sysvia.portb ^= 0x80;
        if (htop[-1].A_sysvia.t1setint)
          /*T1 interrupt flag set*/
          htop[-1].A_sysvia.ifr |= 0x40;
        break;
    }

    htop[-1].B_sysvia.t1doubled += 0x20000;
    htop[-1].A_sysvia.aftert1 = TRUE;
  }
  else if (htop[-1].A_sysvia.aftert1)
  {
    if (htop[-1].A_sysvia.acr & 0x40)
    {
      htop[-1].B_sysvia.t1doubled = ((htop[-1].A_sysvia.t1lh<<9) | (htop[-1].A_sysvia.t1ll<<1)) + 1;
    }
    htop[-1].A_sysvia.aftert1 = 0;
  }

  if (!(htop[-1].A_sysvia.acr & 0x20))
  {
    htop[-1].B_sysvia.t2doubled -= htop[-1].cycles.sysvia_original;

    if (htop[-1].B_sysvia.t2doubled == -2)
    {
      if (htop[-1].A_sysvia.t2setint)
      {
        /*on completion of the timing interval,
          T2 interrupt flag is set (IFR b5)*/
        htop[-1].A_sysvia.ifr |= 0x20;
        htop[-1].A_sysvia.t2setint=FALSE;
      }

      htop[-1].B_sysvia.t2doubled += 0x20000;
    }
  }

  htop[-1].cycles.sysvia_togo = htop[-1].cycles.sysvia_original = systemviapickcyclestogo();

  systemviaeventsetirq(htop);
  return htop;
}

struct R6502CPUMAP* systemvia00read(struct R6502CPUMAP* ctop, uintptr_t address_code)
{
  /*input/output reg b*/
  HOSTMAP* htop = (HOSTMAP*)ctop;
  unsigned int nresult;

  /*htop[-1].A_sysvia.pcr & 0x20 = CB2 input*/
  /*htop[-1].A_sysvia.pcr & 0x40 = CB2 active edge input*/
  /*independant mode*/
  if (((htop[-1].A_sysvia.pcr & 0xE0) == 0x20) OR ((htop[-1].A_sysvia.pcr & 0xE0) == 0x60))
  {
    /*clear b4 (CB1)*/
    htop[-1].A_sysvia.ifr &= 0xEF;
  }
  else
  {
    /*clear b4,b3 (CB1,CB2)*/
    htop[-1].A_sysvia.ifr &= 0xE7;
  }
  systemviaregistersetirq(htop);
  /*reads output register bit in orb. pin level has no effect*/
  nresult = (htop[-1].A_sysvia.orb & htop[-1].A_sysvia.ddrb);
  if (htop[-1].A_sysvia.acr & 0x02)
  {
    /*input latching enabled*/
    /*read input level on irb*/
    nresult |= (htop[-1].A_sysvia.irb & ~htop[-1].A_sysvia.ddrb);
  }
  else
  {
    /*input latching disabled*/
    /*read input level on PB pin*/
    nresult |= (htop[-1].A_sysvia.portb & ~htop[-1].A_sysvia.ddrb);
  }
  if (!beebit_button1)
    nresult |= 0x10; /*fire button 1 released*/
  if (!beebit_button2)
    nresult |= 0x20; /*fire button 2 released*/

  nresult |= 0xC0; /*speech system not available*/
  /*nresult |= 0xF0;*/
  #ifdef __DEBUG__
    fprintf(htrace,"=&%X (&%X & &%X) ",nresult,htop[-1].A_sysvia.orb,htop[-1].A_sysvia.ddrb);
  #endif
  htop[-1].m = nresult;

  return ctop;
}

struct R6502CPUMAP* systemvia01read_b(struct R6502CPUMAP* ctop, uintptr_t address_code)
{
  /*input/output reg a*/
  HOSTMAP* htop = (HOSTMAP*)ctop;
  unsigned int nresult;

  /*htop[-1].A_sysvia.pcr & 0x02 = CA2 input*/
  /*htop[-1].A_sysvia.pcr & 0x04 = CA2 active edge input*/
  if (((htop[-1].A_sysvia.pcr & 0x0E) == 0x02) OR ((htop[-1].A_sysvia.pcr & 0x0E) == 0x06))
  {
    /*independant interrupt*/
    /*clear b2 (CA1)*/
    htop[-1].A_sysvia.ifr &= 0xFD;
  }
  else
  {
    /*clear b2,b1 (CA1,CA2)*/
    htop[-1].A_sysvia.ifr &= 0xFC;
  }
  systemviaregistersetirq(htop);
  if (htop[-1].A_sysvia.acr & 0x01)
  {
    /*input latching enabled*/
    nresult = htop[-1].A_sysvia.ira;
  }
  else
  {
    /*input latching disabled*/
    nresult = htop[-1].A_sysvia.porta;
  }
  htop[-1].m = nresult;

  return ctop;
}

struct R6502CPUMAP* systemvia01read_m(struct R6502CPUMAP* ctop, uintptr_t address_code)
{
  /*input/output reg a*/
  HOSTMAP* htop = (HOSTMAP*)ctop;
  unsigned int nresult;

  /*htop[-1].A_sysvia.pcr & 0x02 = CA2 input*/
  /*htop[-1].A_sysvia.pcr & 0x04 = CA2 active edge input*/
  if (((htop[-1].A_sysvia.pcr & 0x0E) == 0x02) OR ((htop[-1].A_sysvia.pcr & 0x0E) == 0x06))
  {
    /*independant interrupt*/
    /*clear b2 (CA1)*/
    htop[-1].A_sysvia.ifr &= 0xFD;
  }
  else
  {
    /*clear b2,b1 (CA1,CA2)*/
    htop[-1].A_sysvia.ifr &= 0xFC;
  }
  systemviaregistersetirq(htop);
  if (htop[-1].A_sysvia.acr & 0x01)
  {
    /*input latching enabled*/
    nresult = htop[-1].A_sysvia.ira;
  }
  else
  {
    /*input latching disabled*/
    if (htop[-1].rtc.chipselect && htop[-1].rtc.readwrite)
    {
      htop[-1].A_sysvia.porta = cmosread(htop[-1].rtc.addrstrobe);
      /*nresult = (htop[-1].A_sysvia.porta & htop[-1].A_sysvia.ddra);
      if (htop[-1].rtc.chipselect)
        nresult |= (htop[-1].A_sysvia.porta & ~htop[-1].A_sysvia.ddra);*/
      nresult = (htop[-1].A_sysvia.ora & htop[-1].A_sysvia.ddra) | (htop[-1].A_sysvia.porta & ~htop[-1].A_sysvia.ddra);
    }
    else
      nresult = htop[-1].A_sysvia.porta;
  }
  htop[-1].m = nresult;

  return ctop;
}

