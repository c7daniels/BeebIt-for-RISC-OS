R6502HOSTMAP* systemvia04read(R6502HOSTMAP* map, unsigned int address_code)
{
  int cyclecount;

  /*T1 low order counter*/
  /*T1 interrupt flag is reset (IFR b6)*/
  map->s0sysvia.ifr &= 0xBF;
  systemviasetirq();
  TIMER_GET_PERIPHERAL_CYCLE_COUNT(cyclecount, map, sysvia)
  map->m = ((map->s2sysvia.t1doubled - cyclecount)>>1)&0xFF;

  return map;
}

R6502HOSTMAP* systemvia05read(R6502HOSTMAP* map, unsigned int address_code)
{
  int cyclecount;

  /*T1 high order counter*/
  TIMER_GET_PERIPHERAL_CYCLE_COUNT(cyclecount, map, sysvia)
  map->m = ((map->s2sysvia.t1doubled - cyclecount)>>9)&0xFF;

  return map;
}

R6502HOSTMAP* systemvia06read(R6502HOSTMAP* map, unsigned int address_code)
{
