R6502HOSTMAP* systemvia0Bwrite(R6502HOSTMAP* map, unsigned int address_code)
{
  int expiryoffset;

  /*auxiliary control reg*/
  if ((map->s0sysvia.acr ^ map->m) & 0x20)
  {
    TIMER_GET_1MHZ_PERIPHERAL_TOGO_FROM_WRITE_OFFSET(expiryoffset, map, sysvia)
    if (!(map->m & 0x20))
    {
      /*one-shot mode*/
      map->s2sysvia.t2doubled += expiryoffset;
      TIMER_LIMIT_PERIPHERAL_CYCLES_TO_GO(map, sysvia, map->s2sysvia.t2doubled + 2)
    }
    else
    {
      /*pulse counting mode*/
      map->s2sysvia.t2doubled -= expiryoffset;
    }
  }
  map->s0sysvia.acr = map->m;

  return map;
}

R6502HOSTMAP* systemvia0Cwrite(R6502HOSTMAP* map, unsigned int address_code)
{
  /*peripheral control reg*/
  map->s0sysvia.pcr = map->m;
  /*CA1 active edge*/
  if (map->s0sysvia.pcr & 0x01)
  {
    /*set b2 (CA1)*/
    map->s0sysvia.ifr |= 0x02;
  }
  /*CA2 active edge*/
  if ((map->s0sysvia.pcr & 0x0E) == 0x04)
  {
    /*set b1 (CA2)*/
    map->s0sysvia.ifr |= 0x01;
  }
  /*CB1 active edge*/
  if (map->s0sysvia.pcr & 0x10)
  {
    /*set b5 (CB1)*/
    map->s0sysvia.ifr |= 0x10;
  }
  /*CB2 active edge*/
  if ((map->s0sysvia.pcr & 0xE0) == 0x40)
  {
    /*set b4 (CB2)*/
    map->s0sysvia.ifr |= 0x08;
  }

  return map;
}

