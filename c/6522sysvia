static int systemviapickcyclestogo(void)
{
  int cyclestogo;

  // the interrupt flag is set after the counter has passed through zero
  if (!(hostmap.s0sysvia.acr & 0x20))
  {
    if (hostmap.s2sysvia.t1doubled < hostmap.s2sysvia.t2doubled)
    {
      cyclestogo = hostmap.s2sysvia.t1doubled + 2;
    }
    else
    {
      cyclestogo = hostmap.s2sysvia.t2doubled + 2;
    }
  }
  else
  {
    cyclestogo = hostmap.s2sysvia.t1doubled + 2;
  }

  if (hostmap.s2sysvia.aftert1)
  {
    cyclestogo = 1;
  }

  return cyclestogo;
}

void systemviareset(void)
{
  int expiryoffset;
  TIMER_GET_1MHZ_PERIPHERAL_TOGO_FOR_SNAPSHOT_OFFSET(expiryoffset, &hostmap, sysvia)

  hostmap.s2sysvia.t1doubled = expiryoffset;
  hostmap.s2sysvia.t2doubled = expiryoffset;
  hostmap.s0sysvia.sr = 0;

  /*if ier is set to none, a hard reset will be done*/
  hostmap.s0sysvia.ier = 0x80;

  hostmap.s0sysvia.ifr = 0x00;
  hostmap.s0sysvia.ddra = 0; /*input*/
  hostmap.s0sysvia.ddrb = 0; /*input*/
  hostmap.s0sysvia.t1ll = 0xFF;
  hostmap.s0sysvia.t1lh = 0xFF;
  hostmap.s0sysvia.t2ll = 0xFF;
  hostmap.s0sysvia.acr = 0;
  hostmap.s0sysvia.pcr = 0;
  hostmap.s0sysvia.ora = 0xFF;
  hostmap.s0sysvia.ira = 0xFF;
  hostmap.s0sysvia.orb = 0xFF;
  hostmap.s0sysvia.irb = 0xFF;
  hostmap.s0sysvia.porta = 0xFF;
  hostmap.s0sysvia.portb = 0xFF;

  hostmap.s2sysvia.aftert1 = FALSE;
  hostmap.s2sysvia.t1setint = FALSE;
  hostmap.s2sysvia.t2setint = FALSE;

  hostmap.lsoundlatch = FALSE;
  systemviasetirq();
  hostmap.screenstartaddress = 0;
  hostmap.screenstartindex = 0;

  hostmap.s2cycles.sysvia_togo = systemviapickcyclestogo();
  hostmap.s2cycles.sysvia_original = hostmap.s2cycles.sysvia_togo;

  TIMER_LIMIT_CYCLES_TO_GO(&hostmap, hostmap.s2cycles.sysvia_togo)
}

void systemviabeforesnapshot(void)
{
  int expiryoffset;
  TIMER_GET_1MHZ_PERIPHERAL_TOGO_FOR_SNAPSHOT_OFFSET(expiryoffset, &hostmap, sysvia)

  hostmap.s2sysvia.t1doubled -= expiryoffset;
  if (!(hostmap.s0sysvia.acr & 0x20))
  {
    /*one-shot mode*/
    hostmap.s2sysvia.t2doubled -= expiryoffset;
  }
}

void systemviaaftersnapshot(void)
{
  int expiryoffset;
  TIMER_GET_1MHZ_PERIPHERAL_TOGO_FOR_SNAPSHOT_OFFSET(expiryoffset, &hostmap, sysvia)

  hostmap.s2sysvia.t1doubled += expiryoffset;
  TIMER_LIMIT_PERIPHERAL_CYCLES_TO_GO(&hostmap, sysvia, hostmap.s2sysvia.t1doubled + 2)
  if (!(hostmap.s0sysvia.acr & 0x20))
  {
    /*one-shot mode*/
    hostmap.s2sysvia.t2doubled += expiryoffset;
    TIMER_LIMIT_PERIPHERAL_CYCLES_TO_GO(&hostmap, sysvia, hostmap.s2sysvia.t2doubled + 2)
  }
}

R6502HOSTMAP* systemviaatzerocycles(R6502HOSTMAP* map)
{
  /*we are dealing with a 1MHz device here*/
  hostmap.s2sysvia.t1doubled -= map->s2cycles.sysvia_original;

  if (hostmap.s2sysvia.t1doubled == -2)
  {
    switch (hostmap.s0sysvia.acr & 0xC0)
    {
      case 0x00:
        /*output disabled and one-shot mode*/
        /*timed interrupt each time T1 is loaded*/
        if (hostmap.s2sysvia.t1setint)
        {
          /*T1 interrupt flag set*/
          hostmap.s0sysvia.ifr |= 0x40;
          hostmap.s2sysvia.t1setint = FALSE;
        }
        break;
      case 0x40:
        /*output disabled and free-run mode*/
        /*continuous interrupts*/
        /*ELITE uses this one*/
         if (hostmap.s2sysvia.t1setint)
          /*T1 interrupt flag set*/
          hostmap.s0sysvia.ifr |= 0x40;
        break;
      case 0x80:
        /*output enabled and one-shot mode*/
        /*timed interrupt each time T1 is loaded*/
        if (hostmap.s2sysvia.t1setint)
        {
          /*PB7 goes high*/
          hostmap.s0sysvia.portb |= 0x80;
          /*T1 interrupt flag set*/
          hostmap.s0sysvia.ifr |= 0x40;
          hostmap.s2sysvia.t1setint = FALSE;
        }
        break;
      case 0xC0:
        /*output enabled and free-run mode*/
        /*continuous interrupts*/
        hostmap.s0sysvia.portb ^= 0x80;
        if (hostmap.s2sysvia.t1setint)
          /*T1 interrupt flag set*/
          hostmap.s0sysvia.ifr |= 0x40;
        break;
    }

    hostmap.s2sysvia.t1doubled += 0x20000;
    hostmap.s2sysvia.aftert1 = TRUE;
  }
  else if (hostmap.s2sysvia.aftert1)
  {
    if (hostmap.s0sysvia.acr & 0x40)
    {
      hostmap.s2sysvia.t1doubled = ((hostmap.s0sysvia.t1lh<<9) | (hostmap.s0sysvia.t1ll<<1)) + 1;
    }
    hostmap.s2sysvia.aftert1 = 0;
  }

  if (!(hostmap.s0sysvia.acr & 0x20))
  {
    hostmap.s2sysvia.t2doubled -= map->s2cycles.sysvia_original;

    if (hostmap.s2sysvia.t2doubled == -2)
    {
      if (hostmap.s2sysvia.t2setint)
      {
        /*on completion of the timing interval,
          T2 interrupt flag is set (IFR b5)*/
        hostmap.s0sysvia.ifr |= 0x20;
        hostmap.s2sysvia.t2setint=FALSE;
      }

      hostmap.s2sysvia.t2doubled += 0x20000;
    }
  }

  map->s2cycles.sysvia_togo = map->s2cycles.sysvia_original = systemviapickcyclestogo();

  systemviasetirq();
  return map;
}

R6502HOSTMAP* systemvia00read(R6502HOSTMAP* map, unsigned int address_code)
{
  unsigned int nresult;

  /*input/output reg b*/
  /*map->s0sysvia.pcr & 0x20 = CB2 input*/
  /*map->s0sysvia.pcr & 0x40 = CB2 active edge input*/
  /*independant mode*/
  if (((map->s0sysvia.pcr & 0xE0) == 0x20) OR ((map->s0sysvia.pcr & 0xE0) == 0x60))
  {
    /*clear b4 (CB1)*/
    map->s0sysvia.ifr &= 0xEF;
  }
  else
  {
    /*clear b4,b3 (CB1,CB2)*/
    map->s0sysvia.ifr &= 0xE7;
  }
  systemviasetirq();
  /*reads output register bit in orb. pin level has no effect*/
  nresult = (map->s0sysvia.orb & map->s0sysvia.ddrb);
  if (map->s0sysvia.acr & 0x02)
  {
    /*input latching enabled*/
    /*read input level on irb*/
    nresult |= (map->s0sysvia.irb & ~map->s0sysvia.ddrb);
  }
  else
  {
    /*input latching disabled*/
    /*read input level on PB pin*/
    nresult |= (map->s0sysvia.portb & ~map->s0sysvia.ddrb);
  }
  if (!beebit_button1)
    nresult |= 0x10; /*fire button 1 released*/
  if (!beebit_button2)
    nresult |= 0x20; /*fire button 2 released*/

  nresult |= 0xC0; /*speech system not available*/
  /*nresult |= 0xF0;*/
  #ifdef __DEBUG__
    fprintf(htrace,"=&%X (&%X & &%X) ",nresult,map->s0sysvia.orb,map->s0sysvia.ddrb);
  #endif
  map->m = nresult;

  return map;
}

R6502HOSTMAP* systemvia01read_b(R6502HOSTMAP* map, unsigned int address_code)
{
  unsigned int nresult;

  /*input/output reg a*/
  /*map->s0sysvia.pcr & 0x02 = CA2 input*/
  /*map->s0sysvia.pcr & 0x04 = CA2 active edge input*/
  if (((map->s0sysvia.pcr & 0x0E) == 0x02) OR ((map->s0sysvia.pcr & 0x0E) == 0x06))
  {
    /*independant interrupt*/
    /*clear b2 (CA1)*/
    map->s0sysvia.ifr &= 0xFD;
  }
  else
  {
    /*clear b2,b1 (CA1,CA2)*/
    map->s0sysvia.ifr &= 0xFC;
  }
  systemviasetirq();
  if (map->s0sysvia.acr & 0x01)
  {
    /*input latching enabled*/
    nresult = map->s0sysvia.ira;
  }
  else
  {
    /*input latching disabled*/
    nresult = map->s0sysvia.porta;
  }
  map->m = nresult;

  return map;
}

R6502HOSTMAP* systemvia01read_m(R6502HOSTMAP* map, unsigned int address_code)
{
  unsigned int nresult;

  /*input/output reg a*/
  /*map->s0sysvia.pcr & 0x02 = CA2 input*/
  /*map->s0sysvia.pcr & 0x04 = CA2 active edge input*/
  if (((map->s0sysvia.pcr & 0x0E) == 0x02) OR ((map->s0sysvia.pcr & 0x0E) == 0x06))
  {
    /*independant interrupt*/
    /*clear b2 (CA1)*/
    map->s0sysvia.ifr &= 0xFD;
  }
  else
  {
    /*clear b2,b1 (CA1,CA2)*/
    map->s0sysvia.ifr &= 0xFC;
  }
  systemviasetirq();
  if (map->s0sysvia.acr & 0x01)
  {
    /*input latching enabled*/
    nresult = map->s0sysvia.ira;
  }
  else
  {
    /*input latching disabled*/
    if (map->s0rtc.chipselect && map->s0rtc.readwrite)
    {
      map->s0sysvia.porta = cmosread(map->s0rtc.addrstrobe);
      /*nresult = (map->s0sysvia.porta & map->s0sysvia.ddra);
      if (map->s0rtc.chipselect)
        nresult |= (map->s0sysvia.porta & ~map->s0sysvia.ddra);*/
      nresult = (map->s0sysvia.ora & map->s0sysvia.ddra) | (map->s0sysvia.porta & ~map->s0sysvia.ddra);
    }
    else
      nresult = map->s0sysvia.porta;
  }
  map->m = nresult;

  return map;
}

