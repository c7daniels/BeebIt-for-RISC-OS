static inline void systemviaportbwrite_latchb(HOSTMAP* htop, uint8_t value)
{
  int nlatch,lenabled;

  nlatch = (htop[-1].A_sysvia.portb & 0x07);
  lenabled = (htop[-1].A_sysvia.portb & 0x08);

  switch (nlatch)
  {
    case 0x00:
      /*sound write enable*/
      if (lenabled AND !htop[-1].lsoundlatch)
      {
#ifdef __RISCOS__
        zeribeepwrite(htop, htop[-1].A_sysvia.ora);
#endif
      }
      htop[-1].lsoundlatch = lenabled;
      break;
    case 0x01:
      /*read speech*/
      break;
    case 0x02:
      /*write speech*/
      break;
    case 0x03:
      /*keyboard*/
      if (!lenabled)
        htop[-1].A_sysvia.porta = keyboardread(htop[-1].A_sysvia.porta,htop[-1].A_sysvia.ddra);
      break;
    case 0x04:
      /*Screen Size hi*/
      if (!lenabled)
      {
        htop[-1].screenstartindex &= 2;
        htop[-1].screenstartaddress=ScreenStartArray[htop[-1].screenstartindex];
      }
      else
      {
        htop[-1].screenstartindex |= 1;
        htop[-1].screenstartaddress=ScreenStartArray[htop[-1].screenstartindex];
      }
      break;
    case 0x05:
      /*Screen Size lo*/
      if (!lenabled)
      {
        htop[-1].screenstartindex &= 1;
        htop[-1].screenstartaddress=ScreenStartArray[htop[-1].screenstartindex];
      }
      else
      {
        htop[-1].screenstartindex |= 2;
        htop[-1].screenstartaddress=ScreenStartArray[htop[-1].screenstartindex];
      }
      break;
    case 0x06:
      /*caps lock on/off*/
      /*get keyboard status*/
#ifdef __RISCOS__
      regs.r[0] = 202;
      regs.r[1] = 0;
      regs.r[2] = 255;
      _kernel_swi(OS_Byte,&regs,&regs);

      beebit_leds = (beebit_leds & 0xEF) | (lenabled ? 0x10 : 0x00);

      if ((regs.r[1] ^ beebit_leds) & 0x10)
      {
        /*only update the keyboard leds if they differ*/

        /*set keyboard status*/
        regs.r[0] = 202;
        regs.r[1] = beebit_leds & 0x10;
        regs.r[2] = 0xEF;
        _kernel_swi(OS_Byte,&regs,&regs);

        /*set the leds*/
        regs.r[0] = 118;
        _kernel_swi(OS_Byte,&regs,&regs);
      }
#endif
      break;
    case 0x07:
      /*shift lock on/off*/
      break;
  }
}

