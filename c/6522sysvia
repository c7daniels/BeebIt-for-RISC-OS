struct R6502CPUMAP* systemvia04read(struct R6502CPUMAP* ctop, uintptr_t address_code)
{
  /*T1 low order counter*/
  HOSTMAP* htop = (HOSTMAP*)ctop;
  intptr_t cyclecount;

  /*T1 interrupt flag is reset (IFR b6)*/
  htop[-1].A_sysvia.ifr &= 0xBF;
  systemviaregistersetirq(htop);
  HOST_GET_PERIPHERAL_CYCLE_COUNT(cyclecount, htop, sysvia)
  htop[-1].m = ((htop[-1].B_sysvia.t1doubled - cyclecount)>>1)&0xFF;

  return ctop;
}

