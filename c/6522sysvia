R6502HOSTMAP* systemvia08read(R6502HOSTMAP* map, unsigned int address_code)
{
  int cyclecount;

  /*T2 low order counter*/
  /*T2 interrupt flag is cleared (IFR b5)*/
  map->s0sysvia.ifr &= 0xDF;
  systemviasetirq();
  if (!(map->s0sysvia.acr & 0x20))
  {
    TIMER_GET_PERIPHERAL_CYCLE_COUNT(cyclecount, map, sysvia)
    map->m = ((map->s2sysvia.t2doubled - cyclecount)>>1)&0xFF;
  }
  else
  {
    map->m = (map->s2sysvia.t2doubled>>1)&0xFF;
  }

  return map;
}

