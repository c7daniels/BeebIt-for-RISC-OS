R6502HOSTMAP* systemvia05write(R6502HOSTMAP* map, unsigned int address_code)
{
  int expiryoffset;

  /*T1 high order counter*/
  map->s0sysvia.t1lh = map->m;
  /*clear T1 interrupt flag (b6)*/
  map->s0sysvia.ifr &= 0xBF;
  systemviasetirq();
  if ((map->s0sysvia.acr & 0xC0) == 0x80)
  {
    /*output enabled (b7=1) and free-run disabled (b6=0)*/
    /*one-shot mode*/
    /*PB7 goes low, but goes high when timer 1 times out*/
    /*map->s0sysvia.orb &= 0x7F;
    map->s0sysvia.irb &= 0x7F;*/
    map->s0sysvia.portb &= 0x7F;
  }
  map->s2sysvia.t1setint = TRUE;
  map->s2sysvia.t1doubled = (map->s0sysvia.t1lh<<9) | (map->s0sysvia.t1ll<<1);
  TIMER_GET_1MHZ_PERIPHERAL_TOGO_FROM_WRITE_OFFSET(expiryoffset, map, sysvia)
  map->s2sysvia.t1doubled += expiryoffset;
  // the interrupt flag is set after the counter has passed through zero
  TIMER_LIMIT_PERIPHERAL_CYCLES_TO_GO(map, sysvia, map->s2sysvia.t1doubled + 2)
  map->s2sysvia.aftert1 = 0;

  return map;
}

