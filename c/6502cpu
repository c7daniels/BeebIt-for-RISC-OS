  CPU_CYCLES(7)
  #ifdef __DEBUG__
    fprintf(htrace," r6502_pc = &%X",r6502_pc);
  #endif
}

void r6502donmi(void)
{
  STACK_PUSH((r6502_pc & 0xFF00)>>8);
  STACK_PUSH(r6502_pc & 0x00FF);
  STACK_PUSH(r6502_ps & NOTBFLAG)
  SETFLAG(IFLAG)
  r6502_pc = (memory[0xFFFB]<<8) + memory[0xFFFA];
  CPU_CYCLES(7)
}
