int r6502reset(R6502HOSTMAP* map)
{
  int lreturn;

  /*map->a = 0;
  map->x = 0;
  map->y = 0;*/
  map->pc_code = BUS_BASEFLAG;
  map->sp_code = (0xFF000001) | (BUS_BASEFLAG<<8);
  map->ps = UFLAG | BFLAG;

  r6502resetbusfork(map);
  r6502resetreadsandwrite8000s(map);

  map->read3000 = r6502read3000;
  map->write3000 = r6502write3000;
  map->read3000_e = NULL;
  map->write3000_e = NULL;
  map->read3000_x = NULL;
  map->write3000_x = NULL;
  map->readC000_y = NULL;
  map->writeC000_y = NULL;

  if (beebit_machinetype == MACHINE_MODELBPLUS)
  {
    map->read3000_ram = r6502readbp3000_ram;
    map->write3000_ram = r6502writebp3000_ram;
    map->read8000_ram = r6502readbp8000_ram;
    map->write8000_ram = r6502writebp8000_ram;

    map->swappagesintomemory = swappagesintomemorybp;
    map->swappagesoutofmemory = swappagesoutofmemorybp;

    r6502resethighforks(map,
        r6502startstretch, r6502startstretch,
        r6502startstretch, r6502startstretch,
        sheilareadsbp, sheilawritesbp);
  }
  else
  {
    map->read3000_ram = NULL;
    map->write3000_ram = NULL;
    map->read8000_ram = NULL;
    map->write8000_ram = NULL;

    map->swappagesintomemory = swappagesintomemoryb;
    map->swappagesoutofmemory = swappagesoutofmemoryb;

    r6502resethighforks(map,
        r6502startstretch, r6502startstretch,
        r6502startstretch, r6502startstretch,
        sheilareadsb, sheilawritesb);
  }

  lreturn = r6502setcpuops(map, r6502sequences);

  map->transition1action = map->fetchaction;
  map->transition2action = map->fetchaction;
  map->timesinterruptmissed = 0;

  map->cpu_state = R6502_FIRST_STEP_IN(R6502_RESET_SEQUENCE);
  map->address_code = (map->address_code & 0xFFFF0000) | BUS_BASEFLAG;

  return lreturn;
}

void r6502resetbusfork(R6502HOSTMAP* map)
{
  int i;
  map->bus_fork[0x00] = r6502read0000;
  map->bus_fork[0x01] = r6502read0000;
  map->bus_fork[0x02] = r6502read0000;
  map->bus_fork[0x03] = r6502read3000;
  map->bus_fork[0x04] = r6502read3000;
  map->bus_fork[0x05] = r6502read3000;
  map->bus_fork[0x06] = r6502read3000;
  map->bus_fork[0x07] = r6502read3000;
  map->bus_fork[0x08] = r6502read8000_0;
  map->bus_fork[0x09] = r6502read8000_0;
  map->bus_fork[0x0A] = r6502read8000_0;
  map->bus_fork[0x0B] = r6502read8000_0;
  map->bus_fork[0x0C] = r6502readC000;
  map->bus_fork[0x0D] = r6502readC000;
  map->bus_fork[0x0E] = r6502readC000;
  map->bus_fork[0x0F] = r6502readF000;
  map->bus_fork[0x10] = r6502write0000;
  map->bus_fork[0x11] = r6502write0000;
  map->bus_fork[0x12] = r6502write0000;
  map->bus_fork[0x13] = r6502write3000;
  map->bus_fork[0x14] = r6502write3000;
  map->bus_fork[0x15] = r6502write3000;
  map->bus_fork[0x16] = r6502write3000;
  map->bus_fork[0x17] = r6502write3000;
  map->bus_fork[0x18] = r6502write8000_0;
  map->bus_fork[0x19] = r6502write8000_0;
  map->bus_fork[0x1A] = r6502write8000_0;
  map->bus_fork[0x1B] = r6502write8000_0;
  map->bus_fork[0x1C] = r6502writeC000;
  map->bus_fork[0x1D] = r6502writeC000;
  map->bus_fork[0x1E] = r6502writeC000;
  map->bus_fork[0x1F] = r6502writeF000;
  for (i=0x20; i<0x40; i++)
  {
    map->bus_fork[i] = r6502stretch1;
  }
  for (i=0x40; i<0x50; i++)
  {
    map->bus_fork[i] = r6502readstretch2;
  }
  for (i=0x50; i<0x60; i++)
  {
    map->bus_fork[i] = r6502writestretch2;
  }
}

int r6502setcpuops(R6502HOSTMAP* map, const R6502OP* const *sequences)
{
  int lreturn;
  int i, j;
  const R6502OP* s;
  R6502OP* entry = map->steps;

  lreturn = TRUE;

  for (j=0; j<R6502_SEQUENCE_CAPACITY; j++)
  {
    s = *sequences;
    i=0;
    if (s)
    {
      for (; s[i]; i++, entry++)
      {
        if (i == (1<<R6502_LOG2_MAX_SEQUENCE_LENGTH))
        {
          lreturn = FALSE;
          break;
        }

        *entry = s[i];
      }
      sequences++;
    }
    for (; i<(1<<R6502_LOG2_MAX_SEQUENCE_LENGTH); i++, entry++)
    {
      *entry = NULL;
    }
  }

  map->yieldaction = r6502yield;
  map->fetchaction = r6502fetch;
  map->interruptfetchaction = r6502interruptfetch;
  map->fetchthentestirqaction = r6502fetchthentestirq;
  map->resetaction = r6502enterreset;
  return lreturn;
}

void r6502resetreadsandwrite8000s(R6502HOSTMAP* map)
{
  const R6502OP reads[0x10] =
  {
    r6502read8000_0, r6502read8000_1,
    r6502read8000_2, r6502read8000_3,
    r6502read8000_4, r6502read8000_5,
    r6502read8000_6, r6502read8000_7,
    r6502read8000_8, r6502read8000_9,
    r6502read8000_A, r6502read8000_B,
    r6502read8000_C, r6502read8000_D,
    r6502read8000_E, r6502read8000_F
  };
  R6502OP writes[0x10] =
  {
    r6502write8000_0, r6502write8000_1,
    r6502write8000_2, r6502write8000_3,
    r6502write8000_4, r6502write8000_5,
    r6502write8000_6, r6502write8000_7,
    r6502write8000_8, r6502write8000_9,
    r6502write8000_A, r6502write8000_B,
    r6502write8000_C, r6502write8000_D,
    r6502write8000_E, r6502write8000_F
  };

  memcpy(map->read8000s, reads, sizeof(reads));
  memcpy(map->write8000s, writes, sizeof(writes));

  if (beebit_machinetype == MACHINE_MODELBPLUS)
  {
    /*make rom F use rom E*/
    map->read8000s[0xF] = reads[0xE];
    map->read8000s[0xF] = writes[0xE];
  }
}

void r6502resethighforks(R6502HOSTMAP* map,
    R6502OP readFC00, R6502OP writeFC00,
    R6502OP readFD00, R6502OP writeFD00,
    const R6502OP* sheila_reads, const R6502OP* sheila_writes)
{
  const int slow_mask = 0x0F00FF0F;
  int i;

  for (i=0; i<0x100; i++)
  {
    map->high_read_fork[i] = readFC00;
    map->high_write_fork[i] = writeFC00;
  }
  for (i=0; i<0x100; i++)
  {
    map->high_read_fork[0x100+i] = readFD00;
    map->high_write_fork[0x100+i] = writeFD00;
  }
  for (i=0; i<0x100; i++)
  {
    if (slow_mask & (1<<(i>>3)))
    {
      map->high_read_fork[0x200+i] = r6502startstretch;
      map->high_write_fork[0x200+i] = r6502startstretch;
    }
    else
    {
      map->high_read_fork[0x200+i] = sheila_reads[i];
      map->high_write_fork[0x200+i] = sheila_writes[i];
    }
  }
  for (i=0; i<0x100; i++)
  {
    map->high_read_fork[0x300+i] = r6502readC000;
    map->high_write_fork[0x300+i] = r6502writeC000;
  }

  for (i=0; i<0x100; i++)
  {
    map->high_stretched_read_fork[i] = r6502readfred;
    map->high_stretched_write_fork[i] = r6502writefred;
  }
  for (i=0; i<0x100; i++)
  {
    map->high_stretched_read_fork[0x100+i] = r6502readjim;
    map->high_stretched_write_fork[0x100+i] = r6502writejim;
  }
  for (i=0; i<0x100; i++)
  {
    map->high_stretched_read_fork[0x200+i] = sheila_reads[i];
    map->high_stretched_write_fork[0x200+i] = sheila_writes[i];
  }
  for (i=0; i<0x100; i++)
  {
    map->high_stretched_read_fork[0x300+i] = r6502readC000;
    map->high_stretched_write_fork[0x300+i] = r6502writeC000;
  }
}

#ifdef BEEBIT_NO_ASM
void r6502execute(R6502HOSTMAP* map)
{
  map->nmis &= NMIS_NOTYIELD;
  do
  {
    map->bus_fork[((map->address_code>>28)|(map->address_code<<4))&0x7F](map);
    if (--map->timers.cyclestogo == 0)
      r6502advancetimers(map);
  }
  while (!(map->nmis & NMIS_YIELD));
}
#endif

void r6502readmemory(R6502HOSTMAP* map, char *buffer, unsigned int naddress, int ncount)
{
  int savedaddresscode = map->address_code;
  int savedcpustate = map->cpu_state;
  unsigned char savedm = map->m;

  map->address_code = ((naddress<<16) & 0xFFFF0000) | BUS_BASEFLAG;
  map->cpu_state = R6502_FIRST_STEP_IN(R6502_READ_SEQUENCE);

  for ( ; ncount > 0; ncount--, buffer++)
  {
    map->readcompleted = FALSE;
    do
    {
      map->bus_fork[((map->address_code>>28)|(map->address_code<<4))&0x7F](map);
    }
    while (!map->readcompleted);
    *buffer = map->m;
    map->address_code = (map->address_code + 0x10000) & 0xFFFFFFFF;
  }

  map->address_code = savedaddresscode;
  map->cpu_state = savedcpustate;
  map->m = savedm;
}
