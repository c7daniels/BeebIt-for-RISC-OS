void r6502showps(void)
{
  #ifdef __DEVELOP__
    if (r6502_ps & CFLAG)
      fprintf(htrace,"C");
    else
      fprintf(htrace,"c");
    if (r6502_ps & ZFLAG)
      fprintf(htrace,"Z");
    else
      fprintf(htrace,"z");
    if (r6502_ps & IFLAG)
      fprintf(htrace,"I");
    else
      fprintf(htrace,"i");
    if (r6502_ps & DFLAG)
      fprintf(htrace,"D");
    else
      fprintf(htrace,"d");
    if (r6502_ps & BFLAG)
      fprintf(htrace,"B");
    else
      fprintf(htrace,"b");
    if (r6502_ps & VFLAG)
      fprintf(htrace,"V");
    else
      fprintf(htrace,"v");
    if (r6502_ps & NFLAG)
      fprintf(htrace,"N");
    else
      fprintf(htrace,"n");

    fprintf(htrace,"\n");
  #endif
}
