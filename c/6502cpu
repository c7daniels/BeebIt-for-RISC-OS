// VECTORS AND SUBROUTINES
R6502CPUMAP* r6502waitonresetstep(R6502CPUMAP* ctop, uintptr_t incremented_cpu_state)
{
  if (ctop[-1].lbreak)
  {
    if (!ctop[-1].oldreset)
    {
      ctop[-1].oldreset = TRUE;
      ctop[-1].resetstartingaction(ctop);
    }

    if (ctop[-1].transition1 == R6502_YIELD_TRANSITION)
    {
      ctop[-1].execute_cpu_state = ctop[-1].cpu_state;
      ctop[-1].cpu_state = ctop[-1].sequences[R6502_YIELD_SEQUENCE];
    }
    R6502_CYCLE_READ_RETURN(ctop, ctop[-1].sync_pc_code)
  }
  else
  {
    ctop[-1].cpu_state = (R6502OP*)incremented_cpu_state;

    if (!ctop[-1].oldreset)
    {
      ctop[-1].oldreset = TRUE;
      ctop[-1].resetstartingaction(ctop);
    }

    ctop[-1].oldreset = FALSE;
    ctop[-1].resetcontinuingaction(ctop);
    R6502_CYCLE_READ_RETURN(ctop, ctop[-1].sync_pc_code)
  }
}

