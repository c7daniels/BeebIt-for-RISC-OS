static R6502CPUMAP* r6502completecycleuninterruptedfetchreturn(R6502CPUMAP* ctop, uint8_t opcode)
{
  ctop[-1].cpu_state = ctop[-1].sequences[opcode];

  logfetch(ctop, ctop[-1].touchptr, 1);

  if (ctop[-1].transition1 == R6502_RESET_TRANSITION)
  {
    ctop[-1].cpu_state = ctop[-1].sequences[R6502_RESET_SEQUENCE];
  }
  else if (ctop[-1].transition1 == R6502_YIELD_TRANSITION)
  {
    ctop[-1].sequencenumber = ctop[-1].m;
    ctop[-1].execute_cpu_state = ctop[-1].cpu_state;
    ctop[-1].cpu_state = ctop[-1].sequences[R6502_YIELD_SEQUENCE];
  }
  R6502_CYCLE_RETURN(ctop)
}

static R6502CPUMAP* r6502completecycleearlyinterruptfetchreturn(R6502CPUMAP* ctop, uint8_t opcode)
{
  uintptr_t interruptqueue_ps = ctop[-1].interruptqueue_ps;

  ctop[-1].cpu_state = ctop[-1].sequences[opcode];

  logfetch(ctop, ctop[-1].touchptr, 1);

  if (ctop[-1].transition1 == R6502_RESET_TRANSITION)
  {
    ctop[-1].cpu_state = ctop[-1].sequences[R6502_RESET_SEQUENCE];
  }
  else if ((interruptqueue_ps>>6) & interruptqueue_ps & (R6502_NMI_IRQ_ENABLE<<12))
  {
    ctop[-1].cpu_state = ctop[-1].sequences[R6502_INTERRUPT_SEQUENCE];
  }
  else if (ctop[-1].transition1 == R6502_YIELD_TRANSITION)
  {
    ctop[-1].sequencenumber = ctop[-1].m;
    ctop[-1].execute_cpu_state = ctop[-1].cpu_state;
    ctop[-1].cpu_state = ctop[-1].sequences[R6502_YIELD_SEQUENCE];
  }
  R6502_CYCLE_RETURN(ctop)
}

static R6502CPUMAP* r6502completecycleinterruptfetchreturn(R6502CPUMAP* ctop,
 uint8_t opcode)
{
  uintptr_t interruptqueue_ps = ctop[-1].interruptqueue_ps;

  ctop[-1].cpu_state = ctop[-1].sequences[opcode];

  logfetch(ctop, ctop[-1].touchptr, 1);

  if (ctop[-1].transition1 == R6502_RESET_TRANSITION)
  {
    ctop[-1].cpu_state = ctop[-1].sequences[R6502_RESET_SEQUENCE];
  }
  else if ((interruptqueue_ps>>6) & interruptqueue_ps & (R6502_NMI_IRQ_ENABLE<<8))
  {
    ctop[-1].cpu_state = ctop[-1].sequences[R6502_INTERRUPT_SEQUENCE];
  }
  else if (ctop[-1].transition1 == R6502_YIELD_TRANSITION)
  {
    ctop[-1].sequencenumber = ctop[-1].m;
    ctop[-1].execute_cpu_state = ctop[-1].cpu_state;
    ctop[-1].cpu_state = ctop[-1].sequences[R6502_YIELD_SEQUENCE];
  }
  R6502_CYCLE_RETURN(ctop)
}

