R6502HOSTMAP* r6502branchtakenstep(R6502HOSTMAP* map)
{
  map->pc_code = (map->pc_code + map->latch) & 0xFFFFFFFF;
  if ((map->address_code>>24) == (map->pc_code>>24))
  {
    map->address_code = map->pc_code;
    if (map->transition1action == map->interruptfetchaction)
    {
      map->cpu_state = R6502_FIRST_STEP_IN(R6502_DECODE_SEQUENCE);

      if (map->timesinterruptmissed < 256)
      {
        map->timesinterruptmissed++;
      }
      else if (map->transition2action == map->yieldaction)
      {
        map->transition2action = map->fetchaction;
        map->nmis |= NMIS_YIELD;
      }
    }
    else
      map->transition1action(map);
  }
  else
  {
    map->address_code = (map->address_code & 0xFF000000) | (map->pc_code & 0x00FFFFFF);
    map->cpu_state++;
  }
  return map;
}

