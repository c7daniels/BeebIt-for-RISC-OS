void r6502reset(R6502CPUMAP* ctop, const R6502OP* const* mainsequences, const R6502OP* const* extrasequences)
{
  int i;

  /*it is assumed that shift fields for AArch32 byte/word aliasing
   have been initialised to zero at load time or by calloc()*/

  ctop[-1].oldreset = FALSE;
  ctop[-1].lbreak = FALSE;

  ctop[-1].sync_pc_code = ADDRESSING_BASECODE;
  ctop[-1].sp_code = 0xFF000000 | (0x0100>>8);
  ctop[-1].interruptqueue_ps = UFLAG | BFLAG | IFLAG;

  for (i=0; i<R6502_MAIN_SEQUENCE_COUNT; i++)
  {
    ctop[-1].sequences[i] = mainsequences[i];
  }
  for (i=0; i<R6502_EXTRA_SEQUENCE_COUNT; i++)
  {
    ctop[-1].sequences[R6502_MAIN_SEQUENCE_COUNT+i] = extrasequences[i];
  }

  ctop[-1].execute_cpu_state = ctop[-1].sequences[R6502_RESET_SEQUENCE];
  ctop[-1].address_code = (ctop[-1].address_code & 0xFFFF0000) | ADDRESSING_BASECODE;
}

void r6502swapopcode07(R6502CPUMAP* ctop)
{
  const R6502OP* s;
#ifndef BEEBIT_NO_ASM
  void* r;
#endif
  s = ctop[-1].sequences[R6502_OPCODE_07_SEQUENCE];

  ctop[-1].sequences[R6502_OPCODE_07_SEQUENCE] = ctop[-1].sequences[0x07];
  ctop[-1].sequences[0x07] = s;

#ifndef BEEBIT_NO_ASM
  r = ctop[-1].opcoderoutines[R6502_OPCODE_07_SEQUENCE];

  ctop[-1].opcoderoutines[R6502_OPCODE_07_SEQUENCE] = ctop[-1].opcoderoutines[0x07];
  ctop[-1].opcoderoutines[0x07] = r;

  r = ctop[-1].o_opcoderoutines[R6502_OPCODE_07_SEQUENCE];

  ctop[-1].o_opcoderoutines[R6502_OPCODE_07_SEQUENCE] = ctop[-1].o_opcoderoutines[0x07];
  ctop[-1].o_opcoderoutines[0x07] = r;
#endif
}

static R6502CPUMAP* r6502readmemoryread(R6502CPUMAP* ctop, uint8_t* p)
{
  ctop[-1].m = *p;
  return ctop;
}

void r6502readmemory(R6502CPUMAP* ctop, char* buffer, uintptr_t naddress, int ncount)
{
  unsigned char savedm = ctop[-1].m;
  uintptr_t address_code = ((naddress<<16) & 0xFFFF0000) | ADDRESSING_BASECODE;
  R6502READSPECIALOP rds = ctop[-1].readspecialaction;

  for ( ; ncount > 0; ncount--, buffer++)
  {
    R6502_TOUCH_ADDRESS(ctop, address_code, rds, rds, rds, r6502readmemoryread)
    *buffer = ctop[-1].m;

    address_code = (address_code + 0x10000) & 0xFFFFFFFF;
  }

  ctop[-1].m = savedm;
}

void r6502beforesnapshot(R6502CPUMAP* ctop)
{
  if (ctop[-1].interruptqueue_ps & R6502_IRQ_ENABLE)
    ctop[-1].interruptqueue_ps &= NOTIFLAG;
}

static R6502CPUMAP* r6502opcoderead(R6502CPUMAP* ctop, uint8_t* p)
{
  ctop[-1].sequencenumber = *p;
  return ctop;
}

static R6502CPUMAP* r6502opcodereadspecial(R6502CPUMAP* ctop, uintptr_t address_code)
{
  ctop[-1].readspecialaction(ctop, address_code);
  ctop[-1].sequencenumber = ctop[-1].m;
  return ctop;
}

void r6502aftersnapshot(R6502CPUMAP* ctop)
{
  uintptr_t address_code = ((ctop[-1].sync_pc_code<<16) & 0xFFFF0000) | ADDRESSING_BASECODE;
  /*a refetch from an I/O address can have side-effects and/or yield a different opcode*/
  R6502READSPECIALOP rds = r6502opcodereadspecial;

  R6502_TOUCH_ADDRESS(ctop, address_code, rds, rds, rds, r6502opcoderead)
  ctop[-1].execute_cpu_state = ctop[-1].sequences[ctop[-1].m];

  if (ctop[-1].interruptqueue_ps & IFLAG)
    ctop[-1].interruptqueue_ps &= ~R6502_IRQ_ENABLE;
  else
    ctop[-1].interruptqueue_ps |= R6502_IRQ_ENABLE | IFLAG;
}
