R6502HOSTMAP* swappagesintomemoryb(R6502HOSTMAP* map)
{
  int nrom;

  nrom = map->romsel & 0x0F;
  memcpy(&memory[0x8000],roms[nrom],0x4000);
  return map;
}

R6502HOSTMAP* swappagesintomemorybp(R6502HOSTMAP* map)
{
  int nrom;
  unsigned int pc = (map->pc_code>>16);

  if ((pc >= 0xC000 AND pc < 0xE000)
    OR ((map->romsel & 0x80) AND pc >= 0xA000 AND pc < 0xB000))
  {
    swappages(&memory[0x3000],&shadow[0x3000],0x50);
  }

  nrom = map->romsel & 0x0F;
  if (nrom == 0x0F)
    nrom = 0x0E;
  if (map->romsel & 0x80)
  {
    memcpy(&memory[0x8000],shadow,0x3000);
    memcpy(&memory[0xB000],&roms[nrom][0x3000],0x1000);
  }
  else
    memcpy(&memory[0x8000],roms[nrom],0x4000);
  return map;
}

R6502HOSTMAP* swappagesoutofmemoryb(R6502HOSTMAP* map)
{
  int nrom;

  nrom = map->romsel & 0x0F;
  if (map->romwritable[nrom])
    memcpy(roms[nrom],&memory[0x8000],0x4000);
  return map;
}

R6502HOSTMAP* swappagesoutofmemorybp(R6502HOSTMAP* map)
{
  int nrom;
  unsigned int pc = (map->pc_code>>16);

  if ((pc >= 0xC000 AND pc < 0xE000)
    OR ((map->romsel & 0x80) AND pc >= 0xA000 AND pc < 0xB000))
  {
    swappages(&memory[0x3000],&shadow[0x3000],0x50);
  }

  nrom = map->romsel & 0x0F;
  if (nrom == 0x0F)
    nrom = 0x0E;  
  if (map->romsel & 0x80)
  {
    memcpy(shadow,&memory[0x8000],0x3000);
    if (map->romwritable[nrom])
      memcpy(&roms[nrom][0x3000],&memory[0xB000],0x1000);
  }
  else
  {
    if (map->romwritable[nrom])
      memcpy(roms[nrom],&memory[0x8000],0x4000);
  }
  return map;
}

