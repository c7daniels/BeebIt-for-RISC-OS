    }
    #ifdef WD1770_DEBUG
    bbcvdu(68);
    bbcvdu(32);
    inttohex(nlocation);
    #endif
    nlocation = nlocation * nsize;
    #ifdef WD1770_DEBUG
    bbcvdu(32);
    inttohex(nlocation);
    bbcvdu(13);
    bbcvdu(10);
    #endif
    w1770writeimage(beebit_driveimage[ndrive], nlocation, nsize);
  }
}

R6502HOSTMAP* w1770poll(R6502HOSTMAP* map)
{
  #ifdef WD1770_DEBUG
  bbcvdu(80);
  bbcvdu(32);
  inttohex(map->s0w1770.commandreg);
  bbcvdu(32);
  inttohex(map->s0w1770.statusreg);
  bbcvdu(13);
  bbcvdu(10);
  #endif
  switch (map->s0w1770.commandreg & 0xF0)
  {
    case 0x00:
      /*restore*/
      if (!(map->s0w1770.statusreg & STATUS_NOTSPINUP))
      {
        /*disable the motor spin up sequence*/
        map->s0w1770.statusreg |= STATUS_NOTSPINUP;
        map->s0w1770.statusreg |= STATUS_MOTORON;
        /*verify?*/
      }
      map->s0w1770.statusreg &= STATUS_NOTBUSY;
      SETNMI;
      break;
    case 0x10:
      /*seek*/
      map->s0w1770.statusreg &= STATUS_NOTBUSY;
      SETNMI;
      break;
    case 0x20:
    case 0x30:
      /*step command*/
      map->s0w1770.statusreg &= STATUS_NOTBUSY;
      SETNMI;
    case 0x40:
    case 0x50:
      /*step in command*/
      map->s0w1770.statusreg &= STATUS_NOTBUSY;
      SETNMI;
      break;
    case 0x60:
    case 0x70:
      /*step out command*/
      map->s0w1770.statusreg &= STATUS_NOTBUSY;
      SETNMI;
      break;
    case 0x80:
    case 0x90:
      /*read sector*/
      if (map->s2w1770.lastbyte)
      {
        /*the last byte of the sector has been read*/
        map->s2w1770.lastbyte = FALSE;
        if (map->s0w1770.commandreg & 0x10)
        {
          /*multiple sector*/
          if (beebit_imagetype[map->s0w1770.drive+map->s0w1770.side] & ADFS_MASK)
          {
            /*ADFS*/
            if (map->s0w1770.sectorreg >= ADFS_SECTORS_PER_TRACK)
              map->s0w1770.statusreg &= STATUS_NOTBUSY;
          }
          else
          {
            /*DFS*/
            if (map->s0w1770.sectorreg >= DFS_SECTORS_PER_TRACK)
              map->s0w1770.statusreg &= STATUS_NOTBUSY;
          }
          map->s2w1770.byteinsector = 0;

        }
        else
          map->s0w1770.statusreg &= STATUS_NOTBUSY;
        SETNMI
      }
      else
      {
        if (!(map->s0w1770.statusreg & STATUS_DATAREQUEST))
        {
          if (map->s2w1770.byteinsector == 0)
            w1770discread();
          map->s0w1770.datareg = w1770_data[map->s2w1770.byteinsector++];
          /*map->s0w1770.statusreg &= STATUS_NOTCRCERROR;*/
          map->s0w1770.statusreg &= STATUS_NOTRECORDTYPE;
          map->s0w1770.statusreg |= STATUS_DATAREQUEST;
          if (beebit_imagetype[map->s0w1770.drive+map->s0w1770.side] & ADFS_MASK)
            /*ADFS*/
            map->s2w1770.lastbyte = (map->s2w1770.byteinsector & ADFS_SECTOR_SIZE);
          else
            /*DFS*/
            map->s2w1770.lastbyte = (map->s2w1770.byteinsector & DFS_SECTOR_SIZE);
          if (map->s2w1770.lastbyte)
          {
            /*end of sector*/
            map->s2w1770.byteinsector = 0;
            /*map->s0w1770.statusreg &= STATUS_NOTBUSY;*/
            map->s2cycles.w1770_togo += (16<<1);
          }
          else
            map->s2cycles.w1770_togo += (64<<1);
          /*map->s2cycles.w1770_togo += (62+(map->s2w1770.byteinsector & 1))<<1;*/
          /*SETNMI;*/
        }
        else
          map->s0w1770.statusreg |= STATUS_LOSTDATA;
        SETNMI
      }
      break;
    case 0xA0:
    case 0xB0:
      /*write sector*/
      if (!beebit_discwritable[map->s0w1770.drive+map->s0w1770.side])
      {
        map->s0w1770.statusreg |= STATUS_WRITEPROTECT;
        map->s0w1770.statusreg &= STATUS_NOTBUSY;
        SETNMI
      }
      else if (!map->s2w1770.writegate)
      {
        map->s2cycles.w1770_togo += (64<<1);
        SETNMI
      }
      else
      {
        if (map->s2w1770.lastbyte)
        {
          /*the last byte of the sector has been written*/
          map->s2w1770.lastbyte = FALSE;
        }
        else
        {
          if (!(map->s0w1770.statusreg & STATUS_DATAREQUEST))
          {
            #ifdef WD1770_DEBUG
            bbcvdu(66);
            bbcvdu(32);
            inttohex(map->s2w1770.byteinsector);
            bbcvdu(32);
            inttohex(map->s0w1770.datareg);
            bbcvdu(13);
            bbcvdu(10);
            #endif
            w1770_data[map->s2w1770.byteinsector++] = map->s0w1770.datareg;
            /*map->s0w1770.statusreg &= STATUS_NOTCRCERROR;*/
            map->s0w1770.statusreg &= STATUS_NOTRECORDTYPE;
            map->s0w1770.statusreg |= STATUS_DATAREQUEST;

            if (beebit_imagetype[map->s0w1770.drive+map->s0w1770.side] & ADFS_MASK)
              /*ADFS*/
              map->s2w1770.lastbyte = (map->s2w1770.byteinsector & ADFS_SECTOR_SIZE);
            else
              /*DFS*/
              map->s2w1770.lastbyte = (map->s2w1770.byteinsector & DFS_SECTOR_SIZE);
            if (map->s2w1770.lastbyte)
            {
              w1770discwrite();
              /*end of sector*/
              map->s2w1770.byteinsector = 0;
              /*map->s0w1770.statusreg &= STATUS_NOTBUSY;*/
              map->s2cycles.w1770_togo += (16<<1);

              if (map->s0w1770.commandreg & 0x10)
              {
                /*multiple sector*/
                if (beebit_imagetype[map->s0w1770.drive+map->s0w1770.side] & ADFS_MASK)
                {
                  /*ADFS*/
                  if (map->s0w1770.sectorreg >= ADFS_SECTORS_PER_TRACK)
                    map->s0w1770.statusreg &= STATUS_NOTBUSY;
                }
                else
                {
                  /*DFS*/
                  if (map->s0w1770.sectorreg >= DFS_SECTORS_PER_TRACK)
                    map->s0w1770.statusreg &= STATUS_NOTBUSY;
                }
                map->s2w1770.byteinsector = 0;
              }
              else
                map->s0w1770.statusreg &= STATUS_NOTBUSY;
              SETNMI
            }
            else
              map->s2cycles.w1770_togo += (64<<1);
            /*map->s2cycles.w1770_togo += (62+(map->s2w1770.byteinsector & 1))<<1;*/
            /*SETNMI;*/
          }
          else
            map->s0w1770.statusreg |= STATUS_LOSTDATA;
          SETNMI
        }
      }
      break;
    case 0xC0:
      /*read address*/
      switch (map->s2w1770.byteinsector)
      {
        case 0:
          map->s0w1770.datareg = map->s0w1770.track;
          break;
        case 1:
          map->s0w1770.datareg = map->s0w1770.side;
          break;
        case 2:
          map->s0w1770.datareg = map->s0w1770.sectorreg;
          break;
        case 3:
          /*sector length*/
          map->s0w1770.datareg = 1;
          break;
        case 4:
        case 5:
          map->s0w1770.datareg = 0;
          break;
        default:
          map->s0w1770.statusreg &= STATUS_NOTBUSY;
      }
      map->s2w1770.byteinsector++;
      SETNMI
      break;
    case 0xD0:
    case 0xE0:
    case 0xF0:
      break;
  }

  if ((map->nmis & NMIS_NMI) AND !(map->nmis & NMIS_OLDNMI))
  {
    r6502startinterrupt(map);
  }
  return map;
}

void w1770type1flags(char nvalue)
{
  /*step time*/
  switch (nvalue & 0x03)
  {
    case 0x00:
      hostmap.s2w1770.steptime = 6000;
      break;
    case 0x01:
      hostmap.s2w1770.steptime = 12000;
      break;
    case 0x02:
      hostmap.s2w1770.steptime = 20000;
      break;
    case 0x03:
      hostmap.s2w1770.steptime = 30000;
      break;
  }

  /*verify flag*/
  if (nvalue & 0x04)
    hostmap.s2cycles.w1770_togo += (30000<<1); /*30ms*/

  hostmap.s0w1770.statusreg |= STATUS_BUSY;
  hostmap.s0w1770.statusreg &= STATUS_NOTDATAREQUEST;
  hostmap.s0w1770.statusreg &= STATUS_NOTCRCERROR;
  hostmap.s0w1770.statusreg &= STATUS_NOTNOTFOUND;
  UNSETNMI

  /*motor on*/
  if (nvalue & 0x08)
  {
    /*disable the motor spin up sequence*/
    hostmap.s0w1770.statusreg |= STATUS_NOTSPINUP;
    hostmap.s2cycles.w1770_togo += (WD1770_ONEREVOLUTION<<1);
  }
  else
  {
    if (!(hostmap.s0w1770.statusreg & STATUS_MOTORON))
    {
      /*the motor is off*/
      /*turn motor on*/
      hostmap.s0w1770.statusreg |= STATUS_MOTORON;
      hostmap.s0w1770.statusreg &= STATUS_SPINUP;
      /*wait 6 revolutions*/
      hostmap.s2cycles.w1770_togo += ((WD1770_ONEREVOLUTION<<1)*6);
    }
  }
}

void w1770commandrestore(char nvalue)
{
  w1770type1flags(nvalue);
  if (hostmap.s0w1770.track == 0)
    hostmap.s0w1770.trackreg = 0;
  else
  {
    if (hostmap.s0w1770.track <= 255)
    {
      hostmap.s0w1770.track = hostmap.s0w1770.trackreg = 0;
      hostmap.s0w1770.statusreg &= STATUS_TRACKZERO;
    }
    else
    {
      hostmap.s0w1770.track -= 0xFF;
      if (nvalue & 0x04)
        hostmap.s0w1770.statusreg |= STATUS_NOTTRACKZERO;
    }
  }
  if (hostmap.s2cycles.w1770_togo <= 0)
    hostmap.s2cycles.w1770_togo = 1;
}

void w1770commandseek(char nvalue)
{
  w1770type1flags(nvalue);
  hostmap.s0w1770.trackreg = hostmap.s0w1770.track = hostmap.s0w1770.datareg;
  if (hostmap.s2cycles.w1770_togo <= 0)
    hostmap.s2cycles.w1770_togo = 1;
}

void w1770commandstep(char nvalue)
{
  w1770type1flags(nvalue);
  switch (hostmap.s2w1770.stepdir)
  {
    case WD1770_STEPIN:
      hostmap.s0w1770.track++;
      break;
    case WD1770_STEPOUT:
      hostmap.s0w1770.track--;
      break;
  }
  /*update track register*/
  if (hostmap.s0w1770.commandreg & 0x10)
    hostmap.s0w1770.trackreg = hostmap.s0w1770.track = hostmap.s0w1770.track;

  hostmap.s2cycles.w1770_togo += (hostmap.s2w1770.steptime<<1);
}

void w1770commandstepin(char nvalue)
{
  w1770type1flags(nvalue);
  hostmap.s0w1770.track++;
  hostmap.s2w1770.stepdir = WD1770_STEPIN;
  /*update track register*/
  if (hostmap.s0w1770.commandreg & 0x10)
    hostmap.s0w1770.trackreg = hostmap.s0w1770.track = hostmap.s0w1770.track;

  hostmap.s2cycles.w1770_togo += (hostmap.s2w1770.steptime<<1);
}

void w1770commandstepout(char nvalue)
{
  w1770type1flags(nvalue);
  hostmap.s0w1770.track--;
  hostmap.s2w1770.stepdir = WD1770_STEPOUT;
  /*update track register*/
  if (hostmap.s0w1770.commandreg & 0x10)
    hostmap.s0w1770.trackreg = hostmap.s0w1770.track;

  hostmap.s2cycles.w1770_togo += (hostmap.s2w1770.steptime<<1);
}

void w1770type2flags(char nvalue)
{
  hostmap.s0w1770.statusreg |= STATUS_BUSY;
  hostmap.s0w1770.statusreg &= STATUS_NOTLOSTDATA;
  hostmap.s0w1770.statusreg &= STATUS_NOTNOTFOUND;
  hostmap.s0w1770.statusreg &= STATUS_NOTRECORDTYPE;
  hostmap.s0w1770.statusreg &= STATUS_NOTWRITEPROTECT;
  UNSETNMI

  /*motor on*/
  if (nvalue & 0x08)
  {
    /*disable the motor spin up sequence*/
    hostmap.s0w1770.statusreg |= STATUS_NOTSPINUP;
    hostmap.s2cycles.w1770_togo += (WD1770_ONEREVOLUTION<<1);
  }
  else
  {
    if (!(hostmap.s0w1770.statusreg & STATUS_MOTORON))
    {
      /*the motor is off*/
      /*turn motor on*/
      hostmap.s0w1770.statusreg |= STATUS_MOTORON;
      hostmap.s0w1770.statusreg &= STATUS_SPINUP;
      /*wait 6 revolutions*/
      hostmap.s2cycles.w1770_togo += ((WD1770_ONEREVOLUTION<<1)*6);
    }
  }

  if (nvalue & 0x04)
    /*settling delay 30ms*/
    hostmap.s2cycles.w1770_togo += (30000<<1);
}

void w1770commandreadsector(char nvalue)
{
  w1770type2flags(nvalue);
  hostmap.s0w1770.statusreg &= STATUS_NOTDATAREQUEST;
  hostmap.s2w1770.byteinsector = 0;

  /*an underestimate of the time to recognise and read the first byte in the sector*/
  hostmap.s2cycles.w1770_togo += (320<<1);
}

void w1770commandwritesector(char nvalue)
{
  w1770type2flags(nvalue);

  if (beebit_discwritable[hostmap.s0w1770.drive+hostmap.s0w1770.side])
    hostmap.s0w1770.statusreg |= STATUS_DATAREQUEST;

  hostmap.s2w1770.byteinsector = 0;

  hostmap.s2w1770.writegate = FALSE;

  /*an underestimate of the time to recognise the first byte in the sector*/
  hostmap.s2cycles.w1770_togo += (256<<1);
}

void w1770type3flags(char nvalue)
{
  hostmap.s0w1770.statusreg |= STATUS_BUSY;
  hostmap.s0w1770.statusreg &= STATUS_NOTDATAREQUEST;
  hostmap.s0w1770.statusreg &= STATUS_NOTLOSTDATA;
  hostmap.s0w1770.statusreg &= STATUS_NOTNOTFOUND;
  hostmap.s0w1770.statusreg &= STATUS_NOTRECORDTYPE;
  UNSETNMI

  /*motor on*/
  if (nvalue & 0x08)
  {
    /*disable the motor spin up sequence*/
    hostmap.s0w1770.statusreg |= STATUS_NOTSPINUP;
    hostmap.s2cycles.w1770_togo += (WD1770_ONEREVOLUTION<<1);
  }
  else
  {
    if (!(hostmap.s0w1770.statusreg & STATUS_MOTORON))
    {
      /*the motor is off*/
      /*turn motor on*/
      hostmap.s0w1770.statusreg |= STATUS_MOTORON;
      hostmap.s0w1770.statusreg &= STATUS_SPINUP;
      /*wait 6 revolutions*/
      hostmap.s2cycles.w1770_togo += ((WD1770_ONEREVOLUTION<<1)*6);
    }
  }

  if (nvalue & 0x04)
    /*settling delay 30ms*/
    hostmap.s2cycles.w1770_togo += (30000<<1);
}

