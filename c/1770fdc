struct R6502CPUMAP* w1770datawrite(struct R6502CPUMAP* ctop, uintptr_t address_code, uint8_t value)
{
  HOSTMAP* htop = (HOSTMAP*)ctop;
  if (htop[-1].A_w1770.commandreg & 0x80)
  {
    htop[-1].A_w1770.statusreg &= STATUS_NOTDATAREQUEST;
    htop[-1].B_w1770.writegate = TRUE;
  }
  htop[-1].A_w1770.datareg = value;
  return ctop;
}
