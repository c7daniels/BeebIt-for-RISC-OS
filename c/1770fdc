        nsize = DFS_SECTOR_SIZE;
        break;
      case DFS_DSD_TRACK:
        ndrive = hostmap.s0w1770.drive;
        nlocation = ((hostmap.s0w1770.track*2)*DFS_SECTORS_PER_TRACK)+hostmap.s0w1770.sectorreg;
        if (hostmap.s0w1770.side > 0)
          nlocation += DFS_SECTORS_PER_TRACK;
        nsize = DFS_SECTOR_SIZE;
        break;
      case DFS_DSD_SIDE:
        ndrive = hostmap.s0w1770.drive;
        nlocation = (hostmap.s0w1770.track*DFS_SECTORS_PER_TRACK)+hostmap.s0w1770.sectorreg;
        if (hostmap.s0w1770.drive > 0)
          nlocation += beebit_sectorcount[ndrive];
