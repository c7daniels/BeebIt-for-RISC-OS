struct R6502CPUMAP* w1770commandwrite(struct R6502CPUMAP* ctop, uintptr_t address_code, uint8_t value)
{
  HOSTMAP* htop = (HOSTMAP*)ctop;
  REGISTERUNSETNMI
  /*command words are only loaded in the command register when the busy status bit is off (status bit 0)*/
  if (htop[-1].A_w1770.statusreg & STATUS_BUSY)
  {
    if ((value & 0xF0) == 0xD0)
    {
      htop[-1].A_w1770.commandreg = value;
      w1770command(value);
    }
  }
  else
  {
    if (beebit_imagetype[htop[-1].A_w1770.drive+htop[-1].A_w1770.side] == DFS_NONE)
    {
      htop[-1].A_w1770.statusreg &= STATUS_NOTBUSY;
      htop[-1].A_w1770.statusreg |= STATUS_NOTFOUND;
    }
    else
    {
      htop[-1].A_w1770.commandreg = value;
      w1770command(value);
    }
  }
  return ctop;
}

