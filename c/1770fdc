HOSTMAP* w1770poll(HOSTMAP* htop)
{
  #ifdef WD1770_DEBUG
  bbcvdu(80);
  bbcvdu(32);
  inttohex(htop[-1].A_w1770.commandreg);
  bbcvdu(32);
  inttohex(htop[-1].A_w1770.statusreg);
  bbcvdu(13);
  bbcvdu(10);
  #endif
  switch (htop[-1].A_w1770.commandreg & 0xF0)
  {
    case 0x00:
      /*restore*/
      if (!(htop[-1].A_w1770.statusreg & STATUS_NOTSPINUP))
      {
        /*disable the motor spin up sequence*/
        htop[-1].A_w1770.statusreg |= STATUS_NOTSPINUP;
        htop[-1].A_w1770.statusreg |= STATUS_MOTORON;
        /*verify?*/
      }
      htop[-1].A_w1770.statusreg &= STATUS_NOTBUSY;
      EVENTSETNMI
      break;
    case 0x10:
      /*seek*/
      htop[-1].A_w1770.statusreg &= STATUS_NOTBUSY;
      EVENTSETNMI
      break;
    case 0x20:
    case 0x30:
      /*step command*/
      htop[-1].A_w1770.statusreg &= STATUS_NOTBUSY;
      EVENTSETNMI
    case 0x40:
    case 0x50:
      /*step in command*/
      htop[-1].A_w1770.statusreg &= STATUS_NOTBUSY;
      EVENTSETNMI
      break;
    case 0x60:
    case 0x70:
      /*step out command*/
      htop[-1].A_w1770.statusreg &= STATUS_NOTBUSY;
      EVENTSETNMI
      break;
    case 0x80:
    case 0x90:
      /*read sector*/
      if (htop[-1].B_w1770.lastbyte)
      {
        /*the last byte of the sector has been read*/
        htop[-1].B_w1770.lastbyte = FALSE;
        if (htop[-1].A_w1770.commandreg & 0x10)
        {
          /*multiple sector*/
          if (beebit_imagetype[htop[-1].A_w1770.drive+htop[-1].A_w1770.side] & ADFS_MASK)
          {
            /*ADFS*/
            if (htop[-1].A_w1770.sectorreg >= ADFS_SECTORS_PER_TRACK)
              htop[-1].A_w1770.statusreg &= STATUS_NOTBUSY;
          }
          else
          {
            /*DFS*/
            if (htop[-1].A_w1770.sectorreg >= DFS_SECTORS_PER_TRACK)
              htop[-1].A_w1770.statusreg &= STATUS_NOTBUSY;
          }
          htop[-1].B_w1770.byteinsector = 0;

        }
        else
          htop[-1].A_w1770.statusreg &= STATUS_NOTBUSY;
        EVENTSETNMI
      }
      else
      {
        if (!(htop[-1].A_w1770.statusreg & STATUS_DATAREQUEST))
        {
          if (htop[-1].B_w1770.byteinsector == 0)
            w1770discread();
          htop[-1].A_w1770.datareg = w1770_data[htop[-1].B_w1770.byteinsector++];
          /*htop[-1].A_w1770.statusreg &= STATUS_NOTCRCERROR;*/
          htop[-1].A_w1770.statusreg &= STATUS_NOTRECORDTYPE;
          htop[-1].A_w1770.statusreg |= STATUS_DATAREQUEST;
          if (beebit_imagetype[htop[-1].A_w1770.drive+htop[-1].A_w1770.side] & ADFS_MASK)
            /*ADFS*/
            htop[-1].B_w1770.lastbyte = (htop[-1].B_w1770.byteinsector & ADFS_SECTOR_SIZE);
          else
            /*DFS*/
            htop[-1].B_w1770.lastbyte = (htop[-1].B_w1770.byteinsector & DFS_SECTOR_SIZE);
          if (htop[-1].B_w1770.lastbyte)
          {
            /*end of sector*/
            htop[-1].B_w1770.byteinsector = 0;
            /*htop[-1].A_w1770.statusreg &= STATUS_NOTBUSY;*/
            htop[-1].cycles.w1770_togo += (16<<1);
          }
          else
            htop[-1].cycles.w1770_togo += (64<<1);
          /*htop[-1].cycles.w1770_togo += (62+(htop[-1].B_w1770.byteinsector & 1))<<1;*/
          /*EVENTSETNMI*/
        }
        else
          htop[-1].A_w1770.statusreg |= STATUS_LOSTDATA;
        EVENTSETNMI
      }
      break;
    case 0xA0:
    case 0xB0:
      /*write sector*/
      if (!beebit_discwritable[htop[-1].A_w1770.drive+htop[-1].A_w1770.side])
      {
        htop[-1].A_w1770.statusreg |= STATUS_WRITEPROTECT;
        htop[-1].A_w1770.statusreg &= STATUS_NOTBUSY;
        EVENTSETNMI
      }
      else if (!htop[-1].B_w1770.writegate)
      {
        htop[-1].cycles.w1770_togo += (64<<1);
        EVENTSETNMI
      }
      else
      {
        if (htop[-1].B_w1770.lastbyte)
        {
          /*the last byte of the sector has been written*/
          htop[-1].B_w1770.lastbyte = FALSE;
        }
        else
        {
          if (!(htop[-1].A_w1770.statusreg & STATUS_DATAREQUEST))
          {
            #ifdef WD1770_DEBUG
            bbcvdu(66);
            bbcvdu(32);
            inttohex(htop[-1].B_w1770.byteinsector);
            bbcvdu(32);
            inttohex(htop[-1].A_w1770.datareg);
            bbcvdu(13);
            bbcvdu(10);
            #endif
            w1770_data[htop[-1].B_w1770.byteinsector++] = htop[-1].A_w1770.datareg;
            /*htop[-1].A_w1770.statusreg &= STATUS_NOTCRCERROR;*/
            htop[-1].A_w1770.statusreg &= STATUS_NOTRECORDTYPE;
            htop[-1].A_w1770.statusreg |= STATUS_DATAREQUEST;

            if (beebit_imagetype[htop[-1].A_w1770.drive+htop[-1].A_w1770.side] & ADFS_MASK)
              /*ADFS*/
              htop[-1].B_w1770.lastbyte = (htop[-1].B_w1770.byteinsector & ADFS_SECTOR_SIZE);
            else
              /*DFS*/
              htop[-1].B_w1770.lastbyte = (htop[-1].B_w1770.byteinsector & DFS_SECTOR_SIZE);
            if (htop[-1].B_w1770.lastbyte)
            {
              w1770discwrite();
              /*end of sector*/
              htop[-1].B_w1770.byteinsector = 0;
              /*htop[-1].A_w1770.statusreg &= STATUS_NOTBUSY;*/
              htop[-1].cycles.w1770_togo += (16<<1);

              if (htop[-1].A_w1770.commandreg & 0x10)
              {
                /*multiple sector*/
                if (beebit_imagetype[htop[-1].A_w1770.drive+htop[-1].A_w1770.side] & ADFS_MASK)
                {
                  /*ADFS*/
                  if (htop[-1].A_w1770.sectorreg >= ADFS_SECTORS_PER_TRACK)
                    htop[-1].A_w1770.statusreg &= STATUS_NOTBUSY;
                }
                else
                {
                  /*DFS*/
                  if (htop[-1].A_w1770.sectorreg >= DFS_SECTORS_PER_TRACK)
                    htop[-1].A_w1770.statusreg &= STATUS_NOTBUSY;
                }
                htop[-1].B_w1770.byteinsector = 0;
              }
              else
                htop[-1].A_w1770.statusreg &= STATUS_NOTBUSY;
              EVENTSETNMI
            }
            else
              htop[-1].cycles.w1770_togo += (64<<1);
            /*htop[-1].cycles.w1770_togo += (62+(htop[-1].B_w1770.byteinsector & 1))<<1;*/
            /*EVENTSETNMI*/
          }
          else
            htop[-1].A_w1770.statusreg |= STATUS_LOSTDATA;
          EVENTSETNMI
        }
      }
      break;
    case 0xC0:
      /*read address*/
      switch (htop[-1].B_w1770.byteinsector)
      {
        case 0:
          htop[-1].A_w1770.datareg = htop[-1].A_w1770.track;
          break;
        case 1:
          htop[-1].A_w1770.datareg = htop[-1].A_w1770.side;
          break;
        case 2:
          htop[-1].A_w1770.datareg = htop[-1].A_w1770.sectorreg;
          break;
        case 3:
          /*sector length*/
          htop[-1].A_w1770.datareg = 1;
          break;
        case 4:
        case 5:
          htop[-1].A_w1770.datareg = 0;
          break;
        default:
          htop[-1].A_w1770.statusreg &= STATUS_NOTBUSY;
      }
      htop[-1].B_w1770.byteinsector++;
      EVENTSETNMI
      break;
    case 0xD0:
    case 0xE0:
    case 0xF0:
      break;
  }
  return htop;
}

void w1770type1flags(char nvalue)
{
  HOSTMAP* htop = (HOSTMAP*)&hostmap.upper;
  /*step time*/
  switch (nvalue & 0x03)
  {
    case 0x00:
      htop[-1].B_w1770.steptime = 6000;
      break;
    case 0x01:
      htop[-1].B_w1770.steptime = 12000;
      break;
    case 0x02:
      htop[-1].B_w1770.steptime = 20000;
      break;
    case 0x03:
      htop[-1].B_w1770.steptime = 30000;
      break;
  }

  /*verify flag*/
  if (nvalue & 0x04)
    htop[-1].cycles.w1770_togo += (30000<<1); /*30ms*/

  htop[-1].A_w1770.statusreg |= STATUS_BUSY;
  htop[-1].A_w1770.statusreg &= STATUS_NOTDATAREQUEST;
  htop[-1].A_w1770.statusreg &= STATUS_NOTCRCERROR;
  htop[-1].A_w1770.statusreg &= STATUS_NOTNOTFOUND;
  REGISTERUNSETNMI

  /*motor on*/
  if (nvalue & 0x08)
  {
    /*disable the motor spin up sequence*/
    htop[-1].A_w1770.statusreg |= STATUS_NOTSPINUP;
    htop[-1].cycles.w1770_togo += (WD1770_ONEREVOLUTION<<1);
  }
  else
  {
    if (!(htop[-1].A_w1770.statusreg & STATUS_MOTORON))
    {
      /*the motor is off*/
      /*turn motor on*/
      htop[-1].A_w1770.statusreg |= STATUS_MOTORON;
      htop[-1].A_w1770.statusreg &= STATUS_SPINUP;
      /*wait 6 revolutions*/
      htop[-1].cycles.w1770_togo += ((WD1770_ONEREVOLUTION<<1)*6);
    }
  }
}

void w1770commandrestore(char nvalue)
{
  HOSTMAP* htop = (HOSTMAP*)&hostmap.upper;
  w1770type1flags(nvalue);
  if (htop[-1].A_w1770.track == 0)
    htop[-1].A_w1770.trackreg = 0;
  else
  {
    if (htop[-1].A_w1770.track <= 255)
    {
      htop[-1].A_w1770.track = htop[-1].A_w1770.trackreg = 0;
      htop[-1].A_w1770.statusreg &= STATUS_TRACKZERO;
    }
    else
    {
      htop[-1].A_w1770.track -= 0xFF;
      if (nvalue & 0x04)
        htop[-1].A_w1770.statusreg |= STATUS_NOTTRACKZERO;
    }
  }
  if (htop[-1].cycles.w1770_togo <= 0)
    htop[-1].cycles.w1770_togo = 1;
}

void w1770commandseek(char nvalue)
{
  HOSTMAP* htop = (HOSTMAP*)&hostmap.upper;
  w1770type1flags(nvalue);
  htop[-1].A_w1770.trackreg = htop[-1].A_w1770.track = htop[-1].A_w1770.datareg;
  if (htop[-1].cycles.w1770_togo <= 0)
    htop[-1].cycles.w1770_togo = 1;
}

void w1770commandstep(char nvalue)
{
  HOSTMAP* htop = (HOSTMAP*)&hostmap.upper;
  w1770type1flags(nvalue);
  switch (htop[-1].B_w1770.stepdir)
  {
    case WD1770_STEPIN:
      htop[-1].A_w1770.track++;
      break;
    case WD1770_STEPOUT:
      htop[-1].A_w1770.track--;
      break;
  }
  /*update track register*/
  if (htop[-1].A_w1770.commandreg & 0x10)
    htop[-1].A_w1770.trackreg = htop[-1].A_w1770.track = htop[-1].A_w1770.track;

  htop[-1].cycles.w1770_togo += (htop[-1].B_w1770.steptime<<1);
}

void w1770commandstepin(char nvalue)
{
  HOSTMAP* htop = (HOSTMAP*)&hostmap.upper;
  w1770type1flags(nvalue);
  htop[-1].A_w1770.track++;
  htop[-1].B_w1770.stepdir = WD1770_STEPIN;
  /*update track register*/
  if (htop[-1].A_w1770.commandreg & 0x10)
    htop[-1].A_w1770.trackreg = htop[-1].A_w1770.track = htop[-1].A_w1770.track;

  htop[-1].cycles.w1770_togo += (htop[-1].B_w1770.steptime<<1);
}

void w1770commandstepout(char nvalue)
{
  HOSTMAP* htop = (HOSTMAP*)&hostmap.upper;
  w1770type1flags(nvalue);
  htop[-1].A_w1770.track--;
  htop[-1].B_w1770.stepdir = WD1770_STEPOUT;
  /*update track register*/
  if (htop[-1].A_w1770.commandreg & 0x10)
    htop[-1].A_w1770.trackreg = htop[-1].A_w1770.track;

  htop[-1].cycles.w1770_togo += (htop[-1].B_w1770.steptime<<1);
}

void w1770type2flags(char nvalue)
{
  HOSTMAP* htop = (HOSTMAP*)&hostmap.upper;
  htop[-1].A_w1770.statusreg |= STATUS_BUSY;
  htop[-1].A_w1770.statusreg &= STATUS_NOTLOSTDATA;
  htop[-1].A_w1770.statusreg &= STATUS_NOTNOTFOUND;
  htop[-1].A_w1770.statusreg &= STATUS_NOTRECORDTYPE;
  htop[-1].A_w1770.statusreg &= STATUS_NOTWRITEPROTECT;
  REGISTERUNSETNMI

  /*motor on*/
  if (nvalue & 0x08)
  {
    /*disable the motor spin up sequence*/
    htop[-1].A_w1770.statusreg |= STATUS_NOTSPINUP;
    htop[-1].cycles.w1770_togo += (WD1770_ONEREVOLUTION<<1);
  }
  else
  {
    if (!(htop[-1].A_w1770.statusreg & STATUS_MOTORON))
    {
      /*the motor is off*/
      /*turn motor on*/
      htop[-1].A_w1770.statusreg |= STATUS_MOTORON;
      htop[-1].A_w1770.statusreg &= STATUS_SPINUP;
      /*wait 6 revolutions*/
      htop[-1].cycles.w1770_togo += ((WD1770_ONEREVOLUTION<<1)*6);
    }
  }

  if (nvalue & 0x04)
    /*settling delay 30ms*/
    htop[-1].cycles.w1770_togo += (30000<<1);
}

void w1770commandreadsector(char nvalue)
{
  HOSTMAP* htop = (HOSTMAP*)&hostmap.upper;
  w1770type2flags(nvalue);
  htop[-1].A_w1770.statusreg &= STATUS_NOTDATAREQUEST;
  htop[-1].B_w1770.byteinsector = 0;

  /*an underestimate of the time to recognise and read the first byte in the sector*/
  htop[-1].cycles.w1770_togo += (320<<1);
}

void w1770commandwritesector(char nvalue)
{
  HOSTMAP* htop = (HOSTMAP*)&hostmap.upper;
  w1770type2flags(nvalue);

  if (beebit_discwritable[htop[-1].A_w1770.drive+htop[-1].A_w1770.side])
    htop[-1].A_w1770.statusreg |= STATUS_DATAREQUEST;

  htop[-1].B_w1770.byteinsector = 0;

  htop[-1].B_w1770.writegate = FALSE;

  /*an underestimate of the time to recognise the first byte in the sector*/
  htop[-1].cycles.w1770_togo += (256<<1);
}

void w1770type3flags(char nvalue)
{
  HOSTMAP* htop = (HOSTMAP*)&hostmap.upper;
  htop[-1].A_w1770.statusreg |= STATUS_BUSY;
  htop[-1].A_w1770.statusreg &= STATUS_NOTDATAREQUEST;
  htop[-1].A_w1770.statusreg &= STATUS_NOTLOSTDATA;
  htop[-1].A_w1770.statusreg &= STATUS_NOTNOTFOUND;
  htop[-1].A_w1770.statusreg &= STATUS_NOTRECORDTYPE;
  REGISTERUNSETNMI

  /*motor on*/
  if (nvalue & 0x08)
  {
    /*disable the motor spin up sequence*/
    htop[-1].A_w1770.statusreg |= STATUS_NOTSPINUP;
    htop[-1].cycles.w1770_togo += (WD1770_ONEREVOLUTION<<1);
  }
  else
  {
    if (!(htop[-1].A_w1770.statusreg & STATUS_MOTORON))
    {
      /*the motor is off*/
      /*turn motor on*/
      htop[-1].A_w1770.statusreg |= STATUS_MOTORON;
      htop[-1].A_w1770.statusreg &= STATUS_SPINUP;
      /*wait 6 revolutions*/
      htop[-1].cycles.w1770_togo += ((WD1770_ONEREVOLUTION<<1)*6);
    }
  }

  if (nvalue & 0x04)
    /*settling delay 30ms*/
    htop[-1].cycles.w1770_togo += (30000<<1);
}

void w1770commandreadaddress(char nvalue)
{
  HOSTMAP* htop = (HOSTMAP*)&hostmap.upper;
  w1770type3flags(nvalue);
  htop[-1].B_w1770.byteinsector = 0;
  if (htop[-1].cycles.w1770_togo <= 0)
    htop[-1].cycles.w1770_togo = 1;
}

