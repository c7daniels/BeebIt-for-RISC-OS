      case ADFS_NON_INTERLEAVED:
        nlocation = (hostmap.s0w1770.track*ADFS_SECTORS_PER_TRACK)+hostmap.s0w1770.sectorreg;
        nsize = ADFS_SECTOR_SIZE;
        break;
      case ADFS_INTERLEAVED:
