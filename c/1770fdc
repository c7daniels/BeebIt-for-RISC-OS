R6502HOSTMAP* w1770dataread(R6502HOSTMAP* map, unsigned int address_code)
{
  if (map->s0w1770.commandreg & 0x80)
    map->s0w1770.statusreg &= STATUS_NOTDATAREQUEST;
  map->m = map->s0w1770.datareg;
  return map;
}

R6502HOSTMAP* w1770commandwrite(R6502HOSTMAP* map, unsigned int address_code)
{
  UNSETNMI;
  /*command words are only loaded in the command register when the busy status bit is off (status bit 0)*/
  if (map->s0w1770.statusreg & STATUS_BUSY)
  {
    if ((map->m & 0xF0) == 0xD0)
    {
      map->s0w1770.commandreg = map->m;
      w1770command(map->m);
    }
  }
  else
  {
    if (beebit_imagetype[map->s0w1770.drive+map->s0w1770.side] == DFS_NONE)
    {
      map->s0w1770.statusreg &= STATUS_NOTBUSY;
      map->s0w1770.statusreg |= STATUS_NOTFOUND;
    }
    else
    {
      map->s0w1770.commandreg = map->m;
      w1770command(map->m);
    }
  }
  return map;
}

R6502HOSTMAP* w1770trackwrite(R6502HOSTMAP* map, unsigned int address_code)
{
  map->s0w1770.trackreg = map->s0w1770.track = map->m;
  return map;
}

R6502HOSTMAP* w1770sectorwrite(R6502HOSTMAP* map, unsigned int address_code)
{
  map->s0w1770.sectorreg = map->m;
  return map;
}

R6502HOSTMAP* w1770datawrite(R6502HOSTMAP* map, unsigned int address_code)
{
  if (map->s0w1770.commandreg & 0x80)
  {
    map->s0w1770.statusreg &= STATUS_NOTDATAREQUEST;
    map->s2w1770.writegate = TRUE;
  }
  map->s0w1770.datareg = map->m;
  return map;
}
