#include "swis.h"

extern _kernel_swi_regs regs;

/*analog to digital converter*/
static int adc_x_osunits;
static int adc_y_osunits;
static const int adc_floating_value = 0x7FFF;

void adcreset(void)
{
  hostmap.s0adc.channel = 0;
  hostmap.s0adc.flag = 0;
  hostmap.s0adc.resolution = 0;
  hostmap.s0adc.highbyte = 0;
  hostmap.s0adc.lowbyte = 0;
  hostmap.s2cycles.adc_togo = 0;
}

void adcenter(void)
{
  hostmap.s0adc.suppressfirst = 0;
  adc_x_osunits = 0;
  adc_y_osunits = 0;
}

void adcmodevars(void)
{
  int xres,yres;
  int xeig,yeig;

  regs.r[0] = -1;
  regs.r[1] = 4;
  _kernel_swi(OS_ReadModeVariable,&regs,&regs);
  xeig = regs.r[2];
  regs.r[1] = 5;
  _kernel_swi(OS_ReadModeVariable,&regs,&regs);
  yeig = regs.r[2];
  regs.r[1] = 11;
  _kernel_swi(OS_ReadModeVariable,&regs,&regs);
  xres = regs.r[2] + 1;
  regs.r[1] = 12;
  _kernel_swi(OS_ReadModeVariable,&regs,&regs);
  yres = regs.r[2] + 1;

  if (adc_x_osunits != (xres<<xeig))
  {
    adc_x_osunits = (xres<<xeig);
    hostmap.s2adc.input_x_high = (adc_x_osunits>>1)+255;
  }
  if (adc_y_osunits != (yres<<yeig))
  {
    adc_y_osunits = (yres<<yeig);
    hostmap.s2adc.input_y_low = (adc_y_osunits>>1)-255;
  }
}

R6502HOSTMAP* adcpoll(R6502HOSTMAP* map)
{
  int nvalue;
  map->s0adc.status &= 0x0F;

  if (beebit_mouseemulation == MOUSE_JOYSTICK)
  {
    /*mouse position in OS units*/
    _kernel_swi(OS_Mouse,&regs,&regs);

    if (map->s0adc.suppressfirst == 0)
      beebit_button1 = 0;
    else
      beebit_button1 = ((regs.r[2] & 0x04)>>2);

    if (((regs.r[2] & 0x04)>>2) == 0)
      map->s0adc.suppressfirst = 1;

    beebit_button2 = (regs.r[2] & 0x01);
    switch (map->s0adc.status & 3)
    {
      case 0:
        /*master left/right*/
        /*sliding 512 OS unit domain*/
        if (map->s2adc.input_x_high < regs.r[0])
          map->s2adc.input_x_high = regs.r[0];
        else if (map->s2adc.input_x_high - 511 > regs.r[0])
          map->s2adc.input_x_high = regs.r[0] + 511;

        nvalue = (map->s2adc.input_x_high - regs.r[0])<<7;
        break;
      case 1:
        /*master up/down*/
        /*sliding 512 OS unit domain*/
        if (map->s2adc.input_y_low > regs.r[1])
          map->s2adc.input_y_low = regs.r[1];
        else if (map->s2adc.input_y_low + 511 < regs.r[1])
          map->s2adc.input_y_low = regs.r[1] - 511;

        nvalue = (regs.r[1] - map->s2adc.input_y_low)<<7;
        break;
      case 2:
        /*secondary left/right*/
        nvalue = adc_floating_value;
        break;
      case 3:
        /*secondary up/down*/
        nvalue = adc_floating_value;
        break;
      default:
        nvalue = 0;
        break;
    }
  }
  else
    nvalue = adc_floating_value;

  map->s0adc.status |= 0x40; /*not busy*/
  map->s0adc.status |= ((nvalue & 0xC000)>>10);
  map->s0adc.highbyte = (nvalue>>8);
  map->s0adc.lowbyte = (nvalue & 0xF0);

  if (beebit_mouseemulation == MOUSE_JOYSTICK)
  {
    if (beebit_button1)
      map->s0sysvia.portb &= 0xEF;
    else
      map->s0sysvia.portb |= 0x10;

    if (beebit_button2)
      map->s0sysvia.portb &= 0xDF;
    else
      map->s0sysvia.portb |= 0x20;
  }

  map->s0sysvia.irb = (map->s0sysvia.orb & map->s0sysvia.ddrb) + (map->s0sysvia.portb & ~map->s0sysvia.ddrb);
  /*set CB1 to indicate end of conversion*/
  map->s0sysvia.ifr |= 0x10;

  return map;
}

R6502HOSTMAP* adc00read(R6502HOSTMAP* map, unsigned int address_code)
{
  /*&FC00
   *b0+b1: which of the 4 input channels was selected.
   *b2: not used.
   *b3=0: 8 bit resolution/4ms
   *b3=1: 10 bit resolution/10ms
   *b4: 2nd MSB
   *b5: 1st MSB
   *b6:
   */
  map->m = map->s0adc.status;
  return map;
}

R6502HOSTMAP* adc01read(R6502HOSTMAP* map, unsigned int address_code)
{
  map->m = map->s0adc.highbyte;
  return map;
}

R6502HOSTMAP* adc02read(R6502HOSTMAP* map, unsigned int address_code)
{
  map->m = map->s0adc.lowbyte;
  return map;
}

R6502HOSTMAP* adcwrite(R6502HOSTMAP* map, unsigned int address_code)
{
  /*if naddress=&FC00 then
   * b1+b0: which of the 4 input channels to select.
   * b2: flag input.
   * b3=0: 8 bit resolution/4ms
   * b3=1: 10 bit resolution/10ms
   * interrupt is generated when conversion is done.
   */
  int cyclecount;
  map->s0adc.channel = (map->m & 3);
  map->s0adc.flag = (map->m & 4)>>2;
  map->s0adc.resolution = (map->m & 8)>>3;
  /*busy*/
  map->s0adc.status = (map->m & 0x0F);
  /*not complete*/
  map->s0adc.status |= 0x80;
  if (map->s0adc.resolution)
    map->s2cycles.adc_togo =  10000<<1;
  else
    map->s2cycles.adc_togo =   4000<<1;
  TIMER_GET_TOGO_FROM_WRITE_OFFSET(cyclecount, &hostmap)
  map->s2cycles.adc_togo += 1 + cyclecount;
  TIMER_LIMIT_CYCLES_TO_GO(&hostmap, map->s2cycles.adc_togo)
  return map;
}
